    {
      "id": "node-3e2dc15654",
      "title": "期限切れログ判定",
      "body": "ログファイルの更新日時や名前の日付から、保持期限を過ぎているか判定する。",
      "powanKind": "organ",
      "code": "from datetime import datetime, timedelta\nfrom pathlib import Path\n\n\ndef is_expired_log(path: str | Path, *, days: int, now: datetime | None = None) -> bool:\n    current = now or datetime.now()\n    cutoff = current - timedelta(days=max(0, days))\n    return datetime.fromtimestamp(Path(path).stat().st_mtime) < cutoff",
      "parent": "node-ce9e2eeef0",
