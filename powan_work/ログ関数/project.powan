    {
      "id": "node-c81fb2773f",
      "title": "フォーマッタ適用",
      "body": "コンソールハンドラへ選択済みフォーマッタを設定する。",
      "powanKind": "organ",
      "code": "\"\"\"Apply an already selected formatter to a console handler.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\n\n\ndef apply_formatter(\n    handler: logging.Handler,\n    formatter: logging.Formatter,\n) -> logging.Handler:\n    \"\"\"Set ``formatter`` on ``handler`` and return the same handler.\"\"\"\n    handler.setFormatter(formatter)\n    return handler\n\n\n__all__ = [\"apply_formatter\"]\n",
