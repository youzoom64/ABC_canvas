    {
      "id": "node-c299dfcb1f",
      "title": "日時形式定義",
      "body": "ログに表示する日時の書式を定義する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nDEFAULT_DATE_FORMAT = '%Y-%m-%d %H:%M:%S'\n\n\ndef date_format(value: str | None = None) -> str:\n    clean = str(value or '').strip()\n    return clean or DEFAULT_DATE_FORMAT\n",
