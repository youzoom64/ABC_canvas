      "code": "import re\nfrom typing import Optional\n\n_SAFE = re.compile(r\"[^A-Za-z0-9._-]+\")\n\n\ndef app_name_to_file_stem(app_name: Optional[str], default: str = \"app\") -> str:\n    stem = _SAFE.sub(\"_\", (app_name or default).strip()).strip(\"._-\")\n    return stem or default",
