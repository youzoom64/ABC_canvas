    {
      "id": "node-784e538d05",
      "title": "発生場所文字列生成",
      "body": "モジュール名、関数名、行番号をまとめて原因追跡しやすい場所文字列を生成する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\n\ndef location_text(module: str | None, func: str | None, lineno: int | str | None) -> str:\n    module_text = str(module or '<module>').strip() or '<module>'\n    func_text = str(func or '').strip()\n    line_text = '?' if lineno in (None, '') else str(lineno)\n    name = f'{module_text}.{func_text}' if func_text else module_text\n    return f'{name}:{line_text}'\n",
      "parent": "node-0b0c56f7ad",
      "children": [],
      "style": {
