    {
      "id": "node-e248375f07",
      "title": "例外チェーン抽出",
      "body": "__cause__ や __context__ をたどり、連鎖した例外の原因関係を失わずに記録できる形へ整える。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\n\ndef exception_chain(exc: BaseException, *, limit: int = 20) -> list[dict[str, str]]:\n    \"\"\"Return cause/context exceptions in order without infinite loops.\"\"\"\n    chain: list[dict[str, str]] = []\n    seen: set[int] = set()\n    current = exc.__cause__ or exc.__context__\n    while current is not None and id(current) not in seen and len(chain) < limit:\n        seen.add(id(current))\n        relation = \"cause\" if current is exc.__cause__ else \"context\"\n        chain.append({\"relation\": relation, \"type\": type(current).__name__, \"message\": str(current)})\n        current = current.__cause__ or current.__context__\n    return chain\n",
      "parent": "node-efe6206313",
      "children": [],
      "style": {
        "shape": "cloud",
        "color": "#ffffff",
        "accent": "#8ddcff",
        "glow": true,
        "blur": true,
        "motion": "soft"
