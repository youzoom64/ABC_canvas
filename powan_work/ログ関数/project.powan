    {
      "id": "node-269bc71eec",
      "title": "行番号表示",
      "body": "ログ発生元の行番号を表示しやすい形に整える。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\n\ndef display_line_number(lineno: int | str | None) -> str:\n    if lineno in (None, ''):\n        return '?'\n    value = int(lineno)\n    return str(value) if value >= 0 else '?'\n",
