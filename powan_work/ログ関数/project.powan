    {
      "id": "node-d13bbaf356",
      "title": "拡張子補完",
      "body": "ログファイル名に必要な拡張子がない場合に .log などを補完する。",
      "powanKind": "organ",
      "code": "from pathlib import Path\n\n\ndef ensure_log_suffix(filename: str, suffix: str = \".log\") -> str:\n    suffix = suffix if suffix.startswith(\".\") else f\".{suffix}\"\n    path = Path(filename)\n    return str(path if path.suffix else path.with_suffix(suffix))",
