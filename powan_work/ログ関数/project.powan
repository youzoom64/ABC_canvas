    {
      "id": "node-e8e8751320",
      "title": "通常ファイルハンドラ生成",
      "body": "ローテーションなしで単一ログファイルへ書き込むFileHandlerを生成する。",
      "powanKind": "organ",
      "code": "import logging\nfrom pathlib import Path\n\n\ndef create_plain_file_handler(path: str | Path, encoding: str = \"utf-8\") -> logging.FileHandler:\n    Path(path).parent.mkdir(parents=True, exist_ok=True)\n    return logging.FileHandler(path, encoding=encoding)",
