    {
      "id": "node-6178896ba5",
      "title": "レベル適用",
      "body": "loggerとhandlerへログレベルを適用する。親側のログレベル機構と接続しやすいよう、標準loggingのlevel値を受け取って反映する。",
      "powanKind": "organ",
      "code": "import logging\nfrom collections.abc import Iterable\n\n\ndef apply_level(\n    logger: logging.Logger,\n    handlers: logging.Handler | Iterable[logging.Handler],\n    level: int = logging.INFO,\n) -> logging.Logger:\n    \"\"\"Apply a standard logging level to the logger and handler input.\"\"\"\n    logger.setLevel(level)\n    if isinstance(handlers, logging.Handler):\n        handlers.setLevel(level)\n        return logger\n    for handler in handlers:\n        handler.setLevel(level)\n    return logger\n",
      "parent": "node-4e907d218e",
      "children": [],
      "style": {
        "shape": "cloud",
        "color": "#ffffff",
        "accent": "#8ddcff",
        "glow": true,
        "blur": true,
        "motion": "soft"
      },
      "layout": {
        "x": 6350,
        "y": 5610,
        "width": 220,
        "height": 132
      },
      "nestedLayoutByParent": {
        "node-4e907d218e": {
