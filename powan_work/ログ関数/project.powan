    {
      "id": "node-3d06feb95b",
      "title": "メッセージ文字列化",
      "body": "任意のログメッセージ値を安全に文字列へ変換する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\n\ndef message_to_text(value: object) -> str:\n    if value is None:\n        return ''\n    try:\n        return str(value)\n    except Exception as exc:\n        return f'<unprintable message: {type(exc).__name__}>'\n",
      "parent": "node-b867eee2fd",
      "children": [],
