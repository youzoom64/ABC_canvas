    {
      "id": "node-25279f4cee",
      "title": "日付付きファイル名生成",
      "body": "日付単位でログを分けたい時に、アプリ名と日付を含むログファイル名を生成する。",
      "powanKind": "organ",
      "code": "from datetime import date\nfrom typing import Optional\n\n\ndef make_dated_log_filename(stem: str, day: Optional[date] = None, suffix: str = \".log\") -> str:\n    suffix = suffix if suffix.startswith(\".\") else f\".{suffix}\"\n    return f\"{stem}_{day or date.today():%Y%m%d}{suffix}\"",
