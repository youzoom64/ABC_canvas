    {
      "id": "node-ff3726114e",
      "title": "機械向け構造化情報生成",
      "body": "検索、集計、外部連携に使えるように、例外情報を辞書などの構造化データに整える。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nfrom typing import Any\n\n\ndef structured_exception_record(level: str, message: str, exc_info: dict[str, Any], context: dict[str, Any] | None = None) -> dict[str, Any]:\n    \"\"\"Create a dictionary suitable for JSON logs or external sinks.\"\"\"\n    return {\"level\": level.upper(), \"message\": message, \"exception\": dict(exc_info), \"context\": dict(context or {})}\n",
      "parent": "node-661f21f41b",
      "children": [],
      "style": {
