    {
      "id": "node-cf047b81df",
      "title": "ログレベル定義",
      "body": "trace、debug、info、warning、error、critical の6段階を定数として持つ臓器ポワン。ログレベルの正式名称と基本セットを定義する。",
      "powanKind": "organ",
      "code": "\"\"\"Canonical names for the six supported logging levels.\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Final\n\nTRACE: Final[str] = \"trace\"\nDEBUG: Final[str] = \"debug\"\nINFO: Final[str] = \"info\"\nWARNING: Final[str] = \"warning\"\nERROR: Final[str] = \"error\"\nCRITICAL: Final[str] = \"critical\"\n\nLOG_LEVELS: Final[tuple[str, ...]] = (\n    TRACE,\n    DEBUG,\n    INFO,\n    WARNING,\n    ERROR,\n    CRITICAL,\n)\n\nLOG_LEVEL_SET: Final[frozenset[str]] = frozenset(LOG_LEVELS)\n\n\ndef is_defined_log_level(level: str) -> bool:\n    \"\"\"Return True when level is one of the canonical six names.\"\"\"\n\n    return level.lower() in LOG_LEVEL_SET\n",
      "parent": "node-defe15d75c",
      "children": [],
      "style": {
        "shape": "cloud",
        "color": "#ffffff",
        "accent": "#8ddcff",
        "glow": true,
