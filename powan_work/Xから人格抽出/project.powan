    {
      "id": "node-5ffa8bdf42",
      "title": "YouTube字幕取得ポワン",
      "body": "YouTube URLを受け取り、既存のC:\\project_root\\app_workspaces\\API\\scripts\\youtube_subtitle.pyまたはsubtitle_downloader.pyを使って字幕一覧確認と字幕本文取得を行う臓器ポワン。公式字幕と自動生成字幕を区別し、取得できた字幕テキスト、言語、保存先、取得不能理由を返す。動画保存や音声文字起こしやDB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport importlib\nimport json\nimport os\nimport re\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Sequence\nfrom urllib.parse import parse_qs, urlparse\n\nDEFAULT_API_ROOT = r\"C:\\project_root\\app_workspaces\\API\"\nSCRIPT_FILES = {\n    \"subtitle_downloader\": \"scripts/subtitle_downloader.py\",\n    \"youtube_subtitle\": \"scripts/youtube_subtitle.py\",\n}\n\n\ndef fetch_youtube_subtitle(\n    url: str,\n    *,\n    post_id: str | int | None = None,\n    media_index: str | int | None = None,\n    output_dir: str | os.PathLike[str] | None = None,\n    preferred_languages: str | Sequence[str] | None = None,\n    fallback_languages: Sequence[str] = (\"en\",),\n    api_root: str | os.PathLike[str] = DEFAULT_API_ROOT,\n) -> dict[str, Any]:\n    \"\"\"Fetch one YouTube subtitle track as JSON-ready material.\n\n    This organ only lists/downloads subtitles through the existing API scripts.\n    It does not download video, transcribe audio, or write to a database.\n    \"\"\"\n    normalized_url = _normalize_url(url)\n    api_root_path = Path(api_root)\n    video_id = _extract_video_id(normalized_url)\n    languages = _normalize_languages(preferred_languages, fallback_languages)\n    resolved_output_dir = _resolve_output_dir(\n        output_dir=output_dir,\n        api_root=api_root_path,\n        video_id=video_id,\n        url=normalized_url,\n        post_id=post_id,\n        media_index=media_index,\n    )\n\n    result: dict[str, Any] = {\n        \"ok\": False,\n        \"material_type\": \"youtube_subtitle\",\n        \"source_url\": url,\n        \"normalized_url\": normalized_url,\n        \"video_id\": video_id,\n        \"post_id\": post_id,\n        \"media_index\": media_index,\n        \"api_root\": str(api_root_path),\n        \"requested_languages\": languages,\n        \"available_subtitles\": {\"official\": {}, \"auto_generated\": {}},\n        \"available_subtitle_tracks\": [],\n        \"selected_subtitle\": None,\n        \"subtitle_text\": \"\",\n        \"saved_paths\": {\"output_dir\": str(resolved_output_dir)},\n        \"external_operations\": [],\n        \"download_attempts\": [],\n        \"unavailable_reasons\": [],\n        \"failure_reason\": None,\n    }\n\n    if not normalized_url:\n        result[\"failure_reason\"] = \"url is empty\"\n        return result\n\n    if not api_root_path.exists():\n        result[\"failure_reason\"] = f\"api_root does not exist: {api_root_path}\"\n        return result\n\n    resolved_output_dir.mkdir(parents=True, exist_ok=True)\n    modules = _load_existing_api_modules(api_root_path, result[\"external_operations\"])\n\n    catalog = _list_available_subtitles(normalized_url, modules, result[\"external_operations\"])\n    result[\"available_subtitles\"] = catalog\n    result[\"available_subtitle_tracks\"] = _catalog_as_tracks(catalog)\n\n    attempts = _build_download_attempts(catalog, languages, result[\"unavailable_reasons\"])\n    if not attempts:\n        result[\"failure_reason\"] = (\n            \"no subtitles matched requested languages\"\n            if _catalog_has_entries(catalog)\n            else \"subtitle list is empty or unavailable\"\n        )\n        return result\n\n    for attempt in attempts:\n        attempt_record = {\n            \"requested_language\": attempt[\"requested_language\"],\n            \"language\": attempt[\"language\"],\n            \"subtitle_type\": attempt[\"subtitle_type\"],\n            \"is_auto_generated\": attempt[\"is_auto_generated\"],\n            \"status\": \"pending\",\n            \"error\": None,\n        }\n        result[\"download_attempts\"].append(attempt_record)\n        try:\n            text_path, text = _download_text_with_existing_scripts(\n                normalized_url,\n                resolved_output_dir,\n                attempt[\"language\"],\n                attempt[\"is_auto_generated\"],\n                modules,\n                result[\"external_operations\"],\n            )\n            text_path = str(Path(text_path).resolve())\n            attempt_record[\"status\"] = \"ok\"\n            result[\"ok\"] = True\n            result[\"selected_subtitle\"] = {\n                \"requested_language\": attempt[\"requested_language\"],\n                \"language\": attempt[\"language\"],\n                \"subtitle_type\": attempt[\"subtitle_type\"],\n                \"is_auto_generated\": attempt[\"is_auto_generated\"],\n                \"text_length\": len(text),\n                \"text_path\": text_path,\n            }\n            result[\"subtitle_text\"] = text\n            result[\"saved_paths\"] = {\n                \"output_dir\": str(resolved_output_dir.resolve()),\n                \"subtitle_text\": text_path,\n                \"related_subtitle_files\": _related_subtitle_files(text_path),\n            }\n            result[\"failure_reason\"] = None\n            return result\n        except Exception as exc:\n            message = f\"{type(exc).__name__}: {exc}\"\n            attempt_record[\"status\"] = \"failed\"\n            attempt_record[\"error\"] = message\n            result[\"unavailable_reasons\"].append(\n                {\n                    \"language\": attempt[\"language\"],\n                    \"subtitle_type\": attempt[\"subtitle_type\"],\n                    \"reason\": message,\n                }\n            )\n\n    result[\"failure_reason\"] = \"all subtitle download attempts failed\"\n    return result\n\n\ndef run(\n    url: str,\n    *,\n    post_id: str | int | None = None,\n    media_index: str | int | None = None,\n    output_dir: str | os.PathLike[str] | None = None,\n    lang: str | Sequence[str] | None = None,\n    api_root: str | os.PathLike[str] = DEFAULT_API_ROOT,\n) -> dict[str, Any]:\n    \"\"\"Small alias for callers that want a simple organ entrypoint.\"\"\"\n    return fetch_youtube_subtitle(\n        url,\n        post_id=post_id,\n        media_index=media_index,\n        output_dir=output_dir,\n        preferred_languages=lang,\n        api_root=api_root,\n    )\n\n\ndef _normalize_url(url: str) -> str:\n    value = str(url or \"\").strip()\n    if value and \"://\" not in value and (\"youtube.\" in value or \"youtu.be\" in value):\n        value = \"https://\" + value\n    return value\n\n\ndef _extract_video_id(url: str) -> str | None:\n    parsed = urlparse(url)\n    host = (parsed.netloc or \"\").lower()\n    query = parse_qs(parsed.query)\n    if query.get(\"v\"):\n        return query[\"v\"][0]\n    path_parts = [part for part in parsed.path.split(\"/\") if part]\n    if \"youtu.be\" in host and path_parts:\n        return path_parts[0]\n    if path_parts and path_parts[0] in {\"shorts\", \"embed\", \"live\"} and len(path_parts) > 1:\n        return path_parts[1]\n    return None\n\n\ndef _normalize_languages(\n    preferred_languages: str | Sequence[str] | None,\n    fallback_languages: Sequence[str],\n) -> list[str]:\n    raw_items: list[str] = []\n    if preferred_languages is None:\n        raw_items.append(\"ja\")\n    elif isinstance(preferred_languages, str):\n        raw_items.extend(re.split(r\"[,\\s]+\", preferred_languages))\n    else:\n        raw_items.extend(str(item) for item in preferred_languages)\n    raw_items.extend(str(item) for item in fallback_languages)\n\n    languages: list[str] = []\n    for item in raw_items:\n        clean = item.strip()\n        if clean and clean not in languages:\n            languages.append(clean)\n    return languages or [\"ja\"]\n\n\ndef _resolve_output_dir(\n    *,\n    output_dir: str | os.PathLike[str] | None,\n    api_root: Path,\n    video_id: str | None,\n    url: str,\n    post_id: str | int | None,\n    media_index: str | int | None,\n) -> Path:\n    if output_dir:\n        return Path(output_dir)\n    url_hash = hashlib.sha1(url.encode(\"utf-8\", errors=\"replace\")).hexdigest()[:12]\n    parts = [api_root, \"outputs\", \"youtube_subtitles\"]\n    if post_id is not None:\n        parts.append(\"post_\" + _safe_path_part(post_id))\n    if media_index is not None:\n        parts.append(\"media_\" + _safe_path_part(media_index))\n    parts.append(_safe_path_part(video_id or f\"url_{url_hash}\"))\n    return Path(*parts)\n\n\ndef _safe_path_part(value: object) -> str:\n    text = str(value or \"unknown\")\n    text = re.sub(r\"[^A-Za-z0-9_.-]+\", \"_\", text).strip(\"._\")\n    return (text or \"unknown\")[:80]\n\n\ndef _load_existing_api_modules(api_root: Path, operations: list[dict[str, Any]]) -> dict[str, Any]:\n    api_root_text = str(api_root.resolve())\n    if api_root_text not in sys.path:\n        sys.path.insert(0, api_root_text)\n\n    modules: dict[str, Any] = {}\n    for module_name in (\"subtitle_downloader\", \"youtube_subtitle\"):\n        script_path = str((api_root / SCRIPT_FILES[module_name]).resolve())\n        op = {\n            \"stage\": \"import_script\",\n            \"script\": script_path,\n            \"module\": f\"scripts.{module_name}\",\n            \"status\": \"pending\",\n            \"error\": None,\n        }\n        try:\n            modules[module_name] = importlib.import_module(f\"scripts.{module_name}\")\n            op[\"status\"] = \"ok\"\n        except Exception as exc:\n            op[\"status\"] = \"failed\"\n            op[\"error\"] = f\"{type(exc).__name__}: {exc}\"\n        operations.append(op)\n    return modules\n\n\ndef _list_available_subtitles(\n    url: str,\n    modules: dict[str, Any],\n    operations: list[dict[str, Any]],\n) -> dict[str, dict[str, str]]:\n    catalog = _empty_catalog()\n\n    module = modules.get(\"subtitle_downloader\")\n    if module is not None:\n        op = _operation(\"list_subtitles\", module, \"get_available_subtitles\")\n        try:\n            raw = module.get_available_subtitles(url)\n            _merge_catalog(catalog, _catalog_from_subtitle_downloader(raw))\n            op.update(_catalog_counts(catalog))\n            op[\"status\"] = \"ok\"\n        except Exception as exc:\n            op[\"status\"] = \"failed\"\n            op[\"error\"] = f\"{type(exc).__name__}: {exc}\"\n        operations.append(op)\n\n    module = modules.get(\"youtube_subtitle\")\n    if module is not None:\n        op = _operation(\"list_subtitles\", module, \"list_available_subtitles\")\n        try:\n            raw = module.list_available_subtitles(url)\n            _merge_catalog(catalog, _catalog_from_youtube_subtitle(raw))\n            op.update(_catalog_counts(catalog))\n            op[\"status\"] = \"ok\"\n        except Exception as exc:\n            op[\"status\"] = \"failed\"\n            op[\"error\"] = f\"{type(exc).__name__}: {exc}\"\n        operations.append(op)\n\n    return catalog\n\n\ndef _empty_catalog() -> dict[str, dict[str, str]]:\n    return {\"official\": {}, \"auto_generated\": {}}\n\n\ndef _catalog_from_subtitle_downloader(raw: Any) -> dict[str, dict[str, str]]:\n    catalog = _empty_catalog()\n    if not isinstance(raw, dict):\n        return catalog\n    for code, label in (raw.get(\"manual\") or {}).items():\n        catalog[\"official\"][str(code)] = str(label or \"manual\")\n    for code, label in (raw.get(\"auto\") or {}).items():\n        catalog[\"auto_generated\"][str(code)] = str(label or \"auto\")\n    return catalog\n\n\ndef _catalog_from_youtube_subtitle(raw: Any) -> dict[str, dict[str, str]]:\n    catalog = _empty_catalog()\n    if not isinstance(raw, dict):\n        return catalog\n    for code, info in raw.items():\n        target = \"auto_generated\" if isinstance(info, dict) and info.get(\"auto\") else \"official\"\n        label = info.get(\"name\") if isinstance(info, dict) else \"\"\n        catalog[target][str(code)] = str(label or target)\n    return catalog\n\n\ndef _merge_catalog(base: dict[str, dict[str, str]], incoming: dict[str, dict[str, str]]) -> None:\n    for source_type in (\"official\", \"auto_generated\"):\n        for code, label in incoming.get(source_type, {}).items():\n            base[source_type].setdefault(code, label)\n\n\ndef _catalog_counts(catalog: dict[str, dict[str, str]]) -> dict[str, int]:\n    return {\n        \"official_count\": len(catalog.get(\"official\", {})),\n        \"auto_generated_count\": len(catalog.get(\"auto_generated\", {})),\n    }\n\n\ndef _catalog_has_entries(catalog: dict[str, dict[str, str]]) -> bool:\n    return bool(catalog.get(\"official\") or catalog.get(\"auto_generated\"))\n\n\ndef _catalog_as_tracks(catalog: dict[str, dict[str, str]]) -> list[dict[str, Any]]:\n    tracks: list[dict[str, Any]] = []\n    for source_type, is_auto in ((\"official\", False), (\"auto_generated\", True)):\n        for language, label in sorted(catalog.get(source_type, {}).items()):\n            tracks.append(\n                {\n                    \"language\": language,\n                    \"subtitle_type\": source_type,\n                    \"is_auto_generated\": is_auto,\n                    \"label\": label,\n                }\n            )\n    return tracks\n\n\ndef _build_download_attempts(\n    catalog: dict[str, dict[str, str]],\n    languages: Sequence[str],\n    unavailable_reasons: list[dict[str, Any]],\n) -> list[dict[str, Any]]:\n    attempts: list[dict[str, Any]] = []\n    if not _catalog_has_entries(catalog):\n        for requested in languages:\n            attempts.append(_attempt(requested, requested, \"official\"))\n            attempts.append(_attempt(requested, requested, \"auto_generated\"))\n        return attempts\n\n    for requested in languages:\n        found = False\n        official_language = _match_language(catalog.get(\"official\", {}), requested)\n        if official_language:\n            attempts.append(_attempt(requested, official_language, \"official\"))\n            found = True\n        auto_language = _match_language(catalog.get(\"auto_generated\", {}), requested)\n        if auto_language:\n            attempts.append(_attempt(requested, auto_language, \"auto_generated\"))\n            found = True\n        if not found:\n            unavailable_reasons.append(\n                {\n                    \"requested_language\": requested,\n                    \"reason\": \"not listed in official or auto-generated subtitles\",\n                }\n            )\n    return attempts\n\n\ndef _attempt(requested: str, language: str, source_type: str) -> dict[str, Any]:\n    return {\n        \"requested_language\": requested,\n        \"language\": language,\n        \"subtitle_type\": source_type,\n        \"is_auto_generated\": source_type == \"auto_generated\",\n    }\n\n\ndef _match_language(candidates: dict[str, str], requested: str) -> str | None:\n    requested_norm = _language_norm(requested)\n    for code in candidates:\n        if _language_norm(code) == requested_norm:\n            return code\n    requested_base = _language_base(requested)\n    for code in candidates:\n        if _language_base(code) == requested_base:\n            return code\n    return None\n\n\ndef _language_norm(value: str) -> str:\n    return str(value or \"\").strip().lower().replace(\"_\", \"-\")\n\n\ndef _language_base(value: str) -> str:\n    return _language_norm(value).split(\"-\", 1)[0]\n\n\ndef _download_text_with_existing_scripts(\n    url: str,\n    output_dir: Path,\n    language: str,\n    is_auto_generated: bool,\n    modules: dict[str, Any],\n    operations: list[dict[str, Any]],\n) -> tuple[str, str]:\n    errors: list[str] = []\n    for module_name, function_name in (\n        (\"subtitle_downloader\", \"download_subtitle_as_text\"),\n        (\"youtube_subtitle\", \"download_subtitle_as_text\"),\n    ):\n        module = modules.get(module_name)\n        if module is None:\n            continue\n        op = _operation(\"download_subtitle_text\", module, function_name)\n        op.update(\n            {\n                \"language\": language,\n                \"is_auto_generated\": is_auto_generated,\n                \"output_dir\": str(output_dir),\n            }\n        )\n        try:\n            if module_name == \"subtitle_downloader\":\n                path = module.download_subtitle_as_text(\n                    url,\n                    output_dir=str(output_dir),\n                    lang=language,\n                    auto=is_auto_generated,\n                )\n            else:\n                path = module.download_subtitle_as_text(\n                    url,\n                    output_dir=str(output_dir),\n                    lang=language,\n                    auto_generated=is_auto_generated,\n                )\n            text = _read_downloaded_text(path)\n            op[\"status\"] = \"ok\"\n            op[\"text_path\"] = str(Path(path).resolve())\n            op[\"text_length\"] = len(text)\n            operations.append(op)\n            return str(path), text\n        except Exception as exc:\n            message = f\"{type(exc).__name__}: {exc}\"\n            op[\"status\"] = \"failed\"\n            op[\"error\"] = message\n            operations.append(op)\n            errors.append(f\"{module_name}.{function_name}: {message}\")\n\n    raise RuntimeError(\" | \".join(errors) or \"no existing subtitle script could be used\")\n\n\ndef _read_downloaded_text(path: str | os.PathLike[str] | None) -> str:\n    if not path:\n        raise RuntimeError(\"subtitle helper returned an empty path\")\n    text_path = Path(path)\n    if not text_path.exists():\n        raise FileNotFoundError(str(text_path))\n    text = text_path.read_text(encoding=\"utf-8\", errors=\"replace\")\n    if not text.strip():\n        raise RuntimeError(f\"downloaded subtitle text is empty: {text_path}\")\n    return text\n\n\ndef _operation(stage: str, module: Any, function_name: str) -> dict[str, Any]:\n    return {\n        \"stage\": stage,\n        \"script\": str(Path(getattr(module, \"__file__\", \"\")).resolve()),\n        \"function\": function_name,\n        \"status\": \"pending\",\n        \"error\": None,\n    }\n\n\ndef _related_subtitle_files(text_path: str) -> list[str]:\n    path = Path(text_path)\n    if not path.exists():\n        return []\n    stem = path.with_suffix(\"\")\n    related: list[str] = []\n    for suffix in (\".txt\", \".vtt\", \".srt\"):\n        candidate = stem.with_suffix(suffix)\n        if candidate.exists():\n            related.append(str(candidate.resolve()))\n    return related\n\n\ndef main(argv: Sequence[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Fetch YouTube subtitles as JSON material.\")\n    parser.add_argument(\"url\")\n    parser.add_argument(\"--lang\", action=\"append\", dest=\"languages\", help=\"Preferred language. Can be repeated.\")\n    parser.add_argument(\"--output-dir\", default=None)\n    parser.add_argument(\"--post-id\", default=None)\n    parser.add_argument(\"--media-index\", default=None)\n    parser.add_argument(\"--api-root\", default=DEFAULT_API_ROOT)\n    args = parser.parse_args(argv)\n\n    payload = fetch_youtube_subtitle(\n        args.url,\n        post_id=args.post_id,\n        media_index=args.media_index,\n        output_dir=args.output_dir,\n        preferred_languages=args.languages,\n        api_root=args.api_root,\n    )\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n    return 0 if payload.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
