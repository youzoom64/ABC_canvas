    {
      "id": "node-6c7697f7e0",
      "title": "返信元行き先発見ポワン",
      "body": "現在表示中のX返信投稿から、返信元として辿るべき投稿URLと投稿IDを画面上の会話スレッドから見つける臓器ポワン。対象投稿より前に表示されている別statusの記事を候補にし、リプ元到達ポワンが実際に遷移するための replyToUrl、replyToPostId、根拠を返す。返信チェーン全体の再帰追跡は行わず、1段分の返信元発見だけを担当する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport re\nimport time\nfrom typing import Any\nfrom urllib.parse import urljoin, urlparse\n\nlog = logging.getLogger(\"reply_parent_destination\")\n\nSTATUS_RE = re.compile(r\"/(?:i/web/)?status/(\\d+)\")\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef normalize_url(href: str | None, *, base_url: str = \"https://x.com\") -> str:\n    if not href:\n        return \"\"\n    url = urljoin(base_url, href.strip())\n    parsed = urlparse(url)\n    if parsed.netloc in {\"twitter.com\", \"mobile.twitter.com\"}:\n        parsed = parsed._replace(netloc=\"x.com\")\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if parsed.netloc == \"x.com\" and len(parts) >= 3 and parts[1] == \"status\" and parts[2].isdigit():\n        parsed = parsed._replace(path=f\"/{parts[0]}/status/{parts[2]}\", query=\"\")\n    return parsed._replace(fragment=\"\").geturl()\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    match = STATUS_RE.search(url)\n    return match.group(1) if match else None\n\n\ndef author_from_status_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    parsed = urlparse(url)\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if len(parts) >= 3 and parts[1] == \"status\":\n        return parts[0]\n    return None\n\n\ndef _snapshot_articles(driver: Any) -> list[dict[str, Any]]:\n    script = r\"\"\"\nconst textOf = (el) => (el && (el.innerText || el.textContent) || '').trim();\nconst attr = (el, name) => el ? (el.getAttribute(name) || '') : '';\nconst rectOf = (el) => {\n  const r = el.getBoundingClientRect();\n  return {x: Math.round(r.x), y: Math.round(r.y), width: Math.round(r.width), height: Math.round(r.height), bottom: Math.round(r.bottom)};\n};\nconst articles = Array.from(document.querySelectorAll('article[data-testid=\"tweet\"]'));\nreturn articles.map((article, index) => {\n  const links = Array.from(article.querySelectorAll('a[href]')).map((a) => ({\n    href: a.href || attr(a, 'href'),\n    text: textOf(a),\n    ariaLabel: attr(a, 'aria-label'),\n    dataTestId: attr(a, 'data-testid'),\n  }));\n  const statusLinks = links.filter((link) => /\\/status\\/\\d+/.test(link.href || ''));\n  const times = Array.from(article.querySelectorAll('time')).map((t) => ({\n    datetime: attr(t, 'datetime'),\n    text: textOf(t),\n    href: (t.closest('a') && t.closest('a').href) || '',\n  }));\n  const tweetTexts = Array.from(article.querySelectorAll('[data-testid=\"tweetText\"]')).map(textOf).filter(Boolean);\n  const socialContext = textOf(article.querySelector('[data-testid=\"socialContext\"]'));\n  return {\n    index,\n    rect: rectOf(article),\n    text: tweetTexts.join('\\n'),\n    socialContext,\n    links,\n    statusLinks,\n    times,\n    articleText: textOf(article),\n  };\n});\n\"\"\"\n    value = driver.execute_script(script)\n    return value if isinstance(value, list) else []\n\n\ndef _article_status_url(article: dict[str, Any]) -> str:\n    for time_item in article.get(\"times\") or []:\n        url = normalize_url(time_item.get(\"href\"))\n        if status_id_from_url(url):\n            return url\n    for link in article.get(\"statusLinks\") or []:\n        url = normalize_url(link.get(\"href\"))\n        if status_id_from_url(url):\n            return url\n    return \"\"\n\n\ndef _article_summary(article: dict[str, Any]) -> dict[str, Any]:\n    url = _article_status_url(article)\n    text = article.get(\"text\") or \"\"\n    return {\n        \"index\": article.get(\"index\"),\n        \"url\": url,\n        \"postId\": status_id_from_url(url),\n        \"authorId\": author_from_status_url(url),\n        \"text\": text[:280],\n        \"rect\": article.get(\"rect\") or {},\n        \"socialContext\": article.get(\"socialContext\") or \"\",\n    }\n\n\ndef _pick_current_article(\n    articles: list[dict[str, Any]],\n    *,\n    current_post_id: str | None = None,\n    article_index: int | None = None,\n) -> dict[str, Any] | None:\n    if current_post_id:\n        for article in articles:\n            if status_id_from_url(_article_status_url(article)) == current_post_id:\n                return article\n    if article_index is not None and 0 <= article_index < len(articles):\n        return articles[article_index]\n    if articles:\n        current_url_id = status_id_from_url(getattr(_pick_current_article, \"current_url\", \"\"))\n        if current_url_id:\n            for article in articles:\n                if status_id_from_url(_article_status_url(article)) == current_url_id:\n                    return article\n    return articles[0] if articles else None\n\n\ndef find_reply_parent_destination(\n    driver: Any,\n    *,\n    current_post_id: str | None = None,\n    article_index: int | None = None,\n    wait: float = 10.0,\n) -> dict[str, Any]:\n    deadline = time.time() + wait\n    articles: list[dict[str, Any]] = []\n    current: dict[str, Any] | None = None\n    expected_post_id = current_post_id or status_id_from_url(getattr(driver, \"current_url\", \"\"))\n\n    while time.time() < deadline:\n        articles = _snapshot_articles(driver)\n        setattr(_pick_current_article, \"current_url\", getattr(driver, \"current_url\", \"\"))\n        current = _pick_current_article(\n            articles,\n            current_post_id=current_post_id,\n            article_index=article_index,\n        )\n        if current:\n            current_id = status_id_from_url(_article_status_url(current))\n            if not expected_post_id or current_id == expected_post_id:\n                break\n        time.sleep(0.25)\n\n    if not articles:\n        return {\n            \"found\": False,\n            \"reason\": \"no_articles\",\n            \"currentUrl\": getattr(driver, \"current_url\", \"\"),\n            \"articles\": [],\n            \"evidence\": [\"article[data-testid=tweet] が見つからない\"],\n        }\n    if not current:\n        return {\n            \"found\": False,\n            \"reason\": \"current_article_not_found\",\n            \"currentUrl\": getattr(driver, \"current_url\", \"\"),\n            \"expectedPostId\": expected_post_id,\n            \"articles\": [_article_summary(article) for article in articles],\n            \"evidence\": [\"対象投稿の記事が画面内に見つからない\"],\n        }\n\n    current_summary = _article_summary(current)\n    if expected_post_id and current_summary.get(\"postId\") != expected_post_id:\n        return {\n            \"found\": False,\n            \"reason\": \"target_article_not_loaded\",\n            \"currentUrl\": getattr(driver, \"current_url\", \"\"),\n            \"expectedPostId\": expected_post_id,\n            \"current\": current_summary,\n            \"articles\": [_article_summary(article) for article in articles],\n            \"evidence\": [\"URLまたは指定postIdと一致する記事が、待機時間内に表示されなかった\"],\n        }\n    current_id = current_summary.get(\"postId\")\n    current_index = int(current.get(\"index\") or 0)\n\n    candidates: list[dict[str, Any]] = []\n    for article in articles:\n        idx = int(article.get(\"index\") or 0)\n        if idx >= current_index:\n            continue\n        summary = _article_summary(article)\n        if not summary.get(\"postId\") or summary.get(\"postId\") == current_id:\n            continue\n        candidates.append(summary)\n\n    # Xの会話ページでは、対象投稿の直前にある別status記事が返信元であることが多い。\n    candidates.sort(key=lambda item: int(item.get(\"index\") or -1), reverse=True)\n    parent = candidates[0] if candidates else None\n    if not parent:\n        return {\n            \"found\": False,\n            \"reason\": \"no_visible_parent_article\",\n            \"currentUrl\": getattr(driver, \"current_url\", \"\"),\n            \"current\": current_summary,\n            \"candidates\": [],\n            \"articles\": [_article_summary(article) for article in articles],\n            \"evidence\": [\"対象投稿より前に、別statusの投稿記事が見つからなかった\"],\n        }\n\n    return {\n        \"found\": True,\n        \"method\": \"visible_thread_parent_article\",\n        \"replyToUrl\": parent.get(\"url\"),\n        \"replyToPostId\": parent.get(\"postId\"),\n        \"replyToAuthorId\": parent.get(\"authorId\"),\n        \"current\": current_summary,\n        \"parent\": parent,\n        \"candidates\": candidates,\n        \"evidence\": [\n            \"Xの会話表示で、対象投稿より前に表示されている最も近い別status記事を返信元候補にした\",\n            f\"current_index={current_index}\",\n            f\"parent_index={parent.get('index')}\",\n        ],\n        \"confidence\": 0.72,\n    }\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Find the visible reply parent destination on an X page.\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--url\", help=\"Optional X status URL to open before detection.\")\n    parser.add_argument(\"--current-post-id\", help=\"Post id of the current/reply post.\")\n    parser.add_argument(\"--article-index\", type=int, help=\"Article index to treat as current post.\")\n    parser.add_argument(\"--wait\", type=float, default=10.0)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n\n    from scripts.chrome_debug import get_driver\n\n    driver = get_driver(port=args.port, wait=args.wait)\n    if args.url:\n        log.info(\"reply_parent.open url=%s\", args.url)\n        # XのSPAはURLだけ変わって古いarticleが残ることがあるので、単体実行時は一度空ページを挟む。\n        driver.get(\"about:blank\")\n        time.sleep(0.5)\n        driver.get(args.url)\n\n    result = find_reply_parent_destination(\n        driver,\n        current_post_id=args.current_post_id,\n        article_index=args.article_index,\n        wait=args.wait,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"found\") else 2\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
