  "nodes": [
    {
      "id": "node-12d93ab587",
      "title": "X投稿収集ポワン",
      "body": "Xアカウントの投稿を集めて保存する臓器ポワン。既存のx_collect_account.pyを中心に、指定アカウントの投稿・返信・リポスト・引用を可能な範囲で取得し、SQLite DB、JSONL、state.json、runsログ、必要に応じたスクリーンショットへ保存する。役割は収集と保存までで、RAG、意味検索、矛盾判定はここでは扱わない。",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport subprocess\nfrom pathlib import Path\nfrom typing import Any\n\nlog = logging.getLogger(\"x_post_collector\")\n\nDEFAULT_CHROME_PATH = r\"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\"\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef build_debug_chrome_command(\n    *,\n    api_root: str | Path | None = None,\n    chrome_path: str = DEFAULT_CHROME_PATH,\n    port: int = 9221,\n    profile_dir: str = \"Profile 4\",\n    headless: bool = False,\n) -> list[str]:\n    root = Path(api_root).resolve() if api_root else Path.cwd().resolve()\n    user_data_dir = root / \"scripts\" / f\"chrome_debug_data_{port}\"\n    command = [\n        chrome_path,\n        f\"--remote-debugging-port={port}\",\n        f\"--user-data-dir={user_data_dir}\",\n        f\"--profile-directory={profile_dir}\",\n    ]\n    if headless:\n        command.extend([\"--headless=new\", \"--disable-gpu\"])\n    return command\n\n\ndef command_text(command: list[str]) -> str:\n    return subprocess.list2cmdline(command)\n\n\ndef start_selenium_debug_chrome(\n    *,\n    port: int = 9221,\n    profile_dir: str = \"Profile 4\",\n    headless: bool = False,\n    reuse_existing: bool = True,\n    wait: float = 15.0,\n) -> Any:\n    from scripts.chrome_debug import get_driver, launch_chrome\n\n    log.info(\n        \"selenium_debug.start port=%s profile_dir=%s headless=%s reuse_existing=%s\",\n        port,\n        profile_dir,\n        headless,\n        reuse_existing,\n    )\n\n    if reuse_existing:\n        try:\n            log.info(\"selenium_debug.reuse.try port=%s\", port)\n            driver = get_driver(port=port)\n            log.info(\"selenium_debug.reuse.ok current_url=%s\", driver.current_url)\n            return driver\n        except Exception as exc:\n            log.warning(\"selenium_debug.reuse.failed port=%s error=%s\", port, exc)\n\n    log.info(\"selenium_debug.launch port=%s profile_dir=%s headless=%s\", port, profile_dir, headless)\n    launch_chrome(profile_dir=profile_dir, port=port, headless=headless)\n\n    log.info(\"selenium_debug.connect port=%s wait=%s\", port, wait)\n    driver = get_driver(port=port, wait=wait)\n    caps = getattr(driver, \"capabilities\", {}) or {}\n    log.info(\n        \"selenium_debug.ready browser=%s version=%s current_url=%s title=%s\",\n        caps.get(\"browserName\"),\n        caps.get(\"browserVersion\"),\n        driver.current_url,\n        driver.title,\n    )\n    return driver\n\n\ndef import_collect_account():\n    try:\n        from tools.x.x_collect_account import collect_account\n\n        return collect_account\n    except ModuleNotFoundError:\n        from scripts.x_collect_account import collect_account\n\n        return collect_account\n\n\ndef collect_x_posts(\n    *,\n    account: str,\n    output_root: str | None = None,\n    batch_size: int = 200,\n    target_count: str = \"all\",\n    include: str = \"post,reply,repost,quote\",\n    screenshots: bool = True,\n    port: int = 9221,\n    profile_dir: str = \"Profile 4\",\n    headless: bool = False,\n    reuse_existing: bool = True,\n    wait: float = 15.0,\n    monitor_latest: bool = True,\n) -> dict[str, Any]:\n    driver = start_selenium_debug_chrome(\n        port=port,\n        profile_dir=profile_dir,\n        headless=headless,\n        reuse_existing=reuse_existing,\n        wait=wait,\n    )\n    collect_account = import_collect_account()\n    log.info(\n        \"x_collect.start account=%s batch_size=%s target_count=%s include=%s screenshots=%s\",\n        account,\n        batch_size,\n        target_count,\n        include,\n        screenshots,\n    )\n    result = collect_account(\n        account=account,\n        output_root=output_root,\n        batch_size=batch_size,\n        target_count=target_count,\n        include=include,\n        screenshots=screenshots,\n        port=port,\n        profile_dir=profile_dir,\n        launch_debug_chrome=False,\n        headless=headless,\n        monitor_latest=monitor_latest,\n        driver=driver,\n    )\n    log.info(\"x_collect.done status=%s saved=%s\", result.get(\"status\"), result.get(\"saved\"))\n    return result\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Collect X account posts through Selenium debug Chrome.\")\n    parser.add_argument(\"--account\", required=True)\n    parser.add_argument(\"--output-root\", default=None)\n    parser.add_argument(\"--batch-size\", type=int, default=200)\n    parser.add_argument(\"--target-count\", default=\"all\")\n    parser.add_argument(\"--include\", default=\"post,reply,repost,quote\")\n    parser.add_argument(\"--no-screenshots\", action=\"store_true\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--profile-dir\", default=\"Profile 4\")\n    parser.add_argument(\"--headless\", action=\"store_true\")\n    parser.add_argument(\"--no-reuse\", action=\"store_true\")\n    parser.add_argument(\"--wait\", type=float, default=15.0)\n    parser.add_argument(\"--no-monitor-latest\", action=\"store_true\")\n    parser.add_argument(\"--api-root\", default=None)\n    parser.add_argument(\"--chrome-path\", default=DEFAULT_CHROME_PATH)\n    parser.add_argument(\"--print-launch-command\", action=\"store_true\")\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n    launch_command = build_debug_chrome_command(\n        api_root=args.api_root,\n        chrome_path=args.chrome_path,\n        port=args.port,\n        profile_dir=args.profile_dir,\n        headless=args.headless,\n    )\n    log.info(\"chrome_debug.command %s\", command_text(launch_command))\n\n    if args.print_launch_command:\n        print(command_text(launch_command))\n        return 0\n\n    result = collect_x_posts(\n        account=args.account,\n        output_root=args.output_root,\n        batch_size=args.batch_size,\n        target_count=args.target_count,\n        include=args.include,\n        screenshots=not args.no_screenshots,\n        port=args.port,\n        profile_dir=args.profile_dir,\n        headless=args.headless,\n        reuse_existing=not args.no_reuse,\n        wait=args.wait,\n        monitor_latest=not args.no_monitor_latest,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
