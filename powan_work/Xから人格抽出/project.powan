    {
      "id": "node-50607708e4",
      "title": "ニュース本文確認ポワン",
      "body": "終端投稿にニュース記事や外部記事リンクが含まれている時、その記事本文を確認対象として扱う神経ポワン。X終端投稿から外部URLを抽出し、短縮URLやリダイレクトを展開し、既存のAPI scripts/article_rag/extractors.py などの本文抽出材料を使って記事本文、タイトル、媒体名、公開日、取得不能理由を整理し、最後にDBへ保存する流れを束ねる。RAG、意味検索、矛盾判定は行わず、収集と保存だけを担当する。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport importlib\nimport json\nimport sys\nfrom collections.abc import Mapping\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom types import SimpleNamespace\nfrom typing import Any\n\n\nCOMPONENT_TYPE = \"news_or_article\"\nCHILD_TITLE = \"ニュース本文確認ポワン\"\nDEFAULT_PROJECT_FILE = \"project.powan\"\nDEFAULT_JSONL_PATH = \"data/news_article_component_events.jsonl\"\nDEFAULT_RUNS_LOG_PATH = \"runs/news_article_component.log\"\n\nSTAGE_URL_EXTRACTION = \"urlExtraction\"\nSTAGE_URL_EXPANSION = \"urlExpansion\"\nSTAGE_ARTICLE_EXTRACTION = \"articleExtraction\"\nSTAGE_METADATA_EXTRACTION = \"metadataExtraction\"\nSTAGE_UNAVAILABLE_REASON = \"unavailableReason\"\nSTAGE_DB_SAVE = \"dbSave\"\nSTAGE_ORDER = (\n    STAGE_URL_EXTRACTION,\n    STAGE_URL_EXPANSION,\n    STAGE_ARTICLE_EXTRACTION,\n    STAGE_METADATA_EXTRACTION,\n    STAGE_UNAVAILABLE_REASON,\n    STAGE_DB_SAVE,\n)\n\nCHILD_TITLES = {\n    STAGE_URL_EXTRACTION: \"ニュースURL抽出ポワン\",\n    STAGE_URL_EXPANSION: \"ニュースURL展開ポワン\",\n    STAGE_ARTICLE_EXTRACTION: \"ニュース本文抽出ポワン\",\n    STAGE_METADATA_EXTRACTION: \"ニュースメタ情報抽出ポワン\",\n    STAGE_UNAVAILABLE_REASON: \"ニュース取得不能理由整理ポワン\",\n    STAGE_DB_SAVE: \"ニュース本文DB保存ポワン\",\n}\n\nFUNCTION_CANDIDATES = {\n    STAGE_URL_EXTRACTION: (\"extract_news_urls\", \"extract\", \"run\"),\n    STAGE_URL_EXPANSION: (\"expand_news_url\", \"expand_news_urls\", \"expand\", \"run\"),\n    STAGE_ARTICLE_EXTRACTION: (\"extract_news_article\", \"extract_news_articles\", \"extract\", \"run\"),\n    STAGE_METADATA_EXTRACTION: (\"extract_news_metadata\", \"extract_metadata\", \"run\"),\n    STAGE_UNAVAILABLE_REASON: (\"classify_unavailable_reason\", \"classify_news_fetch_failure\", \"classify\", \"run\"),\n    STAGE_DB_SAVE: (\"save_news_content\", \"save_news_record\", \"save_news_records\", \"save\", \"run\"),\n}\n\nSTAGE_ALIASES = {\n    STAGE_URL_EXTRACTION: (\"newsUrlExtraction\", \"news_url_extraction\", \"url_extraction\"),\n    STAGE_URL_EXPANSION: (\"newsUrlExpansion\", \"news_url_expansion\", \"url_expansion\"),\n    STAGE_ARTICLE_EXTRACTION: (\"newsArticleExtraction\", \"news_article_extraction\", \"article_extraction\"),\n    STAGE_METADATA_EXTRACTION: (\"newsMetadataExtraction\", \"news_metadata_extraction\", \"metadata_extraction\"),\n    STAGE_UNAVAILABLE_REASON: (\"newsUnavailableReason\", \"news_unavailable_reason\", \"failureReason\"),\n    STAGE_DB_SAVE: (\"newsArticleDbSave\", \"news_article_db_save\", \"db_save\", \"save\"),\n}\n\nURL_KEYS = (\"raw_url\", \"rawUrl\", \"expanded_url\", \"expandedUrl\", \"card_url\", \"cardUrl\", \"url\", \"source_url\", \"sourceUrl\")\nFINAL_URL_KEYS = (\"canonicalUrl\", \"canonical_url\", \"finalUrl\", \"final_url\", \"expandedUrl\", \"expanded_url\", \"url\")\nPOST_ID_KEYS = (\"terminal_post_id\", \"postId\", \"post_id\", \"tweetId\", \"tweet_id\", \"statusId\", \"status_id\")\nTEXT_KEYS = (\"article_text\", \"articleText\", \"text\", \"body\", \"content\", \"fulltext\")\nTITLE_KEYS = (\"title\", \"headline\", \"card_title\", \"cardTitle\", \"ogTitle\", \"og_title\")\nSITE_KEYS = (\"site_name\", \"siteName\", \"source_name\", \"sourceName\", \"media_name\", \"mediaName\", \"domain\", \"host\")\nAUTHOR_KEYS = (\"author\", \"byline\", \"creator\")\nPUBLISHED_KEYS = (\"published_at\", \"publishedAt\", \"datePublished\", \"date_published\", \"pubDate\", \"date\")\nEXTRACTOR_KEYS = (\"extraction_method\", \"extractionMethod\", \"extractor\", \"extractor_name\", \"extractorName\")\nHTTP_STATUS_KEYS = (\"http_status\", \"httpStatus\", \"statusCode\", \"status_code\")\n\nALLOWED_ERROR_TYPES = {\n    \"url_expand_failed\",\n    \"http_error\",\n    \"robots_or_auth_blocked\",\n    \"paywall_or_login_required\",\n    \"article_text_empty\",\n    \"unsupported_content_type\",\n    \"extractor_failed\",\n    \"db_write_failed\",\n}\n\n\ndef confirm_news_articles(\n    input_json: Any = None,\n    *,\n    child_runners: Mapping[str, Any] | None = None,\n    child_results: Mapping[str, Any] | None = None,\n    options: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    payload = normalize_json_value(input_json)\n    opts = build_options(payload, options)\n    envelope = terminal_envelope(payload)\n    supplied = merge_child_results(payload.get(\"childResults\"), child_results)\n    runners, load_errors = build_runners(child_runners or {}, opts)\n    notes = [{\"stage\": \"loadProjectChildren\", \"errors\": load_errors}] if load_errors else []\n\n    explicit_candidates = normalize_article_urls(find_article_urls(payload), envelope)\n    if explicit_candidates:\n        url_extraction = {\n            \"ok\": True,\n            \"stage\": STAGE_URL_EXTRACTION,\n            \"source\": \"article_urls\",\n            \"urls\": explicit_candidates,\n        }\n        candidates = explicit_candidates\n    else:\n        url_extraction = run_child(\n            STAGE_URL_EXTRACTION,\n            envelope,\n            runners=runners,\n            child_results=supplied,\n            allow_missing=opts[\"allowMissingChildren\"],\n            notes=notes,\n        )\n        candidates = normalize_article_urls(candidate_urls(url_extraction), envelope)\n\n    item_results: list[dict[str, Any]] = []\n    save_results: list[dict[str, Any]] = []\n\n    for index, candidate in enumerate(candidates):\n        item = process_article_candidate(\n            payload=payload,\n            envelope=envelope,\n            candidate=candidate,\n            index=index,\n            url_extraction=url_extraction,\n            runners=runners,\n            child_results=supplied,\n            opts=opts,\n            notes=notes,\n        )\n        item_results.append(item)\n        save_results.append(item.get(\"save_result\") or {})\n\n    child_result = make_overall_child_result(payload, envelope, item_results, url_extraction, save_results)\n    if not candidates:\n        child_result[\"status\"] = \"skipped\"\n        child_result[\"error_type\"] = \"no_article_url\"\n        child_result[\"error_message\"] = \"news_or_article component had no article_urls.\"\n        child_result[\"retryable\"] = False\n\n    return {\n        \"ok\": child_result[\"status\"] in {\"success\", \"partial\", \"skipped\"},\n        \"status\": child_result[\"status\"],\n        \"component_type\": COMPONENT_TYPE,\n        \"inputJson\": payload,\n        \"child_result\": child_result,\n        \"childResultJson\": snapshot_child_result_input(supplied),\n        \"childResults\": {\n            STAGE_URL_EXTRACTION: url_extraction,\n            STAGE_DB_SAVE: save_results,\n        },\n        \"items\": item_results,\n        \"notes\": notes,\n    }\n\n\ndef process_article_candidate(\n    *,\n    payload: Mapping[str, Any],\n    envelope: Mapping[str, Any],\n    candidate: Mapping[str, Any],\n    index: int,\n    url_extraction: Mapping[str, Any],\n    runners: Mapping[str, Any],\n    child_results: Mapping[str, Any],\n    opts: Mapping[str, Any],\n    notes: list[dict[str, Any]],\n) -> dict[str, Any]:\n    expansion = run_child(\n        STAGE_URL_EXPANSION,\n        make_expansion_input(payload, envelope, candidate, index, opts),\n        runners=runners,\n        child_results=child_results,\n        index=index,\n        allow_missing=opts[\"allowMissingChildren\"],\n        notes=notes,\n    )\n    article = None\n    metadata = None\n    failure = None\n\n    if result_ok(expansion):\n        article = run_child(\n            STAGE_ARTICLE_EXTRACTION,\n            make_article_input(payload, envelope, candidate, expansion, index, opts),\n            runners=runners,\n            child_results=child_results,\n            index=index,\n            allow_missing=opts[\"allowMissingChildren\"],\n            notes=notes,\n        )\n    else:\n        failure = classify_failure(payload, envelope, candidate, expansion, STAGE_URL_EXPANSION, runners, child_results, index, opts, notes)\n\n    if article is not None and result_ok(article) and first_text(unwrap_result(article), TEXT_KEYS):\n        metadata = run_child(\n            STAGE_METADATA_EXTRACTION,\n            make_metadata_input(payload, envelope, candidate, expansion, article, index),\n            runners=runners,\n            child_results=child_results,\n            index=index,\n            allow_missing=opts[\"allowMissingChildren\"],\n            notes=notes,\n        )\n    elif article is not None:\n        failure = classify_failure(payload, envelope, candidate, article, STAGE_ARTICLE_EXTRACTION, runners, child_results, index, opts, notes)\n\n    save_payload = make_save_payload(\n        payload=payload,\n        envelope=envelope,\n        index=index,\n        candidate=candidate,\n        url_extraction=url_extraction,\n        url_expansion=expansion,\n        article_extraction=article,\n        metadata_extraction=metadata,\n        unavailable_reason=failure,\n        opts=opts,\n    )\n    save_result = run_child(\n        STAGE_DB_SAVE,\n        save_payload,\n        runners=runners,\n        child_results=child_results,\n        index=index,\n        allow_missing=opts[\"allowMissingChildren\"],\n        notes=notes,\n    )\n    item_child_result = make_item_child_result(\n        payload=payload,\n        envelope=envelope,\n        candidate=candidate,\n        index=index,\n        expansion=expansion,\n        article=article,\n        metadata=metadata,\n        failure=failure,\n        save_payload=save_payload,\n        save_result=save_result,\n        opts=opts,\n    )\n    artifact_paths = persist_logs(item_child_result, opts)\n    item_child_result[\"artifact_paths\"] = unique_strings([*item_child_result.get(\"artifact_paths\", []), *artifact_paths])\n    return {\n        \"index\": index,\n        \"candidate\": candidate,\n        \"child_result\": item_child_result,\n        \"save_payload\": save_payload,\n        \"save_result\": save_result,\n        \"childResults\": {\n            STAGE_URL_EXPANSION: expansion,\n            STAGE_ARTICLE_EXTRACTION: article,\n            STAGE_METADATA_EXTRACTION: metadata,\n            STAGE_UNAVAILABLE_REASON: failure,\n            STAGE_DB_SAVE: save_result,\n        },\n    }\n\n\ndef classify_failure(\n    payload: Mapping[str, Any],\n    envelope: Mapping[str, Any],\n    candidate: Mapping[str, Any],\n    failed_result: Any,\n    failed_stage: str,\n    runners: Mapping[str, Any],\n    child_results: Mapping[str, Any],\n    index: int,\n    opts: Mapping[str, Any],\n    notes: list[dict[str, Any]],\n) -> dict[str, Any]:\n    return run_child(\n        STAGE_UNAVAILABLE_REASON,\n        {\n            \"inputJson\": payload,\n            \"terminal_post_envelope\": envelope,\n            \"candidate\": candidate,\n            \"failedStage\": failed_stage,\n            \"failedResult\": failed_result,\n            \"index\": index,\n        },\n        runners=runners,\n        child_results=child_results,\n        index=index,\n        allow_missing=opts[\"allowMissingChildren\"],\n        notes=notes,\n    )\n\n\ndef run_child(\n    stage: str,\n    payload: Any,\n    *,\n    runners: Mapping[str, Any],\n    child_results: Mapping[str, Any],\n    index: int | None = None,\n    allow_missing: bool,\n    notes: list[dict[str, Any]],\n) -> dict[str, Any]:\n    supplied = supplied_child_result(child_results, stage, index=index)\n    if supplied is not None:\n        notes.append({\"stage\": stage, \"index\": index, \"source\": \"childResultJson\"})\n        return ensure_result_dict(supplied, stage=stage, source=\"childResultJson\")\n    runner = find_runner(runners, stage)\n    if runner is None:\n        result = {\n            \"ok\": False,\n            \"stage\": stage,\n            \"source\": \"missing\",\n            \"index\": index,\n            \"error\": {\"type\": \"MissingChildRunner\", \"reason\": \"child_runner_missing\", \"message\": f\"Child runner is required for {stage}.\"},\n            \"input\": payload,\n        }\n        notes.append({\"stage\": stage, \"index\": index, \"source\": \"missing\", \"ok\": False})\n        if allow_missing:\n            return result\n        raise RuntimeError(result[\"error\"][\"message\"])\n    notes.append({\"stage\": stage, \"index\": index, \"source\": \"runner\"})\n    try:\n        return ensure_result_dict(call_runner(stage, runner, payload), stage=stage, source=\"runner\")\n    except Exception as exc:\n        return {\n            \"ok\": False,\n            \"stage\": stage,\n            \"source\": \"runner\",\n            \"error\": {\"type\": exc.__class__.__name__, \"message\": str(exc), \"reason\": \"child_runner_failed\"},\n        }\n\n\ndef call_runner(stage: str, runner: Any, payload: Any) -> Any:\n    if isinstance(runner, str):\n        runner = importlib.import_module(runner)\n    if callable(runner):\n        return runner(payload)\n    for name in FUNCTION_CANDIDATES.get(stage, (\"run\",)):\n        func = getattr(runner, name, None)\n        if callable(func):\n            return call_stage_function(stage, name, func, payload)\n    raise TypeError(f\"No callable child entrypoint for stage {stage}\")\n\n\ndef call_stage_function(stage: str, name: str, func: Any, payload: Any) -> Any:\n    if stage == STAGE_URL_EXPANSION:\n        url = first_text(payload, (\"url\", \"raw_url\", \"rawUrl\", \"expanded_url\", \"expandedUrl\", \"card_url\", \"cardUrl\"))\n        if name == \"expand_news_urls\":\n            result = func([url])\n            return result[0] if isinstance(result, list) and result else result\n        if name == \"expand_news_url\":\n            kwargs = {}\n            if first_text(payload, (\"saveHtmlDir\", \"save_html_dir\")):\n                kwargs[\"save_html_dir\"] = first_text(payload, (\"saveHtmlDir\", \"save_html_dir\"))\n            if payload.get(\"timeout\") is not None:\n                kwargs[\"timeout\"] = payload.get(\"timeout\")\n            return func(url, **kwargs)\n    if stage == STAGE_ARTICLE_EXTRACTION and name == \"extract_news_articles\":\n        result = func([payload])\n        return result[0] if isinstance(result, list) and result else result\n    if stage == STAGE_DB_SAVE and name in {\"save_news_content\", \"save_news_record\", \"save_news_records\"}:\n        db_path = first_text(payload, (\"dbPath\", \"db_path\"))\n        return func(payload, db_path=db_path) if db_path else func(payload)\n    return func(payload)\n\n\ndef make_expansion_input(payload: Mapping[str, Any], envelope: Mapping[str, Any], candidate: Mapping[str, Any], index: int, opts: Mapping[str, Any]) -> dict[str, Any]:\n    return {\n        \"inputJson\": payload,\n        \"terminal_post_envelope\": envelope,\n        \"candidate\": candidate,\n        \"url\": first_text(candidate, URL_KEYS),\n        \"postId\": trace_value(envelope, \"terminal_post_id\"),\n        \"source_entity_index\": candidate.get(\"source_entity_index\"),\n        \"evidence_url\": candidate.get(\"evidence_url\"),\n        \"saveHtmlDir\": opts.get(\"saveHtmlDir\", \"\"),\n        \"timeout\": opts.get(\"timeout\"),\n        \"index\": index,\n    }\n\n\ndef make_article_input(payload: Mapping[str, Any], envelope: Mapping[str, Any], candidate: Mapping[str, Any], expansion: Mapping[str, Any], index: int, opts: Mapping[str, Any]) -> dict[str, Any]:\n    expanded = unwrap_result(expansion)\n    return {\n        \"inputJson\": payload,\n        \"terminal_post_envelope\": envelope,\n        \"candidate\": candidate,\n        \"urlExpansion\": expansion,\n        \"url\": first_text(expanded, (\"canonicalUrl\", \"canonical_url\", \"finalUrl\", \"final_url\", \"url\")) or first_text(candidate, URL_KEYS),\n        \"post_id\": trace_value(envelope, \"terminal_post_id\"),\n        \"timeout\": opts.get(\"articleTimeout\"),\n        \"max_pages\": opts.get(\"maxPages\"),\n        \"index\": index,\n    }\n\n\ndef make_metadata_input(payload: Mapping[str, Any], envelope: Mapping[str, Any], candidate: Mapping[str, Any], expansion: Mapping[str, Any], article: Mapping[str, Any], index: int) -> dict[str, Any]:\n    expanded = unwrap_result(expansion)\n    article_data = unwrap_result(article)\n    metadata = dict(article_data.get(\"metadata\") or {}) if isinstance(article_data, Mapping) else {}\n    metadata.update(dict(expanded.get(\"metadata\") or {}) if isinstance(expanded, Mapping) else {})\n    return {\n        \"inputJson\": payload,\n        \"terminal_post_envelope\": envelope,\n        \"candidate\": candidate,\n        \"url\": first_text(candidate, URL_KEYS),\n        \"final_url\": first_text(expanded, (\"finalUrl\", \"final_url\", \"url\")),\n        \"canonical_url\": first_text(expanded, (\"canonicalUrl\", \"canonical_url\")),\n        \"title\": first_text(article_data, TITLE_KEYS) or first_text(candidate, (\"card_title\", \"cardTitle\")),\n        \"metadata\": metadata,\n        \"article\": article_data,\n        \"index\": index,\n    }\n\n\ndef make_save_payload(\n    *,\n    payload: Mapping[str, Any],\n    envelope: Mapping[str, Any],\n    index: int,\n    candidate: Mapping[str, Any],\n    url_extraction: Mapping[str, Any],\n    url_expansion: Mapping[str, Any],\n    article_extraction: Mapping[str, Any] | None,\n    metadata_extraction: Mapping[str, Any] | None,\n    unavailable_reason: Mapping[str, Any] | None,\n    opts: Mapping[str, Any],\n) -> dict[str, Any]:\n    expanded = unwrap_result(url_expansion)\n    article = unwrap_result(article_extraction or {})\n    meta = unwrap_result(metadata_extraction or {})\n    reason = unwrap_result(unavailable_reason or {})\n    raw_url = first_text(candidate, (\"raw_url\", \"rawUrl\", \"url\", \"source_url\", \"sourceUrl\"))\n    final_url = first_text(expanded, (\"canonicalUrl\", \"canonical_url\", \"finalUrl\", \"final_url\", \"url\")) or first_text(candidate, (\"expanded_url\", \"expandedUrl\", \"card_url\", \"cardUrl\")) or raw_url\n    metadata = merge_dicts(article.get(\"metadata\") if isinstance(article, Mapping) else {}, meta if isinstance(meta, Mapping) else {})\n    failure_type = normalize_error_type(reason, url_expansion, article_extraction, STAGE_ARTICLE_EXTRACTION if article_extraction is not None else STAGE_URL_EXPANSION)\n    return {\n        \"run_id\": trace_value(envelope, \"run_id\"),\n        \"trace_id\": trace_value(envelope, \"trace_id\"),\n        \"terminal_post_id\": trace_value(envelope, \"terminal_post_id\"),\n        \"component_type\": COMPONENT_TYPE,\n        \"source_url\": raw_url,\n        \"url\": raw_url,\n        \"originalUrl\": raw_url,\n        \"finalUrl\": final_url,\n        \"canonicalUrl\": first_text(expanded, (\"canonicalUrl\", \"canonical_url\")) or final_url,\n        \"title\": first_text(article, TITLE_KEYS) or first_text(meta, TITLE_KEYS) or first_text(candidate, (\"card_title\", \"cardTitle\")),\n        \"siteName\": first_text(meta, SITE_KEYS) or first_text(article, SITE_KEYS),\n        \"author\": first_text(meta, AUTHOR_KEYS) or first_text(article, AUTHOR_KEYS),\n        \"publishedAt\": first_text(meta, PUBLISHED_KEYS) or first_text(article, PUBLISHED_KEYS),\n        \"articleText\": first_text(article, TEXT_KEYS),\n        \"extractionMethod\": first_text(article, EXTRACTOR_KEYS) or first_text(meta, EXTRACTOR_KEYS),\n        \"httpStatus\": first_text(expanded, HTTP_STATUS_KEYS),\n        \"failureType\": failure_type if failure_type and failure_type != \"db_write_failed\" else \"\",\n        \"failureStage\": first_text(reason, (\"failedStage\", \"failure_stage\", \"stage\")),\n        \"failureMessage\": first_text(reason, (\"reason\", \"message\", \"error_message\", \"errorMessage\", \"raw_error\")),\n        \"retryable\": pick_retryable(reason, expanded),\n        \"metadata\": metadata,\n        \"error\": reason if failure_type else None,\n        \"dbPath\": opts.get(\"dbPath\", \"\"),\n        \"rawJson\": {\n            \"inputJson\": payload,\n            \"terminal_post_envelope\": envelope,\n            \"candidate\": candidate,\n            \"urlExtraction\": url_extraction,\n            \"urlExpansion\": url_expansion,\n            \"articleExtraction\": article_extraction,\n            \"metadataExtraction\": metadata_extraction,\n            \"unavailableReason\": unavailable_reason,\n        },\n    }\n\n\ndef make_item_child_result(\n    *,\n    payload: Mapping[str, Any],\n    envelope: Mapping[str, Any],\n    candidate: Mapping[str, Any],\n    index: int,\n    expansion: Mapping[str, Any],\n    article: Mapping[str, Any] | None,\n    metadata: Mapping[str, Any] | None,\n    failure: Mapping[str, Any] | None,\n    save_payload: Mapping[str, Any],\n    save_result: Mapping[str, Any],\n    opts: Mapping[str, Any],\n) -> dict[str, Any]:\n    expanded = unwrap_result(expansion)\n    article_data = unwrap_result(article or {})\n    meta = unwrap_result(metadata or {})\n    save_data = unwrap_result(save_result or {})\n    raw_url = first_text(candidate, (\"raw_url\", \"rawUrl\", \"url\", \"source_url\", \"sourceUrl\"))\n    final_url = first_text(save_data, (\"final_url\", \"finalUrl\", \"canonical_url\", \"canonicalUrl\")) or first_text(save_payload, (\"finalUrl\", \"canonicalUrl\"))\n    article_text = first_text(save_payload, (\"articleText\", \"article_text\", \"text\")) or first_text(article_data, TEXT_KEYS)\n    title = first_text(save_payload, TITLE_KEYS) or first_text(article_data, TITLE_KEYS) or first_text(meta, TITLE_KEYS) or first_text(candidate, (\"card_title\", \"cardTitle\"))\n    site_name = first_text(save_payload, SITE_KEYS) or first_text(meta, SITE_KEYS) or first_text(article_data, SITE_KEYS)\n    error_type = \"db_write_failed\" if not result_ok(save_result) else normalize_error_type(failure, expansion, article, \"\")\n    status = item_status(article_text, title, site_name, final_url, save_result, error_type)\n    extracted_metadata = {\n        \"site_name\": site_name,\n        \"title\": title,\n        \"author\": first_text(save_payload, AUTHOR_KEYS) or first_text(meta, AUTHOR_KEYS),\n        \"published_at\": first_text(save_payload, PUBLISHED_KEYS) or first_text(meta, PUBLISHED_KEYS),\n        \"language\": first_text(article_data, (\"language\", \"lang\")),\n    }\n    artifact_paths = unique_strings([\n        first_text(save_data, (\"db_path\", \"dbPath\")),\n        first_text(expanded, (\"htmlPath\", \"html_path\")),\n    ])\n    return {\n        \"status\": status,\n        \"component_type\": COMPONENT_TYPE,\n        \"run_id\": trace_value(envelope, \"run_id\"),\n        \"trace_id\": trace_value(envelope, \"trace_id\"),\n        \"terminal_post_id\": trace_value(envelope, \"terminal_post_id\"),\n        \"source_url\": raw_url,\n        \"raw_url\": raw_url,\n        \"final_url\": final_url,\n        \"site_name\": site_name,\n        \"title\": title,\n        \"author\": extracted_metadata[\"author\"],\n        \"published_at\": extracted_metadata[\"published_at\"],\n        \"article_text_ref\": article_text_ref(article_text, save_data),\n        \"excerpt\": excerpt(article_text or first_text(candidate, (\"card_description\", \"cardDescription\")), 280),\n        \"extraction_method\": first_text(save_payload, EXTRACTOR_KEYS),\n        \"http_status\": first_text(save_payload, HTTP_STATUS_KEYS),\n        \"artifact_paths\": artifact_paths,\n        \"extracted_metadata\": extracted_metadata,\n        \"model_or_tool_info\": {\"tool\": \"child_powans\", \"rag\": False, \"embedding\": False, \"contradiction_judgement\": False},\n        \"evidence_json\": make_evidence_json(payload, envelope, candidate, expansion, article, metadata, failure, save_result, index),\n        \"error_type\": error_type,\n        \"error_message\": error_message(failure, save_result, error_type),\n        \"retryable\": pick_retryable(unwrap_result(failure or {}), expanded),\n        \"finished_at\": now_iso(),\n    }\n\n\ndef make_overall_child_result(\n    payload: Mapping[str, Any],\n    envelope: Mapping[str, Any],\n    items: list[dict[str, Any]],\n    url_extraction: Mapping[str, Any],\n    save_results: list[dict[str, Any]],\n) -> dict[str, Any]:\n    child_results = [item[\"child_result\"] for item in items]\n    statuses = [item.get(\"status\") for item in child_results]\n    if not statuses:\n        status = \"skipped\"\n    elif all(value == \"success\" for value in statuses):\n        status = \"success\"\n    elif any(value in {\"success\", \"partial\"} for value in statuses):\n        status = \"partial\"\n    else:\n        status = \"failed\"\n    first_error = next((item for item in child_results if item.get(\"error_type\")), {})\n    return {\n        \"status\": status,\n        \"component_type\": COMPONENT_TYPE,\n        \"run_id\": trace_value(envelope, \"run_id\"),\n        \"trace_id\": trace_value(envelope, \"trace_id\"),\n        \"terminal_post_id\": trace_value(envelope, \"terminal_post_id\"),\n        \"source_url\": first_text(child_results[0], (\"source_url\",)) if child_results else \"\",\n        \"artifact_paths\": unique_strings(path for item in child_results for path in item.get(\"artifact_paths\", [])),\n        \"extracted_metadata\": {\"article_count\": len(child_results), \"saved_count\": sum(1 for item in save_results if result_ok(item))},\n        \"model_or_tool_info\": {\"tool\": \"child_powans\", \"rag\": False, \"embedding\": False, \"contradiction_judgement\": False},\n        \"evidence_json\": {\"input_keys\": sorted(payload.keys()), \"urlExtraction\": url_extraction, \"items\": [item.get(\"evidence_json\") for item in child_results]},\n        \"error_type\": first_error.get(\"error_type\", \"\"),\n        \"error_message\": first_error.get(\"error_message\", \"\"),\n        \"retryable\": any(bool(item.get(\"retryable\")) for item in child_results),\n        \"finished_at\": now_iso(),\n        \"items\": child_results,\n    }\n\n\ndef item_status(article_text: str, title: str, site_name: str, final_url: str, save_result: Mapping[str, Any], error_type_value: str) -> str:\n    if error_type_value == \"db_write_failed\" or not result_ok(save_result):\n        return \"failed\"\n    if article_text:\n        return \"success\"\n    if title or site_name or final_url:\n        return \"partial\"\n    return \"failed\"\n\n\ndef normalize_error_type(failure: Any, expansion: Any, article: Any, failed_stage: str) -> str:\n    if failure:\n        data = unwrap_result(failure)\n        raw = first_text(data, (\"failure_type\", \"failureType\", \"unavailable_reason\", \"unavailableReason\", \"reason\", \"error_type\", \"type\"))\n        mapped = map_error_type(raw, first_text(data, HTTP_STATUS_KEYS), first_text(data, (\"raw_error\", \"message\", \"error\")))\n        if mapped:\n            return mapped\n    if failed_stage == STAGE_URL_EXPANSION and not result_ok(expansion):\n        return \"http_error\" if first_text(unwrap_result(expansion), HTTP_STATUS_KEYS) else \"url_expand_failed\"\n    if article is not None and not result_ok(article):\n        return \"article_text_empty\" if \"empty\" in error_message(article, {}, \"\").lower() else \"extractor_failed\"\n    return \"\"\n\n\ndef map_error_type(raw: str, status: str = \"\", message: str = \"\") -> str:\n    text = \" \".join([raw, status, message]).lower()\n    if not text:\n        return \"\"\n    if any(word in text for word in (\"paywall\", \"subscription\", \"login required\")):\n        return \"paywall_or_login_required\"\n    if any(word in text for word in (\"robots\", \"auth\", \"forbidden\", \"403\", \"blocked\")):\n        return \"robots_or_auth_blocked\"\n    if any(word in text for word in (\"empty\", \"too_short\", \"short\", \"no body\")):\n        return \"article_text_empty\"\n    if any(word in text for word in (\"unsupported\", \"content_type\", \"pdf\", \"binary\")):\n        return \"unsupported_content_type\"\n    if status and str(status).strip().isdigit() and int(status) >= 400:\n        return \"http_error\"\n    if any(word in text for word in (\"redirect\", \"url\", \"dns\", \"timeout\", \"connection\")):\n        return \"url_expand_failed\"\n    if raw in ALLOWED_ERROR_TYPES:\n        return raw\n    return \"extractor_failed\"\n\n\ndef persist_logs(child_result: Mapping[str, Any], opts: Mapping[str, Any]) -> list[str]:\n    if not opts.get(\"writeLogs\", True):\n        return []\n    paths: list[str] = []\n    event = {\n        \"event_ts\": now_iso(),\n        \"event\": \"child_result_recorded\",\n        \"run_id\": child_result.get(\"run_id\"),\n        \"trace_id\": child_result.get(\"trace_id\"),\n        \"terminal_post_id\": child_result.get(\"terminal_post_id\"),\n        \"content_class\": COMPONENT_TYPE,\n        \"components\": [COMPONENT_TYPE],\n        \"child_title\": CHILD_TITLE,\n        \"status\": child_result.get(\"status\"),\n        \"error_type\": child_result.get(\"error_type\"),\n        \"retryable\": child_result.get(\"retryable\"),\n        \"artifact_paths\": child_result.get(\"artifact_paths\", []),\n        \"evidence_urls\": evidence_urls(child_result),\n    }\n    jsonl_path = first_text(opts, (\"jsonlPath\", \"jsonl_path\"))\n    runs_path = first_text(opts, (\"runsLogPath\", \"runs_log_path\"))\n    if jsonl_path:\n        append_jsonl(jsonl_path, event)\n        paths.append(jsonl_path)\n    if runs_path:\n        append_line(runs_path, runs_summary(child_result))\n        paths.append(runs_path)\n    return paths\n\n\ndef append_jsonl(path_value: str, event: Mapping[str, Any]) -> None:\n    path = Path(path_value)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with path.open(\"a\", encoding=\"utf-8\", newline=\"\\n\") as fh:\n        fh.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + \"\\n\")\n\n\ndef append_line(path_value: str, text: str) -> None:\n    path = Path(path_value)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with path.open(\"a\", encoding=\"utf-8\", newline=\"\\n\") as fh:\n        fh.write(text.rstrip() + \"\\n\")\n\n\ndef runs_summary(child_result: Mapping[str, Any]) -> str:\n    return (\n        f\"{child_result.get('finished_at')} run={child_result.get('run_id')} trace={child_result.get('trace_id')} \"\n        f\"post={child_result.get('terminal_post_id')} component={COMPONENT_TYPE} status={child_result.get('status')} \"\n        f\"source={child_result.get('source_url')} final={child_result.get('final_url')} \"\n        f\"title={compact(child_result.get('title'), 90)} error={child_result.get('error_type') or '-'}\"\n    )\n\n\ndef build_options(payload: Mapping[str, Any], options: Mapping[str, Any] | None) -> dict[str, Any]:\n    raw = merge_dicts(payload.get(\"options\") if isinstance(payload.get(\"options\"), Mapping) else {}, options or {})\n    return {\n        \"projectFile\": raw.get(\"projectFile\") or raw.get(\"project_file\") or DEFAULT_PROJECT_FILE,\n        \"autoLoadProjectChildren\": raw.get(\"autoLoadProjectChildren\", raw.get(\"auto_load_project_children\", True)) is not False,\n        \"allowMissingChildren\": raw.get(\"allowMissingChildren\", raw.get(\"allow_missing_children\", True)) is not False,\n        \"writeLogs\": raw.get(\"writeLogs\", raw.get(\"write_logs\", True)) is not False,\n        \"jsonlPath\": raw.get(\"jsonlPath\") or raw.get(\"jsonl_path\") or DEFAULT_JSONL_PATH,\n        \"runsLogPath\": raw.get(\"runsLogPath\") or raw.get(\"runs_log_path\") or DEFAULT_RUNS_LOG_PATH,\n        \"dbPath\": raw.get(\"dbPath\") or raw.get(\"db_path\") or \"\",\n        \"saveHtmlDir\": raw.get(\"saveHtmlDir\") or raw.get(\"save_html_dir\") or \"\",\n        \"timeout\": raw.get(\"timeout\"),\n        \"articleTimeout\": raw.get(\"articleTimeout\") or raw.get(\"article_timeout\"),\n        \"maxPages\": raw.get(\"maxPages\") or raw.get(\"max_pages\"),\n    }\n\n\ndef build_runners(child_runners: Mapping[str, Any], opts: Mapping[str, Any]) -> tuple[dict[str, Any], list[dict[str, str]]]:\n    runners: dict[str, Any] = {}\n    errors: list[dict[str, str]] = []\n    if opts.get(\"autoLoadProjectChildren\", True):\n        runners, errors = load_project_child_runners(str(opts.get(\"projectFile\") or DEFAULT_PROJECT_FILE))\n    runners.update(normalize_runners(child_runners))\n    return runners, errors\n\n\ndef load_project_child_runners(project_file: str) -> tuple[dict[str, Any], list[dict[str, str]]]:\n    path = Path(project_file)\n    if not path.exists():\n        return {}, [{\"stage\": \"project\", \"message\": f\"project file not found: {project_file}\"}]\n    data = json.loads(path.read_text(encoding=\"utf-8\"))\n    nodes = data.get(\"nodes\") if isinstance(data, Mapping) else []\n    runners: dict[str, Any] = {}\n    errors: list[dict[str, str]] = []\n    for stage, title in CHILD_TITLES.items():\n        node = next((item for item in nodes if isinstance(item, Mapping) and item.get(\"title\") == title), None)\n        code = str((node or {}).get(\"code\") or \"\")\n        if not code:\n            errors.append({\"stage\": stage, \"title\": title, \"message\": \"child code is empty\"})\n            continue\n        ns = {\"__name__\": f\"powan_{stage}\", \"__file__\": f\"{project_file}:{title}\"}\n        try:\n            exec(compile(code, f\"{project_file}:{title}\", \"exec\"), ns)\n            runners[stage] = SimpleNamespace(**ns)\n        except Exception as exc:\n            errors.append({\"stage\": stage, \"title\": title, \"message\": f\"{exc.__class__.__name__}: {exc}\"})\n    return runners, errors\n\n\ndef normalize_runners(runners: Mapping[str, Any]) -> dict[str, Any]:\n    out: dict[str, Any] = {}\n    for key, value in runners.items():\n        stage = canonical_stage(str(key))\n        if stage:\n            out[stage] = value\n    return out\n\n\ndef find_runner(runners: Mapping[str, Any], stage: str) -> Any:\n    if stage in runners:\n        return runners[stage]\n    for alias in STAGE_ALIASES.get(stage, ()):\n        if alias in runners:\n            return runners[alias]\n    return None\n\n\ndef canonical_stage(value: str) -> str:\n    if value in STAGE_ORDER:\n        return value\n    for stage, aliases in STAGE_ALIASES.items():\n        if value in aliases:\n            return stage\n    return \"\"\n\n\ndef terminal_envelope(payload: Mapping[str, Any]) -> dict[str, Any]:\n    envelope = payload.get(\"terminal_post_envelope\") or payload.get(\"terminalPostEnvelope\") or payload\n    return dict(envelope) if isinstance(envelope, Mapping) else {}\n\n\ndef find_article_urls(payload: Mapping[str, Any]) -> list[Any]:\n    for key in (\"article_urls\", \"articleUrls\", \"news_article_urls\", \"newsArticleUrls\"):\n        value = payload.get(key)\n        if isinstance(value, list):\n            return value\n    envelope = terminal_envelope(payload)\n    value = envelope.get(\"article_urls\") or envelope.get(\"articleUrls\")\n    return value if isinstance(value, list) else []\n\n\ndef normalize_article_urls(raw_items: Any, envelope: Mapping[str, Any]) -> list[dict[str, Any]]:\n    if not isinstance(raw_items, list):\n        return []\n    out: list[dict[str, Any]] = []\n    for index, raw in enumerate(raw_items):\n        item = dict(raw) if isinstance(raw, Mapping) else {\"raw_url\": str(raw)}\n        url = first_text(item, URL_KEYS)\n        if not url:\n            continue\n        item.setdefault(\"raw_url\", url)\n        item.setdefault(\"source_entity_index\", index)\n        item.setdefault(\"evidence_url\", trace_value(envelope, \"terminal_post_url\") or url)\n        item.setdefault(\"postId\", trace_value(envelope, \"terminal_post_id\"))\n        out.append(item)\n    return out\n\n\ndef candidate_urls(url_extraction: Any) -> list[dict[str, Any]]:\n    result = unwrap_result(url_extraction)\n    if isinstance(result, list):\n        return [dict(item) if isinstance(item, Mapping) else {\"url\": str(item)} for item in result]\n    if not isinstance(result, Mapping):\n        return []\n    for key in (\"urls\", \"candidateUrls\", \"candidate_urls\", \"items\", \"results\"):\n        value = result.get(key)\n        if isinstance(value, list):\n            return [dict(item) if isinstance(item, Mapping) else {\"url\": str(item)} for item in value]\n    return [dict(result)] if first_text(result, URL_KEYS) else []\n\n\ndef merge_child_results(*sources: Any) -> dict[str, Any]:\n    merged: dict[str, Any] = {}\n    for source in sources:\n        value = normalize_json_value(source)\n        if isinstance(value, Mapping):\n            for key, item in value.items():\n                merged[canonical_stage(str(key)) or str(key)] = item\n    return merged\n\n\ndef supplied_child_result(child_results: Mapping[str, Any], stage: str, *, index: int | None) -> Any:\n    if stage not in child_results:\n        return None\n    value = child_results[stage]\n    if index is None:\n        return value\n    if isinstance(value, list):\n        return value[index] if index < len(value) else None\n    if isinstance(value, Mapping):\n        for key in (\"items\", \"results\", \"records\"):\n            items = value.get(key)\n            if isinstance(items, list):\n                return items[index] if index < len(items) else None\n        return value.get(str(index), value)\n    return value\n\n\ndef ensure_result_dict(value: Any, *, stage: str, source: str) -> dict[str, Any]:\n    if isinstance(value, Mapping):\n        result = dict(value)\n        result.setdefault(\"stage\", stage)\n        result.setdefault(\"source\", source)\n        result.setdefault(\"ok\", not bool(result.get(\"error\")))\n        return result\n    return {\"ok\": True, \"stage\": stage, \"source\": source, \"result\": value}\n\n\ndef result_ok(value: Any) -> bool:\n    return isinstance(value, Mapping) and value.get(\"ok\") is not False and not value.get(\"error\")\n\n\ndef unwrap_result(value: Any) -> Any:\n    if isinstance(value, Mapping):\n        if any(key in value for key in (*TEXT_KEYS, *TITLE_KEYS, *FINAL_URL_KEYS, \"urls\", \"error\")):\n            return value\n        for key in (\"result\", \"data\", \"article\", \"record\", \"metadata\"):\n            inner = value.get(key)\n            if isinstance(inner, Mapping):\n                return inner\n    return value\n\n\ndef make_evidence_json(payload: Mapping[str, Any], envelope: Mapping[str, Any], candidate: Mapping[str, Any], expansion: Any, article: Any, metadata: Any, failure: Any, save_result: Any, index: int) -> dict[str, Any]:\n    return {\n        \"index\": index,\n        \"terminal_post_url\": trace_value(envelope, \"terminal_post_url\"),\n        \"parent_trace\": envelope.get(\"parent_trace\") or [],\n        \"discovery_path\": envelope.get(\"discovery_path\") or [],\n        \"component_flags\": envelope.get(\"component_flags\") or {},\n        \"evidence_urls\": unique_strings([candidate.get(\"evidence_url\"), *listify(payload.get(\"evidence_urls\")), *listify(envelope.get(\"evidence_urls\"))]),\n        \"candidate\": candidate,\n        \"urlExpansion\": expansion,\n        \"articleExtraction\": article,\n        \"metadataExtraction\": metadata,\n        \"unavailableReason\": failure,\n        \"dbSave\": save_result,\n    }\n\n\ndef evidence_urls(child_result: Mapping[str, Any]) -> list[str]:\n    evidence = child_result.get(\"evidence_json\") if isinstance(child_result.get(\"evidence_json\"), Mapping) else {}\n    return unique_strings([child_result.get(\"source_url\"), child_result.get(\"final_url\"), *listify(evidence.get(\"evidence_urls\"))])\n\n\ndef article_text_ref(text: str, save_data: Mapping[str, Any]) -> dict[str, Any] | None:\n    if not text:\n        return None\n    ref = {\"sha256\": hashlib.sha256(text.encode(\"utf-8\")).hexdigest(), \"length\": len(text)}\n    for key in (\"db_path\", \"source_id\", \"article_id\"):\n        value = save_data.get(key)\n        if value not in (None, \"\"):\n            ref[key] = value\n    return ref\n\n\ndef error_message(failure: Any, save_result: Any, error_type_value: str) -> str:\n    if error_type_value == \"db_write_failed\":\n        return first_text(unwrap_result(save_result), (\"message\", \"error\", \"error_message\", \"errorMessage\")) or \"DB save failed.\"\n    return first_text(unwrap_result(failure or {}), (\"reason\", \"message\", \"error_message\", \"errorMessage\", \"raw_error\", \"error\"))\n\n\ndef pick_retryable(reason: Any, expanded: Any) -> bool:\n    for data in (reason, expanded):\n        if isinstance(data, Mapping):\n            value = data.get(\"retryable\")\n            if isinstance(value, bool):\n                return value\n            if str(value).lower() in {\"true\", \"1\", \"yes\"}:\n                return True\n    status = first_text(expanded, HTTP_STATUS_KEYS)\n    return status in {\"429\", \"500\", \"502\", \"503\", \"504\"}\n\n\ndef trace_value(envelope: Mapping[str, Any], key: str) -> str:\n    value = envelope.get(key)\n    if key == \"terminal_post_id\":\n        value = value or first_text(envelope, POST_ID_KEYS)\n    return str(value).strip() if value not in (None, \"\") else \"\"\n\n\ndef snapshot_child_result_input(child_results: Mapping[str, Any]) -> dict[str, Any]:\n    return {key: value for key, value in child_results.items() if key in STAGE_ORDER}\n\n\ndef first_text(record: Any, keys: tuple[str, ...]) -> str:\n    if not isinstance(record, Mapping):\n        return \"\"\n    for key in keys:\n        value = record.get(key)\n        if value not in (None, \"\") and not isinstance(value, (dict, list, tuple)):\n            text = str(value).strip()\n            if text:\n                return text\n    return \"\"\n\n\ndef merge_dicts(*items: Any) -> dict[str, Any]:\n    out: dict[str, Any] = {}\n    for item in items:\n        if isinstance(item, Mapping):\n            out.update(dict(item))\n    return out\n\n\ndef normalize_json_value(value: Any) -> Any:\n    if value is None:\n        return {}\n    if isinstance(value, (Mapping, list)):\n        return value\n    if isinstance(value, str):\n        text = value.strip()\n        if not text:\n            return {}\n        try:\n            return json.loads(text)\n        except json.JSONDecodeError:\n            return value\n    return value\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        text = sys.stdin.read().strip()\n        return json.loads(text) if text else {}\n    path = Path(value)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef unique_strings(values: Any) -> list[str]:\n    out: list[str] = []\n    for value in values:\n        text = str(value or \"\").strip()\n        if text and text not in out:\n            out.append(text)\n    return out\n\n\ndef listify(value: Any) -> list[Any]:\n    return value if isinstance(value, list) else []\n\n\ndef excerpt(text: str, limit: int) -> str:\n    return compact(text, limit)\n\n\ndef compact(value: Any, limit: int) -> str:\n    text = \" \".join(str(value or \"\").split())\n    return text if len(text) <= limit else text[: max(0, limit - 1)] + \"...\"\n\n\ndef now_iso() -> str:\n    return datetime.now(timezone.utc).isoformat()\n\n\ndef run(input_json: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return confirm_news_articles(input_json, **kwargs)\n\n\ndef orchestrate(input_json: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return confirm_news_articles(input_json, **kwargs)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Confirm and save news/article component material.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results-json\", default=\"\", help=\"Precomputed child results as JSON or a JSON file path.\")\n    parser.add_argument(\"--project-file\", default=DEFAULT_PROJECT_FILE)\n    parser.add_argument(\"--no-project-children\", action=\"store_true\")\n    parser.add_argument(\"--no-logs\", action=\"store_true\")\n    parser.add_argument(\"--jsonl-path\", default=DEFAULT_JSONL_PATH)\n    parser.add_argument(\"--runs-log-path\", default=DEFAULT_RUNS_LOG_PATH)\n    parser.add_argument(\"--db-path\", default=\"\")\n    args = parser.parse_args(argv)\n    try:\n        result = confirm_news_articles(\n            load_json_arg(args.input_json),\n            child_results=load_json_arg(args.child_results_json) if args.child_results_json else {},\n            options={\n                \"projectFile\": args.project_file,\n                \"autoLoadProjectChildren\": not args.no_project_children,\n                \"writeLogs\": not args.no_logs,\n                \"jsonlPath\": args.jsonl_path,\n                \"runsLogPath\": args.runs_log_path,\n                \"dbPath\": args.db_path,\n            },\n        )\n    except Exception as exc:\n        result = {\"ok\": False, \"status\": \"failed\", \"error\": {\"type\": exc.__class__.__name__, \"message\": str(exc)}}\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
