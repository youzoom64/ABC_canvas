    {
      "id": "node-6897c1cb8b",
      "title": "ニュースメタ情報抽出ポワン",
      "body": "ニュース本文抽出結果やHTMLメタ情報から、媒体名、著者、公開日、更新日、OGタイトル、OG説明、canonical URLなどを整理する臓器ポワン。本文取得そのものやDB保存は行わず、後続保存に渡すメタ情報を整形する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport email.utils\nimport json\nimport re\nfrom datetime import datetime, timezone\nfrom html import unescape\nfrom html.parser import HTMLParser\nfrom typing import Any\nfrom urllib.parse import parse_qsl, urlencode, urljoin, urlparse, urlunparse\n\nTRACKING_QUERY_KEYS = {\n    \"fbclid\",\n    \"gclid\",\n    \"yclid\",\n    \"mc_cid\",\n    \"mc_eid\",\n    \"igshid\",\n    \"ref\",\n    \"ref_src\",\n    \"spm\",\n}\nTRACKING_QUERY_PREFIXES = (\"utm_\",)\n\nTITLE_INPUT_KEYS = (\"title\", \"headline\", \"name\", \"ogTitle\", \"og_title\")\nSITE_INPUT_KEYS = (\n    \"siteName\",\n    \"site_name\",\n    \"sourceName\",\n    \"source_name\",\n    \"mediaName\",\n    \"media_name\",\n    \"publisher\",\n    \"publisherName\",\n    \"publisher_name\",\n    \"provider\",\n    \"source\",\n)\nAUTHOR_INPUT_KEYS = (\"author\", \"byline\", \"creator\", \"writer\", \"authors\")\nPUBLISHED_INPUT_KEYS = (\n    \"publishedAt\",\n    \"published_at\",\n    \"published\",\n    \"publishDate\",\n    \"publish_date\",\n    \"pubDate\",\n    \"datePublished\",\n    \"date_published\",\n)\nUPDATED_INPUT_KEYS = (\n    \"updatedAt\",\n    \"updated_at\",\n    \"modifiedAt\",\n    \"modified_at\",\n    \"dateModified\",\n    \"date_modified\",\n)\nCANONICAL_INPUT_KEYS = (\n    \"canonicalUrl\",\n    \"canonical_url\",\n    \"canonical\",\n    \"canonicalUrlHint\",\n    \"canonical_url_hint\",\n)\nDESCRIPTION_INPUT_KEYS = (\"description\", \"summary\", \"ogDescription\", \"og_description\")\nIMAGE_INPUT_KEYS = (\n    \"thumbnailUrl\",\n    \"thumbnail_url\",\n    \"imageUrl\",\n    \"image_url\",\n    \"ogImage\",\n    \"og_image\",\n    \"image\",\n    \"thumbnail\",\n)\n\nTITLE_META_KEYS = (\"og:title\", \"twitter:title\")\nDESCRIPTION_META_KEYS = (\"og:description\", \"twitter:description\", \"description\")\nSITE_META_KEYS = (\"og:site_name\", \"application-name\", \"twitter:site\")\nAUTHOR_META_KEYS = (\n    \"author\",\n    \"article:author\",\n    \"twitter:creator\",\n    \"dc.creator\",\n    \"parsely-author\",\n    \"sailthru.author\",\n)\nPUBLISHED_META_KEYS = (\n    \"article:published_time\",\n    \"og:published_time\",\n    \"publish-date\",\n    \"pubdate\",\n    \"date\",\n    \"datepublished\",\n    \"dc.date\",\n    \"sailthru.date\",\n)\nUPDATED_META_KEYS = (\n    \"article:modified_time\",\n    \"article:updated_time\",\n    \"og:updated_time\",\n    \"last-modified\",\n    \"modified\",\n    \"updated_time\",\n    \"datemodified\",\n)\nIMAGE_META_KEYS = (\"og:image\", \"og:image:url\", \"twitter:image\", \"thumbnail\", \"thumbnail_url\", \"image\")\n\n\nclass _HTMLMetadataParser(HTMLParser):\n    def __init__(self) -> None:\n        super().__init__(convert_charrefs=True)\n        self.meta: dict[str, str] = {}\n        self.links: dict[str, str] = {}\n        self.title = \"\"\n        self._capture_title = False\n        self._capture_json_ld = False\n        self._script_parts: list[str] = []\n        self.json_ld_texts: list[str] = []\n\n    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:\n        tag_name = tag.lower()\n        attr_map = {str(k or \"\").lower(): str(v or \"\") for k, v in attrs}\n        if tag_name == \"title\":\n            self._capture_title = True\n            return\n        if tag_name == \"meta\":\n            key = (\n                attr_map.get(\"property\")\n                or attr_map.get(\"name\")\n                or attr_map.get(\"itemprop\")\n                or attr_map.get(\"http-equiv\")\n                or \"\"\n            ).strip().lower()\n            content = (attr_map.get(\"content\") or \"\").strip()\n            if key and content and key not in self.meta:\n                self.meta[key] = unescape(content)\n            return\n        if tag_name == \"link\":\n            href = (attr_map.get(\"href\") or \"\").strip()\n            rel = (attr_map.get(\"rel\") or \"\").strip().lower()\n            if href and rel:\n                if \"canonical\" in rel and \"canonical\" not in self.links:\n                    self.links[\"canonical\"] = unescape(href)\n                elif \"image_src\" in rel and \"image_src\" not in self.links:\n                    self.links[\"image_src\"] = unescape(href)\n            return\n        if tag_name == \"script\" and \"ld+json\" in (attr_map.get(\"type\") or \"\").lower():\n            self._capture_json_ld = True\n            self._script_parts = []\n\n    def handle_endtag(self, tag: str) -> None:\n        tag_name = tag.lower()\n        if tag_name == \"title\":\n            self._capture_title = False\n            return\n        if tag_name == \"script\" and self._capture_json_ld:\n            text = \"\".join(self._script_parts).strip()\n            if text:\n                self.json_ld_texts.append(text)\n            self._capture_json_ld = False\n            self._script_parts = []\n\n    def handle_data(self, data: str) -> None:\n        if self._capture_title and not self.title:\n            self.title = _normalize_space(data)\n        elif self._capture_json_ld:\n            self._script_parts.append(data)\n\n\ndef _normalize_space(value: Any) -> str:\n    return re.sub(r\"\\s+\", \" \", str(value or \"\").strip())\n\n\ndef _as_text(value: Any) -> str:\n    if value is None:\n        return \"\"\n    if isinstance(value, bytes):\n        return value.decode(\"utf-8\", errors=\"replace\").strip()\n    if isinstance(value, (str, int, float, bool)):\n        return _normalize_space(unescape(str(value)))\n    if isinstance(value, list):\n        for item in value:\n            text = _as_text(item)\n            if text:\n                return text\n        return \"\"\n    if isinstance(value, dict):\n        for key in (\"name\", \"headline\", \"text\", \"content\", \"url\", \"@id\"):\n            text = _as_text(value.get(key))\n            if text:\n                return text\n        return \"\"\n    return _normalize_space(value)\n\n\ndef _safe_dict(value: Any) -> dict[str, Any]:\n    if isinstance(value, dict):\n        return dict(value)\n    if isinstance(value, str) and value.strip():\n        try:\n            loaded = json.loads(value)\n        except Exception:\n            return {}\n        return loaded if isinstance(loaded, dict) else {}\n    return {}\n\n\ndef _coerce_payload(input_data: Any) -> dict[str, Any]:\n    if isinstance(input_data, dict):\n        return input_data\n    if isinstance(input_data, str) and input_data.strip():\n        loaded = json.loads(input_data)\n        if isinstance(loaded, dict):\n            return loaded\n    raise ValueError(\"input must be a JSON object\")\n\n\ndef _first_nonempty(*values: Any) -> str:\n    for value in values:\n        text = _as_text(value)\n        if text:\n            return text\n    return \"\"\n\n\ndef _pick(mappings: list[dict[str, Any]], keys: tuple[str, ...]) -> str:\n    for mapping in mappings:\n        if not isinstance(mapping, dict):\n            continue\n        for key in keys:\n            if key in mapping:\n                text = _as_text(mapping.get(key))\n                if text:\n                    return text\n    return \"\"\n\n\ndef _meta_first(meta: dict[str, str], keys: tuple[str, ...]) -> str:\n    for key in keys:\n        text = _as_text(meta.get(key.lower()))\n        if text:\n            return text\n    return \"\"\n\n\ndef _json_safe(value: Any) -> Any:\n    try:\n        return json.loads(json.dumps(value, ensure_ascii=False, default=str))\n    except Exception:\n        return _as_text(value)\n\n\ndef _load_json_lenient(text: str) -> Any:\n    cleaned = (text or \"\").strip()\n    cleaned = re.sub(r\"^\\s*<!--\", \"\", cleaned)\n    cleaned = re.sub(r\"-->\\s*$\", \"\", cleaned).strip()\n    if not cleaned:\n        return None\n    try:\n        return json.loads(cleaned)\n    except Exception:\n        pass\n    match = re.search(r\"(\\{.*\\}|\\[.*\\])\", cleaned, flags=re.DOTALL)\n    if match:\n        try:\n            return json.loads(match.group(1))\n        except Exception:\n            return None\n    return None\n\n\ndef _iter_jsonld_nodes(value: Any) -> list[dict[str, Any]]:\n    nodes: list[dict[str, Any]] = []\n\n    def walk(item: Any) -> None:\n        if isinstance(item, str):\n            parsed = _load_json_lenient(item)\n            if parsed is not None:\n                walk(parsed)\n            return\n        if isinstance(item, list):\n            for child in item:\n                walk(child)\n            return\n        if not isinstance(item, dict):\n            return\n        nodes.append(item)\n        for key in (\"@graph\", \"itemListElement\", \"mainEntity\", \"mainEntityOfPage\"):\n            if key in item:\n                walk(item.get(key))\n\n    walk(value)\n    return nodes\n\n\ndef _jsonld_first(nodes: list[dict[str, Any]], keys: tuple[str, ...]) -> str:\n    for node in nodes:\n        for key in keys:\n            if key in node:\n                text = _as_text(node.get(key))\n                if text:\n                    return text\n    return \"\"\n\n\ndef _jsonld_publisher_name(nodes: list[dict[str, Any]]) -> str:\n    for node in nodes:\n        text = _as_text(node.get(\"publisher\"))\n        if text:\n            return text\n    for node in nodes:\n        node_type = _as_text(node.get(\"@type\")).lower()\n        if \"organization\" in node_type or \"newsmediaorganization\" in node_type:\n            text = _as_text(node.get(\"name\"))\n            if text:\n                return text\n    return \"\"\n\n\ndef _parse_html(html: str, base_url: str) -> dict[str, Any]:\n    html_text = _as_text(html)\n    if not html_text:\n        return {\"meta\": {}, \"links\": {}, \"title\": \"\", \"jsonld\": []}\n    try:\n        from bs4 import BeautifulSoup  # type: ignore\n\n        soup = BeautifulSoup(html_text, \"html.parser\")\n        meta: dict[str, str] = {}\n        links: dict[str, str] = {}\n        for tag in soup.find_all(\"meta\"):\n            key = (\n                tag.get(\"property\")\n                or tag.get(\"name\")\n                or tag.get(\"itemprop\")\n                or tag.get(\"http-equiv\")\n                or \"\"\n            )\n            content = tag.get(\"content\") or \"\"\n            key_text = _as_text(key).lower()\n            content_text = _as_text(content)\n            if key_text and content_text and key_text not in meta:\n                meta[key_text] = content_text\n        for tag in soup.find_all(\"link\"):\n            href = _as_text(tag.get(\"href\"))\n            rel = \" \".join(str(x).lower() for x in (tag.get(\"rel\") or []))\n            if href and \"canonical\" in rel and \"canonical\" not in links:\n                links[\"canonical\"] = href\n            elif href and \"image_src\" in rel and \"image_src\" not in links:\n                links[\"image_src\"] = href\n        jsonld: list[dict[str, Any]] = []\n        for script in soup.find_all(\"script\"):\n            script_type = _as_text(script.get(\"type\")).lower()\n            if \"ld+json\" not in script_type:\n                continue\n            loaded = _load_json_lenient(script.get_text(\"\", strip=False))\n            jsonld.extend(_iter_jsonld_nodes(loaded))\n        title = soup.title.get_text(\" \", strip=True) if soup.title else \"\"\n        return {\"meta\": meta, \"links\": links, \"title\": _normalize_space(title), \"jsonld\": jsonld}\n    except Exception:\n        parser = _HTMLMetadataParser()\n        parser.feed(html_text)\n        jsonld: list[dict[str, Any]] = []\n        for item in parser.json_ld_texts:\n            jsonld.extend(_iter_jsonld_nodes(item))\n        return {\"meta\": parser.meta, \"links\": parser.links, \"title\": parser.title, \"jsonld\": jsonld}\n\n\ndef _absolute_url(raw_url: Any, base_url: str = \"\") -> str:\n    text = _as_text(raw_url)\n    if not text:\n        return \"\"\n    if base_url:\n        return urljoin(base_url, text)\n    return text\n\n\ndef _canonicalize_url(raw_url: Any, base_url: str = \"\") -> str:\n    text = _absolute_url(raw_url, base_url)\n    if not text:\n        return \"\"\n    parsed = urlparse(text)\n    if parsed.scheme not in {\"http\", \"https\"} or not parsed.netloc:\n        return text\n    pairs: list[tuple[str, str]] = []\n    for key, value in parse_qsl(parsed.query, keep_blank_values=True):\n        clean_key = key.strip()\n        lower_key = clean_key.lower()\n        if lower_key in TRACKING_QUERY_KEYS:\n            continue\n        if any(lower_key.startswith(prefix) for prefix in TRACKING_QUERY_PREFIXES):\n            continue\n        pairs.append((clean_key, value))\n    path = parsed.path or \"/\"\n    query = urlencode(sorted(pairs), doseq=True)\n    return urlunparse((parsed.scheme.lower(), parsed.netloc.lower(), path, \"\", query, \"\"))\n\n\ndef _normalize_datetime(value: Any) -> str:\n    text = _as_text(value)\n    if not text:\n        return \"\"\n    candidate = text.strip()\n    if candidate.endswith(\"Z\"):\n        candidate = f\"{candidate[:-1]}+00:00\"\n    try:\n        dt = datetime.fromisoformat(candidate)\n    except ValueError:\n        dt = None\n    if dt is None:\n        for pattern in (\"%Y-%m-%d\", \"%Y/%m/%d\", \"%Y-%m-%d %H:%M:%S\", \"%Y/%m/%d %H:%M:%S\"):\n            try:\n                dt = datetime.strptime(candidate, pattern)\n                break\n            except ValueError:\n                continue\n    if dt is None:\n        try:\n            dt = email.utils.parsedate_to_datetime(text)\n        except Exception:\n            return text\n    if dt.tzinfo is None:\n        dt = dt.replace(tzinfo=timezone.utc)\n    else:\n        dt = dt.astimezone(timezone.utc)\n    return dt.isoformat(timespec=\"seconds\")\n\n\ndef _looks_like_url(value: str) -> bool:\n    parsed = urlparse(value)\n    return parsed.scheme in {\"http\", \"https\"} and bool(parsed.netloc)\n\n\ndef extract_news_metadata(input_data: Any) -> dict[str, Any]:\n    try:\n        payload = _coerce_payload(input_data)\n    except Exception as exc:\n        return {\n            \"ok\": False,\n            \"error\": str(exc),\n            \"metadata\": {},\n            \"title\": \"\",\n            \"siteName\": \"\",\n            \"author\": \"\",\n            \"publishedAt\": \"\",\n            \"updatedAt\": \"\",\n            \"canonicalUrl\": \"\",\n        }\n\n    source_metadata = _safe_dict(payload.get(\"metadata\"))\n    raw_json = _safe_dict(payload.get(\"raw_json\") or payload.get(\"rawJson\"))\n    nested_article = _safe_dict(payload.get(\"article\"))\n    nested_result = _safe_dict(payload.get(\"result\"))\n    nested_extracted = _safe_dict(payload.get(\"extracted\"))\n    mappings = [payload, source_metadata, raw_json, nested_article, nested_result, nested_extracted]\n\n    url = _pick(mappings, (\"url\", \"source_url\", \"sourceUrl\"))\n    final_url = _pick(mappings, (\"final_url\", \"finalUrl\", \"resolved_url\", \"resolvedUrl\")) or url\n    html = _pick(mappings, (\"html\", \"raw_html\", \"rawHtml\", \"page_html\", \"pageHtml\"))\n    base_url = final_url or url\n\n    html_data = _parse_html(html, base_url) if html else {\"meta\": {}, \"links\": {}, \"title\": \"\", \"jsonld\": []}\n    meta = html_data.get(\"meta\") or {}\n    links = html_data.get(\"links\") or {}\n    jsonld_nodes = html_data.get(\"jsonld\") or []\n\n    og_title = _meta_first(meta, TITLE_META_KEYS)\n    jsonld_title = _jsonld_first(jsonld_nodes, (\"headline\", \"name\", \"title\"))\n    input_title = _pick(mappings, TITLE_INPUT_KEYS)\n    title = _first_nonempty(input_title, og_title, jsonld_title, html_data.get(\"title\"))\n    if _looks_like_url(title):\n        title = _first_nonempty(og_title, jsonld_title, html_data.get(\"title\"), title)\n\n    site_name = _first_nonempty(\n        _pick(mappings, SITE_INPUT_KEYS),\n        _meta_first(meta, SITE_META_KEYS),\n        _jsonld_publisher_name(jsonld_nodes),\n        urlparse(final_url or url).netloc,\n    )\n    author = _first_nonempty(\n        _pick(mappings, AUTHOR_INPUT_KEYS),\n        _meta_first(meta, AUTHOR_META_KEYS),\n        _jsonld_first(jsonld_nodes, (\"author\", \"creator\")),\n    )\n    published_at = _normalize_datetime(\n        _first_nonempty(\n            _pick(mappings, PUBLISHED_INPUT_KEYS),\n            _meta_first(meta, PUBLISHED_META_KEYS),\n            _jsonld_first(jsonld_nodes, (\"datePublished\", \"dateCreated\")),\n        )\n    )\n    updated_at = _normalize_datetime(\n        _first_nonempty(\n            _pick(mappings, UPDATED_INPUT_KEYS),\n            _meta_first(meta, UPDATED_META_KEYS),\n            _jsonld_first(jsonld_nodes, (\"dateModified\", \"dateUpdated\")),\n        )\n    )\n    canonical_url = _canonicalize_url(\n        _first_nonempty(\n            _pick(mappings, CANONICAL_INPUT_KEYS),\n            links.get(\"canonical\"),\n            meta.get(\"og:url\"),\n            _jsonld_first(jsonld_nodes, (\"url\", \"mainEntityOfPage\", \"@id\")),\n            final_url,\n            url,\n        ),\n        base_url,\n    )\n    og_description = _first_nonempty(\n        _pick(mappings, DESCRIPTION_INPUT_KEYS),\n        _meta_first(meta, DESCRIPTION_META_KEYS),\n        _jsonld_first(jsonld_nodes, (\"description\", \"abstract\")),\n    )\n    thumbnail_url = _absolute_url(\n        _first_nonempty(\n            _pick(mappings, IMAGE_INPUT_KEYS),\n            _meta_first(meta, IMAGE_META_KEYS),\n            links.get(\"image_src\"),\n            _jsonld_first(jsonld_nodes, (\"image\", \"thumbnailUrl\")),\n        ),\n        base_url,\n    )\n\n    metadata: dict[str, Any] = _json_safe(source_metadata) if isinstance(source_metadata, dict) else {}\n    metadata.update(\n        {\n            \"metadata_extractor\": \"news_metadata_powan\",\n            \"source_url\": url or None,\n            \"final_url\": final_url or None,\n            \"canonical_url\": canonical_url or None,\n            \"title\": title or None,\n            \"site_name\": site_name or None,\n            \"author\": author or None,\n            \"published_at\": published_at or None,\n            \"updated_at\": updated_at or None,\n            \"og_title\": og_title or None,\n            \"og_description\": og_description or None,\n            \"thumbnail_url\": thumbnail_url or None,\n        }\n    )\n    if meta:\n        metadata[\"html_meta_keys\"] = sorted(meta.keys())\n    jsonld_types = []\n    for node in jsonld_nodes:\n        node_type = _as_text(node.get(\"@type\"))\n        if node_type and node_type not in jsonld_types:\n            jsonld_types.append(node_type)\n    if jsonld_types:\n        metadata[\"json_ld_types\"] = jsonld_types\n\n    return {\n        \"ok\": True,\n        \"metadata\": metadata,\n        \"title\": title,\n        \"siteName\": site_name,\n        \"author\": author,\n        \"publishedAt\": published_at,\n        \"updatedAt\": updated_at,\n        \"canonicalUrl\": canonical_url,\n        \"ogTitle\": og_title,\n        \"ogDescription\": og_description,\n        \"thumbnailUrl\": thumbnail_url,\n    }\n\n\ndef run(input_data: Any) -> dict[str, Any]:\n    return extract_news_metadata(input_data)\n\n\ndef main(input_data: Any) -> dict[str, Any]:\n    return extract_news_metadata(input_data)\n\n\nif __name__ == \"__main__\":\n    import sys\n\n    raw = sys.stdin.read()\n    result = extract_news_metadata(raw or {})\n    print(json.dumps(result, ensure_ascii=False, indent=2))",
