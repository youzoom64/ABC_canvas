    {
      "id": "node-b2f75ff6e8",
      "title": "次ポスト取得ポワン",
      "body": "リプ元、リポスト元、引用元などの参照から、次に調べるポスト本体を取得する臓器ポワン。postId、URL、userId、外部カードなど形の違う参照を受け取り、取得結果をpost、notFound、private、deleted、rateLimited、invalidRefなどの状態付きで返す。どのAPIや保存済みデータを使うかは外から渡される取得器に任せ、ここでは参照を次ポストへ変換する役目を持つ。コードは後で持つ。",
      "powanKind": "organ",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\nexport type FetchNextPostFetcher = (ref: PostRef) => Promise<FetchResult> | FetchResult;\n\nconst VALID_REF_KINDS: readonly RefKind[] = [\n  \"reply_parent\",\n  \"repost_source\",\n  \"quote_source\",\n  \"url_post\",\n];\n\nconst VALID_FETCH_STATUSES: readonly FetchStatus[] = [\n  \"ok\",\n  \"not_found\",\n  \"private\",\n  \"deleted\",\n  \"rate_limited\",\n  \"invalid_ref\",\n  \"error\",\n];\n\n/**\n * Fetches the next post indicated by a relation reference.\n *\n * This organ owns only the handoff from a normalized PostRef to the supplied\n * fetcher. It does not call APIs, browse, read files, or decide the relation.\n */\nexport async function fetchNextPost(\n  ref: PostRef,\n  fetcher: FetchNextPostFetcher,\n): Promise<FetchResult> {\n  const normalizedRef = normalizePostRef(ref);\n  if (!normalizedRef) {\n    return { status: \"invalid_ref\", reason: \"ref must include a valid kind and postId or url\" };\n  }\n\n  if (typeof fetcher !== \"function\") {\n    return { status: \"error\", reason: \"fetcher must be a function\" };\n  }\n\n  try {\n    const result = await fetcher(normalizedRef);\n    return normalizeFetchResult(result);\n  } catch (error) {\n    return { status: \"error\", reason: errorToReason(error) };\n  }\n}\n\nfunction normalizePostRef(value: PostRef): PostRef | null {\n  if (!isRecord(value) || !isValidRefKind(value.kind)) {\n    return null;\n  }\n\n  const postId = normalizeText(value.postId);\n  const url = normalizeText(value.url);\n  if (!postId && !url) {\n    return null;\n  }\n\n  const normalized: PostRef = {\n    kind: value.kind,\n    evidence: normalizeText(value.evidence) ?? \"unknown\",\n    confidence: normalizeConfidence(value.confidence),\n  };\n\n  if (postId) normalized.postId = postId;\n  if (url) normalized.url = url;\n  return normalized;\n}\n\nfunction normalizeFetchResult(value: FetchResult): FetchResult {\n  if (!isRecord(value) || !isValidFetchStatus(value.status)) {\n    return { status: \"error\", reason: \"fetcher returned an invalid FetchResult\" };\n  }\n\n  const reason = normalizeText(value.reason);\n  if (value.status !== \"ok\") {\n    return reason ? { status: value.status, reason } : { status: value.status };\n  }\n\n  if (!isRecord(value.post)) {\n    return { status: \"error\", reason: \"fetcher returned ok without post\" };\n  }\n\n  const result: FetchResult = { status: \"ok\", post: value.post as PostLike };\n  if (reason) result.reason = reason;\n  return result;\n}\n\nfunction isValidRefKind(value: unknown): value is RefKind {\n  return typeof value === \"string\" && (VALID_REF_KINDS as readonly string[]).includes(value);\n}\n\nfunction isValidFetchStatus(value: unknown): value is FetchStatus {\n  return typeof value === \"string\" && (VALID_FETCH_STATUSES as readonly string[]).includes(value);\n}\n\nfunction normalizeText(value: unknown): string | undefined {\n  if (typeof value !== \"string\") return undefined;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : undefined;\n}\n\nfunction normalizeConfidence(value: unknown): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return 0;\n  if (value < 0) return 0;\n  if (value > 1) return 1;\n  return value;\n}\n\nfunction errorToReason(error: unknown): string {\n  if (error instanceof Error) {\n    const message = normalizeText(error.message);\n    return message ?? error.name ?? \"fetcher threw\";\n  }\n\n  return normalizeText(error) ?? \"fetcher threw\";\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n}",
