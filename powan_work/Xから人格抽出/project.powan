    {
      "id": "node-f69ae61794",
      "title": "画像ファイル保存ポワン",
      "body": "X画像URL抽出ポワンで得た画像URLから画像ファイルをローカルへ保存し、保存パス、sha256、width、height、mime、post_id、media_indexをDB保存できる形に整える臓器候補ポワン。画像を後から再解析できるよう、外部URLだけに依存しない状態を作る。まだコードは持たない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport mimetypes\nimport os\nimport sys\nimport tempfile\nfrom io import BytesIO\nfrom pathlib import Path\nfrom typing import Any\nfrom urllib.error import HTTPError, URLError\nfrom urllib.parse import parse_qs, unquote, urlparse\nfrom urllib.request import Request, urlopen\n\nDEFAULT_OUT_DIR = Path(\"./data/x_media/images\")\nDEFAULT_TIMEOUT_SECONDS = 30.0\nDEFAULT_MAX_BYTES = 50 * 1024 * 1024\nUSER_AGENT = (\n    \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) \"\n    \"AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126 Safari/537.36\"\n)\n\nLARGE_URL_KEYS = (\n    \"imageUrlLarge\",\n    \"image_url_large\",\n    \"largeImageUrl\",\n    \"large_image_url\",\n    \"largeUrl\",\n    \"large_url\",\n)\nSMALL_URL_KEYS = (\n    \"imageUrlSmall\",\n    \"image_url_small\",\n    \"smallImageUrl\",\n    \"small_image_url\",\n    \"smallUrl\",\n    \"small_url\",\n)\nFALLBACK_URL_KEYS = (\"imageUrl\", \"image_url\", \"source_url\", \"url\")\nPOST_ID_KEYS = (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\")\nMEDIA_INDEX_KEYS = (\n    \"media_index\",\n    \"mediaIndex\",\n    \"image_index\",\n    \"imageIndex\",\n    \"photo_index\",\n    \"photoIndex\",\n    \"index\",\n)\nALT_KEYS = (\"alt\", \"altText\", \"alt_text\")\n\nMIME_TO_EXT = {\n    \"image/jpeg\": \".jpg\",\n    \"image/jpg\": \".jpg\",\n    \"image/png\": \".png\",\n    \"image/gif\": \".gif\",\n    \"image/webp\": \".webp\",\n    \"image/avif\": \".avif\",\n    \"image/heic\": \".heic\",\n    \"image/heif\": \".heif\",\n    \"image/bmp\": \".bmp\",\n    \"image/tiff\": \".tif\",\n}\nEXT_TO_MIME = {ext: mime for mime, ext in MIME_TO_EXT.items()}\nEXT_TO_MIME[\".jpeg\"] = \"image/jpeg\"\n\n\nclass ImageSaveError(RuntimeError):\n    pass\n\n\ndef load_json(path: str) -> Any:\n    if path == \"-\":\n        raw = sys.stdin.read()\n        if not raw.strip():\n            raise ImageSaveError(\"stdin is empty; pass X image extraction JSON\")\n        return json.loads(raw)\n    return json.loads(Path(path).read_text(encoding=\"utf-8\"))\n\n\ndef pick_first(mapping: dict[str, Any], keys: tuple[str, ...]) -> Any:\n    for key in keys:\n        value = mapping.get(key)\n        if value not in (None, \"\"):\n            return value\n    return None\n\n\ndef choose_source_url(item: dict[str, Any]) -> str:\n    for key_group in (LARGE_URL_KEYS, SMALL_URL_KEYS, FALLBACK_URL_KEYS):\n        value = pick_first(item, key_group)\n        if isinstance(value, str) and value.strip():\n            return value.strip()\n    raise ImageSaveError(\"record has no imageUrlLarge or imageUrlSmall\")\n\n\ndef find_records(payload: Any) -> list[dict[str, Any]]:\n    if isinstance(payload, list):\n        raw_records = payload\n        root: dict[str, Any] = {}\n    elif isinstance(payload, dict):\n        root = payload\n        if any(key in payload for key in LARGE_URL_KEYS + SMALL_URL_KEYS + FALLBACK_URL_KEYS):\n            raw_records = [payload]\n        else:\n            raw_records = []\n            for key in (\"images\", \"media\", \"items\", \"results\", \"photos\", \"attachments\"):\n                value = payload.get(key)\n                if isinstance(value, list):\n                    raw_records.extend(value)\n            data = payload.get(\"data\")\n            if isinstance(data, dict) and any(\n                key in data for key in LARGE_URL_KEYS + SMALL_URL_KEYS + FALLBACK_URL_KEYS\n            ):\n                raw_records.append(data)\n            elif isinstance(data, list):\n                raw_records.extend(data)\n    else:\n        raise ImageSaveError(\"input JSON must be an object or a list\")\n\n    root_post_id = pick_first(root, POST_ID_KEYS) if isinstance(root, dict) else None\n    records: list[dict[str, Any]] = []\n    for offset, raw in enumerate(raw_records):\n        if isinstance(raw, str):\n            item: dict[str, Any] = {\"imageUrlLarge\": raw}\n        elif isinstance(raw, dict):\n            item = dict(raw)\n        else:\n            continue\n        if pick_first(item, POST_ID_KEYS) is None and root_post_id is not None:\n            item[\"post_id\"] = root_post_id\n        if pick_first(item, MEDIA_INDEX_KEYS) is None:\n            item[\"media_index\"] = offset\n        records.append(item)\n    return records\n\n\ndef download_bytes(url: str, timeout: float, max_bytes: int) -> tuple[bytes, str, str]:\n    parsed = urlparse(url)\n    if parsed.scheme == \"file\":\n        path_text = unquote(parsed.path)\n        if os.name == \"nt\" and path_text.startswith(\"/\") and len(path_text) > 3 and path_text[2] == \":\":\n            path_text = path_text[1:]\n        data = Path(path_text).read_bytes()\n        if max_bytes and len(data) > max_bytes:\n            raise ImageSaveError(f\"image exceeds max bytes: {len(data)} > {max_bytes}\")\n        return data, mimetypes.guess_type(path_text)[0] or \"\", url\n\n    if parsed.scheme not in (\"http\", \"https\"):\n        raise ImageSaveError(f\"unsupported image URL scheme: {parsed.scheme or 'missing'}\")\n\n    request = Request(\n        url,\n        headers={\n            \"User-Agent\": USER_AGENT,\n            \"Accept\": \"image/avif,image/webp,image/apng,image/*,*/*;q=0.8\",\n        },\n    )\n    try:\n        with urlopen(request, timeout=timeout) as response:\n            content_type = response.headers.get(\"Content-Type\", \"\")\n            limit = max_bytes + 1 if max_bytes else -1\n            data = response.read(limit)\n            if max_bytes and len(data) > max_bytes:\n                raise ImageSaveError(f\"image exceeds max bytes: more than {max_bytes}\")\n            return data, content_type, response.geturl()\n    except HTTPError as exc:\n        raise ImageSaveError(f\"download failed: HTTP {exc.code}\") from exc\n    except URLError as exc:\n        raise ImageSaveError(f\"download failed: {exc.reason}\") from exc\n\n\ndef clean_content_type(content_type: str) -> str:\n    return content_type.split(\";\", 1)[0].strip().lower()\n\n\ndef extension_from_url(url: str) -> str:\n    parsed = urlparse(url)\n    query_format = parse_qs(parsed.query).get(\"format\", [\"\"])[0].lower().strip(\".\")\n    if query_format:\n        if query_format == \"jpg\":\n            return \".jpg\"\n        return f\".{query_format}\"\n    suffix = Path(unquote(parsed.path)).suffix.lower()\n    if suffix in EXT_TO_MIME or suffix in (\".jpg\", \".jpeg\", \".png\", \".gif\", \".webp\", \".avif\"):\n        return \".jpg\" if suffix == \".jpeg\" else suffix\n    return \"\"\n\n\ndef sniff_mime_and_ext(data: bytes, content_type: str, url: str) -> tuple[str, str]:\n    if data.startswith(b\"\\xff\\xd8\\xff\"):\n        return \"image/jpeg\", \".jpg\"\n    if data.startswith(b\"\\x89PNG\\r\\n\\x1a\\n\"):\n        return \"image/png\", \".png\"\n    if data.startswith((b\"GIF87a\", b\"GIF89a\")):\n        return \"image/gif\", \".gif\"\n    if data.startswith(b\"RIFF\") and len(data) >= 12 and data[8:12] == b\"WEBP\":\n        return \"image/webp\", \".webp\"\n    if len(data) >= 12 and data[4:8] == b\"ftyp\" and data[8:12] in (b\"avif\", b\"avis\"):\n        return \"image/avif\", \".avif\"\n    if len(data) >= 12 and data[4:8] == b\"ftyp\" and data[8:12] in (b\"heic\", b\"heix\", b\"hevc\", b\"hevx\"):\n        return \"image/heic\", \".heic\"\n    if data.startswith(b\"BM\"):\n        return \"image/bmp\", \".bmp\"\n\n    mime = clean_content_type(content_type)\n    ext = MIME_TO_EXT.get(mime, \"\")\n    if mime.startswith(\"image/\") and ext:\n        return mime, ext\n\n    url_ext = extension_from_url(url)\n    if url_ext:\n        guessed = mimetypes.guess_type(\"x\" + url_ext)[0] or \"image/\" + url_ext[1:]\n        return EXT_TO_MIME.get(url_ext, guessed), url_ext\n    return mime or \"application/octet-stream\", ext or \".bin\"\n\n\ndef image_dimensions(data: bytes, mime: str) -> tuple[int | None, int | None]:\n    try:\n        from PIL import Image  # type: ignore\n\n        with Image.open(BytesIO(data)) as image:\n            return int(image.width), int(image.height)\n    except Exception:\n        pass\n\n    if mime == \"image/png\" and len(data) >= 24:\n        return int.from_bytes(data[16:20], \"big\"), int.from_bytes(data[20:24], \"big\")\n    if mime == \"image/gif\" and len(data) >= 10:\n        return int.from_bytes(data[6:8], \"little\"), int.from_bytes(data[8:10], \"little\")\n    if mime == \"image/jpeg\":\n        return jpeg_dimensions(data)\n    if mime == \"image/webp\":\n        return webp_dimensions(data)\n    return None, None\n\n\ndef jpeg_dimensions(data: bytes) -> tuple[int | None, int | None]:\n    if not data.startswith(b\"\\xff\\xd8\"):\n        return None, None\n    sof_markers = {0xC0, 0xC1, 0xC2, 0xC3, 0xC5, 0xC6, 0xC7, 0xC9, 0xCA, 0xCB, 0xCD, 0xCE, 0xCF}\n    index = 2\n    while index < len(data) - 1:\n        if data[index] != 0xFF:\n            index += 1\n            continue\n        while index < len(data) and data[index] == 0xFF:\n            index += 1\n        if index >= len(data):\n            break\n        marker = data[index]\n        index += 1\n        if marker == 0xD9 or 0xD0 <= marker <= 0xD7:\n            continue\n        if index + 2 > len(data):\n            break\n        segment_length = int.from_bytes(data[index:index + 2], \"big\")\n        if segment_length < 2:\n            break\n        segment_start = index + 2\n        segment_end = index + segment_length\n        if marker in sof_markers and segment_start + 5 <= len(data):\n            height = int.from_bytes(data[segment_start + 1:segment_start + 3], \"big\")\n            width = int.from_bytes(data[segment_start + 3:segment_start + 5], \"big\")\n            return width, height\n        index = segment_end\n    return None, None\n\n\ndef webp_dimensions(data: bytes) -> tuple[int | None, int | None]:\n    if len(data) < 20 or data[0:4] != b\"RIFF\" or data[8:12] != b\"WEBP\":\n        return None, None\n    index = 12\n    while index + 8 <= len(data):\n        chunk = data[index:index + 4]\n        size = int.from_bytes(data[index + 4:index + 8], \"little\")\n        start = index + 8\n        if chunk == b\"VP8X\" and start + 10 <= len(data):\n            width = int.from_bytes(data[start + 4:start + 7] + b\"\\x00\", \"little\") + 1\n            height = int.from_bytes(data[start + 7:start + 10] + b\"\\x00\", \"little\") + 1\n            return width, height\n        if chunk == b\"VP8 \" and start + 10 <= len(data) and data[start + 3:start + 6] == b\"\\x9d\\x01\\x2a\":\n            width = int.from_bytes(data[start + 6:start + 8], \"little\") & 0x3FFF\n            height = int.from_bytes(data[start + 8:start + 10], \"little\") & 0x3FFF\n            return width, height\n        if chunk == b\"VP8L\" and start + 5 <= len(data):\n            bits = int.from_bytes(data[start + 1:start + 5], \"little\")\n            width = (bits & 0x3FFF) + 1\n            height = ((bits >> 14) & 0x3FFF) + 1\n            return width, height\n        index = start + size + (size % 2)\n    return None, None\n\n\ndef write_deduped_file(out_dir: Path, data: bytes, sha256: str, extension: str) -> tuple[Path, bool]:\n    bucket = out_dir / sha256[:2]\n    bucket.mkdir(parents=True, exist_ok=True)\n    existing = next(bucket.glob(f\"{sha256}.*\"), None)\n    if existing is not None:\n        return existing, True\n\n    final_path = bucket / f\"{sha256}{extension}\"\n    fd, temp_name = tempfile.mkstemp(prefix=f\".{sha256}.\", suffix=\".tmp\", dir=str(bucket))\n    try:\n        with os.fdopen(fd, \"wb\") as handle:\n            handle.write(data)\n        os.replace(temp_name, final_path)\n    finally:\n        temp_path = Path(temp_name)\n        if temp_path.exists():\n            temp_path.unlink()\n    return final_path, False\n\n\ndef save_one(item: dict[str, Any], out_dir: Path, timeout: float, max_bytes: int) -> dict[str, Any]:\n    source_url = choose_source_url(item)\n    data, content_type, final_url = download_bytes(source_url, timeout=timeout, max_bytes=max_bytes)\n    sha256 = hashlib.sha256(data).hexdigest()\n    mime, extension = sniff_mime_and_ext(data, content_type, final_url or source_url)\n    width, height = image_dimensions(data, mime)\n    local_path, reused = write_deduped_file(out_dir, data, sha256, extension)\n\n    result = {\n        \"sha256\": sha256,\n        \"mime\": mime,\n        \"extension\": extension,\n        \"width\": width,\n        \"height\": height,\n        \"bytes\": len(data),\n        \"local_path\": str(local_path.resolve()),\n        \"source_url\": source_url,\n        \"post_id\": pick_first(item, POST_ID_KEYS),\n        \"media_index\": pick_first(item, MEDIA_INDEX_KEYS),\n        \"reused\": reused,\n    }\n    alt_text = pick_first(item, ALT_KEYS)\n    if alt_text is not None:\n        result[\"alt\"] = alt_text\n    if final_url and final_url != source_url:\n        result[\"final_url\"] = final_url\n    return result\n\n\ndef save_images(payload: Any, out_dir: Path, timeout: float, max_bytes: int) -> dict[str, Any]:\n    records = find_records(payload)\n    images: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    for fallback_index, item in enumerate(records):\n        post_id = pick_first(item, POST_ID_KEYS)\n        media_index = pick_first(item, MEDIA_INDEX_KEYS)\n        try:\n            images.append(save_one(item, out_dir, timeout=timeout, max_bytes=max_bytes))\n        except Exception as exc:\n            errors.append(\n                {\n                    \"post_id\": post_id,\n                    \"media_index\": media_index if media_index is not None else fallback_index,\n                    \"source_url\": pick_first(item, LARGE_URL_KEYS + SMALL_URL_KEYS + FALLBACK_URL_KEYS),\n                    \"error\": str(exc),\n                }\n            )\n    return {\n        \"ok\": not errors,\n        \"out_dir\": str(out_dir.resolve()),\n        \"count\": len(images),\n        \"images\": images,\n        \"errors\": errors,\n    }\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=\"Save X image extraction JSON to local deduped image files.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"Path to X image extraction JSON, or - for stdin.\")\n    parser.add_argument(\"--out-dir\", default=str(DEFAULT_OUT_DIR), help=\"Directory for saved images.\")\n    parser.add_argument(\"--timeout\", type=float, default=DEFAULT_TIMEOUT_SECONDS, help=\"Download timeout seconds.\")\n    parser.add_argument(\"--max-bytes\", type=int, default=DEFAULT_MAX_BYTES, help=\"Maximum image bytes; 0 disables the limit.\")\n    parser.add_argument(\"--compact\", action=\"store_true\", help=\"Write compact JSON output.\")\n    return parser\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = build_parser().parse_args(argv)\n    try:\n        payload = load_json(args.input_json)\n        result = save_images(\n            payload,\n            out_dir=Path(args.out_dir),\n            timeout=args.timeout,\n            max_bytes=max(0, args.max_bytes),\n        )\n    except Exception as exc:\n        result = {\"ok\": False, \"count\": 0, \"images\": [], \"errors\": [{\"error\": str(exc)}]}\n\n    if args.compact:\n        json.dump(result, sys.stdout, ensure_ascii=False, separators=(\",\", \":\"))\n    else:\n        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)\n    sys.stdout.write(\"\\n\")\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
