    {
      "id": "node-cbe477fb44",
      "title": "返信連鎖追跡ポワン",
      "body": "Xの返信投稿を起点に、Seleniumで表示される会話スレッド上の返信元を1段ずつ辿る臓器ポワン。返信元が見えなくなった地点では、それを最終根とは決めず、現在投稿の本文・URL・リンク・引用カード候補・外部リンクなどを含むhandoffPostとして返し、投稿出どころ判定ポワンへ渡せる形にする。引用、リポスト、外部ニュース、動画、画像の判定はここでは行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport re\nimport time\nfrom typing import Any\nfrom urllib.parse import urljoin, urlparse\n\nlog = logging.getLogger(\"reply_chain_trace\")\n\nSTATUS_RE = re.compile(r\"/(?:i/web/)?status/(\\d+)\")\nX_HOSTS = {\"x.com\", \"twitter.com\", \"mobile.twitter.com\"}\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef normalize_url(href: str | None, *, base_url: str = \"https://x.com\") -> str:\n    if not href:\n        return \"\"\n    url = urljoin(base_url, href.strip())\n    parsed = urlparse(url)\n    if parsed.netloc in {\"twitter.com\", \"mobile.twitter.com\"}:\n        parsed = parsed._replace(netloc=\"x.com\")\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if parsed.netloc == \"x.com\" and len(parts) >= 3 and parts[1] == \"status\" and parts[2].isdigit():\n        parsed = parsed._replace(path=f\"/{parts[0]}/status/{parts[2]}\", query=\"\")\n    return parsed._replace(fragment=\"\").geturl()\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    match = STATUS_RE.search(url)\n    return match.group(1) if match else None\n\n\ndef author_from_status_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    parsed = urlparse(url)\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if len(parts) >= 3 and parts[1] == \"status\":\n        return parts[0]\n    return None\n\n\ndef _trim(value: Any, limit: int = 1200) -> str:\n    text = str(value or \"\").strip()\n    return text if len(text) <= limit else text[:limit]\n\n\ndef _snapshot_articles(driver: Any) -> list[dict[str, Any]]:\n    script = r\"\"\"\nconst textOf = (el) => (el && (el.innerText || el.textContent) || '').trim();\nconst attr = (el, name) => el ? (el.getAttribute(name) || '') : '';\nconst rectOf = (el) => {\n  const r = el.getBoundingClientRect();\n  return {x: Math.round(r.x), y: Math.round(r.y), width: Math.round(r.width), height: Math.round(r.height), bottom: Math.round(r.bottom)};\n};\nreturn Array.from(document.querySelectorAll('article[data-testid=\"tweet\"]')).map((article, index) => {\n  const links = Array.from(article.querySelectorAll('a[href]')).map((a) => ({\n    href: a.href || attr(a, 'href'),\n    text: textOf(a),\n    ariaLabel: attr(a, 'aria-label'),\n    dataTestId: attr(a, 'data-testid'),\n  }));\n  const statusLinks = links.filter((link) => /\\/status\\/\\d+/.test(link.href || ''));\n  const externalLinks = links.filter((link) => {\n    try {\n      const u = new URL(link.href || '');\n      return !['x.com', 'twitter.com', 'mobile.twitter.com'].includes(u.hostname);\n    } catch (_) {\n      return false;\n    }\n  });\n  const times = Array.from(article.querySelectorAll('time')).map((t) => ({\n    datetime: attr(t, 'datetime'),\n    text: textOf(t),\n    href: (t.closest('a') && t.closest('a').href) || '',\n  }));\n  const tweetTexts = Array.from(article.querySelectorAll('[data-testid=\"tweetText\"]')).map(textOf).filter(Boolean);\n  const socialContext = textOf(article.querySelector('[data-testid=\"socialContext\"]'));\n  const media = Array.from(article.querySelectorAll('[data-testid=\"tweetPhoto\"], [data-testid=\"videoPlayer\"], [data-testid=\"card.wrapper\"]')).map((el) => ({\n    dataTestId: attr(el, 'data-testid'),\n    text: textOf(el),\n    rect: rectOf(el),\n  }));\n  return {index, rect: rectOf(article), text: tweetTexts.join('\\n'), articleText: textOf(article), socialContext, links, statusLinks, externalLinks, times, media};\n});\n\"\"\"\n    value = driver.execute_script(script)\n    return value if isinstance(value, list) else []\n\n\ndef _article_status_url(article: dict[str, Any]) -> str:\n    for time_item in article.get(\"times\") or []:\n        url = normalize_url(time_item.get(\"href\"))\n        if status_id_from_url(url):\n            return url\n    for link in article.get(\"statusLinks\") or []:\n        url = normalize_url(link.get(\"href\"))\n        if status_id_from_url(url):\n            return url\n    return \"\"\n\n\ndef _compact_link(link: dict[str, Any]) -> dict[str, Any]:\n    url = normalize_url(link.get(\"url\") or link.get(\"href\"))\n    return {\n        \"url\": url or None,\n        \"href\": url or None,\n        \"postId\": status_id_from_url(url),\n        \"authorId\": author_from_status_url(url),\n        \"text\": _trim(link.get(\"text\"), 240),\n        \"ariaLabel\": _trim(link.get(\"ariaLabel\"), 240),\n        \"dataTestId\": link.get(\"dataTestId\") or None,\n    }\n\n\ndef _dedupe_links(links: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    seen: set[str] = set()\n    unique: list[dict[str, Any]] = []\n    for item in links:\n        key = str(item.get(\"url\") or item.get(\"href\") or item.get(\"text\") or \"\")\n        if not key or key in seen:\n            continue\n        seen.add(key)\n        unique.append(item)\n    return unique\n\n\ndef _article_summary(article: dict[str, Any]) -> dict[str, Any]:\n    url = _article_status_url(article)\n    return {\n        \"index\": article.get(\"index\"),\n        \"url\": url,\n        \"postId\": status_id_from_url(url),\n        \"authorId\": author_from_status_url(url),\n        \"text\": _trim(article.get(\"text\"), 280),\n        \"articleText\": _trim(article.get(\"articleText\"), 500),\n        \"rect\": article.get(\"rect\") or {},\n        \"socialContext\": article.get(\"socialContext\") or \"\",\n    }\n\n\ndef _article_handoff_record(article: dict[str, Any]) -> dict[str, Any]:\n    summary = _article_summary(article)\n    links = _dedupe_links([_compact_link(link) for link in article.get(\"links\") or []])\n    status_links = _dedupe_links([_compact_link(link) for link in article.get(\"statusLinks\") or []])\n    external_links = _dedupe_links([_compact_link(link) for link in article.get(\"externalLinks\") or []])\n    return {\n        \"id\": summary.get(\"postId\"),\n        \"postId\": summary.get(\"postId\"),\n        \"url\": summary.get(\"url\"),\n        \"authorId\": summary.get(\"authorId\"),\n        \"text\": _trim(article.get(\"text\"), 2000),\n        \"articleText\": _trim(article.get(\"articleText\"), 4000),\n        \"socialContext\": article.get(\"socialContext\") or \"\",\n        \"links\": links,\n        \"statusLinks\": status_links,\n        \"externalLinks\": external_links,\n        \"times\": article.get(\"times\") or [],\n        \"media\": article.get(\"media\") or [],\n        \"raw\": {\n            \"source\": \"reply_chain_trace.visible_article\",\n            \"rect\": article.get(\"rect\") or {},\n        },\n    }\n\n\ndef _pick_article_by_post_id(articles: list[dict[str, Any]], post_id: str | None) -> dict[str, Any] | None:\n    if post_id:\n        for article in articles:\n            if status_id_from_url(_article_status_url(article)) == post_id:\n                return article\n    return articles[0] if articles else None\n\n\ndef open_status_page(\n    driver: Any,\n    *,\n    url: str,\n    post_id: str | None,\n    wait: float,\n    hard_open: bool = True,\n) -> dict[str, Any]:\n    target_url = normalize_url(url)\n    if not target_url or not status_id_from_url(target_url):\n        return {\"ok\": False, \"reason\": \"invalid_status_url\", \"url\": url}\n    target_post_id = post_id or status_id_from_url(target_url)\n\n    if hard_open:\n        driver.get(\"about:blank\")\n        time.sleep(0.5)\n    log.info(\"reply_chain.open url=%s post_id=%s\", target_url, target_post_id)\n    driver.get(target_url)\n\n    deadline = time.time() + wait\n    last_articles: list[dict[str, Any]] = []\n    while time.time() < deadline:\n        last_articles = _snapshot_articles(driver)\n        article = _pick_article_by_post_id(last_articles, target_post_id)\n        if article and (not target_post_id or status_id_from_url(_article_status_url(article)) == target_post_id):\n            return {\n                \"ok\": True,\n                \"currentUrl\": getattr(driver, \"current_url\", \"\"),\n                \"post\": _article_summary(article),\n                \"postRecord\": _article_handoff_record(article),\n                \"articles\": [_article_summary(item) for item in last_articles],\n            }\n        time.sleep(0.25)\n\n    return {\n        \"ok\": False,\n        \"reason\": \"target_post_not_visible\",\n        \"currentUrl\": getattr(driver, \"current_url\", \"\"),\n        \"expectedPostId\": target_post_id,\n        \"articles\": [_article_summary(item) for item in last_articles],\n    }\n\n\ndef _parent_candidates(articles: list[dict[str, Any]], current_article: dict[str, Any]) -> list[dict[str, Any]]:\n    current = _article_summary(current_article)\n    current_index = int(current_article.get(\"index\") or 0)\n    current_id = current.get(\"postId\")\n    candidates: list[dict[str, Any]] = []\n    for article in articles:\n        idx = int(article.get(\"index\") or 0)\n        if idx >= current_index:\n            continue\n        summary = _article_summary(article)\n        if not summary.get(\"postId\") or summary.get(\"postId\") == current_id:\n            continue\n        candidates.append(summary)\n    candidates.sort(key=lambda item: int(item.get(\"index\") or -1), reverse=True)\n    return candidates\n\n\ndef find_visible_reply_parent(driver: Any, *, current_post_id: str | None, wait: float) -> dict[str, Any]:\n    deadline = time.time() + wait\n    articles: list[dict[str, Any]] = []\n    current_article: dict[str, Any] | None = None\n    last_current: dict[str, Any] | None = None\n    last_candidates: list[dict[str, Any]] = []\n\n    while time.time() < deadline:\n        articles = _snapshot_articles(driver)\n        current_article = _pick_article_by_post_id(articles, current_post_id)\n        if current_article and (not current_post_id or status_id_from_url(_article_status_url(current_article)) == current_post_id):\n            last_current = current_article\n            last_candidates = _parent_candidates(articles, current_article)\n            if last_candidates:\n                parent = last_candidates[0]\n                return {\n                    \"found\": True,\n                    \"method\": \"visible_thread_parent_article\",\n                    \"current\": _article_summary(current_article),\n                    \"parent\": parent,\n                    \"replyToUrl\": parent.get(\"url\"),\n                    \"replyToPostId\": parent.get(\"postId\"),\n                    \"replyToAuthorId\": parent.get(\"authorId\"),\n                    \"candidates\": last_candidates,\n                }\n        time.sleep(0.25)\n\n    if not last_current:\n        return {\"found\": False, \"reason\": \"current_article_not_found\", \"articles\": [_article_summary(a) for a in articles]}\n\n    return {\n        \"found\": False,\n        \"reason\": \"no_visible_reply_parent\",\n        \"current\": _article_summary(last_current),\n        \"handoffPost\": _article_handoff_record(last_current),\n        \"needsOriginClassification\": True,\n        \"candidates\": last_candidates,\n        \"articles\": [_article_summary(a) for a in articles],\n    }\n\n\ndef trace_reply_chain(\n    driver: Any,\n    *,\n    start_url: str,\n    start_post_id: str | None = None,\n    max_depth: int = 8,\n    wait: float = 20.0,\n) -> dict[str, Any]:\n    current_url = normalize_url(start_url)\n    current_post_id = start_post_id or status_id_from_url(current_url)\n    seen: set[str] = set()\n    path: list[dict[str, Any]] = []\n    reply_chain_end_post: dict[str, Any] | None = None\n    handoff_post: dict[str, Any] | None = None\n    needs_origin_classification = False\n    stop_reason = \"max_depth\"\n\n    for depth in range(max_depth):\n        opened = open_status_page(driver, url=current_url, post_id=current_post_id, wait=wait)\n        if not opened.get(\"ok\"):\n            stop_reason = str(opened.get(\"reason\") or \"open_failed\")\n            path.append({\"depth\": depth, \"url\": current_url, \"postId\": current_post_id, \"open\": opened})\n            break\n\n        current = opened.get(\"post\") or {}\n        current_record = opened.get(\"postRecord\") or {}\n        current_id = current.get(\"postId\") or current_post_id or status_id_from_url(current_url)\n        if current_id in seen:\n            stop_reason = \"cycle\"\n            path.append({\"depth\": depth, \"current\": current, \"reason\": \"cycle\"})\n            reply_chain_end_post = current_record or current\n            break\n        if current_id:\n            seen.add(current_id)\n\n        parent = find_visible_reply_parent(driver, current_post_id=current_id, wait=wait)\n        step = {\"depth\": depth, \"current\": current, \"replyParent\": parent}\n        path.append(step)\n\n        if not parent.get(\"found\"):\n            stop_reason = \"reply_chain_finished\"\n            reply_chain_end_post = parent.get(\"handoffPost\") or current_record or current\n            handoff_post = parent.get(\"handoffPost\") or current_record or current\n            needs_origin_classification = True\n            break\n\n        next_url = normalize_url(parent.get(\"replyToUrl\"))\n        next_id = parent.get(\"replyToPostId\") or status_id_from_url(next_url)\n        if not next_url or not next_id:\n            stop_reason = \"invalid_parent_ref\"\n            reply_chain_end_post = current_record or current\n            handoff_post = current_record or current\n            needs_origin_classification = True\n            break\n\n        current_url = next_url\n        current_post_id = next_id\n    else:\n        stop_reason = \"max_depth\"\n\n    return {\n        \"ok\": bool(path),\n        \"startUrl\": start_url,\n        \"startPostId\": start_post_id or status_id_from_url(start_url),\n        \"replyChainEndPost\": reply_chain_end_post,\n        \"rootPost\": None,\n        \"rootIsFinal\": False,\n        \"handoffPost\": handoff_post,\n        \"needsOriginClassification\": needs_origin_classification,\n        \"stopReason\": stop_reason,\n        \"depth\": len(path),\n        \"path\": path,\n    }\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Trace visible X reply chain and hand the end post to origin classification.\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--url\", required=True, help=\"Start X status URL.\")\n    parser.add_argument(\"--post-id\", help=\"Start post id. Defaults to id parsed from --url.\")\n    parser.add_argument(\"--max-depth\", type=int, default=8)\n    parser.add_argument(\"--wait\", type=float, default=20.0)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n\n    from scripts.chrome_debug import get_driver\n\n    driver = get_driver(port=args.port, wait=args.wait)\n    result = trace_reply_chain(\n        driver,\n        start_url=args.url,\n        start_post_id=args.post_id,\n        max_depth=args.max_depth,\n        wait=args.wait,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 2\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
