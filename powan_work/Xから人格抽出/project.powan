    {
      "id": "node-6b03f1e267",
      "title": "Xページ観察ポワン",
      "body": "Seleniumで開いているXページ、または指定URLへ遷移したXページのDOM構造を観察する臓器ポワン。投稿article、tweetText、time、statusリンク、画像、動画などのセレクタ数と、先頭投稿サンプルをJSONで返す。収集や追跡は行わず、X構造整理ポワンが現物のページ構造を確認するための観察役に徹する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nfrom typing import Any\n\nfrom selenium.common.exceptions import TimeoutException\nfrom selenium.webdriver.common.by import By\nfrom selenium.webdriver.remote.webdriver import WebDriver\nfrom selenium.webdriver.support.ui import WebDriverWait\n\nlog = logging.getLogger(\"x_page_observer\")\n\nDEFAULT_SELECTORS = {\n    \"tweet_articles\": \"article[data-testid='tweet']\",\n    \"tweet_texts\": \"div[data-testid='tweetText']\",\n    \"times\": \"time\",\n    \"status_links\": \"a[href*='/status/']\",\n    \"photos\": \"div[data-testid='tweetPhoto'] img\",\n    \"videos\": \"div[data-testid='videoPlayer']\",\n    \"external_links\": \"a[target='_blank']\",\n}\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef get_debug_driver(*, port: int = 9221) -> WebDriver:\n    from scripts.chrome_debug import get_driver\n\n    log.info(\"driver.connect port=%s\", port)\n    return get_driver(port=port)\n\n\ndef wait_for_ready(driver: WebDriver, *, wait_seconds: float = 15.0) -> str:\n    wait = WebDriverWait(driver, wait_seconds)\n    try:\n        wait.until(lambda d: d.execute_script(\"return document.readyState\") in {\"interactive\", \"complete\"})\n    except TimeoutException:\n        log.warning(\"page.ready.timeout wait_seconds=%s\", wait_seconds)\n    return str(driver.execute_script(\"return document.readyState\") or \"\")\n\n\ndef count_selectors(driver: WebDriver, selectors: dict[str, str]) -> dict[str, int]:\n    counts: dict[str, int] = {}\n    for name, selector in selectors.items():\n        try:\n            counts[name] = len(driver.find_elements(By.CSS_SELECTOR, selector))\n        except Exception as exc:\n            log.warning(\"selector.count.failed name=%s selector=%s error=%s\", name, selector, exc)\n            counts[name] = -1\n    return counts\n\n\ndef _first_text(element, max_chars: int) -> str:\n    text = (element.text or \"\").strip()\n    return text[:max_chars]\n\n\ndef sample_tweet_articles(driver: WebDriver, *, limit: int = 5, max_text_chars: int = 500) -> list[dict[str, Any]]:\n    articles = driver.find_elements(By.CSS_SELECTOR, DEFAULT_SELECTORS[\"tweet_articles\"])\n    samples: list[dict[str, Any]] = []\n    for index, article in enumerate(articles[:limit], 1):\n        links = []\n        for link in article.find_elements(By.CSS_SELECTOR, \"a[href]\"):\n            href = link.get_attribute(\"href\") or \"\"\n            if href and href not in links:\n                links.append(href)\n        times = [item.get_attribute(\"datetime\") or \"\" for item in article.find_elements(By.CSS_SELECTOR, \"time\")]\n        text_nodes = article.find_elements(By.CSS_SELECTOR, DEFAULT_SELECTORS[\"tweet_texts\"])\n        samples.append(\n            {\n                \"index\": index,\n                \"text\": _first_text(text_nodes[0], max_text_chars) if text_nodes else \"\",\n                \"article_text\": _first_text(article, max_text_chars),\n                \"time_values\": [item for item in times if item],\n                \"status_links\": [href for href in links if \"/status/\" in href],\n                \"link_count\": len(links),\n            }\n        )\n    return samples\n\n\ndef observe_x_page(\n    driver: WebDriver,\n    *,\n    url: str | None = None,\n    wait_seconds: float = 15.0,\n    sample_limit: int = 5,\n) -> dict[str, Any]:\n    if url:\n        log.info(\"observe.navigate url=%s\", url)\n        driver.get(url)\n    ready_state = wait_for_ready(driver, wait_seconds=wait_seconds)\n    counts = count_selectors(driver, DEFAULT_SELECTORS)\n    result = {\n        \"url\": driver.current_url,\n        \"title\": driver.title,\n        \"ready_state\": ready_state,\n        \"selector_counts\": counts,\n        \"tweet_samples\": sample_tweet_articles(driver, limit=sample_limit),\n    }\n    log.info(\n        \"observe.done url=%s tweets=%s texts=%s status_links=%s\",\n        result[\"url\"],\n        counts.get(\"tweet_articles\"),\n        counts.get(\"tweet_texts\"),\n        counts.get(\"status_links\"),\n    )\n    return result\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Observe the current or specified X page DOM structure.\")\n    parser.add_argument(\"--url\", default=\"\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--wait-seconds\", type=float, default=15.0)\n    parser.add_argument(\"--sample-limit\", type=int, default=5)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n    driver = get_debug_driver(port=args.port)\n    result = observe_x_page(\n        driver,\n        url=args.url or None,\n        wait_seconds=args.wait_seconds,\n        sample_limit=args.sample_limit,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
