    {
      "id": "node-6609a28795",
      "title": "ニュース本文DB保存ポワン",
      "body": "ニュースURL抽出、URL展開、本文抽出、メタ情報抽出、取得不能理由整理の結果を受け取り、SQLite DBへ保存する臓器ポワン。X終端投稿と記事URLを紐づけ、本文、メタ情報、取得不能理由、抽出方式、raw JSONを後から参照できるように保存する。取得処理そのものは行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport sqlite3\nimport sys\nfrom collections.abc import Mapping\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\nfrom urllib.parse import parse_qsl, urlencode, urlparse, urlunparse\n\n\nDEFAULT_DB_PATH = \"data/x_news_content.db\"\nTRACKING_QUERY_KEYS = {\n    \"fbclid\",\n    \"gclid\",\n    \"igshid\",\n    \"mc_cid\",\n    \"mc_eid\",\n    \"mkt_tok\",\n    \"ocid\",\n    \"ref_src\",\n    \"spm\",\n    \"utm_campaign\",\n    \"utm_content\",\n    \"utm_medium\",\n    \"utm_source\",\n    \"utm_term\",\n}\n\nPOST_ID_KEYS = {\"postid\", \"tweetid\", \"statusid\", \"conversationid\", \"restid\", \"idstr\"}\nORIGINAL_URL_KEYS = {\"originalurl\", \"inputurl\", \"sourceurl\", \"requesturl\", \"url\"}\nFINAL_URL_KEYS = {\"finalurl\", \"expandedurl\", \"resolvedurl\", \"effectiveurl\"}\nCANONICAL_URL_KEYS = {\"canonicalurl\", \"canonical\"}\nTITLE_KEYS = {\"title\", \"headline\", \"ogtitle\", \"twittertitle\", \"cardtitle\"}\nTEXT_KEYS = {\"articletext\", \"text\", \"body\", \"content\", \"fulltext\"}\nSITE_NAME_KEYS = {\"sitename\", \"sourcename\", \"medianame\", \"publisher\", \"domain\", \"host\"}\nPUBLISHED_AT_KEYS = {\n    \"publishedat\",\n    \"publishdate\",\n    \"datepublished\",\n    \"pubdate\",\n    \"createdat\",\n    \"date\",\n}\nEXTRACTOR_KEYS = {\"extractor\", \"extractorname\", \"extractionmethod\"}\nRAW_JSON_KEYS = {\"rawjson\", \"raw\", \"sourcejson\", \"payloadjson\"}\nFAILURE_TYPE_KEYS = {\"failuretype\", \"unavailablereason\", \"reason\", \"errortype\", \"type\"}\nFAILURE_STAGE_KEYS = {\"failurestage\", \"stage\", \"step\"}\nFAILURE_MESSAGE_KEYS = {\"message\", \"errormessage\", \"detail\", \"details\", \"description\"}\n\nNESTED_MAP_KEYS = {\n    \"source\",\n    \"urlsource\",\n    \"urlresult\",\n    \"urlresults\",\n    \"expansion\",\n    \"urlexpansion\",\n    \"expanded\",\n    \"article\",\n    \"articleresult\",\n    \"extraction\",\n    \"extract\",\n    \"meta\",\n    \"metadata\",\n    \"failure\",\n    \"failureresult\",\n    \"error\",\n}\n\n\nclass NewsDBSaveError(RuntimeError):\n    pass\n\n\ndef save_news_content(payload: Any = None, *, db_path: str = DEFAULT_DB_PATH, **kwargs: Any) -> dict[str, Any]:\n    \"\"\"Save already-collected news article material into SQLite.\n\n    This organ never fetches URLs, expands redirects, extracts article bodies,\n    creates embeddings, runs RAG, summarizes, or judges contradictions.\n    \"\"\"\n    prepared = _prepare_payload(payload, kwargs)\n    records = _records_from_payload(prepared)\n    if not records:\n        raise NewsDBSaveError(\"no news article record supplied\")\n    if len(records) == 1:\n        return save_news_record(records[0], db_path=db_path)\n    return save_news_records(records, db_path=db_path)\n\n\ndef save_news_records(records: list[Any], *, db_path: str = DEFAULT_DB_PATH) -> dict[str, Any]:\n    outputs = [save_news_record(record, db_path=db_path) for record in records]\n    return {\n        \"ok\": all(item.get(\"ok\") for item in outputs),\n        \"status\": \"batch_saved\",\n        \"count\": len(outputs),\n        \"article_count\": sum(1 for item in outputs if item.get(\"article_saved\")),\n        \"failure_count\": sum(1 for item in outputs if item.get(\"failure_saved\")),\n        \"db_path\": str(_resolve_db_path(db_path)),\n        \"results\": outputs,\n    }\n\n\ndef save_news_record(record_input: Any, *, db_path: str = DEFAULT_DB_PATH) -> dict[str, Any]:\n    record = _record_from_input(record_input)\n    fields = _extract_fields(record)\n    resolved_db_path = _resolve_db_path(db_path)\n\n    conn = _connect(resolved_db_path)\n    try:\n        _init_db(conn)\n        source_id = _upsert_source(conn, fields)\n        article_id = None\n        failure_id = None\n\n        if fields[\"article_text\"]:\n            article_id = _upsert_article(conn, source_id, fields)\n            if not fields[\"failure_type\"]:\n                conn.execute(\"DELETE FROM x_news_fetch_failures WHERE source_id = ?\", (source_id,))\n        elif not fields[\"failure_type\"]:\n            fields[\"failure_type\"] = \"empty_body\"\n            fields[\"failure_stage\"] = fields[\"failure_stage\"] or \"article_text\"\n            fields[\"failure_message\"] = \"article_text was empty\"\n\n        if fields[\"failure_type\"]:\n            failure_id = _upsert_failure(conn, source_id, fields)\n\n        conn.commit()\n    except Exception:\n        conn.rollback()\n        raise\n    finally:\n        conn.close()\n\n    return {\n        \"ok\": True,\n        \"status\": \"saved\",\n        \"content_ok\": bool(fields[\"article_text\"] and not fields[\"failure_type\"]),\n        \"article_saved\": article_id is not None,\n        \"failure_saved\": failure_id is not None,\n        \"db_path\": str(resolved_db_path),\n        \"source_id\": source_id,\n        \"article_id\": article_id,\n        \"failure_id\": failure_id,\n        \"post_id\": fields[\"post_id\"],\n        \"url\": fields[\"original_url\"],\n        \"final_url\": fields[\"final_url\"],\n        \"canonical_url\": fields[\"canonical_url\"],\n        \"title\": fields[\"title\"],\n        \"text\": fields[\"article_text\"],\n        \"metadata\": fields[\"metadata\"],\n        \"error\": fields[\"error\"],\n        \"raw_json\": fields[\"raw_json_value\"],\n    }\n\n\ndef _init_db(conn: sqlite3.Connection) -> None:\n    conn.execute(\"PRAGMA foreign_keys = ON\")\n    conn.execute(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS x_news_sources (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            post_id TEXT NOT NULL DEFAULT '',\n            original_url TEXT NOT NULL,\n            final_url TEXT NOT NULL DEFAULT '',\n            canonical_url TEXT NOT NULL DEFAULT '',\n            url_key TEXT NOT NULL,\n            source_payload_json TEXT NOT NULL DEFAULT '{}',\n            raw_json TEXT NOT NULL DEFAULT 'null',\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL,\n            UNIQUE(post_id, original_url)\n        )\n        \"\"\"\n    )\n    conn.execute(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS x_news_articles (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            source_id INTEGER NOT NULL UNIQUE,\n            post_id TEXT NOT NULL DEFAULT '',\n            original_url TEXT NOT NULL,\n            final_url TEXT NOT NULL DEFAULT '',\n            canonical_url TEXT NOT NULL DEFAULT '',\n            url_key TEXT NOT NULL,\n            title TEXT NOT NULL DEFAULT '',\n            site_name TEXT NOT NULL DEFAULT '',\n            published_at TEXT,\n            article_text TEXT NOT NULL DEFAULT '',\n            extractor TEXT NOT NULL DEFAULT '',\n            metadata_json TEXT NOT NULL DEFAULT '{}',\n            raw_json TEXT NOT NULL DEFAULT 'null',\n            content_hash TEXT NOT NULL DEFAULT '',\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL,\n            FOREIGN KEY(source_id) REFERENCES x_news_sources(id) ON DELETE CASCADE\n        )\n        \"\"\"\n    )\n    conn.execute(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS x_news_fetch_failures (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            source_id INTEGER NOT NULL,\n            post_id TEXT NOT NULL DEFAULT '',\n            original_url TEXT NOT NULL,\n            final_url TEXT NOT NULL DEFAULT '',\n            canonical_url TEXT NOT NULL DEFAULT '',\n            failure_type TEXT NOT NULL,\n            failure_stage TEXT NOT NULL DEFAULT '',\n            message TEXT NOT NULL DEFAULT '',\n            retryable INTEGER,\n            metadata_json TEXT NOT NULL DEFAULT '{}',\n            raw_json TEXT NOT NULL DEFAULT 'null',\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL,\n            FOREIGN KEY(source_id) REFERENCES x_news_sources(id) ON DELETE CASCADE,\n            UNIQUE(source_id, failure_type, failure_stage)\n        )\n        \"\"\"\n    )\n    for sql in (\n        \"CREATE INDEX IF NOT EXISTS idx_x_news_sources_post ON x_news_sources(post_id)\",\n        \"CREATE INDEX IF NOT EXISTS idx_x_news_sources_url_key ON x_news_sources(url_key)\",\n        \"CREATE INDEX IF NOT EXISTS idx_x_news_articles_post ON x_news_articles(post_id)\",\n        \"CREATE INDEX IF NOT EXISTS idx_x_news_articles_url_key ON x_news_articles(url_key)\",\n        \"CREATE INDEX IF NOT EXISTS idx_x_news_failures_post ON x_news_fetch_failures(post_id)\",\n        \"CREATE INDEX IF NOT EXISTS idx_x_news_failures_type ON x_news_fetch_failures(failure_type)\",\n    ):\n        conn.execute(sql)\n\n\ndef _upsert_source(conn: sqlite3.Connection, fields: dict[str, Any]) -> int:\n    now = _now()\n    conn.execute(\n        \"\"\"\n        INSERT INTO x_news_sources (\n            post_id, original_url, final_url, canonical_url, url_key,\n            source_payload_json, raw_json, created_at, updated_at\n        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n        ON CONFLICT(post_id, original_url) DO UPDATE SET\n            final_url = excluded.final_url,\n            canonical_url = excluded.canonical_url,\n            url_key = excluded.url_key,\n            source_payload_json = excluded.source_payload_json,\n            raw_json = excluded.raw_json,\n            updated_at = excluded.updated_at\n        \"\"\",\n        (\n            fields[\"post_id\"],\n            fields[\"original_url\"],\n            fields[\"final_url\"],\n            fields[\"canonical_url\"],\n            fields[\"url_key\"],\n            _json_dumps(fields[\"source_payload\"]),\n            fields[\"raw_json\"],\n            now,\n            now,\n        ),\n    )\n    row = conn.execute(\n        \"SELECT id FROM x_news_sources WHERE post_id = ? AND original_url = ?\",\n        (fields[\"post_id\"], fields[\"original_url\"]),\n    ).fetchone()\n    if row is None:\n        raise NewsDBSaveError(\"failed to save x_news_sources row\")\n    return int(row[\"id\"])\n\n\ndef _upsert_article(conn: sqlite3.Connection, source_id: int, fields: dict[str, Any]) -> int:\n    now = _now()\n    conn.execute(\n        \"\"\"\n        INSERT INTO x_news_articles (\n            source_id, post_id, original_url, final_url, canonical_url, url_key,\n            title, site_name, published_at, article_text, extractor,\n            metadata_json, raw_json, content_hash, created_at, updated_at\n        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n        ON CONFLICT(source_id) DO UPDATE SET\n            post_id = excluded.post_id,\n            original_url = excluded.original_url,\n            final_url = excluded.final_url,\n            canonical_url = excluded.canonical_url,\n            url_key = excluded.url_key,\n            title = excluded.title,\n            site_name = excluded.site_name,\n            published_at = excluded.published_at,\n            article_text = excluded.article_text,\n            extractor = excluded.extractor,\n            metadata_json = excluded.metadata_json,\n            raw_json = excluded.raw_json,\n            content_hash = excluded.content_hash,\n            updated_at = excluded.updated_at\n        \"\"\",\n        (\n            source_id,\n            fields[\"post_id\"],\n            fields[\"original_url\"],\n            fields[\"final_url\"],\n            fields[\"canonical_url\"],\n            fields[\"url_key\"],\n            fields[\"title\"],\n            fields[\"site_name\"],\n            fields[\"published_at\"] or None,\n            fields[\"article_text\"],\n            fields[\"extractor\"],\n            _json_dumps(fields[\"metadata\"]),\n            fields[\"raw_json\"],\n            _content_hash(fields[\"article_text\"]),\n            now,\n            now,\n        ),\n    )\n    row = conn.execute(\"SELECT id FROM x_news_articles WHERE source_id = ?\", (source_id,)).fetchone()\n    if row is None:\n        raise NewsDBSaveError(\"failed to save x_news_articles row\")\n    return int(row[\"id\"])\n\n\ndef _upsert_failure(conn: sqlite3.Connection, source_id: int, fields: dict[str, Any]) -> int:\n    now = _now()\n    conn.execute(\n        \"\"\"\n        INSERT INTO x_news_fetch_failures (\n            source_id, post_id, original_url, final_url, canonical_url,\n            failure_type, failure_stage, message, retryable,\n            metadata_json, raw_json, created_at, updated_at\n        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n        ON CONFLICT(source_id, failure_type, failure_stage) DO UPDATE SET\n            post_id = excluded.post_id,\n            original_url = excluded.original_url,\n            final_url = excluded.final_url,\n            canonical_url = excluded.canonical_url,\n            message = excluded.message,\n            retryable = excluded.retryable,\n            metadata_json = excluded.metadata_json,\n            raw_json = excluded.raw_json,\n            updated_at = excluded.updated_at\n        \"\"\",\n        (\n            source_id,\n            fields[\"post_id\"],\n            fields[\"original_url\"],\n            fields[\"final_url\"],\n            fields[\"canonical_url\"],\n            fields[\"failure_type\"],\n            fields[\"failure_stage\"],\n            fields[\"failure_message\"],\n            fields[\"retryable\"],\n            _json_dumps(fields[\"metadata\"]),\n            fields[\"raw_json\"],\n            now,\n            now,\n        ),\n    )\n    row = conn.execute(\n        \"\"\"\n        SELECT id FROM x_news_fetch_failures\n         WHERE source_id = ? AND failure_type = ? AND failure_stage = ?\n        \"\"\",\n        (source_id, fields[\"failure_type\"], fields[\"failure_stage\"]),\n    ).fetchone()\n    if row is None:\n        raise NewsDBSaveError(\"failed to save x_news_fetch_failures row\")\n    return int(row[\"id\"])\n\n\ndef _extract_fields(record: Mapping[str, Any]) -> dict[str, Any]:\n    maps = _candidate_maps(record)\n    original_url = _first_text(maps, ORIGINAL_URL_KEYS)\n    final_url = _first_text(maps, FINAL_URL_KEYS) or original_url\n    canonical_url = _first_text(maps, CANONICAL_URL_KEYS) or final_url\n    if not original_url:\n        original_url = canonical_url or final_url\n    if not original_url:\n        raise NewsDBSaveError(\"original url is required\")\n\n    metadata = _merged_metadata(record, maps)\n    title = _first_text(maps, TITLE_KEYS)\n    article_text = _first_text(maps, TEXT_KEYS)\n    site_name = _first_text(maps, SITE_NAME_KEYS)\n    published_at = _first_text(maps, PUBLISHED_AT_KEYS)\n    extractor = _first_text(maps, EXTRACTOR_KEYS)\n    error_value = _first_error(record, maps)\n    failure_type = _first_text(maps, FAILURE_TYPE_KEYS)\n    failure_stage = _first_text(maps, FAILURE_STAGE_KEYS)\n    failure_message = _first_text(maps, FAILURE_MESSAGE_KEYS)\n\n    if isinstance(error_value, Mapping):\n        error_maps = [error_value]\n        failure_type = failure_type or _first_text(error_maps, FAILURE_TYPE_KEYS)\n        failure_stage = failure_stage or _first_text(error_maps, FAILURE_STAGE_KEYS)\n        failure_message = failure_message or _first_text(error_maps, FAILURE_MESSAGE_KEYS)\n    elif error_value:\n        failure_message = failure_message or str(error_value)\n\n    if error_value and not failure_type:\n        failure_type = \"fetch_failed\"\n\n    raw_json_value = _first_value(maps, RAW_JSON_KEYS)\n    if raw_json_value is None:\n        raw_json_value = record\n\n    metadata.setdefault(\"site_name\", site_name)\n    metadata.setdefault(\"published_at\", published_at)\n    metadata.setdefault(\"extractor\", extractor)\n    metadata.setdefault(\"final_url\", final_url)\n    metadata.setdefault(\"canonical_url\", canonical_url)\n\n    return {\n        \"post_id\": _first_text(maps, POST_ID_KEYS),\n        \"original_url\": original_url,\n        \"final_url\": final_url,\n        \"canonical_url\": canonical_url,\n        \"url_key\": _url_key(canonical_url or final_url or original_url),\n        \"title\": title,\n        \"site_name\": site_name,\n        \"published_at\": published_at,\n        \"article_text\": article_text,\n        \"extractor\": extractor,\n        \"failure_type\": failure_type,\n        \"failure_stage\": failure_stage,\n        \"failure_message\": failure_message,\n        \"retryable\": _retryable_value(record, maps),\n        \"metadata\": metadata,\n        \"error\": error_value,\n        \"raw_json\": _json_dumps(raw_json_value),\n        \"raw_json_value\": raw_json_value,\n        \"source_payload\": _source_payload(record, original_url, final_url, canonical_url),\n    }\n\n\ndef _prepare_payload(payload: Any, kwargs: dict[str, Any]) -> Any:\n    if payload is None:\n        payload = {}\n    if isinstance(payload, str) and _looks_like_json(payload):\n        payload = json.loads(payload)\n    if not kwargs:\n        return payload\n    if isinstance(payload, Mapping):\n        merged = dict(payload)\n        merged.update({key: value for key, value in kwargs.items() if value is not None})\n        return merged\n    merged = {\"payload\": payload}\n    merged.update({key: value for key, value in kwargs.items() if value is not None})\n    return merged\n\n\ndef _records_from_payload(payload: Any) -> list[Any]:\n    if isinstance(payload, list):\n        return payload\n    if isinstance(payload, Mapping):\n        for key in (\"results\", \"articles\", \"items\", \"records\"):\n            value = payload.get(key)\n            if isinstance(value, list):\n                return value\n        return [payload]\n    if isinstance(payload, str) and payload.strip():\n        return [{\"url\": payload.strip()}]\n    return []\n\n\ndef _record_from_input(value: Any) -> dict[str, Any]:\n    if isinstance(value, Mapping):\n        return dict(value)\n    if isinstance(value, str) and value.strip():\n        if _looks_like_json(value):\n            loaded = json.loads(value)\n            if isinstance(loaded, Mapping):\n                return dict(loaded)\n            raise NewsDBSaveError(\"JSON string must describe one object\")\n        return {\"url\": value.strip()}\n    raise NewsDBSaveError(\"record must be a JSON object or URL string\")\n\n\ndef _candidate_maps(record: Mapping[str, Any]) -> list[Mapping[str, Any]]:\n    maps: list[Mapping[str, Any]] = [record]\n    for key, value in record.items():\n        if _key_token(key) in NESTED_MAP_KEYS and isinstance(value, Mapping):\n            maps.append(value)\n    for item in list(maps):\n        metadata = item.get(\"metadata\") if isinstance(item, Mapping) else None\n        if isinstance(metadata, Mapping) and metadata not in maps:\n            maps.append(metadata)\n        error = item.get(\"error\") if isinstance(item, Mapping) else None\n        if isinstance(error, Mapping) and error not in maps:\n            maps.append(error)\n    return maps\n\n\ndef _merged_metadata(record: Mapping[str, Any], maps: list[Mapping[str, Any]]) -> dict[str, Any]:\n    merged: dict[str, Any] = {}\n    for item in maps:\n        if _key_token(next(iter(item.keys()), \"\")) == \"error\":\n            continue\n        value = item.get(\"metadata\") if isinstance(item, Mapping) else None\n        if isinstance(value, Mapping):\n            merged.update(dict(value))\n    for key in (\"statusCode\", \"status_code\", \"contentType\", \"content_type\", \"domain\", \"htmlPath\", \"html_path\"):\n        value = _first_existing(record, key)\n        if value not in (None, \"\"):\n            merged[_snake_key(key)] = value\n    return merged\n\n\ndef _source_payload(record: Mapping[str, Any], original_url: str, final_url: str, canonical_url: str) -> dict[str, Any]:\n    return {\n        \"post_id\": _first_text(_candidate_maps(record), POST_ID_KEYS),\n        \"original_url\": original_url,\n        \"final_url\": final_url,\n        \"canonical_url\": canonical_url,\n    }\n\n\ndef _first_text(maps: list[Mapping[str, Any]], key_tokens: set[str]) -> str:\n    value = _first_value(maps, key_tokens)\n    if value is None:\n        return \"\"\n    if isinstance(value, (dict, list, tuple)):\n        return \"\"\n    return str(value).strip()\n\n\ndef _first_value(maps: list[Mapping[str, Any]], key_tokens: set[str]) -> Any:\n    for item in maps:\n        for key, value in item.items():\n            if _key_token(key) in key_tokens and value not in (None, \"\"):\n                return value\n    return None\n\n\ndef _first_error(record: Mapping[str, Any], maps: list[Mapping[str, Any]]) -> Any:\n    for item in maps:\n        if \"error\" in item and item.get(\"error\") not in (None, \"\", False):\n            return item.get(\"error\")\n    ok_value = _first_existing(record, \"ok\")\n    if ok_value is False:\n        return {\"type\": \"not_ok\", \"message\": \"upstream result had ok=false\"}\n    return None\n\n\ndef _retryable_value(record: Mapping[str, Any], maps: list[Mapping[str, Any]]) -> int | None:\n    for item in maps:\n        for key, value in item.items():\n            if _key_token(key) in {\"retryable\", \"shouldretry\"}:\n                if isinstance(value, bool):\n                    return int(value)\n                if str(value).strip().lower() in {\"true\", \"1\", \"yes\"}:\n                    return 1\n                if str(value).strip().lower() in {\"false\", \"0\", \"no\"}:\n                    return 0\n    return None\n\n\ndef _first_existing(record: Mapping[str, Any], key_name: str) -> Any:\n    wanted = _key_token(key_name)\n    for key, value in record.items():\n        if _key_token(key) == wanted:\n            return value\n    return None\n\n\ndef _resolve_db_path(db_path: str | Path) -> Path:\n    path = Path(str(db_path or DEFAULT_DB_PATH)).expanduser()\n    if not path.is_absolute():\n        path = Path.cwd() / path\n    path.parent.mkdir(parents=True, exist_ok=True)\n    return path\n\n\ndef _connect(db_path: Path) -> sqlite3.Connection:\n    conn = sqlite3.connect(str(db_path))\n    conn.row_factory = sqlite3.Row\n    conn.execute(\"PRAGMA foreign_keys = ON\")\n    return conn\n\n\ndef _json_dumps(value: Any) -> str:\n    try:\n        return json.dumps(value, ensure_ascii=False, sort_keys=True, default=str)\n    except TypeError:\n        return json.dumps(str(value), ensure_ascii=False)\n\n\ndef _content_hash(text: str) -> str:\n    return hashlib.sha256((text or \"\").encode(\"utf-8\")).hexdigest()\n\n\ndef _url_key(url: str) -> str:\n    parsed = urlparse(url or \"\")\n    query = []\n    for key, value in parse_qsl(parsed.query, keep_blank_values=True):\n        key_lower = key.lower()\n        if key_lower in TRACKING_QUERY_KEYS or key_lower.startswith(\"utm_\"):\n            continue\n        query.append((key_lower, value))\n    path = parsed.path or \"/\"\n    if path != \"/\" and path.endswith(\"/\"):\n        path = path.rstrip(\"/\")\n    return urlunparse(\n        (\n            (parsed.scheme or \"https\").lower(),\n            (parsed.netloc or \"\").lower(),\n            path,\n            \"\",\n            urlencode(sorted(query)),\n            \"\",\n        )\n    )\n\n\ndef _key_token(key: Any) -> str:\n    return \"\".join(ch for ch in str(key or \"\").lower() if ch.isalnum())\n\n\ndef _snake_key(key: str) -> str:\n    output = []\n    for char in str(key):\n        if char.isupper() and output:\n            output.append(\"_\")\n        output.append(char.lower())\n    return \"\".join(output)\n\n\ndef _looks_like_json(text: str) -> bool:\n    stripped = (text or \"\").strip()\n    return (stripped.startswith(\"{\") and stripped.endswith(\"}\")) or (\n        stripped.startswith(\"[\") and stripped.endswith(\"]\")\n    )\n\n\ndef _now() -> str:\n    return datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n\n\ndef load_input_payload(input_json: str) -> Any:\n    if not input_json or input_json == \"-\":\n        raw = sys.stdin.read().strip()\n        return json.loads(raw) if raw else {}\n    path = Path(input_json)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(input_json)\n\n\ndef run(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return save_news_content(payload, **kwargs)\n\n\ndef save(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return save_news_content(payload, **kwargs)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Save collected X news article results into SQLite.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--db-path\", default=DEFAULT_DB_PATH)\n    parser.add_argument(\"--pretty\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    try:\n        payload = load_input_payload(args.input_json)\n        result = save_news_content(payload, db_path=args.db_path)\n    except Exception as exc:\n        result = {\n            \"ok\": False,\n            \"status\": \"save_failed\",\n            \"error\": {\"type\": exc.__class__.__name__, \"message\": str(exc)},\n        }\n\n    print(json.dumps(result, ensure_ascii=False, indent=2 if args.pretty else None))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
      "parent": "node-50607708e4",
      "children": [],
      "style": {
        "shape": "cloud",
        "color": "#ffffff",
