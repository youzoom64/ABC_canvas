    {
      "id": "node-1646a8a2b9",
      "title": "引用カード行き先発見ポワン",
      "body": "Xの画面に表示された引用カードが、どの投稿へ向かうのかを見つける臓器ポワン。画面投稿読み取りポワンが引用っぽい中身を見つけた時に、そのカード周辺のstatusリンク、引用本文や日時の近くのクリック領域、必要に応じたクリック前後のURL変化を調べ、引用元の投稿URLと投稿IDを返す。役割は行き先発見までで、引用元として正しいか、会話の発端かどうかの判定は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport re\nimport time\nfrom typing import Any\nfrom urllib.parse import urljoin, urlparse\n\nlog = logging.getLogger(\"quote_card_destination\")\n\nSTATUS_RE = re.compile(r\"/(?:i/web/)?status/(\\d+)\")\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef normalize_url(href: str | None, *, base_url: str = \"https://x.com\") -> str:\n    if not href:\n        return \"\"\n    url = urljoin(base_url, href.strip())\n    parsed = urlparse(url)\n    if parsed.netloc in {\"twitter.com\", \"mobile.twitter.com\"}:\n        parsed = parsed._replace(netloc=\"x.com\")\n    return parsed._replace(fragment=\"\").geturl()\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    match = STATUS_RE.search(url)\n    return match.group(1) if match else None\n\n\ndef author_from_status_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    parsed = urlparse(url)\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if len(parts) >= 3 and parts[1] == \"status\":\n        return parts[0]\n    return None\n\n\ndef _dedupe(candidates: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    seen: set[str] = set()\n    out: list[dict[str, Any]] = []\n    for item in candidates:\n        url = item.get(\"url\") or item.get(\"href\") or \"\"\n        if not url or url in seen:\n            continue\n        seen.add(url)\n        out.append(item)\n    return out\n\n\ndef _snapshot_quote_area(driver: Any, article: Any) -> dict[str, Any]:\n    script = r\"\"\"\nconst article = arguments[0];\nconst textOf = (el) => (el && (el.innerText || el.textContent) || '').trim();\nconst attr = (el, name) => el ? (el.getAttribute(name) || '') : '';\nconst rectOf = (el) => {\n  const r = el.getBoundingClientRect();\n  return {x: Math.round(r.x), y: Math.round(r.y), width: Math.round(r.width), height: Math.round(r.height), right: Math.round(r.right), bottom: Math.round(r.bottom)};\n};\nconst intersects = (a, b) => !!a && !!b && a.x < b.right && a.right > b.x && a.y < b.bottom && a.bottom > b.y;\nconst containsPoint = (rect, x, y) => !!rect && x >= rect.x && x <= rect.right && y >= rect.y && y <= rect.bottom;\nconst statusish = (href) => /\\/status\\/\\d+/.test(href || '');\n\nconst tweetTextEls = Array.from(article.querySelectorAll('[data-testid=\"tweetText\"]'));\nconst timeEls = Array.from(article.querySelectorAll('time'));\nconst links = Array.from(article.querySelectorAll('a[href]')).map((a) => ({\n  href: a.href || attr(a, 'href'),\n  text: textOf(a),\n  ariaLabel: attr(a, 'aria-label'),\n  role: attr(a, 'role'),\n  dataTestId: attr(a, 'data-testid'),\n  rect: rectOf(a),\n}));\nconst times = timeEls.map((t) => ({\n  datetime: attr(t, 'datetime'),\n  text: textOf(t),\n  href: (t.closest('a') && t.closest('a').href) || '',\n  rect: rectOf(t),\n}));\nconst tweetTexts = tweetTextEls.map((el) => ({text: textOf(el), rect: rectOf(el)})).filter((x) => x.text);\nconst ownUrl = times.length ? (times[0].href || '') : '';\nconst quoteTextEl = tweetTextEls.length > 1 ? tweetTextEls[1] : null;\nconst quoteTimeEl = timeEls.length > 1 ? timeEls[1] : null;\nconst quoteTextRect = quoteTextEl ? rectOf(quoteTextEl) : null;\nconst quoteTimeRect = quoteTimeEl ? rectOf(quoteTimeEl) : null;\n\nconst ancestorCandidates = [];\nif (quoteTextEl) {\n  let el = quoteTextEl;\n  for (let depth = 0; el && el !== article && depth < 9; depth += 1, el = el.parentElement) {\n    const rect = rectOf(el);\n    const innerLinks = Array.from(el.querySelectorAll('a[href]')).map((a) => ({\n      href: a.href || attr(a, 'href'),\n      text: textOf(a),\n      ariaLabel: attr(a, 'aria-label'),\n      role: attr(a, 'role'),\n      dataTestId: attr(a, 'data-testid'),\n      rect: rectOf(a),\n      source: `quote_ancestor_${depth}`,\n    }));\n    ancestorCandidates.push({\n      depth,\n      tagName: el.tagName,\n      role: attr(el, 'role'),\n      dataTestId: attr(el, 'data-testid'),\n      text: textOf(el),\n      rect,\n      links: innerLinks,\n      clickable: !!(el.closest('a[href]') || el.closest('[role=\"link\"]')),\n    });\n  }\n}\n\nconst nearbyStatusLinks = links.filter((link) => statusish(link.href) && (\n  intersects(link.rect, quoteTextRect) || intersects(link.rect, quoteTimeRect) ||\n  (quoteTextRect && containsPoint(link.rect, quoteTextRect.x + 8, quoteTextRect.y + 8))\n));\n\nreturn {\n  ownUrl,\n  tweetTexts,\n  times,\n  links,\n  statusLinks: links.filter((link) => statusish(link.href)),\n  nearbyStatusLinks,\n  ancestorCandidates,\n  quoteText: tweetTexts.length > 1 ? tweetTexts[1] : null,\n  quoteTime: times.length > 1 ? times[1] : null,\n};\n\"\"\"\n    return driver.execute_script(script, article) or {}\n\n\ndef _candidate_from_link(link: dict[str, Any], *, source: str, base_url: str, own_id: str | None) -> dict[str, Any] | None:\n    url = normalize_url(link.get(\"href\") or link.get(\"url\"), base_url=base_url)\n    status_id = status_id_from_url(url)\n    if not status_id or (own_id and status_id == own_id):\n        return None\n    return {\n        \"url\": url,\n        \"id\": status_id,\n        \"authorId\": author_from_status_url(url),\n        \"source\": source,\n        \"text\": link.get(\"text\") or \"\",\n        \"raw\": link,\n    }\n\n\ndef find_quote_card_destination(driver: Any, article: Any, *, base_url: str = \"https://x.com\") -> dict[str, Any]:\n    \"\"\"Find a destination status URL for the visible quote card inside one article.\"\"\"\n    snapshot = _snapshot_quote_area(driver, article)\n    own_url = normalize_url(snapshot.get(\"ownUrl\"), base_url=base_url)\n    own_id = status_id_from_url(own_url)\n\n    candidates: list[dict[str, Any]] = []\n    for link in snapshot.get(\"nearbyStatusLinks\") or []:\n        candidate = _candidate_from_link(link, source=\"near_quote_area\", base_url=base_url, own_id=own_id)\n        if candidate:\n            candidates.append(candidate)\n\n    for ancestor in snapshot.get(\"ancestorCandidates\") or []:\n        for link in ancestor.get(\"links\") or []:\n            candidate = _candidate_from_link(\n                link,\n                source=f\"{link.get('source') or 'quote_ancestor'}\",\n                base_url=base_url,\n                own_id=own_id,\n            )\n            if candidate:\n                candidates.append(candidate)\n\n    for link in snapshot.get(\"statusLinks\") or []:\n        candidate = _candidate_from_link(link, source=\"article_status_link\", base_url=base_url, own_id=own_id)\n        if candidate:\n            candidates.append(candidate)\n\n    candidates = _dedupe(candidates)\n    return {\n        \"ok\": bool(candidates),\n        \"url\": candidates[0][\"url\"] if candidates else None,\n        \"id\": candidates[0][\"id\"] if candidates else None,\n        \"authorId\": candidates[0].get(\"authorId\") if candidates else None,\n        \"candidates\": candidates,\n        \"quoteText\": snapshot.get(\"quoteText\"),\n        \"quoteTime\": snapshot.get(\"quoteTime\"),\n        \"raw\": {\n            \"ownUrl\": own_url,\n            \"ownId\": own_id,\n            \"statusLinkCount\": len(snapshot.get(\"statusLinks\") or []),\n            \"ancestorCount\": len(snapshot.get(\"ancestorCandidates\") or []),\n        },\n    }\n\n\ndef click_quote_card_and_capture_url(\n    driver: Any,\n    article: Any,\n    *,\n    timeout: float = 5.0,\n    restore: bool = True,\n) -> dict[str, Any]:\n    \"\"\"Optional fallback: click the quote-looking card and observe URL change.\"\"\"\n    start_url = driver.current_url\n    script = r\"\"\"\nconst article = arguments[0];\nconst tweetTexts = Array.from(article.querySelectorAll('[data-testid=\"tweetText\"]'));\nconst quoteText = tweetTexts.length > 1 ? tweetTexts[1] : null;\nif (!quoteText) return {ok:false, reason:'no_second_tweet_text'};\nlet el = quoteText;\nfor (let depth = 0; el && el !== article && depth < 9; depth += 1, el = el.parentElement) {\n  const roleLink = el.closest('[role=\"link\"]');\n  const anchor = el.closest('a[href]') || el.querySelector('a[href]');\n  const target = anchor || roleLink || el;\n  if (target) {\n    target.scrollIntoView({block:'center', inline:'center'});\n    const r = target.getBoundingClientRect();\n    target.click();\n    return {ok:true, clickedTag: target.tagName, role: target.getAttribute('role') || '', href: target.href || '', rect:{x:r.x,y:r.y,width:r.width,height:r.height}};\n  }\n}\nreturn {ok:false, reason:'no_click_target'};\n\"\"\"\n    click_result = driver.execute_script(script, article) or {}\n    if not click_result.get(\"ok\"):\n        return {\"ok\": False, \"reason\": click_result.get(\"reason\") or \"click_failed\", \"click\": click_result}\n\n    deadline = time.monotonic() + timeout\n    new_url = start_url\n    while time.monotonic() < deadline:\n        new_url = driver.current_url\n        if new_url != start_url and status_id_from_url(new_url):\n            break\n        time.sleep(0.25)\n\n    result = {\n        \"ok\": new_url != start_url and bool(status_id_from_url(new_url)),\n        \"url\": normalize_url(new_url),\n        \"id\": status_id_from_url(new_url),\n        \"authorId\": author_from_status_url(new_url),\n        \"startUrl\": start_url,\n        \"click\": click_result,\n    }\n    if restore and result[\"ok\"]:\n        driver.back()\n        time.sleep(0.75)\n    return result\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Find quote-card destination URLs in visible X tweet articles.\")\n    parser.add_argument(\"--url\", default=\"\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--article-index\", type=int, default=0, help=\"0-based visible tweet article index\")\n    parser.add_argument(\"--wait\", type=float, default=20.0)\n    parser.add_argument(\"--click-probe\", action=\"store_true\")\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n\n    from scripts.chrome_debug import get_driver\n    from selenium.webdriver.common.by import By\n\n    driver = get_driver(port=args.port, wait=args.wait)\n    if args.url:\n        log.info(\"quote_destination.navigate url=%s\", args.url)\n        driver.get(args.url)\n\n    deadline = time.monotonic() + args.wait\n    articles = []\n    while time.monotonic() < deadline:\n        articles = driver.find_elements(By.CSS_SELECTOR, \"article[data-testid='tweet']\")\n        if len(articles) > args.article_index:\n            break\n        time.sleep(0.5)\n\n    if len(articles) <= args.article_index:\n        print(json.dumps({\"ok\": False, \"error\": \"article_not_found\", \"articleCount\": len(articles)}, ensure_ascii=False, indent=2))\n        return 1\n\n    article = articles[args.article_index]\n    result = find_quote_card_destination(driver, article, base_url=driver.current_url or \"https://x.com\")\n    if not result.get(\"ok\") and args.click_probe:\n        click_probe = click_quote_card_and_capture_url(driver, article, timeout=args.wait)\n        result[\"clickProbe\"] = click_probe\n        if click_probe.get(\"ok\"):\n            result[\"ok\"] = True\n            result[\"url\"] = click_probe.get(\"url\")\n            result[\"id\"] = click_probe.get(\"id\")\n            result[\"authorId\"] = click_probe.get(\"authorId\")\n            result[\"source\"] = \"click_probe\"\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 2\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
