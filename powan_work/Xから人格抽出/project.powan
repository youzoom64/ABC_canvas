    {
      "id": "node-4937477ca8",
      "title": "YouTube動画保存ポワン",
      "body": "YouTube URLを受け取り、既存のC:\\project_root\\app_workspaces\\API\\scripts\\video_downloader.pyを使って動画ファイルを保存する臓器ポワン。字幕だけでは足りない場合や映像確認が必要な場合に、保存先、ファイル情報、動画ID、元URLを返す。字幕取得やフレーム抽出やDB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport re\nimport subprocess\nimport sys\nfrom collections.abc import Mapping\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\nfrom urllib.parse import parse_qs, urlparse\n\n\nAPI_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\")\nVIDEO_DOWNLOADER_SCRIPT = API_ROOT / \"scripts\" / \"video_downloader.py\"\nDEFAULT_OUTPUT_DIR = Path(\"data\") / \"x_media\" / \"youtube_videos\"\n\nURL_KEYS = (\"url\", \"youtube_url\", \"youtubeUrl\", \"source_url\", \"sourceUrl\", \"video_url\", \"videoUrl\", \"href\", \"expanded_url\", \"expandedUrl\", \"original_url\", \"originalUrl\")\nPOST_ID_KEYS = (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\")\nMEDIA_INDEX_KEYS = (\"media_index\", \"mediaIndex\", \"index\", \"ordinal\", \"position\")\nNESTED_KEYS = (\"youtube\", \"youtubeVideo\", \"youtube_video\", \"youtubeVideos\", \"youtube_videos\", \"videos\", \"video\", \"media\", \"items\", \"results\", \"attachments\", \"links\", \"urls\", \"cards\", \"card\", \"entities\")\nVIDEO_SUFFIXES = {\".mp4\", \".webm\", \".mkv\", \".mov\", \".m4v\", \".avi\"}\nYOUTUBE_ID_RE = re.compile(r\"^[A-Za-z0-9_-]{11}$\")\n\n\nclass YouTubeVideoSaveError(RuntimeError):\n    pass\n\ndef save_youtube_video(\n    video_input: Any = None,\n    *,\n    url: str = \"\",\n    output_dir: str | Path = DEFAULT_OUTPUT_DIR,\n    post_id: str = \"\",\n    media_index: int | None = None,\n) -> dict[str, Any]:\n    metadata: dict[str, Any] = {\n        \"sourceScript\": display_path(VIDEO_DOWNLOADER_SCRIPT),\n        \"sourceFunction\": \"scripts.video_downloader.download\",\n        \"outputDir\": display_path(resolve_output_dir(output_dir)),\n    }\n    original_url = url.strip() if isinstance(url, str) else \"\"\n    video_id = \"\"\n    try:\n        record = select_youtube_record(video_input, override_url=original_url)\n        original_url = first_youtube_url(record) or original_url\n        if not original_url:\n            raise YouTubeVideoSaveError(\"input did not contain a YouTube URL\")\n\n        resolved_post_id = post_id or first_text(record, POST_ID_KEYS)\n        resolved_media_index = media_index if media_index is not None else first_int(record, MEDIA_INDEX_KEYS)\n        canonical_url = canonical_youtube_url(original_url)\n        video_id = extract_youtube_video_id(canonical_url) or extract_youtube_video_id(original_url)\n        if not is_youtube_url(canonical_url):\n            raise YouTubeVideoSaveError(f\"not a YouTube URL: {original_url}\")\n        if not video_id:\n            raise YouTubeVideoSaveError(f\"could not extract YouTube video id: {original_url}\")\n\n        destination = resolve_output_dir(output_dir)\n        destination.mkdir(parents=True, exist_ok=True)\n        before = snapshot_files(destination)\n        started_at = datetime.now(timezone.utc).isoformat()\n\n        raw_path = call_existing_video_downloader(canonical_url, destination)\n        local_path = resolve_downloaded_path(raw_path, destination, before)\n        file_size = local_path.stat().st_size\n        digest = sha256_file(local_path)\n\n        metadata.update(\n            {\n                \"originalUrl\": original_url,\n                \"canonicalUrl\": canonical_url,\n                \"postId\": resolved_post_id,\n                \"post_id\": resolved_post_id,\n                \"mediaIndex\": resolved_media_index,\n                \"media_index\": resolved_media_index,\n                \"videoId\": video_id,\n                \"urlType\": \"youtube\",\n                \"returnedPath\": str(raw_path),\n                \"fileName\": local_path.name,\n                \"extension\": local_path.suffix.lstrip(\".\").lower(),\n                \"downloadStartedAt\": started_at,\n                \"downloadedAt\": datetime.now(timezone.utc).isoformat(),\n                \"subtitleDownloadDisabled\": True,\n            }\n        )\n        return build_result(\n            ok=True,\n            url=original_url,\n            video_id=video_id,\n            local_path=display_path(local_path),\n            byte_count=file_size,\n            sha256=digest,\n            metadata=metadata,\n            error=None,\n            post_id=resolved_post_id,\n            media_index=resolved_media_index,\n        )\n    except Exception as exc:\n        metadata.setdefault(\"originalUrl\", original_url)\n        metadata.setdefault(\"videoId\", video_id)\n        return build_result(\n            ok=False,\n            url=original_url,\n            video_id=video_id,\n            local_path=\"\",\n            byte_count=0,\n            sha256=\"\",\n            metadata=metadata,\n            error=str(exc) or exc.__class__.__name__,\n            post_id=post_id,\n            media_index=media_index,\n        )\n\ndef call_existing_video_downloader(url: str, destination: Path) -> Path:\n    python_path = api_python_path()\n    wrapper = r'''\nimport contextlib, json, os, sys\nfrom pathlib import Path\napi_root = Path(sys.argv[1])\nurl = sys.argv[2]\ndestination = Path(sys.argv[3])\nsys.path.insert(0, str(api_root))\nimport scripts.video_downloader as video_downloader\nif video_downloader.detect_url_type(url) != \"youtube\":\n    raise RuntimeError(f\"video_downloader detected non-youtube URL: {url}\")\n@contextlib.contextmanager\ndef video_only_ytdlp_options():\n    original = video_downloader.yt_dlp.YoutubeDL\n    def factory(options=None, *args, **kwargs):\n        clean = dict(options or {})\n        clean[\"writesubtitles\"] = False\n        clean[\"writeautomaticsub\"] = False\n        clean[\"skip_download\"] = False\n        clean.pop(\"subtitleslangs\", None)\n        clean.pop(\"subtitlesformat\", None)\n        return original(clean, *args, **kwargs)\n    video_downloader.yt_dlp.YoutubeDL = factory\n    try:\n        yield\n    finally:\n        video_downloader.yt_dlp.YoutubeDL = original\nos.chdir(api_root)\nwith video_only_ytdlp_options():\n    path = video_downloader.download(url, str(destination), convert_to_mp3=False)\nprint(json.dumps({\"path\": path}, ensure_ascii=False))\n'''\n    proc = subprocess.run(\n        [str(python_path), \"-c\", wrapper, str(API_ROOT), url, str(destination)],\n        cwd=str(API_ROOT),\n        capture_output=True,\n        text=True,\n        encoding=\"utf-8\",\n        errors=\"replace\",\n    )\n    if proc.returncode != 0:\n        detail = (proc.stderr or proc.stdout).strip()\n        raise YouTubeVideoSaveError(f\"video_downloader subprocess failed: {detail}\")\n    lines = [line for line in proc.stdout.splitlines() if line.strip()]\n    if not lines:\n        raise YouTubeVideoSaveError(\"video_downloader subprocess returned no output\")\n    try:\n        return Path(json.loads(lines[-1])[\"path\"])\n    except Exception as exc:\n        raise YouTubeVideoSaveError(f\"could not parse video_downloader output: {lines[-1]}\") from exc\n\ndef api_python_path() -> Path:\n    for candidate in (API_ROOT / \"venv\" / \"Scripts\" / \"python.exe\", API_ROOT / \".venv\" / \"Scripts\" / \"python.exe\"):\n        if candidate.exists():\n            return candidate\n    raise YouTubeVideoSaveError(\"API venv python was not found\")\n\ndef select_youtube_record(video_input: Any, *, override_url: str = \"\") -> dict[str, Any]:\n    if override_url:\n        base = dict(video_input) if isinstance(video_input, Mapping) else {}\n        return {**base, \"url\": override_url}\n    if video_input is None:\n        return {}\n    if isinstance(video_input, str):\n        return {\"url\": video_input}\n    found = find_youtube_record(video_input, inherited_post_id=\"\", inherited_media_index=None)\n    if found is None:\n        return dict(video_input) if isinstance(video_input, Mapping) else {}\n    return found\n\ndef find_youtube_record(\n    value: Any,\n    *,\n    inherited_post_id: str,\n    inherited_media_index: int | None,\n) -> dict[str, Any] | None:\n    if isinstance(value, str):\n        return {\"url\": value} if is_youtube_url(value) else None\n    if isinstance(value, list):\n        for item in value:\n            found = find_youtube_record(\n                item,\n                inherited_post_id=inherited_post_id,\n                inherited_media_index=inherited_media_index,\n            )\n            if found is not None:\n                return found\n        return None\n    if not isinstance(value, Mapping):\n        return None\n\n    record = dict(value)\n    local_post_id = first_text(record, POST_ID_KEYS) or inherited_post_id\n    local_media_index = first_int(record, MEDIA_INDEX_KEYS)\n    if local_media_index is None:\n        local_media_index = inherited_media_index\n\n    direct_url = first_youtube_url(record)\n    if direct_url:\n        return {\n            **record,\n            \"url\": direct_url,\n            \"post_id\": local_post_id,\n            \"postId\": local_post_id,\n            \"media_index\": local_media_index,\n            \"mediaIndex\": local_media_index,\n        }\n\n    for key in NESTED_KEYS:\n        if key not in record:\n            continue\n        found = find_youtube_record(\n            record[key],\n            inherited_post_id=local_post_id,\n            inherited_media_index=local_media_index,\n        )\n        if found is not None:\n            return found\n\n    for item in record.values():\n        if isinstance(item, (Mapping, list)):\n            found = find_youtube_record(\n                item,\n                inherited_post_id=local_post_id,\n                inherited_media_index=local_media_index,\n            )\n            if found is not None:\n                return found\n    return None\n\ndef first_youtube_url(record: Mapping[str, Any]) -> str:\n    for key in URL_KEYS:\n        candidate = first_youtube_url_value(record.get(key))\n        if candidate:\n            return candidate\n    for key in NESTED_KEYS:\n        candidate = first_youtube_url_value(record.get(key))\n        if candidate:\n            return candidate\n    return \"\"\n\ndef first_youtube_url_value(value: Any) -> str:\n    if isinstance(value, str):\n        clean = value.strip()\n        return clean if is_youtube_url(clean) else \"\"\n    if isinstance(value, list):\n        for item in value:\n            candidate = first_youtube_url_value(item)\n            if candidate:\n                return candidate\n        return \"\"\n    if isinstance(value, Mapping):\n        for key in URL_KEYS:\n            candidate = first_youtube_url_value(value.get(key))\n            if candidate:\n                return candidate\n        for item in value.values():\n            if isinstance(item, (str, list, Mapping)):\n                candidate = first_youtube_url_value(item)\n                if candidate:\n                    return candidate\n    return \"\"\n\ndef canonical_youtube_url(url: str) -> str:\n    clean = normalize_url_text(url)\n    video_id = extract_youtube_video_id(clean)\n    if video_id:\n        return f\"https://www.youtube.com/watch?v={video_id}\"\n    return clean\n\ndef normalize_url_text(url: str) -> str:\n    clean = str(url or \"\").strip()\n    if clean.startswith((\"youtube.com/\", \"www.youtube.com/\", \"m.youtube.com/\", \"youtu.be/\")):\n        return f\"https://{clean}\"\n    return clean\n\ndef is_youtube_url(url: str) -> bool:\n    clean = normalize_url_text(url)\n    try:\n        host = urlparse(clean).netloc.lower()\n    except ValueError:\n        return False\n    host = host.removeprefix(\"www.\").removeprefix(\"m.\")\n    return host == \"youtu.be\" or host.endswith(\"youtube.com\") or host.endswith(\"youtube-nocookie.com\")\n\ndef extract_youtube_video_id(url: str) -> str:\n    clean = normalize_url_text(url)\n    try:\n        parsed = urlparse(clean)\n    except ValueError:\n        return \"\"\n    host = parsed.netloc.lower().removeprefix(\"www.\").removeprefix(\"m.\")\n    path_parts = [part for part in parsed.path.split(\"/\") if part]\n\n    if host == \"youtu.be\" and path_parts:\n        return clean_video_id(path_parts[0])\n\n    query_id = parse_qs(parsed.query).get(\"v\", [\"\"])[0]\n    if query_id:\n        return clean_video_id(query_id)\n\n    if host.endswith(\"youtube.com\") or host.endswith(\"youtube-nocookie.com\"):\n        for marker in (\"shorts\", \"embed\", \"live\", \"v\"):\n            if marker in path_parts:\n                index = path_parts.index(marker)\n                if index + 1 < len(path_parts):\n                    return clean_video_id(path_parts[index + 1])\n    return \"\"\n\ndef clean_video_id(value: str) -> str:\n    candidate = str(value or \"\").split(\"?\")[0].split(\"&\")[0].strip()\n    return candidate if YOUTUBE_ID_RE.match(candidate) else \"\"\n\ndef resolve_output_dir(output_dir: str | Path) -> Path:\n    path = Path(output_dir).expanduser()\n    if not path.is_absolute():\n        path = (Path.cwd() / path).resolve()\n    return path\n\ndef snapshot_files(directory: Path) -> dict[Path, tuple[int, int]]:\n    if not directory.exists():\n        return {}\n    snapshot: dict[Path, tuple[int, int]] = {}\n    for path in directory.rglob(\"*\"):\n        if not path.is_file():\n            continue\n        stat = path.stat()\n        snapshot[path.resolve()] = (stat.st_size, stat.st_mtime_ns)\n    return snapshot\n\ndef resolve_downloaded_path(raw_path: Path, output_dir: Path, before: dict[Path, tuple[int, int]]) -> Path:\n    candidates = [raw_path]\n    if raw_path.suffix.lower() != \".mp4\":\n        candidates.append(raw_path.with_suffix(\".mp4\"))\n    for candidate in candidates:\n        candidate = candidate if candidate.is_absolute() else (API_ROOT / candidate)\n        if candidate.exists() and candidate.is_file():\n            return candidate.resolve()\n\n    changed: list[Path] = []\n    for path in output_dir.rglob(\"*\"):\n        if not path.is_file() or path.suffix.lower() not in VIDEO_SUFFIXES:\n            continue\n        resolved = path.resolve()\n        stat = path.stat()\n        current = (stat.st_size, stat.st_mtime_ns)\n        if before.get(resolved) != current:\n            changed.append(resolved)\n    if changed:\n        changed.sort(key=lambda item: item.stat().st_mtime_ns, reverse=True)\n        return changed[0]\n    raise YouTubeVideoSaveError(f\"download finished but no video file was found under {output_dir}\")\n\ndef sha256_file(path: Path) -> str:\n    hasher = hashlib.sha256()\n    with path.open(\"rb\") as handle:\n        for chunk in iter(lambda: handle.read(1024 * 1024), b\"\"):\n            hasher.update(chunk)\n    return hasher.hexdigest()\n\ndef first_text(record: Mapping[str, Any], keys: tuple[str, ...]) -> str:\n    for key in keys:\n        value = record.get(key)\n        if value is not None:\n            text = str(value).strip()\n            if text:\n                return text\n    return \"\"\n\ndef first_int(record: Mapping[str, Any], keys: tuple[str, ...]) -> int | None:\n    for key in keys:\n        value = record.get(key)\n        parsed = to_int(value)\n        if parsed is not None:\n            return parsed\n    return None\n\ndef to_int(value: Any) -> int | None:\n    if value is None or value == \"\":\n        return None\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return None\n\ndef build_result(*, ok: bool, url: str, video_id: str, local_path: str, byte_count: int, sha256: str, metadata: dict[str, Any], error: str | None, post_id: str, media_index: int | None) -> dict[str, Any]:\n    return {\n        \"ok\": ok,\n        \"url\": url,\n        \"videoId\": video_id,\n        \"localPath\": local_path,\n        \"bytes\": byte_count,\n        \"sha256\": sha256,\n        \"metadata\": metadata,\n        \"error\": error,\n        \"postId\": post_id,\n        \"post_id\": post_id,\n        \"mediaIndex\": media_index,\n        \"media_index\": media_index,\n    }\n\ndef display_path(path: Path) -> str:\n    try:\n        return str(Path(path).resolve())\n    except OSError:\n        return str(path)\n\ndef load_json_arg(value: str) -> Any:\n    if not value:\n        return {}\n    if value == \"-\":\n        raw = sys.stdin.read()\n        return json.loads(raw) if raw.strip() else {}\n    candidate = Path(value)\n    if candidate.exists():\n        return json.loads(candidate.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(\n        description=\"Save one YouTube video using the existing API video_downloader.py script.\"\n    )\n    parser.add_argument(\"--url\", default=\"\", help=\"YouTube URL. Overrides any URL in --input-json.\")\n    parser.add_argument(\"--input-json\", default=\"\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--out-dir\", default=str(DEFAULT_OUTPUT_DIR))\n    parser.add_argument(\"--post-id\", default=\"\")\n    parser.add_argument(\"--media-index\", type=int, default=None)\n    parser.add_argument(\"--indent\", type=int, default=2)\n    args = parser.parse_args(argv)\n\n    payload = load_json_arg(args.input_json)\n    result = save_youtube_video(\n        payload,\n        url=args.url,\n        output_dir=args.out_dir,\n        post_id=args.post_id,\n        media_index=args.media_index,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
