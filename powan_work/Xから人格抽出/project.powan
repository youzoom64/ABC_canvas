    {
      "id": "node-e6277e3b72",
      "title": "テストGUIポワン",
      "body": "X投稿収集テストをユーザーが操作するための臓器ポワン。投稿URL入力、既存DB投稿選択、テスト種別選択、実行ボタン、判定結果、証拠、ログ、正解ラベル修正、再テスト実行を画面として提供する。最初は単発投稿と既存DB投稿を選んで結果を見られることを重視する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse, json, re, sqlite3, uuid\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\ntry:\n    import tkinter as tk\n    from tkinter import filedialog, ttk\nexcept Exception:  # pragma: no cover\n    tk = None\n    ttk = None\n    filedialog = None\n\nSCHEMA_INPUT = \"x-post-test-input/v1\"\nSCHEMA_RESULT = \"x-post-test-result/v1\"\nDEFAULT_PROJECT_FILE = \"project.powan\"\nDEFAULT_STATE_DIR = \".powan_test_gui\"\nRESULT_STORE_PATH = \"x_post_test_results.json\"\nLABEL_STORE_PATH = \"x_post_test_expected_labels.json\"\nTEST_TYPES = [\"post_reading\", \"origin_judgement\", \"terminal_judgement\", \"content_classification\", \"collection_connectivity\", \"material_check\"]\nFORBIDDEN_ACTIONS = [\"selenium_execution\", \"deep_reply_quote_repost_trace\", \"external_material_fetch\", \"image_or_video_reading\", \"youtube_or_news_download\", \"production_x_archive_write\"]\nSTATUS_RE = re.compile(r\"/(?:i/web/)?status/(\\d+)\")\nURL_RE = re.compile(r\"https?://[^\\s)\\]}>\\\"']+\")\nYOUTUBE_RE = re.compile(r\"(?:youtube\\.com|youtu\\.be)\", re.IGNORECASE)\nNEWS_RE = re.compile(r\"/(?:news|article|articles|story|press|world|business|politics|economy|tech)(?:/|$)\", re.IGNORECASE)\n\ndef now_iso() -> str:\n    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()\n\ndef pretty(data: Any) -> str:\n    return json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True)\n\ndef safe_json_loads(value: str) -> Any:\n    try:\n        return json.loads(value) if value else None\n    except json.JSONDecodeError:\n        return {\"_rawText\": value, \"_parseError\": \"invalid_json\"}\n\ndef post_id_from_url(url: str) -> str:\n    match = STATUS_RE.search(url or \"\")\n    return match.group(1) if match else \"\"\n\ndef compact_text(text: str, limit: int = 90) -> str:\n    cleaned = \" \".join(str(text or \"\").split())\n    return cleaned if len(cleaned) <= limit else cleaned[: limit - 1] + \"...\"\n\ndef post_to_target(post: dict[str, str], db_path: str) -> dict[str, Any]:\n    return {\n        \"postId\": post.get(\"id\", \"\"), \"postUrl\": post.get(\"url\", \"\"), \"account\": post.get(\"account\", \"\"),\n        \"type\": post.get(\"type\", \"\"), \"authorHandle\": post.get(\"author_handle\", \"\"), \"authorName\": post.get(\"author_name\", \"\"),\n        \"createdAt\": post.get(\"created_at\", \"\"), \"text\": post.get(\"text\", \"\"),\n        \"rawJson\": safe_json_loads(post.get(\"raw_json\", \"\")), \"dbPath\": db_path,\n    }\n\n\nclass JsonContractStore:\n    def __init__(self, project_file: Path = Path(DEFAULT_PROJECT_FILE), result_store: str = RESULT_STORE_PATH, label_store: str = LABEL_STORE_PATH) -> None:\n        self.project_file = project_file\n        self.result_store = result_store\n        self.label_store = label_store\n        self.result_run = self._load_powan_run(\"テスト結果保存・比較ポワン\")\n        self.label_run = self._load_powan_run(\"正解ラベル管理ポワン\")\n\n    def _load_powan_run(self, title: str):\n        data = json.loads(self.project_file.read_text(encoding=\"utf-8\"))\n        node = next((item for item in data.get(\"nodes\", []) if item.get(\"title\") == title), None)\n        code = (node or {}).get(\"code\") or \"\"\n        if not code:\n            raise RuntimeError(f\"{title} has no code\")\n        namespace = {\"__name__\": f\"powan_contract_{title}\", \"__file__\": str(self.project_file)}\n        exec(compile(code, f\"<{title}>\", \"exec\"), namespace)\n        if not callable(namespace.get(\"run\")):\n            raise RuntimeError(f\"{title} has no run(payload) contract\")\n        return namespace[\"run\"]\n\n    def common_input(self, test_input: dict[str, Any]) -> dict[str, Any]:\n        target = test_input.get(\"target\") or {}\n        return {\n            \"source_type\": \"x_post\",\n            \"target_kind\": test_input.get(\"testType\", \"\"),\n            \"canonical_url\": target.get(\"postUrl\", \"\"),\n            \"post_id\": target.get(\"postId\") or post_id_from_url(str(target.get(\"postUrl\") or \"\")),\n            \"run_id\": test_input.get(\"runId\", \"\"),\n            \"needs_browser\": False,\n            \"warnings\": [],\n        }\n\n    def input_identity(self, test_input: dict[str, Any]) -> dict[str, Any]:\n        common = self.common_input(test_input)\n        normalized = self.result_run({\"action\": \"normalize-input\", \"test_input\": common, \"store_path\": self.result_store})\n        if not normalized.get(\"ok\"):\n            raise RuntimeError(f\"normalize-input failed: {normalized}\")\n        return {\"common_input\": normalized[\"input\"], \"input_key\": normalized[\"input_key\"], \"input_hash\": normalized[\"input_hash\"]}\n\n    def save_result(self, test_input: dict[str, Any], result: dict[str, Any]) -> dict[str, Any]:\n        identity = self.input_identity(test_input)\n        saved = self.result_run({\n            \"action\": \"save\",\n            \"store_path\": self.result_store,\n            \"test_id\": identity[\"input_key\"],\n            \"test_type\": test_input.get(\"testType\", \"\"),\n            \"test_input\": identity[\"common_input\"],\n            \"result\": result,\n            \"evidence\": result.get(\"evidence\", []),\n            \"logs\": result.get(\"logs\", []),\n            \"success\": result.get(\"status\") == \"pass\",\n        })\n        return {\"identity\": identity, \"saved\": saved}\n\n    def load_label(self, test_input: dict[str, Any]) -> dict[str, str]:\n        identity = self.input_identity(test_input)\n        loaded = self.label_run({\"action\": \"get\", \"store_path\": self.label_store, \"test_id\": identity[\"input_key\"], \"test_input\": identity[\"common_input\"]})\n        record = loaded.get(\"label\") or {}\n        expected = record.get(\"expected\") if isinstance(record, dict) else {}\n        decision = expected.get(\"decision\") if isinstance(expected, dict) else {}\n        return {\n            \"expectedStatus\": str((expected or {}).get(\"status\") or \"\"),\n            \"expectedOriginType\": str((decision or {}).get(\"originType\") or \"\"),\n            \"expectedTerminalState\": str((decision or {}).get(\"terminalState\") or \"\"),\n            \"expectedContentType\": str((decision or {}).get(\"contentType\") or \"\"),\n            \"note\": str(record.get(\"memo\") or \"\"),\n        }\n\n    def save_label(self, test_input: dict[str, Any], fields: dict[str, str], auto_result: dict[str, Any] | None = None) -> dict[str, Any]:\n        identity = self.input_identity(test_input)\n        expected: dict[str, Any] = {}\n        if fields.get(\"expectedStatus\"):\n            expected[\"status\"] = fields[\"expectedStatus\"]\n        decision = {dst: fields[src] for src, dst in [(\"expectedOriginType\", \"originType\"), (\"expectedTerminalState\", \"terminalState\"), (\"expectedContentType\", \"contentType\")] if fields.get(src)}\n        if decision:\n            expected[\"decision\"] = decision\n        return self.label_run({\n            \"action\": \"upsert\",\n            \"store_path\": self.label_store,\n            \"test_id\": identity[\"input_key\"],\n            \"test_input\": identity[\"common_input\"],\n            \"expected\": expected,\n            \"auto_result_snapshot\": auto_result or {},\n            \"judge\": \"human\",\n            \"memo\": fields.get(\"note\", \"\"),\n            \"reason\": \"saved from test GUI\",\n        })\n\n    def compare_label(self, test_input: dict[str, Any], result: dict[str, Any]) -> dict[str, Any]:\n        identity = self.input_identity(test_input)\n        return self.label_run({\n            \"action\": \"compare\",\n            \"store_path\": self.label_store,\n            \"test_id\": identity[\"input_key\"],\n            \"test_input\": identity[\"common_input\"],\n            \"auto_result\": result,\n        })\n\n    def latest_results(self, limit: int = 20) -> list[dict[str, Any]]:\n        listed = self.result_run({\"action\": \"list\", \"store_path\": self.result_store, \"limit\": limit})\n        return listed.get(\"results\", []) if listed.get(\"ok\") else [listed]\n\n\nclass XArchiveReader:\n    def __init__(self, db_path: Path) -> None:\n        self.db_path = db_path\n\n    def _connect_ro(self) -> sqlite3.Connection:\n        if not self.db_path.exists():\n            raise FileNotFoundError(str(self.db_path))\n        return sqlite3.connect(self.db_path.resolve().as_uri() + \"?mode=ro\", uri=True)\n\n    def list_posts(self, limit: int = 200) -> list[dict[str, str]]:\n        wanted = [\"id\", \"account\", \"type\", \"author_handle\", \"author_name\", \"url\", \"created_at\", \"text\", \"raw_json\"]\n        with self._connect_ro() as con:\n            columns = {row[1] for row in con.execute(\"PRAGMA table_info(posts)\").fetchall()}\n            if not columns:\n                raise RuntimeError(\"posts table was not found\")\n            select = \", \".join(col if col in columns else \"'' AS \" + col for col in wanted)\n            order = \"collected_at DESC\" if \"collected_at\" in columns else \"id DESC\"\n            rows = con.execute(f\"SELECT {select} FROM posts ORDER BY {order} LIMIT ?\", (limit,)).fetchall()\n        return [{key: str(value or \"\") for key, value in zip(wanted, row)} for row in rows]\n\n\nclass FirstStageRunner:\n    def run(self, test_input: dict[str, Any]) -> dict[str, Any]:\n        logs = [\"first-stage runner: Selenium and external fetches are disabled\"]\n        evidence: list[dict[str, Any]] = []\n        target = test_input.get(\"target\") or {}\n        test_type = test_input.get(\"testType\") or \"post_reading\"\n        text = str(target.get(\"text\") or \"\")\n        url = str(target.get(\"postUrl\") or \"\")\n        post_id = str(target.get(\"postId\") or post_id_from_url(url) or \"\")\n        raw_json = target.get(\"rawJson\")\n        raw_text = pretty(raw_json) if raw_json not in (None, \"\") else \"\"\n        post_type = str(target.get(\"type\") or \"unknown\").lower()\n        links = URL_RE.findall(\"\\n\".join([text, url, raw_text]))\n        has_media = any(token in raw_text.lower() for token in [\"photo\", \"image\", \"media_url\", \"video\", \"thumbnail\"])\n        if not url and not post_id:\n            return self._result(test_input, \"fail\", False, {\"error\": \"missing_target\"}, evidence, logs + [\"No URL or DB post id was provided.\"])\n        evidence.append({\"kind\": \"target\", \"postId\": post_id, \"url\": url, \"type\": post_type})\n        if text:\n            evidence.append({\"kind\": \"text\", \"preview\": compact_text(text, 180), \"length\": len(text)})\n        if links:\n            evidence.append({\"kind\": \"links\", \"count\": len(links), \"items\": links[:8]})\n        if test_type == \"collection_connectivity\":\n            decision = {\"connectivity\": \"not_executed\", \"reason\": \"browser access is disabled in first stage\"}\n            return self._result(test_input, \"needs_browser\", True, decision, evidence, logs)\n        if test_type == \"material_check\":\n            decision = {\"materialCheck\": \"stub\", \"reason\": \"external material acquisition is outside first stage\"}\n            return self._result(test_input, \"needs_browser\", True, decision, evidence, logs)\n        if test_type == \"post_reading\":\n            decision = {\"readable\": bool(url or text or raw_json), \"postId\": post_id, \"hasText\": bool(text), \"hasRawJson\": raw_json not in (None, \"\"), \"hasLinks\": bool(links)}\n            return self._result(test_input, \"pass\" if decision[\"readable\"] else \"fail\", False, decision, evidence, logs)\n        if test_type == \"origin_judgement\":\n            origin = self._origin_from_local(post_type, raw_text, text)\n            needs_browser = origin in {\"reply\", \"quote\", \"repost\", \"unknown\"}\n            decision = {\"originType\": origin, \"confidence\": 0.65 if origin != \"unknown\" else 0.2, \"phase\": \"local_hint_only\", \"reason\": \"deep relation tracing is disabled\"}\n            return self._result(test_input, \"needs_browser\" if needs_browser else \"pass\", needs_browser, decision, evidence, logs)\n        if test_type == \"terminal_judgement\":\n            terminal = \"unknown\" if post_type in {\"reply\", \"quote\", \"repost\"} else \"terminal_candidate\"\n            return self._result(test_input, \"needs_browser\" if terminal == \"unknown\" else \"pass\", terminal == \"unknown\", {\"terminalState\": terminal, \"phase\": \"local_hint_only\"}, evidence, logs)\n        if test_type == \"content_classification\":\n            return self._result(test_input, \"pass\", False, {\"contentType\": self._content_from_local(text, raw_text, links, has_media), \"phase\": \"local_metadata_only\"}, evidence, logs)\n        return self._result(test_input, \"fail\", False, {\"error\": \"unknown_test_type\", \"testType\": test_type}, evidence, logs)\n\n    def _result(self, test_input: dict[str, Any], status: str, needs_browser: bool, decision: dict[str, Any], evidence: list[dict[str, Any]], logs: list[str]) -> dict[str, Any]:\n        summary = \"第一段階では実行禁止のブラウザ/外部取得が必要なのでneeds_browserとして表示しました。\"\n        if not needs_browser:\n            summary = \"第一段階のローカル情報だけで判定しました。\" if status == \"pass\" else \"入力またはローカル判定で失敗しました。\"\n        return {\n            \"schema\": SCHEMA_RESULT,\n            \"runId\": str(uuid.uuid4()),\n            \"createdAt\": now_iso(),\n            \"status\": status,\n            \"needs_browser\": bool(needs_browser),\n            \"testType\": test_input.get(\"testType\", \"\"),\n            \"summary\": summary,\n            \"decision\": decision,\n            \"evidence\": evidence,\n            \"logs\": logs,\n            \"forbiddenActionsSkipped\": FORBIDDEN_ACTIONS,\n            \"input\": test_input,\n        }\n\n    @staticmethod\n    def _origin_from_local(post_type: str, raw_text: str, text: str) -> str:\n        if post_type in {\"reply\", \"quote\", \"repost\", \"post\"}:\n            return \"standalone\" if post_type == \"post\" else post_type\n        haystack = \"\\n\".join([raw_text.lower(), text.lower()])\n        if \"reply\" in haystack or \"in_reply\" in haystack:\n            return \"reply\"\n        if \"quote\" in haystack or \"quoted\" in haystack:\n            return \"quote\"\n        if \"repost\" in haystack or \"retweeted\" in haystack:\n            return \"repost\"\n        return \"unknown\"\n\n    @staticmethod\n    def _content_from_local(text: str, raw_text: str, links: list[str], has_media: bool) -> str:\n        if YOUTUBE_RE.search(\"\\n\".join(links)):\n            return \"youtube\"\n        if any(NEWS_RE.search(link) for link in links):\n            return \"news_article\"\n        if \"video\" in raw_text.lower():\n            return \"video\"\n        if has_media:\n            return \"image\"\n        if links:\n            return \"external_link\"\n        return \"text_only\" if text else \"unavailable\"\n\n\ndef build_input_from_url(url: str, test_type: str, run_id: str = \"\") -> dict[str, Any]:\n    clean_url = url.strip()\n    return {\n        \"schema\": SCHEMA_INPUT, \"source\": \"url\", \"testType\": test_type, \"runId\": run_id.strip(),\n        \"target\": {\"postUrl\": clean_url, \"postId\": post_id_from_url(clean_url)},\n        \"options\": {\"allowSelenium\": False, \"allowExternalFetch\": False, \"phase\": \"first_stage\"},\n    }\n\n\ndef build_input_from_post(post: dict[str, str], db_path: str, test_type: str, run_id: str = \"\") -> dict[str, Any]:\n    return {\n        \"schema\": SCHEMA_INPUT, \"source\": \"db_post\", \"testType\": test_type, \"runId\": run_id.strip(),\n        \"target\": post_to_target(post, db_path),\n        \"options\": {\"allowSelenium\": False, \"allowExternalFetch\": False, \"phase\": \"first_stage\"},\n    }\n\n\nclass TestGuiApp:\n    def __init__(self, root: tk.Tk, store: JsonContractStore, db_path: str = \"\") -> None:\n        self.root, self.store, self.runner = root, store, FirstStageRunner()\n        self.posts: list[dict[str, str]] = []\n        self.last_input: dict[str, Any] | None = None\n        self.last_result: dict[str, Any] | None = None\n        self.db_path_var = tk.StringVar(value=db_path)\n        self.url_var = tk.StringVar()\n        self.run_id_var = tk.StringVar()\n        self.test_type_var = tk.StringVar(value=TEST_TYPES[0])\n        self.status_var = tk.StringVar(value=\"準備できています\")\n        self.label_vars = {key: tk.StringVar() for key in [\"expectedStatus\", \"expectedOriginType\", \"expectedTerminalState\", \"expectedContentType\", \"note\"]}\n        self._build()\n        if db_path:\n            self.load_db_posts()\n\n    def _build(self) -> None:\n        self.root.title(\"X投稿収集テストGUIポワン\")\n        self.root.geometry(\"1120x760\")\n        main = ttk.Frame(self.root, padding=10)\n        main.pack(fill=\"both\", expand=True)\n        for col, weight in [(0, 1), (1, 2)]:\n            main.columnconfigure(col, weight=weight)\n        main.rowconfigure(3, weight=1)\n        db_row = ttk.Frame(main)\n        db_row.grid(row=0, column=0, columnspan=2, sticky=\"ew\", pady=(0, 8))\n        db_row.columnconfigure(1, weight=1)\n        ttk.Label(db_row, text=\"x_archive.db 読取\").grid(row=0, column=0, padx=(0, 6))\n        ttk.Entry(db_row, textvariable=self.db_path_var).grid(row=0, column=1, sticky=\"ew\")\n        ttk.Button(db_row, text=\"選択\", command=self.choose_db).grid(row=0, column=2, padx=4)\n        ttk.Button(db_row, text=\"読込\", command=self.load_db_posts).grid(row=0, column=3)\n        self._build_input_row(main)\n        self._build_post_tree(main)\n        self._build_label_box(main)\n        notebook = ttk.Notebook(main)\n        notebook.grid(row=3, column=0, columnspan=2, sticky=\"nsew\", pady=(8, 0))\n        self.result_text = self._add_text_tab(notebook, \"判定結果\")\n        self.evidence_text = self._add_text_tab(notebook, \"証拠\")\n        self.log_text = self._add_text_tab(notebook, \"ログ\")\n        self.history_text = self._add_text_tab(notebook, \"保存履歴\")\n        ttk.Label(main, textvariable=self.status_var).grid(row=4, column=0, columnspan=2, sticky=\"ew\", pady=(6, 0))\n        self.refresh_history()\n\n    def _build_input_row(self, main: ttk.Frame) -> None:\n        row = ttk.Frame(main)\n        row.grid(row=1, column=0, columnspan=2, sticky=\"ew\", pady=(0, 8))\n        row.columnconfigure(1, weight=1)\n        ttk.Label(row, text=\"投稿URL\").grid(row=0, column=0, padx=(0, 6))\n        ttk.Entry(row, textvariable=self.url_var).grid(row=0, column=1, sticky=\"ew\")\n        ttk.Label(row, text=\"run_id\").grid(row=0, column=2, padx=(8, 6))\n        ttk.Entry(row, width=18, textvariable=self.run_id_var).grid(row=0, column=3)\n        ttk.Label(row, text=\"種別\").grid(row=0, column=4, padx=(8, 6))\n        ttk.Combobox(row, width=24, values=TEST_TYPES, textvariable=self.test_type_var, state=\"readonly\").grid(row=0, column=5)\n        for col, (text, command) in enumerate([(\"実行\", self.run_test), (\"再テスト\", self.retest), (\"保存\", self.save_current_result)], start=6):\n            ttk.Button(row, text=text, command=command).grid(row=0, column=col, padx=(8 if col == 6 else 4, 0))\n\n    def _build_post_tree(self, main: ttk.Frame) -> None:\n        self.tree = ttk.Treeview(main, columns=(\"id\", \"account\", \"type\", \"text\"), show=\"headings\", height=10)\n        for col, width in [(\"id\", 150), (\"account\", 110), (\"type\", 70), (\"text\", 420)]:\n            self.tree.heading(col, text=col)\n            self.tree.column(col, width=width, anchor=\"w\")\n        self.tree.grid(row=2, column=0, sticky=\"nsew\", padx=(0, 8))\n        self.tree.bind(\"<<TreeviewSelect>>\", lambda _event: self.on_target_changed())\n\n    def _build_label_box(self, main: ttk.Frame) -> None:\n        box = ttk.LabelFrame(main, text=\"正解ラベル\")\n        box.grid(row=2, column=1, sticky=\"nsew\")\n        fields = [(\"expectedStatus\", \"期待status\"), (\"expectedOriginType\", \"期待出どころ\"), (\"expectedTerminalState\", \"期待終端\"), (\"expectedContentType\", \"期待内容\"), (\"note\", \"メモ\")]\n        for idx, (key, caption) in enumerate(fields):\n            ttk.Label(box, text=caption).grid(row=idx, column=0, sticky=\"w\", padx=6, pady=3)\n            ttk.Entry(box, textvariable=self.label_vars[key]).grid(row=idx, column=1, sticky=\"ew\", padx=6, pady=3)\n        box.columnconfigure(1, weight=1)\n        ttk.Button(box, text=\"正解ラベル保存\", command=self.save_label).grid(row=5, column=0, columnspan=2, sticky=\"ew\", padx=6, pady=6)\n\n    def _add_text_tab(self, notebook: ttk.Notebook, title: str) -> tk.Text:\n        frame = ttk.Frame(notebook)\n        frame.rowconfigure(0, weight=1)\n        frame.columnconfigure(0, weight=1)\n        text = tk.Text(frame, wrap=\"word\", height=14)\n        scroll = ttk.Scrollbar(frame, orient=\"vertical\", command=text.yview)\n        text.configure(yscrollcommand=scroll.set)\n        text.grid(row=0, column=0, sticky=\"nsew\")\n        scroll.grid(row=0, column=1, sticky=\"ns\")\n        notebook.add(frame, text=title)\n        return text\n\n    def choose_db(self) -> None:\n        path = filedialog.askopenfilename(title=\"x_archive.dbを選択\", filetypes=[(\"SQLite DB\", \"*.db\"), (\"All files\", \"*.*\")])\n        if path:\n            self.db_path_var.set(path)\n\n    def load_db_posts(self) -> None:\n        try:\n            self.posts = XArchiveReader(Path(self.db_path_var.get())).list_posts()\n        except Exception as exc:\n            self.status_var.set(f\"DB読込失敗: {exc}\")\n            return\n        self.tree.delete(*self.tree.get_children())\n        for index, post in enumerate(self.posts):\n            self.tree.insert(\"\", \"end\", iid=str(index), values=(post[\"id\"], post[\"account\"], post[\"type\"], compact_text(post[\"text\"])))\n        self.status_var.set(f\"DB候補を{len(self.posts)}件読みました（読み取り専用）\")\n        self.on_target_changed()\n\n    def selected_post(self) -> dict[str, str] | None:\n        selected = self.tree.selection()\n        return self.posts[int(selected[0])] if selected else None\n\n    def current_input(self) -> dict[str, Any]:\n        post = self.selected_post()\n        if post:\n            return build_input_from_post(post, self.db_path_var.get(), self.test_type_var.get(), self.run_id_var.get())\n        return build_input_from_url(self.url_var.get(), self.test_type_var.get(), self.run_id_var.get())\n\n    def on_target_changed(self) -> None:\n        test_input = self.current_input()\n        label = self.store.load_label(test_input)\n        for key, var in self.label_vars.items():\n            var.set(str(label.get(key) or \"\"))\n\n    def current_label(self) -> dict[str, Any]:\n        return {key: var.get().strip() for key, var in self.label_vars.items() if var.get().strip()}\n\n    def _run_and_show(self, test_input: dict[str, Any], label_prefix: str) -> None:\n        self.last_input = test_input\n        result = self.runner.run(test_input)\n        saved = self.store.save_result(test_input, result)\n        comparison = self.store.compare_label(test_input, result)\n        result[\"labelComparison\"] = comparison.get(\"comparison\", comparison)\n        result[\"targetKey\"] = saved[\"identity\"][\"input_key\"]\n        result[\"inputHash\"] = saved[\"identity\"][\"input_hash\"]\n        result[\"recordId\"] = ((saved.get(\"saved\") or {}).get(\"result_record\") or {}).get(\"record_id\", \"\")\n        self.last_result = result\n        self._show_json(self.result_text, result)\n        self._show_json(self.evidence_text, result.get(\"evidence\", []))\n        self._show_json(self.log_text, {\"logs\": result.get(\"logs\", []), \"labelComparison\": result[\"labelComparison\"], \"saveResult\": saved.get(\"saved\")})\n        self.status_var.set(f\"{label_prefix}: {result['status']} / runId={result['runId']}\")\n        self.refresh_history()\n\n    def run_test(self) -> None:\n        self._run_and_show(self.current_input(), \"実行完了\")\n\n    def retest(self) -> None:\n        self._run_and_show(self.last_input or self.current_input(), \"再テスト完了\")\n\n    def save_current_result(self) -> None:\n        if not self.last_input or not self.last_result:\n            self.status_var.set(\"まだ保存できる結果がありません\")\n            return\n        self.store.save_result(self.last_input, self.last_result)\n        self.status_var.set(f\"結果を保存しました: {self.last_result['runId']}\")\n        self.refresh_history()\n\n    def save_label(self) -> None:\n        test_input = self.current_input()\n        saved = self.store.save_label(test_input, self.current_label(), self.last_result)\n        key = saved.get(\"target_key\", \"\")\n        self.status_var.set(f\"正解ラベルを保存しました: {key}\")\n        if self.last_result:\n            comparison = self.store.compare_label(test_input, self.last_result)\n            self.last_result[\"labelComparison\"] = comparison.get(\"comparison\", comparison)\n            self._show_json(self.log_text, {\"labelComparison\": self.last_result[\"labelComparison\"], \"labelSave\": saved})\n\n    def refresh_history(self) -> None:\n        self._show_json(self.history_text, self.store.latest_results())\n\n    @staticmethod\n    def _show_json(widget: tk.Text, data: Any) -> None:\n        widget.delete(\"1.0\", \"end\")\n        widget.insert(\"1.0\", pretty(data))\n\n\ndef run_cli(args: argparse.Namespace, store: JsonContractStore) -> int:\n    payload = safe_json_loads(args.input_json) if args.input_json else build_input_from_url(args.url, args.test_type, args.run_id)\n    result = FirstStageRunner().run(payload)\n    saved = store.save_result(payload, result)\n    comparison = store.compare_label(payload, result)\n    result[\"labelComparison\"] = comparison.get(\"comparison\", comparison)\n    result[\"targetKey\"] = saved[\"identity\"][\"input_key\"]\n    result[\"inputHash\"] = saved[\"identity\"][\"input_hash\"]\n    result[\"recordId\"] = ((saved.get(\"saved\") or {}).get(\"result_record\") or {}).get(\"record_id\", \"\")\n    print(pretty(result))\n    return 0 if result.get(\"status\") in {\"pass\", \"needs_browser\"} else 1\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"First-stage GUI for X post collection tests.\")\n    parser.add_argument(\"--db\", default=\"\", help=\"read-only x_archive.db path\")\n    parser.add_argument(\"--state-dir\", default=DEFAULT_STATE_DIR, help=\"accepted for GUI temp state only; results and labels use JSON contract stores\")\n    parser.add_argument(\"--project-file\", default=DEFAULT_PROJECT_FILE, help=\"project.powan path used to load JSON contract powan code\")\n    parser.add_argument(\"--result-store\", default=RESULT_STORE_PATH, help=\"x_post_test_results.json path\")\n    parser.add_argument(\"--label-store\", default=LABEL_STORE_PATH, help=\"x_post_test_expected_labels.json path\")\n    parser.add_argument(\"--url\", default=\"\", help=\"single post URL for CLI or GUI prefill\")\n    parser.add_argument(\"--run-id\", default=\"\", help=\"optional external run id\")\n    parser.add_argument(\"--test-type\", default=\"post_reading\", choices=TEST_TYPES)\n    parser.add_argument(\"--input-json\", default=\"\", help=\"common input JSON for CLI execution\")\n    parser.add_argument(\"--no-gui\", action=\"store_true\", help=\"run one stub test and print JSON\")\n    args = parser.parse_args(argv)\n    store = JsonContractStore(Path(args.project_file), args.result_store, args.label_store)\n    if args.no_gui:\n        return run_cli(args, store)\n    if tk is None:\n        raise SystemExit(\"tkinter is not available; use --no-gui for CLI mode\")\n    root = tk.Tk()\n    app = TestGuiApp(root, store, db_path=args.db)\n    if args.url:\n        app.url_var.set(args.url)\n    root.mainloop()\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
