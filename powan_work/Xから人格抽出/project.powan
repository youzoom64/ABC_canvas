    {
      "id": "node-658f20c608",
      "title": "画面投稿読み取りポワン",
      "body": "Xの画面に表示されている投稿を1件ずつ読み取り、投稿ID、投稿URL、投稿者、本文、日時、画像や引用っぽい中身、元の画面情報を取り出して、後続の会話追跡や引用元追跡が扱える発言記録に整える臓器ポワン。Seleniumで見えている投稿カードを読む係であり、発端判定や引用元判定そのものは行わない。内部では構造化JSONに変換するが、意味としては「画面に見えている投稿を、追跡に使える記録へ読み取る」ことを担当する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport re\nimport time\nfrom typing import Any\nfrom urllib.parse import urljoin, urlparse\n\nlog = logging.getLogger(\"dom_article_postlike\")\n\nSTATUS_RE = re.compile(r\"/(?:i/web/)?status/(\\d+)\")\nX_HOSTS = {\"x.com\", \"twitter.com\", \"mobile.twitter.com\"}\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef normalize_url(href: str | None, *, base_url: str = \"https://x.com\") -> str:\n    if not href:\n        return \"\"\n    url = urljoin(base_url, href.strip())\n    parsed = urlparse(url)\n    if parsed.netloc in {\"twitter.com\", \"mobile.twitter.com\"}:\n        parsed = parsed._replace(netloc=\"x.com\")\n    parsed = parsed._replace(fragment=\"\")\n    return parsed.geturl()\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    match = STATUS_RE.search(url)\n    return match.group(1) if match else None\n\n\ndef author_from_status_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    parsed = urlparse(url)\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if len(parts) >= 3 and parts[1] == \"status\":\n        return parts[0]\n    return None\n\n\ndef dedupe_items(items: list[dict[str, Any]], *, key: str) -> list[dict[str, Any]]:\n    seen: set[str] = set()\n    unique: list[dict[str, Any]] = []\n    for item in items:\n        value = str(item.get(key) or \"\")\n        if not value or value in seen:\n            continue\n        seen.add(value)\n        unique.append(item)\n    return unique\n\n\ndef _dom_snapshot(driver: Any, article: Any) -> dict[str, Any]:\n    script = r\"\"\"\nconst article = arguments[0];\nconst textOf = (el) => (el && (el.innerText || el.textContent) || '').trim();\nconst attr = (el, name) => el ? (el.getAttribute(name) || '') : '';\nconst rectOf = (el) => {\n  const r = el.getBoundingClientRect();\n  return {x: Math.round(r.x), y: Math.round(r.y), width: Math.round(r.width), height: Math.round(r.height)};\n};\nconst links = Array.from(article.querySelectorAll('a[href]')).map((a) => ({\n  href: a.href || attr(a, 'href'),\n  text: textOf(a),\n  ariaLabel: attr(a, 'aria-label'),\n  role: attr(a, 'role'),\n  dataTestId: attr(a, 'data-testid'),\n  rect: rectOf(a),\n}));\nconst statusLinks = links.filter((link) => /\\/status\\/\\d+/.test(link.href || ''));\nconst externalLinks = links.filter((link) => {\n  try {\n    const u = new URL(link.href);\n    return !['x.com', 'twitter.com', 'mobile.twitter.com'].includes(u.hostname);\n  } catch (_) {\n    return false;\n  }\n});\nconst times = Array.from(article.querySelectorAll('time')).map((t) => ({\n  datetime: attr(t, 'datetime'),\n  text: textOf(t),\n  href: (t.closest('a') && t.closest('a').href) || '',\n  rect: rectOf(t),\n}));\nconst tweetTexts = Array.from(article.querySelectorAll('[data-testid=\"tweetText\"]')).map((el) => ({\n  text: textOf(el),\n  rect: rectOf(el),\n})).filter((item) => item.text);\nconst socialContext = Array.from(article.querySelectorAll('[data-testid=\"socialContext\"]')).map(textOf).filter(Boolean);\nconst media = Array.from(article.querySelectorAll('[data-testid=\"tweetPhoto\"], [data-testid=\"videoPlayer\"], [data-testid=\"card.wrapper\"]')).map((el) => ({\n  dataTestId: attr(el, 'data-testid'),\n  text: textOf(el),\n  rect: rectOf(el),\n}));\nreturn {\n  articleText: textOf(article),\n  ariaLabel: attr(article, 'aria-label'),\n  tweetTexts,\n  times,\n  links,\n  statusLinks,\n  externalLinks,\n  socialContext,\n  media,\n  rect: rectOf(article),\n};\n\"\"\"\n    return driver.execute_script(script, article) or {}\n\n\ndef article_to_post_like(driver: Any, article: Any, *, base_url: str = \"https://x.com\") -> dict[str, Any]:\n    \"\"\"Convert one X tweet article WebElement into a PostLike-style dict.\n\n    This is an adapter, not a judgement engine. It preserves raw DOM evidence\n    so downstream origin-tracing powans can decide reply/quote/repost meaning.\n    \"\"\"\n    snapshot = _dom_snapshot(driver, article)\n\n    times = snapshot.get(\"times\") or []\n    status_links = []\n    for link in snapshot.get(\"statusLinks\") or []:\n        url = normalize_url(link.get(\"href\"), base_url=base_url)\n        status_id = status_id_from_url(url)\n        if not status_id:\n            continue\n        status_links.append({**link, \"url\": url, \"statusId\": status_id, \"authorId\": author_from_status_url(url)})\n    status_links = dedupe_items(status_links, key=\"url\")\n\n    own_url = \"\"\n    for item in times:\n        own_url = normalize_url(item.get(\"href\"), base_url=base_url)\n        if status_id_from_url(own_url):\n            break\n    if not status_id_from_url(own_url) and status_links:\n        own_url = status_links[0][\"url\"]\n\n    own_id = status_id_from_url(own_url)\n    own_author = author_from_status_url(own_url)\n    tweet_texts = [item.get(\"text\", \"\") for item in snapshot.get(\"tweetTexts\") or [] if item.get(\"text\")]\n    text = tweet_texts[0] if tweet_texts else str(snapshot.get(\"articleText\") or \"\").strip()\n\n    quote_or_status_cards: list[dict[str, Any]] = []\n    for link in status_links:\n        if own_id and link.get(\"statusId\") == own_id:\n            continue\n        quote_or_status_cards.append({\n            \"kind\": \"status_link\",\n            \"url\": link.get(\"url\"),\n            \"id\": link.get(\"statusId\"),\n            \"authorId\": link.get(\"authorId\"),\n            \"text\": link.get(\"text\") or \"\",\n            \"raw\": link,\n        })\n\n    if len(tweet_texts) > 1:\n        quote_or_status_cards.append({\n            \"kind\": \"quote_candidate\",\n            \"text\": tweet_texts[1],\n            \"createdAt\": times[1].get(\"datetime\") if len(times) > 1 and isinstance(times[1], dict) else None,\n            \"url\": quote_or_status_cards[0].get(\"url\") if quote_or_status_cards else None,\n            \"raw\": {\"tweetTextIndex\": 1},\n        })\n\n    urls = []\n    for link in snapshot.get(\"externalLinks\") or []:\n        url = normalize_url(link.get(\"href\"), base_url=base_url)\n        if url:\n            urls.append({**link, \"url\": url})\n    urls = dedupe_items(urls, key=\"url\")\n\n    created_at = None\n    if times and isinstance(times[0], dict):\n        created_at = times[0].get(\"datetime\") or None\n\n    post_like = {\n        \"id\": own_id,\n        \"url\": own_url or None,\n        \"authorId\": own_author,\n        \"text\": text,\n        \"createdAt\": created_at,\n        \"urls\": urls,\n        \"cards\": quote_or_status_cards,\n        \"raw\": {\n            \"source\": \"selenium.article[data-testid=tweet]\",\n            \"articleText\": snapshot.get(\"articleText\") or \"\",\n            \"tweetTexts\": snapshot.get(\"tweetTexts\") or [],\n            \"times\": times,\n            \"statusLinks\": status_links,\n            \"socialContext\": snapshot.get(\"socialContext\") or [],\n            \"media\": snapshot.get(\"media\") or [],\n            \"rect\": snapshot.get(\"rect\") or {},\n        },\n    }\n\n    if quote_or_status_cards:\n        first_card = quote_or_status_cards[0]\n        if first_card.get(\"id\"):\n            post_like[\"quotedPostId\"] = first_card[\"id\"]\n        if first_card.get(\"url\"):\n            post_like[\"quotedStatusUrl\"] = first_card[\"url\"]\n\n    return post_like\n\n\ndef visible_articles_to_post_likes(driver: Any, *, limit: int = 20) -> list[dict[str, Any]]:\n    from selenium.webdriver.common.by import By\n\n    articles = driver.find_elements(By.CSS_SELECTOR, \"article[data-testid='tweet']\")\n    results: list[dict[str, Any]] = []\n    for article in articles[: max(0, limit)]:\n        try:\n            results.append(article_to_post_like(driver, article, base_url=driver.current_url or \"https://x.com\"))\n        except Exception as exc:\n            log.warning(\"postlike.convert.failed error=%s\", exc)\n            results.append({\"error\": str(exc)})\n    return results\n\n\ndef wait_ready(driver: Any, *, timeout: float = 15.0) -> str:\n    deadline = time.monotonic() + timeout\n    state = \"\"\n    while time.monotonic() < deadline:\n        state = str(driver.execute_script(\"return document.readyState\") or \"\")\n        if state == \"complete\":\n            return state\n        time.sleep(0.25)\n    return state\n\n\ndef wait_for_tweet_articles(driver: Any, *, timeout: float = 20.0) -> int:\n    from selenium.webdriver.common.by import By\n\n    deadline = time.monotonic() + timeout\n    last_count = 0\n    while time.monotonic() < deadline:\n        articles = driver.find_elements(By.CSS_SELECTOR, \"article[data-testid='tweet']\")\n        last_count = len(articles)\n        if last_count:\n            return last_count\n        time.sleep(0.5)\n    return last_count\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Convert visible X tweet articles to PostLike-style JSON.\")\n    parser.add_argument(\"--url\", default=\"\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--limit\", type=int, default=20)\n    parser.add_argument(\"--wait\", type=float, default=15.0)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n\n    from scripts.chrome_debug import get_driver\n\n    driver = get_driver(port=args.port, wait=args.wait)\n    if args.url:\n        log.info(\"postlike.navigate url=%s\", args.url)\n        driver.get(args.url)\n        wait_ready(driver, timeout=args.wait)\n\n    article_count = wait_for_tweet_articles(driver, timeout=args.wait)\n    log.info(\"postlike.articles.ready count=%s\", article_count)\n    posts = visible_articles_to_post_likes(driver, limit=args.limit)\n    print(json.dumps({\n        \"ok\": True,\n        \"currentUrl\": driver.current_url,\n        \"title\": driver.title,\n        \"count\": len(posts),\n        \"posts\": posts,\n    }, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
