    {
      "id": "node-dbf9799f66",
      "title": "テスト結果保存・比較ポワン",
      "body": "テスト実行結果、証拠、ログ、正解ラベルとの差分、成功/失敗、失敗理由、再現用入力を保存し、過去結果と比較する臓器ポワン。GUIには差分を見やすく返す。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\nimport hashlib\nimport json\nimport math\nimport os, tempfile\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Mapping, Sequence\nfrom urllib.parse import urlsplit, urlunsplit\nSCHEMA_VERSION, DEFAULT_STORE_PATH = 1, \"x_post_test_results.json\"\nFORBIDDEN_WRITE_NAMES, MISSING = {\"x_archive.db\"}, object()\nCOMMON_INPUT_FIELDS = (\n    \"source_type\", \"target_kind\", \"canonical_url\", \"post_id\", \"account\", \"run_id\",\n    \"db_ref\", \"raw_json\", \"text_preview\", \"selector_note\", \"needs_browser\", \"warnings\",\n)\nINPUT_ALIASES = {\n    \"source_type\": (\"source_type\", \"sourceType\"),\n    \"target_kind\": (\"target_kind\", \"targetKind\"),\n    \"canonical_url\": (\"canonical_url\", \"canonicalUrl\", \"url\", \"post_url\", \"postUrl\"),\n    \"post_id\": (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\"),\n    \"account\": (\"account\", \"screen_name\", \"screenName\", \"username\", \"author\"),\n    \"run_id\": (\"run_id\", \"runId\"),\n    \"db_ref\": (\"db_ref\", \"dbRef\"),\n    \"raw_json\": (\"raw_json\", \"rawJson\", \"raw\"),\n    \"text_preview\": (\"text_preview\", \"textPreview\", \"text\", \"body\"),\n    \"selector_note\": (\"selector_note\", \"selectorNote\"),\n    \"needs_browser\": (\"needs_browser\", \"needsBrowser\"),\n    \"warnings\": (\"warnings\", \"warning\"),\n}\nIDENTITY_FIELDS = (\"source_type\", \"target_kind\", \"canonical_url\", \"post_id\", \"account\", \"db_ref\")\nFALLBACK_IDENTITY_FIELDS = (\"source_type\", \"target_kind\", \"run_id\", \"selector_note\")\nSUCCESS_STATUSES = {\"ok\", \"success\", \"succeeded\", \"passed\", \"pass\", \"matched\", \"complete\", \"completed\"}\nFAILURE_STATUSES = {\"error\", \"failed\", \"fail\", \"failure\", \"mismatch\", \"different\", \"timeout\"}\nclass TestResultStoreError(ValueError):\n    pass\ndef run(payload: Mapping[str, Any] | None = None, **kwargs: Any) -> dict[str, Any]:\n    data = _merge_payload(payload, kwargs)\n    action = _clean_text(data.get(\"action\")) or \"save\"\n    store_path = data.get(\"store_path\") or data.get(\"storePath\") or DEFAULT_STORE_PATH\n    try:\n        if action in {\"save\", \"append\", \"record\", \"save-result\"}:\n            return save_result(\n                store_path=store_path,\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_type=_first_value(data, \"test_type\", \"testType\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                result=_optional_value(data, \"result\"),\n                evidence=_optional_value(data, \"evidence\"),\n                logs=_optional_value(data, \"logs\", \"log\"),\n                confidence=_optional_value(data, \"confidence\"),\n                error=_optional_value(data, \"error\"),\n                artifact_paths=_optional_value(data, \"artifact_paths\", \"artifactPaths\"),\n                created_at=_first_value(data, \"created_at\", \"createdAt\"),\n                success=_optional_value(data, \"success\", \"ok\"),\n            )\n        if action in {\"get\", \"read\", \"load\"}:\n            return read_result(\n                store_path=store_path,\n                record_id=_first_value(data, \"record_id\", \"recordId\"),\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                include_revisions=bool(data.get(\"include_revisions\", data.get(\"includeRevisions\", True))),\n            )\n        if action in {\"list\", \"list-results\"}:\n            return list_results(\n                store_path=store_path,\n                test_type=_first_value(data, \"test_type\", \"testType\"),\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                input_key=_first_value(data, \"input_key\", \"inputKey\"),\n                success=_optional_value(data, \"success\", \"ok\"),\n                limit=_int_value(data.get(\"limit\"), 50),\n                offset=_int_value(data.get(\"offset\"), 0),\n                detail=bool(data.get(\"detail\", False)),\n            )\n        if action in {\"compare\", \"compare-input\", \"compare-past\", \"history-diff\"}:\n            return compare_same_input(\n                store_path=store_path,\n                data=data,\n                previous_limit=_int_value(data.get(\"previous_limit\", data.get(\"previousLimit\")), 5),\n                max_diffs=_int_value(data.get(\"max_diffs\", data.get(\"maxDiffs\")), 100),\n            )\n        if action in {\"normalize-input\", \"input-key\"}:\n            normalized = normalize_test_input(_first_value(data, \"test_input\", \"testInput\", \"input\"))\n            return {\"ok\": True, \"status\": \"normalized\", \"input\": normalized, **make_input_target(normalized)}\n        raise TestResultStoreError(f\"unknown action: {action}\")\n    except Exception as exc:\n        return {\"ok\": False, \"status\": \"error\", \"error\": {\"type\": exc.__class__.__name__, \"message\": str(exc)}}\ndef save_result(\n    *, store_path: str | Path = DEFAULT_STORE_PATH, test_id: Any = None, test_type: Any = None,\n    test_input: Any = None, result: Any = MISSING, evidence: Any = MISSING, logs: Any = MISSING,\n    confidence: Any = MISSING, error: Any = MISSING, artifact_paths: Any = MISSING,\n    created_at: Any = None, success: Any = MISSING,\n) -> dict[str, Any]:\n    record = make_result_record(\n        test_id=test_id, test_type=test_type, test_input=test_input, result=result, evidence=evidence,\n        logs=logs, confidence=confidence, error=error, artifact_paths=artifact_paths,\n        created_at=created_at, success=success,\n    )\n    store = load_result_store(store_path)\n    previous = _records_for_input(store[\"results\"], record[\"input_key\"])\n    store[\"results\"].append(record)\n    save_result_store(store, store_path)\n    comparison = compare_records(previous[0], record) if previous else {\"status\": \"no_previous\", \"matches\": None, \"differences\": []}\n    return {\n        \"ok\": True, \"status\": \"saved\", \"store_path\": str(_resolve_store_path(store_path)),\n        \"result_record\": public_record(record), \"same_input_history_count\": len(previous),\n        \"comparison_to_previous\": comparison,\n    }\ndef read_result(\n    *, store_path: str | Path = DEFAULT_STORE_PATH, record_id: Any = None, test_id: Any = None,\n    test_input: Any = None, include_revisions: bool = True,\n) -> dict[str, Any]:\n    matches = _filter_records(load_result_store(store_path)[\"results\"], record_id=record_id, test_id=test_id, test_input=test_input)\n    if not matches:\n        return {\"ok\": True, \"status\": \"missing\", \"result_record\": None, \"records\": []}\n    result = {\"ok\": True, \"status\": \"found\", \"result_record\": public_record(matches[0])}\n    if include_revisions:\n        result.update({\"records\": [public_record(record) for record in matches], \"count\": len(matches)})\n    return result\ndef list_results(\n    *, store_path: str | Path = DEFAULT_STORE_PATH, test_type: Any = None, test_id: Any = None,\n    test_input: Any = None, input_key: Any = None, success: Any = MISSING,\n    limit: int = 50, offset: int = 0, detail: bool = False,\n) -> dict[str, Any]:\n    records = _sorted_records(load_result_store(store_path)[\"results\"])\n    if test_type:\n        records = [item for item in records if item.get(\"test_type\") == _clean_text(test_type)]\n    if test_id:\n        records = [item for item in records if item.get(\"test_id\") == _clean_text(test_id)]\n    if input_key:\n        records = [item for item in records if item.get(\"input_key\") == _clean_text(input_key)]\n    elif test_input is not None:\n        key = make_input_target(normalize_test_input(test_input))[\"input_key\"]\n        records = [item for item in records if item.get(\"input_key\") == key]\n    if success is not MISSING:\n        wanted = _bool_value(success)\n        records = [item for item in records if bool(item.get(\"success\")) is wanted]\n    total = len(records)\n    limit, offset = max(0, min(int(limit), 500)), max(0, int(offset))\n    page = records[offset: offset + limit] if limit else records[offset:]\n    serialize = public_record if detail else record_summary\n    return {\n        \"ok\": True, \"status\": \"listed\", \"store_path\": str(_resolve_store_path(store_path)),\n        \"count\": len(page), \"total\": total, \"offset\": offset, \"limit\": limit,\n        \"results\": [serialize(record) for record in page],\n    }\ndef compare_same_input(\n    *, store_path: str | Path = DEFAULT_STORE_PATH, data: Mapping[str, Any],\n    previous_limit: int = 5, max_diffs: int = 100,\n) -> dict[str, Any]:\n    records = load_result_store(store_path)[\"results\"]\n    current, persisted = _current_record_for_compare(data, records)\n    if current is None:\n        return {\"ok\": True, \"status\": \"missing\", \"comparison\": {\"status\": \"missing_current\"}}\n    previous = _records_for_input(records, current[\"input_key\"])\n    if persisted:\n        previous = [item for item in previous if item.get(\"record_id\") != current.get(\"record_id\")]\n    previous = previous[: max(0, int(previous_limit))]\n    if not previous:\n        return {\n            \"ok\": True, \"status\": \"no_previous\", \"input_key\": current[\"input_key\"],\n            \"current\": record_summary(current), \"previous\": [],\n            \"comparison\": {\"status\": \"no_previous\", \"matches\": None, \"differences\": []},\n        }\n    return {\n        \"ok\": True, \"status\": \"compared\", \"input_key\": current[\"input_key\"],\n        \"current\": public_record(current), \"previous\": [record_summary(item) for item in previous],\n        \"comparison\": compare_records(previous[0], current, max_diffs=max_diffs),\n        \"comparisons\": [\n            {\"against\": record_summary(item), \"comparison\": compare_records(item, current, max_diffs=max_diffs)}\n            for item in previous\n        ],\n    }\ndef make_result_record(\n    *, test_id: Any = None, test_type: Any = None, test_input: Any = None, result: Any = MISSING,\n    evidence: Any = MISSING, logs: Any = MISSING, confidence: Any = MISSING, error: Any = MISSING,\n    artifact_paths: Any = MISSING, created_at: Any = None, success: Any = MISSING,\n) -> dict[str, Any]:\n    normalized_input = normalize_test_input(test_input)\n    target = make_input_target(normalized_input)\n    created = _clean_text(created_at) or _now()\n    result_value = {} if result is MISSING else _json_safe(result)\n    evidence_value = {} if evidence is MISSING else _json_safe(evidence)\n    logs_value = [] if logs is MISSING else _json_safe(logs)\n    error_value = normalize_error(None if error is MISSING else error)\n    success_value = derive_success(success, result_value, error_value)\n    test_type_value = _clean_text(test_type) or normalized_input.get(\"target_kind\") or normalized_input.get(\"source_type\") or \"unknown\"\n    test_id_value = _clean_text(test_id) or f\"test-{_hash_json([target['input_key'], created, test_type_value])[:16]}\"\n    record_id = f\"result-{_hash_json([test_id_value, target['input_hash'], created, result_value, error_value])[:20]}\"\n    return {\n        \"schema_version\": SCHEMA_VERSION, \"record_id\": record_id, \"test_id\": test_id_value,\n        \"test_type\": test_type_value, **target, \"input\": normalized_input, \"result\": result_value,\n        \"evidence\": evidence_value, \"logs\": logs_value,\n        \"confidence\": None if confidence is MISSING else normalize_confidence(confidence),\n        \"error\": error_value, \"artifact_paths\": normalize_artifact_paths([] if artifact_paths is MISSING else artifact_paths),\n        \"success\": success_value, \"failure_reason\": derive_failure_reason(success_value, result_value, error_value),\n        \"created_at\": created,\n    }\ndef normalize_test_input(value: Any) -> dict[str, Any]:\n    if value is None or value is MISSING:\n        value = {}\n    if not isinstance(value, Mapping):\n        value = {\"raw_json\": value, \"text_preview\": _clean_text(value)[:240]}\n    data = dict(value)\n    normalized: dict[str, Any] = {}\n    for field in COMMON_INPUT_FIELDS:\n        raw = _first_present(data, INPUT_ALIASES[field])\n        if field in {\"source_type\", \"target_kind\", \"post_id\", \"account\", \"run_id\", \"selector_note\"}:\n            normalized[field] = _clean_text(raw)\n        elif field == \"canonical_url\":\n            normalized[field] = canonicalize_url(raw)\n        elif field == \"needs_browser\":\n            normalized[field] = _bool_value(raw)\n        elif field == \"warnings\":\n            normalized[field] = normalize_artifact_paths(raw)\n        elif field == \"text_preview\":\n            normalized[field] = _clean_text(raw)[:500]\n        else:\n            normalized[field] = _json_safe(raw) if raw is not MISSING else None\n    known = {alias for aliases in INPUT_ALIASES.values() for alias in aliases}\n    extra = {key: _json_safe(val) for key, val in data.items() if key not in known}\n    if extra:\n        normalized[\"extra\"] = extra\n    return normalized\ndef make_input_target(normalized_input: Mapping[str, Any]) -> dict[str, Any]:\n    input_hash = _hash_json(normalized_input)\n    identity = {\n        field: _identity_value(normalized_input.get(field))\n        for field in IDENTITY_FIELDS if _has_value(normalized_input.get(field))\n    }\n    if not any(field in identity for field in (\"canonical_url\", \"post_id\", \"db_ref\")):\n        identity = {\n            field: _identity_value(normalized_input.get(field))\n            for field in FALLBACK_IDENTITY_FIELDS if _has_value(normalized_input.get(field))\n        }\n    if not identity:\n        identity = {\"input_hash\": input_hash}\n    return {\"input_key\": f\"input_sha256:{_hash_json(identity)}\", \"input_hash\": input_hash, \"input_identity\": identity}\ndef compare_records(previous: Mapping[str, Any], current: Mapping[str, Any], *, max_diffs: int = 100) -> dict[str, Any]:\n    differences: list[dict[str, Any]] = []\n    for field in (\"success\", \"failure_reason\", \"result\", \"evidence\", \"logs\", \"error\", \"artifact_paths\"):\n        _collect_differences(previous.get(field), current.get(field), f\"$.{field}\", differences, max_diffs)\n    prev_conf, cur_conf = previous.get(\"confidence\"), current.get(\"confidence\")\n    delta = cur_conf - prev_conf if isinstance(prev_conf, (int, float)) and isinstance(cur_conf, (int, float)) else None\n    return {\n        \"status\": \"same_as_previous\" if not differences else \"different_from_previous\",\n        \"matches\": not differences, \"previous_record_id\": previous.get(\"record_id\"),\n        \"current_record_id\": current.get(\"record_id\"), \"success_changed\": previous.get(\"success\") != current.get(\"success\"),\n        \"confidence_delta\": delta, \"difference_count\": len(differences), \"differences\": differences,\n    }\ndef load_result_store(store_path: str | Path = DEFAULT_STORE_PATH) -> dict[str, Any]:\n    path = _resolve_store_path(store_path)\n    if not path.exists():\n        return {\"schema_version\": SCHEMA_VERSION, \"results\": [], \"_passthrough\": {}}\n    try:\n        loaded = json.loads(path.read_text(encoding=\"utf-8\"))\n    except json.JSONDecodeError as exc:\n        raise TestResultStoreError(f\"result store is not valid JSON: {path}\") from exc\n    if not isinstance(loaded, Mapping):\n        raise TestResultStoreError(\"result store root must be an object\")\n    raw_results = loaded.get(\"results\", [])\n    if not isinstance(raw_results, list) and isinstance(loaded.get(\"records\"), Mapping):\n        raw_results = list(loaded[\"records\"].values())\n    if not isinstance(raw_results, list):\n        raise TestResultStoreError(\"result store results must be a list\")\n    passthrough = {key: value for key, value in loaded.items() if key not in {\"schema_version\", \"results\", \"records\"}}\n    return {\n        \"schema_version\": int(loaded.get(\"schema_version\") or SCHEMA_VERSION),\n        \"results\": [normalize_record(item) for item in raw_results if isinstance(item, Mapping)],\n        \"_passthrough\": passthrough,\n    }\ndef save_result_store(store: Mapping[str, Any], store_path: str | Path = DEFAULT_STORE_PATH) -> None:\n    path = _resolve_store_path(store_path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    output = {\n        **dict(store.get(\"_passthrough\", {})), \"schema_version\": SCHEMA_VERSION,\n        \"results\": [normalize_record(item) for item in store.get(\"results\", [])],\n    }\n    tmp_path: Path | None = None\n    try:\n        with tempfile.NamedTemporaryFile(\"w\", encoding=\"utf-8\", dir=str(path.parent), prefix=f\".{path.name}.\", suffix=\".tmp\", delete=False) as handle:\n            tmp_path = Path(handle.name)\n            json.dump(output, handle, ensure_ascii=False, indent=2, sort_keys=True)\n            handle.write(\"\\n\")\n        os.replace(tmp_path, path)\n    finally:\n        if tmp_path and tmp_path.exists():\n            try:\n                tmp_path.unlink()\n            except OSError:\n                pass\ndef normalize_record(value: Mapping[str, Any]) -> dict[str, Any]:\n    record = dict(_json_safe(value))\n    normalized_input = normalize_test_input(record.get(\"input\"))\n    target = make_input_target(normalized_input)\n    record.update(target)\n    record[\"schema_version\"] = int(record.get(\"schema_version\") or SCHEMA_VERSION)\n    record[\"input\"] = normalized_input\n    record[\"test_id\"] = _clean_text(record.get(\"test_id\")) or f\"test-{_hash_json([target['input_key'], record.get('created_at')])[:16]}\"\n    record[\"test_type\"] = _clean_text(record.get(\"test_type\")) or normalized_input.get(\"target_kind\") or \"unknown\"\n    record[\"result\"] = _json_safe(record.get(\"result\", {}))\n    record[\"evidence\"] = _json_safe(record.get(\"evidence\", {}))\n    record[\"logs\"] = _json_safe(record.get(\"logs\", []))\n    record[\"confidence\"] = normalize_confidence(record.get(\"confidence\"))\n    record[\"error\"] = normalize_error(record.get(\"error\"))\n    record[\"artifact_paths\"] = normalize_artifact_paths(record.get(\"artifact_paths\", []))\n    record[\"success\"] = derive_success(record.get(\"success\", MISSING), record[\"result\"], record[\"error\"])\n    record[\"failure_reason\"] = _clean_text(record.get(\"failure_reason\")) or derive_failure_reason(record[\"success\"], record[\"result\"], record[\"error\"])\n    record[\"created_at\"] = _clean_text(record.get(\"created_at\")) or _now()\n    record[\"record_id\"] = _clean_text(record.get(\"record_id\")) or f\"result-{_hash_json([record['test_id'], target['input_hash'], record['created_at'], record['result']])[:20]}\"\n    return record\ndef public_record(record: Mapping[str, Any]) -> dict[str, Any]:\n    return _json_safe(record)\ndef record_summary(record: Mapping[str, Any]) -> dict[str, Any]:\n    test_input = record.get(\"input\") if isinstance(record.get(\"input\"), Mapping) else {}\n    return {\n        \"record_id\": record.get(\"record_id\"), \"test_id\": record.get(\"test_id\"),\n        \"test_type\": record.get(\"test_type\"), \"input_key\": record.get(\"input_key\"),\n        \"source_type\": test_input.get(\"source_type\"), \"target_kind\": test_input.get(\"target_kind\"),\n        \"canonical_url\": test_input.get(\"canonical_url\"), \"post_id\": test_input.get(\"post_id\"),\n        \"account\": test_input.get(\"account\"), \"run_id\": test_input.get(\"run_id\"),\n        \"text_preview\": _clean_text(test_input.get(\"text_preview\"))[:160],\n        \"success\": record.get(\"success\"), \"failure_reason\": record.get(\"failure_reason\"),\n        \"confidence\": record.get(\"confidence\"), \"artifact_count\": len(record.get(\"artifact_paths\") or []),\n        \"created_at\": record.get(\"created_at\"),\n    }\ndef _current_record_for_compare(data: Mapping[str, Any], records: Sequence[Mapping[str, Any]]) -> tuple[dict[str, Any] | None, bool]:\n    record_id = _first_value(data, \"record_id\", \"recordId\")\n    test_id = _first_value(data, \"test_id\", \"testId\")\n    test_input = _first_value(data, \"test_input\", \"testInput\", \"input\")\n    has_unsaved = any(key in data for key in (\"result\", \"evidence\", \"logs\", \"error\", \"artifact_paths\", \"artifactPaths\", \"confidence\", \"success\", \"ok\"))\n    if has_unsaved:\n        return make_result_record(\n            test_id=test_id, test_type=_first_value(data, \"test_type\", \"testType\"), test_input=test_input,\n            result=_optional_value(data, \"result\"), evidence=_optional_value(data, \"evidence\"),\n            logs=_optional_value(data, \"logs\", \"log\"), confidence=_optional_value(data, \"confidence\"),\n            error=_optional_value(data, \"error\"), artifact_paths=_optional_value(data, \"artifact_paths\", \"artifactPaths\"),\n            created_at=_first_value(data, \"created_at\", \"createdAt\"), success=_optional_value(data, \"success\", \"ok\"),\n        ), False\n    matches = _filter_records(records, record_id=record_id, test_id=test_id, test_input=test_input)\n    return (matches[0], True) if matches else (None, False)\ndef _filter_records(records: Sequence[Mapping[str, Any]], *, record_id: Any = None, test_id: Any = None, test_input: Any = None) -> list[dict[str, Any]]:\n    normalized = [normalize_record(item) for item in records]\n    if record_id:\n        normalized = [item for item in normalized if item.get(\"record_id\") == _clean_text(record_id)]\n    if test_id:\n        normalized = [item for item in normalized if item.get(\"test_id\") == _clean_text(test_id)]\n    if test_input is not None:\n        key = make_input_target(normalize_test_input(test_input))[\"input_key\"]\n        normalized = [item for item in normalized if item.get(\"input_key\") == key]\n    return _sorted_records(normalized)\ndef _records_for_input(records: Sequence[Mapping[str, Any]], input_key: str) -> list[dict[str, Any]]:\n    return _sorted_records([normalize_record(item) for item in records if normalize_record(item).get(\"input_key\") == input_key])\ndef _sorted_records(records: Sequence[Mapping[str, Any]]) -> list[dict[str, Any]]:\n    return sorted([normalize_record(item) for item in records], key=lambda item: (item.get(\"created_at\") or \"\", item.get(\"record_id\") or \"\"), reverse=True)\ndef _collect_differences(previous: Any, current: Any, path: str, differences: list[dict[str, Any]], max_diffs: int) -> None:\n    if len(differences) >= max_diffs:\n        return\n    if isinstance(previous, Mapping) and isinstance(current, Mapping):\n        for key in sorted(set(previous) | set(current)):\n            if key not in previous:\n                differences.append({\"path\": f\"{path}.{key}\", \"previous\": None, \"current\": current[key], \"change\": \"added\"})\n            elif key not in current:\n                differences.append({\"path\": f\"{path}.{key}\", \"previous\": previous[key], \"current\": None, \"change\": \"removed\"})\n            else:\n                _collect_differences(previous[key], current[key], f\"{path}.{key}\", differences, max_diffs)\n            if len(differences) >= max_diffs:\n                return\n        return\n    if _is_sequence(previous) and _is_sequence(current):\n        if len(previous) != len(current):\n            differences.append({\"path\": path, \"previous\": previous, \"current\": current, \"change\": \"length_changed\"})\n            return\n        for index, previous_value in enumerate(previous):\n            _collect_differences(previous_value, current[index], f\"{path}[{index}]\", differences, max_diffs)\n        return\n    if previous != current:\n        differences.append({\"path\": path, \"previous\": previous, \"current\": current, \"change\": \"changed\"})\ndef derive_success(success: Any, result: Any, error: Any) -> bool:\n    if success is not MISSING and success is not None and success != \"\":\n        return _bool_value(success)\n    if error:\n        return False\n    if isinstance(result, Mapping):\n        for key in (\"success\", \"ok\", \"passed\"):\n            if key in result:\n                return _bool_value(result[key])\n        status = _clean_text(result.get(\"status\")).lower()\n        if status in SUCCESS_STATUSES:\n            return True\n        if status in FAILURE_STATUSES:\n            return False\n    return True\ndef derive_failure_reason(success: bool, result: Any, error: Any) -> str:\n    if success:\n        return \"\"\n    if isinstance(error, Mapping):\n        return _clean_text(error.get(\"message\") or error.get(\"type\"))\n    if isinstance(result, Mapping):\n        return _clean_text(result.get(\"failure_reason\") or result.get(\"reason\") or result.get(\"status\"))\n    return \"failed\"\ndef normalize_error(value: Any) -> dict[str, Any] | None:\n    if value in (None, \"\", MISSING, False):\n        return None\n    if isinstance(value, Mapping):\n        result = _json_safe(value)\n        result.setdefault(\"message\", _clean_text(result.get(\"error\") or result.get(\"detail\") or result))\n        result.setdefault(\"type\", _clean_text(result.get(\"name\")) or \"Error\")\n        return result\n    return {\"type\": \"Error\", \"message\": _clean_text(value)}\ndef normalize_confidence(value: Any) -> float | None:\n    if value in (None, \"\", MISSING):\n        return None\n    try:\n        number = float(value)\n    except (TypeError, ValueError):\n        return None\n    return number if math.isfinite(number) else None\ndef normalize_artifact_paths(value: Any) -> list[str]:\n    if value in (None, \"\", MISSING):\n        return []\n    if isinstance(value, (str, Path)):\n        return [_clean_text(value)] if _clean_text(value) else []\n    if isinstance(value, Sequence) and not isinstance(value, (bytes, bytearray)):\n        return [_clean_text(item) for item in value if _clean_text(item)]\n    return [_clean_text(value)] if _clean_text(value) else []\ndef canonicalize_url(value: Any) -> str:\n    text = _clean_text(value)\n    if not text:\n        return \"\"\n    try:\n        parts = urlsplit(text)\n    except ValueError:\n        return text\n    if not parts.scheme or not parts.netloc:\n        return text\n    return urlunsplit((parts.scheme.lower(), parts.netloc.lower(), parts.path.rstrip(\"/\") or \"/\", parts.query, \"\"))\ndef _resolve_store_path(store_path: str | Path) -> Path:\n    path = Path(str(store_path or DEFAULT_STORE_PATH)).expanduser()\n    if not path.is_absolute():\n        path = Path.cwd() / path\n    lowered_parts = {part.lower() for part in path.parts}\n    if lowered_parts & FORBIDDEN_WRITE_NAMES or path.suffix.lower() == \".db\":\n        raise TestResultStoreError(\"test results must be stored in a separate JSON file, not x_archive.db or any .db file\")\n    return path\ndef _merge_payload(payload: Mapping[str, Any] | None, kwargs: Mapping[str, Any]) -> dict[str, Any]:\n    if payload is not None and not isinstance(payload, Mapping):\n        raise TestResultStoreError(\"payload must be a JSON object\")\n    data = dict(payload or {})\n    data.update({key: value for key, value in kwargs.items() if value is not None})\n    return data\ndef _first_value(data: Mapping[str, Any], *keys: str) -> Any:\n    for key in keys:\n        value = data.get(key)\n        if value not in (None, \"\"):\n            return value\n    return None\ndef _optional_value(data: Mapping[str, Any], *keys: str) -> Any:\n    for key in keys:\n        if key in data:\n            return data[key]\n    return MISSING\ndef _first_present(data: Mapping[str, Any], keys: Sequence[str]) -> Any:\n    for key in keys:\n        if key in data:\n            return data[key]\n    return MISSING\ndef _identity_value(value: Any) -> Any:\n    return value.strip().lower() if isinstance(value, str) else _json_safe(value)\ndef _has_value(value: Any) -> bool:\n    return value not in (None, \"\", [], {}, MISSING)\ndef _bool_value(value: Any) -> bool:\n    if isinstance(value, bool):\n        return value\n    if isinstance(value, (int, float)):\n        return bool(value)\n    text = _clean_text(value).lower()\n    if text in {\"1\", \"true\", \"yes\", \"y\", \"on\", \"ok\", \"success\", \"passed\"}:\n        return True\n    if text in {\"0\", \"false\", \"no\", \"n\", \"off\", \"failed\", \"error\", \"none\", \"\"}:\n        return False\n    return bool(value)\ndef _int_value(value: Any, default: int) -> int:\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return default\ndef _json_safe(value: Any) -> Any:\n    return json.loads(json.dumps(value, ensure_ascii=False, sort_keys=True, default=str))\ndef _hash_json(value: Any) -> str:\n    encoded = json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(\",\", \":\"), default=str).encode(\"utf-8\")\n    return hashlib.sha256(encoded).hexdigest()\ndef _clean_text(value: Any) -> str:\n    return \"\" if value in (None, MISSING) else str(value).strip()\ndef _is_sequence(value: Any) -> bool:\n    return isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray))\ndef _now() -> str:\n    return datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n",
