    {
      "id": "node-64a6e22f06",
      "title": "YouTubeコメント取得ポワン",
      "body": "YouTube URLを受け取り、既存のC:\\project_root\\app_workspaces\\API\\scripts\\youtube_comments.pyを使ってコメントを取得する臓器ポワン。動画本文そのものではなく周辺文脈として、取得件数、コメント本文、保存先、取得不能理由を返す。DB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport importlib\nimport json\nimport re\nimport sys\nfrom pathlib import Path\nfrom typing import Any\nfrom urllib.parse import parse_qs, urlparse\n\nAPI_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\")\nCOMMENTS_SCRIPT = API_ROOT / \"scripts\" / \"youtube_comments.py\"\nDEFAULT_OUTPUT_ROOT = API_ROOT / \"data\" / \"youtube_context\" / \"comments\"\nDEFAULT_MAX_COMMENTS = 100\nMAX_COMMENT_LIMIT = 1000\n\n\ndef _coerce_max_comments(value: Any) -> int:\n    try:\n        count = int(value)\n    except (TypeError, ValueError):\n        count = DEFAULT_MAX_COMMENTS\n    return max(1, min(MAX_COMMENT_LIMIT, count))\n\n\ndef extract_video_id(url: str) -> str:\n    clean_url = (url or \"\").strip()\n    if not clean_url:\n        return \"\"\n\n    parsed = urlparse(clean_url)\n    host = parsed.netloc.lower().split(\":\", 1)[0]\n    if host.startswith(\"www.\"):\n        host = host[4:]\n    if host.startswith(\"m.\"):\n        host = host[2:]\n    if host.startswith(\"music.\"):\n        host = host[6:]\n\n    if host == \"youtu.be\":\n        return parsed.path.strip(\"/\").split(\"/\", 1)[0][:11]\n\n    if host in {\"youtube.com\", \"youtube-nocookie.com\"} or host.endswith(\".youtube.com\"):\n        query_id = parse_qs(parsed.query).get(\"v\", [\"\"])[0]\n        if query_id:\n            return query_id[:11]\n\n        parts = [part for part in parsed.path.split(\"/\") if part]\n        if len(parts) >= 2 and parts[0] in {\"shorts\", \"embed\", \"live\", \"v\"}:\n            return parts[1][:11]\n\n    match = re.search(r\"(?:v=|youtu\\.be/|shorts/|embed/|live/)([A-Za-z0-9_-]{11})\", clean_url)\n    return match.group(1) if match else \"\"\n\n\ndef _safe_segment(value: Any, fallback: str) -> str:\n    text = str(value or \"\").strip()\n    if not text:\n        text = fallback\n    text = re.sub(r\"[^A-Za-z0-9._-]+\", \"_\", text).strip(\"._-\")\n    return text or fallback\n\n\ndef _build_output_dir(video_id: str, post_id: Any = None, media_index: Any = None, output_dir: str | None = None) -> Path:\n    if output_dir:\n        return Path(output_dir).expanduser().resolve()\n\n    post_segment = _safe_segment(post_id, \"no_post\")\n    video_segment = _safe_segment(video_id, \"no_video_id\")\n    if media_index is None or str(media_index).strip() == \"\":\n        media_segment = \"media_unknown\"\n    else:\n        media_segment = f\"media_{_safe_segment(media_index, 'unknown')}\"\n    return DEFAULT_OUTPUT_ROOT / post_segment / media_segment / video_segment\n\n\ndef _load_download_comments_as_text():\n    if not COMMENTS_SCRIPT.exists():\n        raise FileNotFoundError(f\"youtube_comments.py was not found: {COMMENTS_SCRIPT}\")\n\n    api_root = str(API_ROOT)\n    if api_root not in sys.path:\n        sys.path.insert(0, api_root)\n\n    module = importlib.import_module(\"scripts.youtube_comments\")\n    downloader = getattr(module, \"download_comments_as_text\", None)\n    if downloader is None:\n        raise AttributeError(\"scripts.youtube_comments.download_comments_as_text is missing\")\n    return downloader\n\n\ndef _candidate_json_paths(text_path: Path, output_dir: Path) -> list[Path]:\n    candidates: list[Path] = []\n    if text_path.name:\n        candidates.append(text_path.with_suffix(\".json\"))\n    candidates.extend(sorted(output_dir.glob(\"*_comments.json\"), key=lambda path: path.stat().st_mtime, reverse=True))\n    candidates.extend(sorted(output_dir.glob(\"*.info.json\"), key=lambda path: path.stat().st_mtime, reverse=True))\n\n    unique: list[Path] = []\n    seen: set[str] = set()\n    for path in candidates:\n        key = str(path.resolve()) if path.exists() else str(path)\n        if key not in seen:\n            seen.add(key)\n            unique.append(path)\n    return unique\n\n\ndef _load_comments(text_path: str, output_dir: Path, max_comments: int) -> tuple[list[dict[str, Any]], str]:\n    text_file = Path(text_path)\n    for json_path in _candidate_json_paths(text_file, output_dir):\n        if not json_path.exists():\n            continue\n        with json_path.open(\"r\", encoding=\"utf-8\") as handle:\n            data = json.load(handle)\n\n        if isinstance(data, dict):\n            raw_comments = data.get(\"comments\", [])\n        elif isinstance(data, list):\n            raw_comments = data\n        else:\n            raw_comments = []\n\n        comments = [_normalize_comment(comment, index) for index, comment in enumerate(raw_comments[:max_comments], 1)]\n        return comments, str(json_path)\n\n    return [], \"\"\n\n\ndef _normalize_comment(comment: Any, index: int) -> dict[str, Any]:\n    if not isinstance(comment, dict):\n        return {\n            \"index\": index,\n            \"author\": \"\",\n            \"text\": str(comment),\n            \"likes\": 0,\n            \"time\": \"\",\n            \"isReply\": False,\n        }\n\n    return {\n        \"index\": index,\n        \"author\": str(comment.get(\"author\", \"\") or \"\"),\n        \"text\": str(comment.get(\"text\", \"\") or \"\"),\n        \"likes\": int(comment.get(\"likes\", comment.get(\"like_count\", 0)) or 0),\n        \"time\": str(comment.get(\"time\", comment.get(\"time_text\", \"\")) or \"\"),\n        \"isReply\": bool(comment.get(\"is_reply\", comment.get(\"isReply\", False))),\n    }\n\n\ndef _base_result(url: str, video_id: str, post_id: Any, media_index: Any, output_dir: Path, max_comments: int) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"url\": url,\n        \"videoId\": video_id,\n        \"video_id\": video_id,\n        \"postId\": post_id,\n        \"post_id\": post_id,\n        \"mediaIndex\": media_index,\n        \"media_index\": media_index,\n        \"comments\": [],\n        \"textPath\": \"\",\n        \"jsonPath\": \"\",\n        \"outputDir\": str(output_dir),\n        \"count\": 0,\n        \"maxComments\": max_comments,\n        \"error\": \"\",\n        \"scriptPath\": str(COMMENTS_SCRIPT),\n        \"scriptFunction\": \"scripts.youtube_comments.download_comments_as_text\",\n        \"materialKind\": \"youtube_comments\",\n        \"contextRole\": \"surrounding_context\",\n        \"dbSaved\": False,\n    }\n\n\ndef fetch_youtube_comments(\n    url: str,\n    post_id: str | None = None,\n    media_index: int | str | None = None,\n    output_dir: str | None = None,\n    max_comments: int = DEFAULT_MAX_COMMENTS,\n) -> dict[str, Any]:\n    clean_url = (url or \"\").strip()\n    max_count = _coerce_max_comments(max_comments)\n    video_id = extract_video_id(clean_url)\n    destination = _build_output_dir(video_id, post_id=post_id, media_index=media_index, output_dir=output_dir)\n    result = _base_result(clean_url, video_id, post_id, media_index, destination, max_count)\n\n    if not clean_url:\n        result[\"error\"] = \"url is required\"\n        return result\n    if not video_id:\n        result[\"error\"] = \"could not extract a YouTube video id from url\"\n        return result\n\n    try:\n        destination.mkdir(parents=True, exist_ok=True)\n        downloader = _load_download_comments_as_text()\n        text_path = downloader(clean_url, output_dir=str(destination), max_comments=max_count)\n        if not text_path:\n            result[\"error\"] = \"youtube_comments.py completed but did not return a text path\"\n            return result\n\n        comments, json_path = _load_comments(text_path, destination, max_count)\n        result.update(\n            {\n                \"ok\": True,\n                \"comments\": comments,\n                \"textPath\": str(Path(text_path)),\n                \"jsonPath\": json_path,\n                \"count\": len(comments),\n                \"error\": \"\",\n            }\n        )\n        return result\n    except Exception as exc:\n        result[\"error\"] = str(exc)\n        return result\n\n\ndef run(payload: dict[str, Any] | None = None, **kwargs: Any) -> dict[str, Any]:\n    data = dict(payload or {})\n    data.update(kwargs)\n    return fetch_youtube_comments(\n        url=data.get(\"url\", \"\"),\n        post_id=data.get(\"post_id\", data.get(\"postId\")),\n        media_index=data.get(\"media_index\", data.get(\"mediaIndex\")),\n        output_dir=data.get(\"output_dir\", data.get(\"outputDir\")),\n        max_comments=data.get(\"max_comments\", data.get(\"maxComments\", DEFAULT_MAX_COMMENTS)),\n    )\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Fetch YouTube comments as surrounding context JSON.\")\n    parser.add_argument(\"url\")\n    parser.add_argument(\"--post-id\", default=None)\n    parser.add_argument(\"--media-index\", default=None)\n    parser.add_argument(\"--output-dir\", default=None)\n    parser.add_argument(\"--max-comments\", type=int, default=DEFAULT_MAX_COMMENTS)\n    args = parser.parse_args(argv)\n\n    result = fetch_youtube_comments(\n        args.url,\n        post_id=args.post_id,\n        media_index=args.media_index,\n        output_dir=args.output_dir,\n        max_comments=args.max_comments,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result[\"ok\"] else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
