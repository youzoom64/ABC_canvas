    {
      "id": "node-e252eb2365",
      "title": "動画代表フレーム抽出ポワン",
      "body": "動画ファイル保存ポワンの結果を受け取り、既存の高度な動画サムネイル生成コード C:\\project_root\\app_workspaces\\API\\scripts\\video_thumbnails.py の generate() を呼び出して、動画内容確認に使う代表サムネイルシートを生成する臓器ポワン。フレーム抽出をゼロから実装せず、既存コードの interval、frame_count、page_count、items_per_page、thumbnail_width などを利用する。LMStudio読解やDB保存は行わず、生成されたサムネイルシートのパスと元動画情報だけをJSONで返す。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport sys\nfrom collections.abc import Mapping\nfrom pathlib import Path\nfrom typing import Any\n\n\nAPI_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\")\nSOURCE_SCRIPT = API_ROOT / \"scripts\" / \"video_thumbnails.py\"\nDEFAULT_OUTPUT_DIR = Path(\"data\") / \"x_media\" / \"video_frames\"\n\nPATH_KEYS = (\n    \"local_path\",\n    \"localPath\",\n    \"video_path\",\n    \"videoPath\",\n    \"saved_path\",\n    \"savedPath\",\n    \"file_path\",\n    \"filePath\",\n    \"path\",\n)\nPOST_ID_KEYS = (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\")\nMEDIA_INDEX_KEYS = (\"media_index\", \"mediaIndex\", \"index\", \"ordinal\", \"position\")\nCOLLECTION_KEYS = (\n    \"videos\",\n    \"saved_videos\",\n    \"savedVideos\",\n    \"media_assets\",\n    \"mediaAssets\",\n    \"media\",\n    \"files\",\n    \"assets\",\n    \"results\",\n    \"items\",\n)\n\n\nclass VideoThumbnailSheetError(RuntimeError):\n    pass\n\n\ndef generate_thumbnail_sheets(\n    video_input: Any,\n    *,\n    local_path: str = \"\",\n    output_dir: str | Path = DEFAULT_OUTPUT_DIR,\n    interval: float = 10.0,\n    frame_count: int | None = None,\n    page_count: int | None = None,\n    items_per_page: int | None = None,\n    thumbnail_width: int | None = None,\n    thumbnail_scale: float | None = None,\n    output_width: int = 1920,\n    output_height: int = 1080,\n    start_time: float = 0.0,\n    end_time: float | None = None,\n    font_size: int = 16,\n) -> dict[str, Any]:\n    record = select_video_record(video_input, override_local_path=local_path)\n    video_path = require_local_video_path(record)\n    destination = build_output_dir(\n        Path(output_dir),\n        video_path=video_path,\n        post_id=first_text(record, POST_ID_KEYS),\n        media_index=first_int(record, MEDIA_INDEX_KEYS),\n    )\n    destination.mkdir(parents=True, exist_ok=True)\n\n    generate = import_video_thumbnail_generate()\n    generated = generate(\n        str(video_path),\n        str(destination),\n        interval=interval,\n        frame_count=frame_count,\n        page_count=page_count,\n        items_per_page=items_per_page,\n        thumbnail_width=thumbnail_width,\n        thumbnail_scale=thumbnail_scale,\n        output_width=output_width,\n        output_height=output_height,\n        start_time=start_time,\n        end_time=end_time,\n        font_size=font_size,\n    )\n\n    paths = generated if isinstance(generated, list) else [generated]\n    sheets = [sheet_info(Path(path)) for path in paths]\n    return {\n        \"ok\": True,\n        \"postId\": first_text(record, POST_ID_KEYS),\n        \"mediaIndex\": first_int(record, MEDIA_INDEX_KEYS),\n        \"videoPath\": display_path(video_path),\n        \"sheets\": sheets,\n        \"sourceScript\": display_path(SOURCE_SCRIPT),\n        \"options\": {\n            \"interval\": interval,\n            \"frameCount\": frame_count,\n            \"pageCount\": page_count,\n            \"itemsPerPage\": items_per_page,\n            \"thumbnailWidth\": thumbnail_width,\n            \"thumbnailScale\": thumbnail_scale,\n            \"outputWidth\": output_width,\n            \"outputHeight\": output_height,\n            \"startTime\": start_time,\n            \"endTime\": end_time,\n            \"fontSize\": font_size,\n        },\n    }\n\n\ndef import_video_thumbnail_generate():\n    if not SOURCE_SCRIPT.exists():\n        raise VideoThumbnailSheetError(f\"video_thumbnails.py not found: {SOURCE_SCRIPT}\")\n    api_root_text = str(API_ROOT)\n    if api_root_text not in sys.path:\n        sys.path.insert(0, api_root_text)\n    try:\n        from scripts.video_thumbnails import generate\n    except Exception as exc:\n        raise VideoThumbnailSheetError(f\"failed to import scripts.video_thumbnails.generate: {exc}\") from exc\n    return generate\n\n\ndef select_video_record(video_input: Any, *, override_local_path: str = \"\") -> dict[str, Any]:\n    if override_local_path:\n        base = dict(video_input) if isinstance(video_input, Mapping) else {}\n        return {**base, \"local_path\": override_local_path}\n    if isinstance(video_input, str):\n        return {\"local_path\": video_input}\n    if isinstance(video_input, Mapping):\n        record = dict(video_input)\n        if first_path_value(record):\n            return record\n        for key in COLLECTION_KEYS:\n            value = record.get(key)\n            try:\n                return select_video_record(value)\n            except VideoThumbnailSheetError:\n                pass\n        for value in record.values():\n            if isinstance(value, (Mapping, list)):\n                try:\n                    return select_video_record(value)\n                except VideoThumbnailSheetError:\n                    pass\n    if isinstance(video_input, list):\n        for item in video_input:\n            try:\n                return select_video_record(item)\n            except VideoThumbnailSheetError:\n                pass\n    raise VideoThumbnailSheetError(\"input JSON did not contain a local video path\")\n\n\ndef first_path_value(record: Mapping[str, Any]) -> str:\n    for key in PATH_KEYS:\n        value = record.get(key)\n        if isinstance(value, str):\n            clean = value.strip()\n            if clean and not clean.lower().startswith((\"http://\", \"https://\", \"data:\")):\n                return clean\n    return \"\"\n\n\ndef require_local_video_path(record: Mapping[str, Any]) -> Path:\n    value = first_path_value(record)\n    if not value:\n        raise VideoThumbnailSheetError(\"local video path is required\")\n    path = Path(value).expanduser()\n    if not path.is_absolute():\n        path = (Path.cwd() / path).resolve()\n    if not path.exists():\n        raise VideoThumbnailSheetError(f\"video file does not exist: {path}\")\n    if not path.is_file():\n        raise VideoThumbnailSheetError(f\"video path is not a file: {path}\")\n    return path\n\n\ndef build_output_dir(base: Path, *, video_path: Path, post_id: str, media_index: int | None) -> Path:\n    media_part = str(media_index) if media_index is not None else \"0\"\n    post_part = safe_slug(post_id, fallback=\"no-post\")\n    stem = safe_slug(video_path.stem, fallback=\"video\")\n    digest = hashlib.sha256(str(video_path.resolve()).encode(\"utf-8\")).hexdigest()[:10]\n    return base / f\"{post_part}_m{media_part}_{stem}_{digest}\"\n\n\ndef sheet_info(path: Path) -> dict[str, Any]:\n    resolved = path.resolve()\n    width, height = image_size(resolved)\n    return {\n        \"kind\": \"thumbnail_sheet\",\n        \"localPath\": display_path(resolved),\n        \"width\": width,\n        \"height\": height,\n        \"bytes\": resolved.stat().st_size if resolved.exists() else None,\n        \"sha256\": file_sha256(resolved) if resolved.exists() else \"\",\n    }\n\n\ndef image_size(path: Path) -> tuple[int | None, int | None]:\n    try:\n        from PIL import Image\n\n        with Image.open(path) as image:\n            return int(image.width), int(image.height)\n    except Exception:\n        return None, None\n\n\ndef first_text(record: Mapping[str, Any], keys: tuple[str, ...]) -> str:\n    for key in keys:\n        value = record.get(key)\n        if value is not None:\n            text = str(value).strip()\n            if text:\n                return text\n    return \"\"\n\n\ndef first_int(record: Mapping[str, Any], keys: tuple[str, ...]) -> int | None:\n    for key in keys:\n        value = record.get(key)\n        try:\n            return int(value)\n        except (TypeError, ValueError):\n            continue\n    return None\n\n\ndef safe_slug(value: Any, *, fallback: str) -> str:\n    text = str(value or \"\").strip()\n    if not text:\n        return fallback\n    allowed = []\n    for char in text:\n        if char.isalnum() or char in (\"-\", \"_\"):\n            allowed.append(char)\n        else:\n            allowed.append(\"_\")\n    slug = \"\".join(allowed).strip(\"_\")\n    return slug[:80] or fallback\n\n\ndef file_sha256(path: Path) -> str:\n    digest = hashlib.sha256()\n    with path.open(\"rb\") as handle:\n        for chunk in iter(lambda: handle.read(1024 * 1024), b\"\"):\n            digest.update(chunk)\n    return digest.hexdigest()\n\n\ndef display_path(path: Path) -> str:\n    try:\n        return str(path.resolve())\n    except OSError:\n        return str(path)\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        return json.load(sys.stdin)\n    path = Path(value)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(\n        description=\"Generate video thumbnail sheets through existing API scripts.video_thumbnails.generate.\"\n    )\n    parser.add_argument(\"--input-json\", default=\"-\")\n    parser.add_argument(\"--local-path\", default=\"\")\n    parser.add_argument(\"--out-dir\", default=str(DEFAULT_OUTPUT_DIR))\n    parser.add_argument(\"--interval\", type=float, default=10.0)\n    parser.add_argument(\"--frame-count\", type=int, default=None)\n    parser.add_argument(\"--page-count\", type=int, default=None)\n    parser.add_argument(\"--items-per-page\", type=int, default=None)\n    parser.add_argument(\"--thumbnail-width\", type=int, default=None)\n    parser.add_argument(\"--thumbnail-scale\", type=float, default=None)\n    parser.add_argument(\"--output-width\", type=int, default=1920)\n    parser.add_argument(\"--output-height\", type=int, default=1080)\n    parser.add_argument(\"--start-time\", type=float, default=0.0)\n    parser.add_argument(\"--end-time\", type=float, default=None)\n    parser.add_argument(\"--font-size\", type=int, default=16)\n    args = parser.parse_args(argv)\n\n    try:\n        payload = load_json_arg(args.input_json)\n        result = generate_thumbnail_sheets(\n            payload,\n            local_path=args.local_path,\n            output_dir=args.out_dir,\n            interval=args.interval,\n            frame_count=args.frame_count,\n            page_count=args.page_count,\n            items_per_page=args.items_per_page,\n            thumbnail_width=args.thumbnail_width,\n            thumbnail_scale=args.thumbnail_scale,\n            output_width=args.output_width,\n            output_height=args.output_height,\n            start_time=args.start_time,\n            end_time=args.end_time,\n            font_size=args.font_size,\n        )\n    except Exception as exc:\n        result = {\"ok\": False, \"error\": str(exc), \"sourceScript\": display_path(SOURCE_SCRIPT)}\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
