    {
      "id": "node-a4f8047baa",
      "title": "引用元到達ポワン",
      "body": "対象投稿または返信チェーン上の投稿に引用投稿ID、引用URL、参照カードなどの引用元を示す情報がある時、その引用元投稿へ到達する臓器ポワン。目の前の投稿本文だけで発端を決めず、引用元として示された投稿を取得対象にして、topic_origin候補として扱える形にする。引用元が削除済み、非公開、取得不能の場合は、到達できなかった理由を残す。引用元のさらに引用や複数候補の優先順位づけは自分だけで抱えず、上位の引用・リポスト発端追跡ポワンや別の子ポワンへ渡す。",
      "powanKind": "organ",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\ntype UnknownRecord = Record<string, unknown>;\n\ntype QuoteCandidate = {\n  ref: PostRef;\n  rank: number;\n  order: number;\n};\n\nconst RAW_QUOTE_ID_PATHS: readonly (readonly string[])[] = [\n  [\"quotedPostId\"],\n  [\"quoted_post_id\"],\n  [\"quoted_status_id\"],\n  [\"quoted_status_id_str\"],\n  [\"quoted_tweet_id\"],\n  [\"quoted_tweet_id_str\"],\n  [\"quoteTweetId\"],\n  [\"quote_tweet_id\"],\n  [\"legacy\", \"quoted_status_id\"],\n  [\"legacy\", \"quoted_status_id_str\"],\n  [\"quoted_status\", \"id\"],\n  [\"quoted_status\", \"id_str\"],\n  [\"quoted_status\", \"rest_id\"],\n  [\"quoted_tweet\", \"id\"],\n  [\"quoted_tweet\", \"id_str\"],\n  [\"quoted_tweet\", \"rest_id\"],\n  [\"quoted_status_result\", \"result\", \"rest_id\"],\n  [\"quoted_status_result\", \"result\", \"legacy\", \"id_str\"],\n  [\"quoted_status_result\", \"result\", \"tweet\", \"rest_id\"],\n  [\"quoted_status_result\", \"result\", \"tweet\", \"legacy\", \"id_str\"],\n];\n\nconst RAW_QUOTE_URL_PATHS: readonly (readonly string[])[] = [\n  [\"quotedStatusUrl\"],\n  [\"quoted_status_url\"],\n  [\"quotedTweetUrl\"],\n  [\"quoted_tweet_url\"],\n  [\"quoteTweetUrl\"],\n  [\"quote_tweet_url\"],\n  [\"quoted_status_permalink\", \"expanded\"],\n  [\"quoted_status_permalink\", \"url\"],\n  [\"legacy\", \"quoted_status_permalink\", \"expanded\"],\n  [\"legacy\", \"quoted_status_permalink\", \"url\"],\n  [\"quoted_status\", \"url\"],\n  [\"quoted_tweet\", \"url\"],\n];\n\n/**\n * Finds the post explicitly indicated as this post's quote source.\n *\n * This organ does not fetch the post and does not follow quote chains. It only\n * turns quote-shaped fields, quote cards, or structured post URLs into a PostRef.\n */\nexport function getQuoteSourceRef(post: PostLike): PostRef | null {\n  const candidates: QuoteCandidate[] = [];\n  const push = createCandidateCollector(candidates);\n\n  const directQuotedId = normalizePostId(post.quotedPostId);\n  if (directQuotedId) {\n    push({\n      kind: \"quote_source\",\n      postId: directQuotedId,\n      evidence: \"post.quotedPostId\",\n      confidence: 1,\n    }, 100);\n  }\n\n  for (const path of RAW_QUOTE_ID_PATHS) {\n    const rawId = normalizePostId(readPath(post.raw, path));\n    if (rawId) {\n      push({\n        kind: \"quote_source\",\n        postId: rawId,\n        evidence: `raw.${path.join(\".\")}`,\n        confidence: 0.92,\n      }, 90);\n    }\n  }\n\n  for (const path of RAW_QUOTE_URL_PATHS) {\n    const rawUrl = normalizeUrl(readPath(post.raw, path));\n    const parsed = rawUrl ? parsePostStatusUrl(rawUrl) : null;\n    if (parsed) {\n      push({\n        kind: \"quote_source\",\n        postId: parsed.postId,\n        url: parsed.url,\n        evidence: `raw.${path.join(\".\")}`,\n        confidence: 0.88,\n      }, 86);\n    }\n  }\n\n  collectQuoteSignals(post.raw, \"raw\", false, push, {\n    allowUnhintedStatusUrl: false,\n    baseRank: 76,\n    idConfidence: 0.74,\n    urlConfidence: 0.72,\n  });\n\n  if (Array.isArray(post.cards)) {\n    post.cards.forEach((card, index) => {\n      collectQuoteSignals(card, `cards[${index}]`, false, push, {\n        allowUnhintedStatusUrl: true,\n        baseRank: 70,\n        idConfidence: 0.7,\n        urlConfidence: 0.68,\n      });\n    });\n  }\n\n  if (Array.isArray(post.urls)) {\n    post.urls.forEach((url, index) => {\n      const parsed = parsePostStatusUrl(url);\n      if (parsed) {\n        push({\n          kind: \"url_post\",\n          postId: parsed.postId,\n          url: parsed.url,\n          evidence: `post.urls[${index}]`,\n          confidence: 0.64,\n        }, 62);\n      }\n    });\n  }\n\n  if (candidates.length === 0) {\n    return null;\n  }\n\n  candidates.sort((left, right) => {\n    if (right.rank !== left.rank) return right.rank - left.rank;\n    if (right.ref.confidence !== left.ref.confidence) return right.ref.confidence - left.ref.confidence;\n    return left.order - right.order;\n  });\n\n  return candidates[0].ref;\n}\n\nfunction createCandidateCollector(candidates: QuoteCandidate[]): (ref: PostRef, rank: number) => void {\n  let order = 0;\n  const seen = new Map<string, number>();\n\n  return (ref: PostRef, rank: number): void => {\n    const normalized = normalizeRef(ref);\n    if (!normalized) return;\n\n    const key = `${normalized.kind}:${normalized.postId ?? \"\"}:${normalized.url ?? \"\"}`;\n    const existingIndex = seen.get(key);\n    if (existingIndex === undefined) {\n      candidates.push({ ref: normalized, rank, order });\n      seen.set(key, candidates.length - 1);\n      order += 1;\n      return;\n    }\n\n    const existing = candidates[existingIndex];\n    if (rank > existing.rank || (rank === existing.rank && normalized.confidence > existing.ref.confidence)) {\n      candidates[existingIndex] = { ref: normalized, rank, order: existing.order };\n    }\n  };\n}\n\nfunction normalizeRef(ref: PostRef): PostRef | null {\n  const postId = normalizePostId(ref.postId);\n  const url = normalizeUrl(ref.url);\n  if (!postId && !url) return null;\n\n  const normalized: PostRef = {\n    kind: ref.kind,\n    evidence: ref.evidence.trim() || \"unknown\",\n    confidence: clampConfidence(ref.confidence),\n  };\n  if (postId) normalized.postId = postId;\n  if (url) normalized.url = url;\n  return normalized;\n}\n\nfunction collectQuoteSignals(\n  value: unknown,\n  origin: string,\n  quoteContext: boolean,\n  push: (ref: PostRef, rank: number) => void,\n  options: {\n    allowUnhintedStatusUrl: boolean;\n    baseRank: number;\n    idConfidence: number;\n    urlConfidence: number;\n  },\n): void {\n  const seen = new Set<object>();\n\n  const visit = (current: unknown, path: string, depth: number, hasQuoteHint: boolean): void => {\n    if (depth > 5) return;\n\n    const directUrl = normalizeUrl(current);\n    if (directUrl && (hasQuoteHint || options.allowUnhintedStatusUrl)) {\n      const parsed = parsePostStatusUrl(directUrl);\n      if (parsed) {\n        push({\n          kind: hasQuoteHint ? \"quote_source\" : \"url_post\",\n          postId: parsed.postId,\n          url: parsed.url,\n          evidence: path,\n          confidence: hasQuoteHint ? options.urlConfidence : Math.max(0.55, options.urlConfidence - 0.08),\n        }, hasQuoteHint ? options.baseRank : options.baseRank - 8);\n      }\n    }\n\n    if (!isRecord(current) && !Array.isArray(current)) return;\n    if (typeof current === \"object\" && current !== null) {\n      if (seen.has(current)) return;\n      seen.add(current);\n    }\n\n    if (Array.isArray(current)) {\n      current.forEach((item, index) => visit(item, `${path}[${index}]`, depth + 1, hasQuoteHint));\n      return;\n    }\n\n    for (const [key, child] of Object.entries(current)) {\n      const childPath = `${path}.${key}`;\n      const nextQuoteHint = hasQuoteHint || isQuoteKey(key);\n\n      if (nextQuoteHint && isPostIdKey(key)) {\n        const postId = normalizePostId(child);\n        if (postId) {\n          push({\n            kind: \"quote_source\",\n            postId,\n            evidence: childPath,\n            confidence: options.idConfidence,\n          }, options.baseRank + 2);\n        }\n      }\n\n      if ((nextQuoteHint || options.allowUnhintedStatusUrl) && isUrlKey(key)) {\n        const url = normalizeUrl(child);\n        const parsed = url ? parsePostStatusUrl(url) : null;\n        if (parsed) {\n          push({\n            kind: nextQuoteHint ? \"quote_source\" : \"url_post\",\n            postId: parsed.postId,\n            url: parsed.url,\n            evidence: childPath,\n            confidence: nextQuoteHint ? options.urlConfidence : Math.max(0.55, options.urlConfidence - 0.08),\n          }, nextQuoteHint ? options.baseRank : options.baseRank - 8);\n        }\n      }\n\n      visit(child, childPath, depth + 1, nextQuoteHint);\n    }\n  };\n\n  visit(value, origin, 0, quoteContext);\n}\n\nfunction readPath(value: unknown, path: readonly string[]): unknown {\n  let current = value;\n  for (const segment of path) {\n    if (!isRecord(current)) return undefined;\n    current = current[segment];\n  }\n  return current;\n}\n\nfunction isRecord(value: unknown): value is UnknownRecord {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n}\n\nfunction isQuoteKey(key: string): boolean {\n  const normalized = key.toLowerCase();\n  return normalized.includes(\"quote\") || normalized.includes(\"quoted\");\n}\n\nfunction isPostIdKey(key: string): boolean {\n  const normalized = key.toLowerCase();\n  return normalized === \"id\"\n    || normalized === \"id_str\"\n    || normalized === \"rest_id\"\n    || normalized === \"postid\"\n    || normalized === \"post_id\"\n    || normalized === \"tweetid\"\n    || normalized === \"tweet_id\"\n    || normalized === \"statusid\"\n    || normalized === \"status_id\";\n}\n\nfunction isUrlKey(key: string): boolean {\n  const normalized = key.toLowerCase();\n  return normalized === \"url\"\n    || normalized === \"expanded\"\n    || normalized === \"expanded_url\"\n    || normalized === \"display_url\"\n    || normalized.endsWith(\"url\")\n    || normalized.endsWith(\"uri\")\n    || normalized.includes(\"permalink\");\n}\n\nfunction normalizePostId(value: unknown): string | undefined {\n  if (typeof value === \"string\") {\n    const trimmed = value.trim();\n    return trimmed.length > 0 ? trimmed : undefined;\n  }\n\n  if (typeof value === \"number\" && Number.isSafeInteger(value) && value >= 0) {\n    return String(value);\n  }\n\n  return undefined;\n}\n\nfunction normalizeUrl(value: unknown): string | undefined {\n  if (typeof value !== \"string\") return undefined;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : undefined;\n}\n\nfunction parsePostStatusUrl(value: string): { postId: string; url: string } | null {\n  const trimmed = value.trim();\n  if (!trimmed) return null;\n\n  const parsedFromUrl = parseWithUrl(trimmed);\n  if (parsedFromUrl) return parsedFromUrl;\n\n  const match = trimmed.match(/(?:https?:\\/\\/)?(?:mobile\\.)?(?:x|twitter)\\.com\\/[^\\s/]+\\/status(?:es)?\\/(\\d+)/i)\n    ?? trimmed.match(/(?:https?:\\/\\/)?(?:mobile\\.)?(?:x|twitter)\\.com\\/i\\/web\\/status\\/(\\d+)/i);\n\n  if (!match) return null;\n  return { postId: match[1], url: trimmed };\n}\n\nfunction parseWithUrl(value: string): { postId: string; url: string } | null {\n  try {\n    const parsed = new URL(value);\n    const host = parsed.hostname.toLowerCase();\n    const isSupportedHost = host === \"x.com\"\n      || host === \"twitter.com\"\n      || host === \"mobile.twitter.com\"\n      || host.endsWith(\".x.com\")\n      || host.endsWith(\".twitter.com\");\n    if (!isSupportedHost) return null;\n\n    const statusMatch = parsed.pathname.match(/^\\/[^/]+\\/status(?:es)?\\/(\\d+)/i)\n      ?? parsed.pathname.match(/^\\/i\\/web\\/status\\/(\\d+)/i);\n    if (!statusMatch) return null;\n\n    return { postId: statusMatch[1], url: value };\n  } catch {\n    return null;\n  }\n}\n\nfunction clampConfidence(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  if (value < 0) return 0;\n  if (value > 1) return 1;\n  return value;\n}",
      "parent": "node-2e4b5cd891",
      "children": [],
      "style": {
        "shape": "cloud",
        "color": "#ffffff",
        "accent": "#8ddcff",
        "glow": true,
        "blur": true,
        "motion": "soft"
      },
      "layout": {
        "x": 4742,
        "y": 4757,
