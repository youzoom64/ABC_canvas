    {
      "id": "node-13724a9a39",
      "title": "リプ元到達ポワン",
      "body": "返信投稿から返信元へ到達する流れを束ねる神経ポワン。収集済みDBやraw_jsonから返信元が分かる場合は収集データ返信元抽出ポワンを使い、画面上で辿る場合は返信元行き先発見ポワンで replyToUrl を見つけ、返信元ページ到達ポワンで実際にその投稿ページへ移動して表示確認する。自分自身は1つの巨大な処理を持たず、返信元発見と到達確認の臓器をつなぐ。",
      "powanKind": "nerve",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\nexport type ReplyParentDestination = {\n  replyToUrl?: string;\n  replyToPostId?: string;\n  evidence?: string | string[];\n  confidence?: number;\n};\n\nexport type ReplyParentNerveAdapters = {\n  extractFromCollectedData?: (post: PostLike) => PostRef | null;\n  findReplyParentDestination?: (post: PostLike) => ReplyParentDestination | null;\n  openReplyParentPage?: (destination: ReplyParentDestination) => unknown;\n};\n\ntype ReplyParentCandidate = {\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nconst POST_URL_RE = /https?:\\/\\/(?:www\\.)?(?:x\\.com|twitter\\.com)\\/[^\\s/?#]+\\/status(?:es)?\\/(\\d+)/i;\nconst POST_ID_RE = /^\\d{5,}$/;\n\nconst RAW_RECORD_PATHS: string[][] = [\n  [],\n  [\"legacy\"],\n  [\"post\"],\n  [\"post\", \"legacy\"],\n  [\"tweet\"],\n  [\"tweet\", \"legacy\"],\n  [\"status\"],\n  [\"status\", \"legacy\"],\n  [\"result\"],\n  [\"result\", \"legacy\"],\n  [\"tweetResult\", \"result\"],\n  [\"tweetResult\", \"result\", \"legacy\"],\n  [\"tweet_results\", \"result\"],\n  [\"tweet_results\", \"result\", \"legacy\"],\n  [\"data\", \"tweet\"],\n  [\"data\", \"tweet\", \"legacy\"],\n  [\"data\", \"tweetResult\", \"result\"],\n  [\"data\", \"tweetResult\", \"result\", \"legacy\"],\n];\n\nconst REPLY_ID_KEYS = [\n  \"inReplyToPostId\",\n  \"in_reply_to_post_id\",\n  \"inReplyToId\",\n  \"in_reply_to_id\",\n  \"inReplyToStatusId\",\n  \"in_reply_to_status_id\",\n  \"in_reply_to_status_id_str\",\n  \"inReplyToTweetId\",\n  \"in_reply_to_tweet_id\",\n  \"replyToPostId\",\n  \"reply_to_post_id\",\n  \"replyToStatusId\",\n  \"reply_to_status_id\",\n  \"parentPostId\",\n  \"parent_post_id\",\n  \"parentStatusId\",\n  \"parent_status_id\",\n];\n\nconst REPLY_URL_KEYS = [\n  \"inReplyToUrl\",\n  \"in_reply_to_url\",\n  \"inReplyToPostUrl\",\n  \"in_reply_to_post_url\",\n  \"replyToUrl\",\n  \"reply_to_url\",\n  \"replyToPostUrl\",\n  \"reply_to_post_url\",\n  \"parentUrl\",\n  \"parent_url\",\n  \"parentPostUrl\",\n  \"parent_post_url\",\n  \"parentStatusUrl\",\n  \"parent_status_url\",\n];\n\nconst REPLY_OBJECT_KEYS = [\n  \"inReplyToPost\",\n  \"in_reply_to_post\",\n  \"inReplyToStatus\",\n  \"in_reply_to_status\",\n  \"replyToPost\",\n  \"reply_to_post\",\n  \"replyToStatus\",\n  \"reply_to_status\",\n  \"replyingToPost\",\n  \"replying_to_post\",\n  \"parentPost\",\n  \"parent_post\",\n  \"parentStatus\",\n  \"parent_status\",\n];\n\nconst CONVERSATION_ID_KEYS = [\n  \"conversationId\",\n  \"conversation_id\",\n  \"conversation_id_str\",\n  \"conversationIdStr\",\n  \"conversationRootId\",\n  \"conversation_root_id\",\n];\n\nexport function getReplyParentRef(post: PostLike): PostRef | null {\n  try {\n    return getReplyParentRefFromCollectedData(post);\n  } catch {\n    return null;\n  }\n}\n\nexport function getReplyParentRefFromCollectedData(post: PostLike): PostRef | null {\n  const normalizedPost = normalizePost(post);\n  const records = rawRecordsFromPost(normalizedPost);\n  const candidates: ReplyParentCandidate[] = [];\n\n  addCandidate(candidates, fromExplicitReplyId(normalizedPost.inReplyToPostId));\n  collectRawReplyCandidates(records, candidates);\n  addCandidate(candidates, fromConversationFallback(normalizedPost, records));\n\n  const best = chooseBestCandidate(candidates, normalizedPost);\n  return best ? toReplyParentRef(best) : null;\n}\n\nexport function createReplyParentRefGetter(\n  adapters: Pick<ReplyParentNerveAdapters, \"extractFromCollectedData\"> = {},\n): (post: PostLike) => PostRef | null {\n  return (post: PostLike): PostRef | null => {\n    try {\n      const adapted = normalizeReplyParentRef(adapters.extractFromCollectedData?.(post));\n      return adapted ?? getReplyParentRef(post);\n    } catch {\n      return getReplyParentRef(post);\n    }\n  };\n}\n\nexport function normalizeReplyParentDestination(destination: ReplyParentDestination | null | undefined): PostRef | null {\n  if (!destination || typeof destination !== \"object\") {\n    return null;\n  }\n\n  const postId = normalizePostId(destination.replyToPostId) ?? extractPostIdFromUrl(destination.replyToUrl);\n  const url = normalizeUrl(destination.replyToUrl);\n  if (!postId && !url) {\n    return null;\n  }\n\n  return {\n    kind: \"reply_parent\",\n    ...(postId ? { postId } : {}),\n    ...(url ? { url } : {}),\n    evidence: evidenceText(destination.evidence) ?? \"reply parent destination adapter returned a target\",\n    confidence: clampConfidence(destination.confidence ?? 0.72),\n  };\n}\n\nfunction fromExplicitReplyId(value: unknown): ReplyParentCandidate | null {\n  const postId = normalizePostId(value);\n  if (!postId) {\n    return null;\n  }\n\n  return {\n    postId,\n    evidence: \"inReplyToPostId field points to the reply parent\",\n    confidence: 0.98,\n  };\n}\n\nfunction collectRawReplyCandidates(records: Record<string, unknown>[], candidates: ReplyParentCandidate[]): void {\n  for (const record of records) {\n    const directId = firstPostId(record, REPLY_ID_KEYS);\n    if (directId) {\n      candidates.push({\n        postId: directId,\n        evidence: \"raw reply id field points to the reply parent\",\n        confidence: 0.92,\n      });\n    }\n\n    const directUrl = firstPostUrl(record, REPLY_URL_KEYS);\n    if (directUrl) {\n      candidates.push({\n        postId: extractPostIdFromUrl(directUrl),\n        url: directUrl,\n        evidence: \"raw reply URL field points to the reply parent\",\n        confidence: 0.84,\n      });\n    }\n\n    const nested = firstRecord(record, REPLY_OBJECT_KEYS);\n    if (nested) {\n      addCandidate(candidates, fromNestedReplyObject(nested));\n    }\n  }\n}\n\nfunction fromNestedReplyObject(record: Record<string, unknown>): ReplyParentCandidate | null {\n  const postId = firstPostId(record, [\n    \"id\",\n    \"id_str\",\n    \"postId\",\n    \"post_id\",\n    \"statusId\",\n    \"status_id\",\n    \"tweetId\",\n    \"tweet_id\",\n  ]);\n  const url = firstPostUrl(record, [\"url\", \"permalink\", \"expandedUrl\", \"expanded_url\", \"statusUrl\", \"status_url\"]);\n  if (!postId && !url) {\n    return null;\n  }\n\n  return {\n    postId: postId ?? extractPostIdFromUrl(url),\n    url,\n    evidence: \"raw nested reply parent object is present\",\n    confidence: postId ? 0.88 : 0.8,\n  };\n}\n\nfunction fromConversationFallback(post: PostLike, records: Record<string, unknown>[]): ReplyParentCandidate | null {\n  const currentId = normalizePostId(post.id) ?? extractPostIdFromUrl(post.url);\n  for (const record of records) {\n    const conversationId = firstPostId(record, CONVERSATION_ID_KEYS);\n    if (!conversationId || conversationId === currentId || !hasReplySignal(post, records)) {\n      continue;\n    }\n\n    return {\n      postId: conversationId,\n      evidence: \"conversationId is the best available reply-thread fallback\",\n      confidence: 0.56,\n    };\n  }\n  return null;\n}\n\nfunction hasReplySignal(post: PostLike, records: Record<string, unknown>[]): boolean {\n  if (normalizePostId(post.inReplyToPostId)) {\n    return true;\n  }\n\n  for (const record of records) {\n    if (firstPostId(record, REPLY_ID_KEYS) || firstPostUrl(record, REPLY_URL_KEYS) || firstRecord(record, REPLY_OBJECT_KEYS)) {\n      return true;\n    }\n\n    const replyText = lowerString(firstString(record, [\n      \"replyingTo\",\n      \"replying_to\",\n      \"replyTo\",\n      \"reply_to\",\n      \"inReplyTo\",\n      \"in_reply_to\",\n      \"socialContext\",\n      \"social_context\",\n    ]));\n    if (replyText.includes(\"reply\") || replyText.includes(\"返信\")) {\n      return true;\n    }\n  }\n\n  return false;\n}\n\nfunction rawRecordsFromPost(post: PostLike): Record<string, unknown>[] {\n  const roots = rawRootsFromPost(post);\n  const records: Record<string, unknown>[] = [];\n  const seen = new Set<Record<string, unknown>>();\n\n  for (const root of roots) {\n    for (const path of RAW_RECORD_PATHS) {\n      const record = recordAtPath(root, path);\n      if (record && !seen.has(record)) {\n        seen.add(record);\n        records.push(record);\n      }\n    }\n  }\n\n  return records;\n}\n\nfunction rawRootsFromPost(post: PostLike): Record<string, unknown>[] {\n  const record = asRecord(post);\n  const rawInputs = [\n    post.raw,\n    record?.raw,\n    record?.raw_json,\n    record?.rawJson,\n    record?.rawData,\n    record?.sourceRaw,\n  ];\n\n  const roots: Record<string, unknown>[] = [];\n  const seen = new Set<Record<string, unknown>>();\n  for (const value of rawInputs) {\n    const root = asRecordOrJson(value);\n    if (root && !seen.has(root)) {\n      seen.add(root);\n      roots.push(root);\n    }\n  }\n  return roots;\n}\n\nfunction recordAtPath(root: Record<string, unknown>, path: string[]): Record<string, unknown> | null {\n  let current: Record<string, unknown> | null = root;\n  for (const key of path) {\n    if (!current) {\n      return null;\n    }\n    current = asRecord(current[key]);\n  }\n  return current;\n}\n\nfunction chooseBestCandidate(candidates: ReplyParentCandidate[], post: PostLike): ReplyParentCandidate | null {\n  const currentId = normalizePostId(post.id) ?? extractPostIdFromUrl(post.url);\n  const currentUrl = normalizeUrl(post.url);\n  const unique: ReplyParentCandidate[] = [];\n  const seen = new Set<string>();\n\n  for (const candidate of candidates) {\n    const url = normalizeUrl(candidate.url);\n    const postId = normalizePostId(candidate.postId) ?? extractPostIdFromUrl(url);\n    if (!postId && !url) {\n      continue;\n    }\n    if (postId && postId === currentId) {\n      continue;\n    }\n    if (url && currentUrl && url === currentUrl) {\n      continue;\n    }\n\n    const key = postId ?? url;\n    if (!key || seen.has(key)) {\n      continue;\n    }\n\n    seen.add(key);\n    unique.push({ ...candidate, postId, url, confidence: clampConfidence(candidate.confidence) });\n  }\n\n  unique.sort((left, right) => right.confidence - left.confidence);\n  return unique[0] ?? null;\n}\n\nfunction toReplyParentRef(candidate: ReplyParentCandidate): PostRef {\n  return {\n    kind: \"reply_parent\",\n    ...(candidate.postId ? { postId: candidate.postId } : {}),\n    ...(candidate.url ? { url: candidate.url } : {}),\n    evidence: candidate.evidence,\n    confidence: clampConfidence(candidate.confidence),\n  };\n}\n\nfunction normalizeReplyParentRef(ref: PostRef | null | undefined): PostRef | null {\n  if (!ref || typeof ref !== \"object\") {\n    return null;\n  }\n\n  const postId = normalizePostId(ref.postId) ?? extractPostIdFromUrl(ref.url);\n  const url = normalizeUrl(ref.url);\n  if (!postId && !url) {\n    return null;\n  }\n\n  return {\n    kind: \"reply_parent\",\n    ...(postId ? { postId } : {}),\n    ...(url ? { url } : {}),\n    evidence: cleanString(ref.evidence) ?? \"reply parent adapter returned a reference\",\n    confidence: clampConfidence(ref.confidence),\n  };\n}\n\nfunction normalizePost(post: PostLike | null | undefined): PostLike {\n  return post && typeof post === \"object\" ? post : {};\n}\n\nfunction addCandidate(candidates: ReplyParentCandidate[], candidate: ReplyParentCandidate | null): void {\n  if (candidate) {\n    candidates.push(candidate);\n  }\n}\n\nfunction asRecord(value: unknown): Record<string, unknown> | null {\n  if (typeof value !== \"object\" || value === null || Array.isArray(value)) {\n    return null;\n  }\n  return value as Record<string, unknown>;\n}\n\nfunction asRecordOrJson(value: unknown): Record<string, unknown> | null {\n  const record = asRecord(value);\n  if (record) {\n    return record;\n  }\n  if (typeof value !== \"string\" || !value.trim()) {\n    return null;\n  }\n\n  try {\n    return asRecord(JSON.parse(value));\n  } catch {\n    return null;\n  }\n}\n\nfunction firstRecord(record: Record<string, unknown>, keys: string[]): Record<string, unknown> | null {\n  for (const key of keys) {\n    const value = asRecord(record[key]);\n    if (value) {\n      return value;\n    }\n  }\n  return null;\n}\n\nfunction firstString(record: Record<string, unknown>, keys: string[]): string | undefined {\n  for (const key of keys) {\n    const value = cleanString(record[key]);\n    if (value) {\n      return value;\n    }\n  }\n  return undefined;\n}\n\nfunction firstPostId(record: Record<string, unknown>, keys: string[]): string | undefined {\n  for (const key of keys) {\n    const postId = normalizePostId(record[key]);\n    if (postId) {\n      return postId;\n    }\n  }\n  return undefined;\n}\n\nfunction firstPostUrl(record: Record<string, unknown>, keys: string[]): string | undefined {\n  for (const key of keys) {\n    const url = normalizeUrl(record[key]);\n    if (extractPostIdFromUrl(url)) {\n      return url;\n    }\n  }\n  return undefined;\n}\n\nfunction normalizePostId(value: unknown): string | undefined {\n  if (typeof value === \"number\" && Number.isSafeInteger(value) && value > 0) {\n    return String(value);\n  }\n  if (typeof value !== \"string\") {\n    return undefined;\n  }\n\n  const trimmed = value.trim();\n  return POST_ID_RE.test(trimmed) ? trimmed : undefined;\n}\n\nfunction normalizeUrl(value: unknown): string | undefined {\n  if (typeof value !== \"string\") {\n    return undefined;\n  }\n\n  const trimmed = value.trim();\n  if (!trimmed || !/^https?:\\/\\//i.test(trimmed)) {\n    return undefined;\n  }\n  return trimmed;\n}\n\nfunction extractPostIdFromUrl(url: unknown): string | undefined {\n  const normalizedUrl = normalizeUrl(url);\n  const match = normalizedUrl?.match(POST_URL_RE);\n  return match?.[1];\n}\n\nfunction cleanString(value: unknown): string | undefined {\n  if (typeof value !== \"string\") {\n    return undefined;\n  }\n  const cleaned = value.trim();\n  return cleaned || undefined;\n}\n\nfunction evidenceText(value: unknown): string | undefined {\n  if (Array.isArray(value)) {\n    return value.map(cleanString).filter((item): item is string => Boolean(item)).join(\"; \") || undefined;\n  }\n  return cleanString(value);\n}\n\nfunction lowerString(value: string | undefined): string {\n  return value?.toLowerCase() ?? \"\";\n}\n\nfunction clampConfidence(value: unknown): number {\n  if (typeof value !== \"number\" || Number.isNaN(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}",
