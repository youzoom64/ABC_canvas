    {
      "id": "node-0564ecf32f",
      "title": "YouTube音声文字起こしポワン",
      "body": "保存済みYouTube動画または音声ファイルを受け取り、既存のC:\\project_root\\app_workspaces\\API\\scripts\\transcriber_whisperx.pyを優先し、必要ならtranscriber.pyへフォールバックして音声文字起こしする臓器ポワン。字幕がない、字幕が不足している、または実音声確認が必要な時に使う。DB保存は行わない。",
      "powanKind": "organ",
      "code": "\"\"\"\nYouTube audio transcription organ powan.\n\nInput is a saved YouTube video/audio file. This organ calls the existing API\nworkspace scripts, prefers transcriber_whisperx.py, falls back to transcriber.py,\nand returns JSON material for the later DB-saving powan. It never saves to DB.\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport sys\nimport time\nimport traceback\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Optional\n\nAPI_ROOT = Path(os.environ.get(\"YOUTUBE_TRANSCRIBE_API_ROOT\", r\"C:\\project_root\\app_workspaces\\API\"))\nSCRIPTS_DIR = API_ROOT / \"scripts\"\nWHISPERX_SCRIPT = SCRIPTS_DIR / \"transcriber_whisperx.py\"\nFALLBACK_SCRIPT = SCRIPTS_DIR / \"transcriber.py\"\nTIMESTAMP_RE = re.compile(r\"^\\[(?P<start>\\d+(?:\\.\\d+)?)\\s*-\\s*(?P<end>\\d+(?:\\.\\d+)?)\\]\\s*(?P<text>.*)$\")\n\n\ndef _now() -> str:\n    return datetime.now(timezone.utc).isoformat()\n\n\ndef _bool(value: Any, default: bool) -> bool:\n    if value is None:\n        return default\n    if isinstance(value, bool):\n        return value\n    if isinstance(value, (int, float)):\n        return bool(value)\n    text = str(value).strip().lower()\n    if text in {\"1\", \"true\", \"yes\", \"y\", \"on\"}:\n        return True\n    if text in {\"0\", \"false\", \"no\", \"n\", \"off\"}:\n        return False\n    return default\n\n\ndef _int(value: Any, default: int) -> int:\n    try:\n        return default if value is None or value == \"\" else int(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef _float(value: Any, default: float) -> float:\n    try:\n        return default if value is None or value == \"\" else float(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef _pick(payload: dict[str, Any], *names: str, default: Any = None) -> Any:\n    for name in names:\n        if name in payload and payload[name] is not None:\n            return payload[name]\n    return default\n\n\ndef _ensure_api_import_path() -> None:\n    root = str(API_ROOT)\n    if root not in sys.path:\n        sys.path.insert(0, root)\n\n\ndef _media_path(file_path: str) -> Path:\n    if not file_path:\n        raise ValueError(\"file_path is required.\")\n    path = Path(file_path).expanduser()\n    if not path.is_absolute():\n        path = Path.cwd() / path\n    path = path.resolve()\n    if not path.exists():\n        raise FileNotFoundError(f\"media file does not exist: {path}\")\n    if not path.is_file():\n        raise ValueError(f\"media path is not a file: {path}\")\n    return path\n\n\ndef _output_dir(media_path: Path, output_dir: Optional[str]) -> Path:\n    out = Path(output_dir).expanduser() if output_dir else media_path.parent / \"transcripts\"\n    if not out.is_absolute():\n        out = Path.cwd() / out\n    out.mkdir(parents=True, exist_ok=True)\n    return out.resolve()\n\n\ndef _read_text(path: str) -> str:\n    if not path:\n        return \"\"\n    p = Path(path)\n    if not p.exists():\n        return \"\"\n    return p.read_text(encoding=\"utf-8\", errors=\"replace\")\n\n\ndef _segments(text: str) -> list[dict[str, Any]]:\n    items: list[dict[str, Any]] = []\n    for index, raw in enumerate((text or \"\").splitlines(), start=1):\n        match = TIMESTAMP_RE.match(raw.strip())\n        if not match:\n            continue\n        start = float(match.group(\"start\"))\n        end = float(match.group(\"end\"))\n        items.append(\n            {\n                \"index\": index,\n                \"start\": start,\n                \"end\": end,\n                \"duration\": max(0.0, end - start),\n                \"text\": match.group(\"text\").strip(),\n            }\n        )\n    return items\n\n\ndef _error(\n    engine: str,\n    script_path: Optional[Path],\n    stage: str,\n    exc: BaseException,\n    model: Optional[str],\n    language: Optional[str],\n    output_dir: Optional[Path],\n) -> dict[str, Any]:\n    tb = \"\".join(traceback.format_exception(type(exc), exc, exc.__traceback__))\n    return {\n        \"engine\": engine,\n        \"scriptPath\": str(script_path) if script_path else None,\n        \"stage\": stage,\n        \"type\": type(exc).__name__,\n        \"message\": str(exc),\n        \"model\": model,\n        \"language\": language,\n        \"outputDir\": str(output_dir) if output_dir else None,\n        \"traceback\": tb[-3000:],\n    }\n\n\ndef _attempt(engine: str, script_path: Path, model: str, language: Optional[str], output_dir: Path) -> dict[str, Any]:\n    return {\n        \"engine\": engine,\n        \"scriptPath\": str(script_path),\n        \"model\": model,\n        \"language\": language,\n        \"outputDir\": str(output_dir),\n        \"startedAt\": _now(),\n        \"finishedAt\": None,\n        \"elapsedSec\": None,\n        \"status\": \"running\",\n        \"transcriptPath\": None,\n        \"error\": None,\n    }\n\n\ndef _finish(attempt: dict[str, Any], status: str, started: float) -> None:\n    attempt[\"status\"] = status\n    attempt[\"finishedAt\"] = _now()\n    attempt[\"elapsedSec\"] = round(time.perf_counter() - started, 3)\n\n\ndef _run_engine(\n    engine: str,\n    media_path: Path,\n    output_dir: Path,\n    options: dict[str, Any],\n) -> tuple[Optional[str], dict[str, Any], Optional[dict[str, Any]]]:\n    is_whisperx = engine == \"whisperx\"\n    script_path = WHISPERX_SCRIPT if is_whisperx else FALLBACK_SCRIPT\n    model = options[\"model_size\"] if is_whisperx else options[\"fallback_model_size\"]\n    started = time.perf_counter()\n    attempt = _attempt(engine, script_path, model, options[\"language\"], output_dir)\n\n    try:\n        _ensure_api_import_path()\n        if is_whisperx:\n            from scripts import transcriber_whisperx  # type: ignore\n\n            transcript_path = transcriber_whisperx.transcribe(\n                file_path=str(media_path),\n                output_dir=str(output_dir),\n                model_size=model,\n                device=options[\"device\"],\n                compute_type=options[\"compute_type\"],\n                language=options[\"language\"],\n                beam_size=options[\"beam_size\"],\n                batch_size=options[\"batch_size\"],\n                word_timestamps=options[\"word_timestamps\"],\n                diarize=options[\"diarize\"],\n                hf_token=options[\"hf_token\"],\n                chunk_size=options[\"chunk_size\"],\n                vad_onset=options[\"vad_onset\"],\n                vad_offset=options[\"vad_offset\"],\n                max_segment_sec=options[\"max_segment_sec\"],\n                show_timestamps=options[\"show_timestamps\"],\n            )\n        else:\n            from scripts import transcriber  # type: ignore\n\n            transcript_path = transcriber.transcribe(\n                file_path=str(media_path),\n                output_dir=str(output_dir),\n                model_size=model,\n                device=options[\"device\"],\n                compute_type=options[\"compute_type\"],\n                language=options[\"language\"],\n                beam_size=options[\"beam_size\"],\n                vad_filter=options[\"vad_filter\"],\n                word_timestamps=options[\"word_timestamps\"],\n                show_timestamps=options[\"show_timestamps\"],\n            )\n\n        if not transcript_path:\n            raise RuntimeError(f\"{engine} returned an empty transcript path.\")\n        resolved = str(Path(transcript_path).resolve())\n        if not Path(resolved).exists():\n            raise FileNotFoundError(f\"transcript file was not created: {resolved}\")\n        attempt[\"transcriptPath\"] = resolved\n        _finish(attempt, \"ok\", started)\n        return resolved, attempt, None\n    except Exception as exc:\n        error = _error(engine, script_path, \"transcribe\", exc, model, options[\"language\"], output_dir)\n        attempt[\"error\"] = error\n        _finish(attempt, \"failed\", started)\n        return None, attempt, error\n\n\ndef _empty_result(\n    source_url: Optional[str],\n    video_id: Optional[str],\n    post_id: Optional[str],\n    media_index: Any,\n    language: Optional[str],\n    word_timestamps: bool,\n    diarize: bool,\n) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"engine\": None,\n        \"model\": None,\n        \"language\": language,\n        \"transcriptPath\": None,\n        \"transcriptText\": \"\",\n        \"wordTimestamps\": word_timestamps,\n        \"diarize\": diarize,\n        \"fallbackErrors\": [],\n        \"sourceUrl\": source_url,\n        \"videoId\": video_id,\n        \"postId\": post_id,\n        \"mediaIndex\": media_index,\n        \"inputPath\": None,\n        \"outputDir\": None,\n        \"timestampSegments\": [],\n        \"externalProcessing\": [],\n        \"materials\": [],\n        \"dbSaved\": False,\n        \"failureReason\": None,\n    }\n\n\ndef transcribe_youtube_audio(\n    file_path: str,\n    output_dir: Optional[str] = None,\n    source_url: Optional[str] = None,\n    video_id: Optional[str] = None,\n    post_id: Optional[str] = None,\n    media_index: Any = None,\n    model_size: str = \"large-v3\",\n    fallback_model_size: str = \"base\",\n    language: Optional[str] = \"ja\",\n    device: str = \"auto\",\n    compute_type: str = \"auto\",\n    beam_size: int = 5,\n    batch_size: int = 16,\n    word_timestamps: bool = True,\n    diarize: bool = False,\n    hf_token: Optional[str] = None,\n    chunk_size: int = 30,\n    vad_onset: float = 0.5,\n    vad_offset: float = 0.363,\n    max_segment_sec: float = 10.0,\n    vad_filter: bool = True,\n    show_timestamps: bool = True,\n) -> dict[str, Any]:\n    result = _empty_result(source_url, video_id, post_id, media_index, language, word_timestamps, diarize)\n    try:\n        media = _media_path(file_path)\n        out = _output_dir(media, output_dir)\n    except Exception as exc:\n        err = _error(\"input\", None, \"validate\", exc, None, language, None)\n        result[\"fallbackErrors\"].append(err)\n        result[\"failureReason\"] = err[\"message\"]\n        return result\n\n    result[\"inputPath\"] = str(media)\n    result[\"outputDir\"] = str(out)\n    options = {\n        \"model_size\": model_size,\n        \"fallback_model_size\": fallback_model_size,\n        \"language\": language,\n        \"device\": device,\n        \"compute_type\": compute_type,\n        \"beam_size\": beam_size,\n        \"batch_size\": batch_size,\n        \"word_timestamps\": word_timestamps,\n        \"diarize\": diarize,\n        \"hf_token\": hf_token or os.environ.get(\"HF_TOKEN\") or os.environ.get(\"HUGGINGFACE_TOKEN\"),\n        \"chunk_size\": chunk_size,\n        \"vad_onset\": vad_onset,\n        \"vad_offset\": vad_offset,\n        \"max_segment_sec\": max_segment_sec,\n        \"vad_filter\": vad_filter,\n        \"show_timestamps\": show_timestamps,\n    }\n\n    chosen_engine: Optional[str] = None\n    chosen_model: Optional[str] = None\n    transcript_path: Optional[str] = None\n    for engine in (\"whisperx\", \"faster_whisper\"):\n        path, attempt, err = _run_engine(engine, media, out, options)\n        result[\"externalProcessing\"].append(attempt)\n        if err:\n            result[\"fallbackErrors\"].append(err)\n            continue\n        transcript_path = path\n        chosen_engine = engine\n        chosen_model = options[\"model_size\"] if engine == \"whisperx\" else options[\"fallback_model_size\"]\n        break\n\n    if not transcript_path:\n        result[\"failureReason\"] = \"All transcription engines failed.\"\n        return result\n\n    text = _read_text(transcript_path)\n    timestamp_segments = _segments(text)\n    result.update(\n        {\n            \"ok\": True,\n            \"engine\": chosen_engine,\n            \"model\": chosen_model,\n            \"transcriptPath\": transcript_path,\n            \"transcriptText\": text,\n            \"timestampSegments\": timestamp_segments,\n            \"wordTimestampInfo\": {\n                \"requested\": word_timestamps,\n                \"engine\": chosen_engine,\n                \"note\": \"Existing scripts write timestamped transcript text, not raw word JSON.\",\n            },\n            \"diarization\": {\n                \"requested\": diarize,\n                \"hfTokenProvided\": bool(options[\"hf_token\"]),\n            },\n        }\n    )\n    result[\"materials\"].append(\n        {\n            \"kind\": \"youtube_audio_transcript\",\n            \"path\": transcript_path,\n            \"text\": text,\n            \"engine\": chosen_engine,\n            \"model\": chosen_model,\n            \"language\": language,\n            \"sourceUrl\": source_url,\n            \"videoId\": video_id,\n            \"postId\": post_id,\n            \"mediaIndex\": media_index,\n            \"timestampSegments\": timestamp_segments,\n            \"dbSaved\": False,\n        }\n    )\n    return result\n\n\ndef transcribe_from_payload(payload: dict[str, Any]) -> dict[str, Any]:\n    file_path = _pick(\n        payload,\n        \"file_path\",\n        \"filePath\",\n        \"input_path\",\n        \"inputPath\",\n        \"media_path\",\n        \"mediaPath\",\n        \"audioPath\",\n        \"videoPath\",\n        default=\"\",\n    )\n    return transcribe_youtube_audio(\n        file_path=str(file_path or \"\"),\n        output_dir=_pick(payload, \"output_dir\", \"outputDir\"),\n        source_url=_pick(payload, \"source_url\", \"sourceUrl\", \"url\", \"originalUrl\"),\n        video_id=_pick(payload, \"video_id\", \"videoId\"),\n        post_id=_pick(payload, \"post_id\", \"postId\"),\n        media_index=_pick(payload, \"media_index\", \"mediaIndex\"),\n        model_size=str(_pick(payload, \"model_size\", \"modelSize\", \"model\", default=\"large-v3\")),\n        fallback_model_size=str(_pick(payload, \"fallback_model_size\", \"fallbackModelSize\", \"fallbackModel\", default=\"base\")),\n        language=_pick(payload, \"language\", \"lang\", default=\"ja\"),\n        device=str(_pick(payload, \"device\", default=\"auto\")),\n        compute_type=str(_pick(payload, \"compute_type\", \"computeType\", default=\"auto\")),\n        beam_size=_int(_pick(payload, \"beam_size\", \"beamSize\"), 5),\n        batch_size=_int(_pick(payload, \"batch_size\", \"batchSize\"), 16),\n        word_timestamps=_bool(_pick(payload, \"word_timestamps\", \"wordTimestamps\"), True),\n        diarize=_bool(_pick(payload, \"diarize\", \"diarization\"), False),\n        hf_token=_pick(payload, \"hf_token\", \"hfToken\"),\n        chunk_size=_int(_pick(payload, \"chunk_size\", \"chunkSize\"), 30),\n        vad_onset=_float(_pick(payload, \"vad_onset\", \"vadOnset\"), 0.5),\n        vad_offset=_float(_pick(payload, \"vad_offset\", \"vadOffset\"), 0.363),\n        max_segment_sec=_float(_pick(payload, \"max_segment_sec\", \"maxSegmentSec\"), 10.0),\n        vad_filter=_bool(_pick(payload, \"vad_filter\", \"vadFilter\"), True),\n        show_timestamps=_bool(_pick(payload, \"show_timestamps\", \"showTimestamps\"), True),\n    )\n\n\ndef _stdin_payload() -> dict[str, Any]:\n    raw = sys.stdin.read()\n    if not raw.strip():\n        return {}\n    parsed = json.loads(raw)\n    if not isinstance(parsed, dict):\n        raise ValueError(\"stdin JSON must be an object.\")\n    return parsed\n\n\ndef main(argv: Optional[list[str]] = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Transcribe saved YouTube audio/video using existing API scripts.\")\n    parser.add_argument(\"file_path\", nargs=\"?\")\n    parser.add_argument(\"--stdin-json\", action=\"store_true\")\n    parser.add_argument(\"--output-dir\")\n    parser.add_argument(\"--source-url\")\n    parser.add_argument(\"--video-id\")\n    parser.add_argument(\"--post-id\")\n    parser.add_argument(\"--media-index\")\n    parser.add_argument(\"--model\", \"--model-size\", dest=\"model_size\", default=\"large-v3\")\n    parser.add_argument(\"--fallback-model\", dest=\"fallback_model_size\", default=\"base\")\n    parser.add_argument(\"--language\", default=\"ja\")\n    parser.add_argument(\"--device\", default=\"auto\")\n    parser.add_argument(\"--compute-type\", default=\"auto\")\n    parser.add_argument(\"--no-word-timestamps\", dest=\"word_timestamps\", action=\"store_false\", default=True)\n    parser.add_argument(\"--diarize\", action=\"store_true\")\n    parser.add_argument(\"--hf-token\")\n    args = parser.parse_args(argv)\n\n    if args.stdin_json or (not args.file_path and not sys.stdin.isatty()):\n        result = transcribe_from_payload(_stdin_payload())\n    else:\n        result = transcribe_youtube_audio(\n            file_path=args.file_path or \"\",\n            output_dir=args.output_dir,\n            source_url=args.source_url,\n            video_id=args.video_id,\n            post_id=args.post_id,\n            media_index=args.media_index,\n            model_size=args.model_size,\n            fallback_model_size=args.fallback_model_size,\n            language=args.language,\n            device=args.device,\n            compute_type=args.compute_type,\n            word_timestamps=args.word_timestamps,\n            diarize=args.diarize,\n            hf_token=args.hf_token,\n        )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
