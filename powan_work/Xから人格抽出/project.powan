    {
      "id": "node-3a6ee6ea40",
      "title": "ニュース取得不能理由整理ポワン",
      "body": "ニュースURL展開や本文抽出が失敗した時、HTTPエラー、JS必須、ログイン必須、ペイウォール、削除、地域制限、文字化け、本文短すぎなどの理由を分類する臓器ポワン。再試行方針と保存すべき失敗情報を返す。DB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport json\nimport re\nimport sys\nfrom collections.abc import Mapping\nfrom typing import Any\n\ntry:  # requests は既存の article_rag.extractors.py が使うので、あれば例外型も読めるようにする\n    import requests  # type: ignore\nexcept Exception:  # pragma: no cover - 呼び出し側に requests が無い単体実行も許す\n    requests = None  # type: ignore\n\nFAILURE_TYPES = {\n    \"http_error\",\n    \"timeout\",\n    \"dns_error\",\n    \"js_required\",\n    \"login_required\",\n    \"paywall\",\n    \"deleted\",\n    \"geo_blocked\",\n    \"text_too_short\",\n    \"encoding_error\",\n    \"unknown\",\n}\n\nSTATUS_KEYS = {\n    \"statuscode\",\n    \"status\",\n    \"httpstatus\",\n    \"httpstatuscode\",\n    \"responsestatus\",\n    \"responsestatuscode\",\n    \"code\",\n}\nERROR_KEYS = {\n    \"error\",\n    \"rawerror\",\n    \"raw_error\",\n    \"exception\",\n    \"exceptiontype\",\n    \"exception_type\",\n    \"message\",\n    \"reason\",\n    \"detail\",\n    \"traceback\",\n}\nTEXT_KEYS = {\n    \"text\",\n    \"body\",\n    \"articletext\",\n    \"article_text\",\n    \"content\",\n    \"extractedtext\",\n    \"extracted_text\",\n}\nHTML_KEYS = {\n    \"html\",\n    \"rawhtml\",\n    \"raw_html\",\n    \"responsetext\",\n    \"response_text\",\n    \"pagehtml\",\n    \"page_html\",\n}\nURL_FIELDS = (\"post_id\", \"url\", \"final_url\", \"canonical_url\", \"title\")\n\nTIMEOUT_PATTERNS = [\n    r\"\\btimeout\\b\",\n    r\"timed\\s*out\",\n    r\"read\\s+timed\\s+out\",\n    r\"connect\\s+timed\\s+out\",\n    r\"connecttimeout\",\n    r\"readtimeout\",\n]\nDNS_PATTERNS = [\n    r\"\\bdns\\b\",\n    r\"getaddrinfo\",\n    r\"name\\s+resolution\",\n    r\"failed\\s+to\\s+resolve\",\n    r\"name\\s+or\\s+service\\s+not\\s+known\",\n    r\"temporary\\s+failure\\s+in\\s+name\\s+resolution\",\n    r\"nodename\\s+nor\\s+servname\",\n    r\"nameresolutionerror\",\n    r\"\\[errno\\s+11001\\]\",\n]\nJS_REQUIRED_PATTERNS = [\n    r\"enable\\s+javascript\",\n    r\"javascript\\s+(is\\s+)?disabled\",\n    r\"requires?\\s+javascript\",\n    r\"javascript\\s+を\\s*有効\",\n    r\"javascript\\s+が\\s*無効\",\n    r\"please\\s+enable\\s+js\",\n    r\"cloudflare\\s+ray\",\n    r\"checking\\s+your\\s+browser\",\n]\nLOGIN_PATTERNS = [\n    r\"login\\s+required\",\n    r\"sign\\s+in\\s+to\\s+continue\",\n    r\"please\\s+sign\\s+in\",\n    r\"log\\s*in\\s+to\\s+continue\",\n    r\"ログインしてください\",\n    r\"ログインが必要\",\n    r\"会員登録\",\n    r\"無料会員\",\n    r\"account\\s+required\",\n]\nPAYWALL_PATTERNS = [\n    r\"\\bpaywall\\b\",\n    r\"subscribe\\s+to\\s+(read|continue)\",\n    r\"subscription\\s+required\",\n    r\"subscriber\\s+only\",\n    r\"members?\\s+only\",\n    r\"この記事は会員限定\",\n    r\"有料会員\",\n    r\"購読\",\n    r\"続きを読むには\",\n    r\"premium\\s+article\",\n]\nDELETED_PATTERNS = [\n    r\"\\b404\\b\",\n    r\"\\b410\\b\",\n    r\"not\\s+found\",\n    r\"gone\",\n    r\"deleted\",\n    r\"removed\",\n    r\"no\\s+longer\\s+available\",\n    r\"page\\s+not\\s+found\",\n    r\"ページが見つかりません\",\n    r\"記事が見つかりません\",\n    r\"記事は削除\",\n    r\"公開終了\",\n]\nGEO_PATTERNS = [\n    r\"\\b451\\b\",\n    r\"unavailable\\s+for\\s+legal\\s+reasons\",\n    r\"not\\s+available\\s+in\\s+your\\s+(country|region|location)\",\n    r\"geo[-\\s]?blocked\",\n    r\"region\\s+restricted\",\n    r\"お住まいの地域\",\n    r\"地域制限\",\n    r\"この地域では\",\n]\nENCODING_PATTERNS = [\n    r\"unicodedecodeerror\",\n    r\"unicodeencodeerror\",\n    r\"codec\\s+can't\\s+decode\",\n    r\"unknown\\s+encoding\",\n    r\"invalid\\s+start\\s+byte\",\n    r\"charset\",\n    r\"mojibake\",\n    r\"文字化け\",\n]\nEMPTY_BODY_PATTERNS = [\n    r\"extracted\\s+article\\s+body\\s+is\\s+empty\",\n    r\"body\\s+is\\s+empty\",\n    r\"empty\\s+body\",\n    r\"本文を取得できません\",\n    r\"本文が空\",\n]\n\n\ndef classify_news_fetch_failure(\n    input_value: Any = None,\n    *,\n    min_text_chars: int = 120,\n) -> dict[str, Any]:\n    \"\"\"ニュース取得/抽出結果を受け取り、取得不能理由と次の手を返す。\n\n    DB保存、RAG、embedding、要約、意味検索は行わない。既存の\n    scripts/article_rag/extractors.py が投げる requests 例外や\n    RuntimeError(\"Extracted article body is empty.\") を、保存しやすい\n    小さな JSON に整えるための臓器ポワン。\n    \"\"\"\n    payload = _flatten_payload(_coerce_payload(input_value))\n    min_chars = max(1, int(min_text_chars or 1))\n\n    status_code = _pick_status_code(payload)\n    raw_error = _pick_error_text(payload)\n    exception_type = _first_string(payload, {\"exceptiontype\", \"exception_type\", \"type\", \"class\"})\n    article_text = _pick_article_text(payload)\n    html_text = _pick_html_text(payload)\n    title = _first_string(payload, {\"title\", \"headline\"})\n    context = _merge_context(raw_error, exception_type, article_text, html_text, title)\n    text_length = len(_compact(article_text))\n    explicit_failure = _is_explicit_failure(payload)\n    text_short = text_length < min_chars\n\n    signals = _collect_signals(\n        context=context,\n        status_code=status_code,\n        article_text=article_text,\n        html_text=html_text,\n        text_length=text_length,\n        min_text_chars=min_chars,\n    )\n\n    failure_type = _choose_failure_type(\n        status_code=status_code,\n        signals=signals,\n        text_short=text_short,\n        explicit_failure=explicit_failure,\n    )\n\n    if failure_type is None:\n        return _build_result(\n            payload=payload,\n            ok=True,\n            failure_type=None,\n            reason=f\"本文抽出済みです。本文長 {text_length} 文字で、しきい値 {min_chars} 文字を満たしています。\",\n            retryable=False,\n            suggested_next_step=\"取得成功として title/text/metadata を保存する。\",\n            raw_error=\"\",\n            status_code=status_code,\n            text_length=text_length,\n            signals=signals,\n        )\n\n    reason, retryable, suggested_next_step = _policy_for_failure(\n        failure_type=failure_type,\n        status_code=status_code,\n        text_length=text_length,\n        min_text_chars=min_chars,\n        signals=signals,\n    )\n    if not raw_error:\n        raw_error = _fallback_raw_error(status_code, failure_type, text_length, min_chars)\n\n    return _build_result(\n        payload=payload,\n        ok=False,\n        failure_type=failure_type,\n        reason=reason,\n        retryable=retryable,\n        suggested_next_step=suggested_next_step,\n        raw_error=raw_error,\n        status_code=status_code,\n        text_length=text_length,\n        signals=signals,\n    )\n\n\ndef classify_unavailable_reason(input_value: Any = None, **kwargs: Any) -> dict[str, Any]:\n    \"\"\"呼び出し側が短い名前で使える別名。\"\"\"\n    return classify_news_fetch_failure(input_value, **kwargs)\n\n\ndef run(input_value: Any = None, **kwargs: Any) -> dict[str, Any]:\n    \"\"\"scripts.json 系の薄い関数呼び出しからも使いやすい別名。\"\"\"\n    return classify_news_fetch_failure(input_value, **kwargs)\n\n\ndef _coerce_payload(value: Any) -> dict[str, Any]:\n    if value is None:\n        return {}\n    if isinstance(value, Mapping):\n        return dict(value)\n    if isinstance(value, BaseException):\n        return _payload_from_exception(value)\n    if isinstance(value, str):\n        stripped = value.strip()\n        if stripped.startswith(\"{\"):\n            try:\n                loaded = json.loads(stripped)\n                if isinstance(loaded, Mapping):\n                    return dict(loaded)\n            except Exception:\n                pass\n        return {\"error\": value}\n    return {\"raw_json\": _json_safe(value), \"error\": str(value)}\n\n\ndef _payload_from_exception(exc: BaseException) -> dict[str, Any]:\n    payload: dict[str, Any] = {\n        \"error\": str(exc),\n        \"exception_type\": f\"{exc.__class__.__module__}.{exc.__class__.__name__}\",\n    }\n    response = getattr(exc, \"response\", None)\n    if response is not None:\n        payload[\"status_code\"] = getattr(response, \"status_code\", None)\n        payload[\"final_url\"] = getattr(response, \"url\", None)\n        text = getattr(response, \"text\", None)\n        if text:\n            payload[\"response_text\"] = str(text)[:4000]\n    request = getattr(exc, \"request\", None)\n    if request is not None and getattr(request, \"url\", None):\n        payload.setdefault(\"url\", getattr(request, \"url\", None))\n    return payload\n\n\ndef _flatten_payload(payload: dict[str, Any]) -> dict[str, Any]:\n    flat = dict(payload)\n    result = payload.get(\"result\")\n    if isinstance(result, Mapping):\n        merged = dict(result)\n        merged.update({k: v for k, v in payload.items() if k != \"result\"})\n        flat = merged\n    raw_json = flat.get(\"raw_json\")\n    if isinstance(raw_json, str) and raw_json.strip().startswith(\"{\"):\n        try:\n            loaded = json.loads(raw_json)\n            if isinstance(loaded, Mapping):\n                nested = dict(loaded)\n                nested.update(flat)\n                flat = nested\n        except Exception:\n            pass\n    return flat\n\n\ndef _pick_status_code(payload: Mapping[str, Any]) -> int | None:\n    for value in _iter_values_for_keys(payload, STATUS_KEYS):\n        code = _to_status_code(value)\n        if code is not None:\n            return code\n    error_text = _pick_error_text(payload)\n    match = re.search(r\"(?:status|http|code|response)[^0-9]{0,16}([1-5][0-9]{2})\", error_text, re.I)\n    if match:\n        return int(match.group(1))\n    match = re.search(r\"\\b([1-5][0-9]{2})\\b\", error_text)\n    if match:\n        return int(match.group(1))\n    return None\n\n\ndef _to_status_code(value: Any) -> int | None:\n    if isinstance(value, bool) or value is None:\n        return None\n    if isinstance(value, int) and 100 <= value <= 599:\n        return value\n    text = str(value).strip()\n    match = re.search(r\"\\b([1-5][0-9]{2})\\b\", text)\n    if not match:\n        return None\n    return int(match.group(1))\n\n\ndef _pick_error_text(payload: Mapping[str, Any]) -> str:\n    parts: list[str] = []\n    for value in _iter_values_for_keys(payload, ERROR_KEYS):\n        text = _safe_text(value)\n        if text and text not in parts:\n            parts.append(text)\n    return \" | \".join(parts)[:4000]\n\n\ndef _pick_article_text(payload: Mapping[str, Any]) -> str:\n    for value in _iter_values_for_keys(payload, TEXT_KEYS):\n        text = _safe_text(value)\n        if text and not _looks_like_html(text):\n            return text\n    return \"\"\n\n\ndef _pick_html_text(payload: Mapping[str, Any]) -> str:\n    parts: list[str] = []\n    for value in _iter_values_for_keys(payload, HTML_KEYS):\n        text = _safe_text(value)\n        if text:\n            parts.append(text[:4000])\n    for value in _iter_values_for_keys(payload, TEXT_KEYS):\n        text = _safe_text(value)\n        if text and _looks_like_html(text):\n            parts.append(text[:4000])\n    return \"\\n\".join(parts)\n\n\ndef _is_explicit_failure(payload: Mapping[str, Any]) -> bool:\n    ok_value = payload.get(\"ok\")\n    if ok_value is False:\n        return True\n    status_value = str(payload.get(\"status\") or \"\").strip().lower()\n    if status_value in {\"error\", \"failed\", \"failure\", \"ng\"}:\n        return True\n    if _pick_error_text(payload):\n        return True\n    status_code = _pick_status_code(payload)\n    return bool(status_code and status_code >= 400)\n\n\ndef _choose_failure_type(\n    *,\n    status_code: int | None,\n    signals: set[str],\n    text_short: bool,\n    explicit_failure: bool,\n) -> str | None:\n    if \"timeout\" in signals:\n        return \"timeout\"\n    if \"dns_error\" in signals:\n        return \"dns_error\"\n    if \"encoding_error\" in signals:\n        return \"encoding_error\"\n    if status_code == 451 or \"geo_blocked\" in signals:\n        return \"geo_blocked\"\n    if status_code in {404, 410} or \"deleted\" in signals:\n        return \"deleted\"\n    if status_code == 402 or \"paywall\" in signals:\n        return \"paywall\"\n    if status_code == 401 or \"login_required\" in signals:\n        return \"login_required\"\n    if \"js_required\" in signals and (text_short or explicit_failure):\n        return \"js_required\"\n    if status_code is not None and status_code >= 400:\n        return \"http_error\"\n    if text_short and (explicit_failure or \"empty_body\" in signals or \"text_too_short\" in signals):\n        return \"text_too_short\"\n    if explicit_failure:\n        return \"unknown\"\n    if text_short and not explicit_failure:\n        return \"text_too_short\"\n    return None\n\n\ndef _collect_signals(\n    *,\n    context: str,\n    status_code: int | None,\n    article_text: str,\n    html_text: str,\n    text_length: int,\n    min_text_chars: int,\n) -> set[str]:\n    lower_context = context.lower()\n    signals: set[str] = set()\n    pattern_groups = [\n        (\"timeout\", TIMEOUT_PATTERNS),\n        (\"dns_error\", DNS_PATTERNS),\n        (\"js_required\", JS_REQUIRED_PATTERNS),\n        (\"login_required\", LOGIN_PATTERNS),\n        (\"paywall\", PAYWALL_PATTERNS),\n        (\"deleted\", DELETED_PATTERNS),\n        (\"geo_blocked\", GEO_PATTERNS),\n        (\"encoding_error\", ENCODING_PATTERNS),\n        (\"empty_body\", EMPTY_BODY_PATTERNS),\n    ]\n    for name, patterns in pattern_groups:\n        if _matches_any(lower_context, patterns):\n            signals.add(name)\n\n    if status_code in {408, 425, 429} or (status_code is not None and 500 <= status_code <= 599):\n        signals.add(\"transient_http\")\n    if status_code in {404, 410}:\n        signals.add(\"deleted\")\n    if status_code == 451:\n        signals.add(\"geo_blocked\")\n    if status_code == 401:\n        signals.add(\"login_required\")\n    if status_code == 402:\n        signals.add(\"paywall\")\n    if text_length < min_text_chars:\n        signals.add(\"text_too_short\")\n    if _looks_mojibake(article_text) or _looks_mojibake(html_text):\n        signals.add(\"encoding_error\")\n    return signals\n\n\ndef _policy_for_failure(\n    *,\n    failure_type: str,\n    status_code: int | None,\n    text_length: int,\n    min_text_chars: int,\n    signals: set[str],\n) -> tuple[str, bool, str]:\n    status_part = f\"HTTP {status_code}。\" if status_code else \"\"\n    if failure_type == \"timeout\":\n        return (\n            f\"{status_part}取得がタイムアウトしました。ネットワーク混雑か相手サーバーの遅延です。\",\n            True,\n            \"短いバックオフ後に再試行し、必要なら timeout を延ばす。rawError と URL を保存する。\",\n        )\n    if failure_type == \"dns_error\":\n        return (\n            f\"{status_part}ホスト名を解決できませんでした。URL誤り、DNS障害、一時的な名前解決失敗が候補です。\",\n            True,\n            \"URLのホストを保存し、短時間だけ再試行する。NXDOMAIN が続くなら取得不能として確定する。\",\n        )\n    if failure_type == \"http_error\":\n        retryable = \"transient_http\" in signals\n        step = (\n            \"バックオフして再試行する。429なら間隔を長めに置き、5xxなら後で再取得する。\"\n            if retryable\n            else \"同じ方法での再試行は控えめにし、HTTPステータスと rawError を保存する。\"\n        )\n        return (f\"{status_part}HTTPエラーで本文取得に失敗しました。\", retryable, step)\n    if failure_type == \"js_required\":\n        return (\n            \"静的HTMLだけでは本文が出ず、JavaScript実行が必要なページです。\",\n            False,\n            \"Playwright/ログイン済みChromeなどJS実行可能な取得器に回す。静的抽出の失敗情報は保存する。\",\n        )\n    if failure_type == \"login_required\":\n        return (\n            f\"{status_part}ログインまたは会員状態が必要なページです。\",\n            False,\n            \"ログイン済みブラウザで取得する運用がある時だけ別経路へ回す。なければ login_required として保存する。\",\n        )\n    if failure_type == \"paywall\":\n        return (\n            f\"{status_part}ペイウォールまたは購読者限定記事です。\",\n            False,\n            \"本文を無理に保存せず、媒体名・URL・paywall 理由を保存する。権限がある場合だけ認証済み経路へ回す。\",\n        )\n    if failure_type == \"deleted\":\n        return (\n            f\"{status_part}記事が削除済み、公開終了、または存在しない可能性が高いです。\",\n            False,\n            \"deleted として保存し、同じURLの通常再試行はしない。必要ならアーカイブ探索を別工程に任せる。\",\n        )\n    if failure_type == \"geo_blocked\":\n        return (\n            f\"{status_part}地域制限または法的理由でアクセスできません。\",\n            False,\n            \"geo_blocked として保存する。プロキシや地域別取得は運用判断の別工程に任せる。\",\n        )\n    if failure_type == \"text_too_short\":\n        return (\n            f\"抽出本文が短すぎます。本文長 {text_length} 文字で、しきい値 {min_text_chars} 文字未満です。\",\n            False,\n            \"全文ページ、ページ分割、別セレクタ、JS取得器を試す候補として raw_json と短文を保存する。\",\n        )\n    if failure_type == \"encoding_error\":\n        return (\n            \"文字コード判定またはデコードに失敗し、本文が壊れている可能性があります。\",\n            False,\n            \"HTTPヘッダ、meta charset、raw bytes の有無を保存し、別charsetでの再デコードを別工程に任せる。\",\n        )\n    return (\n        f\"{status_part}既知の規則に当てはまらない取得失敗です。\",\n        True,\n        \"rawError と raw_json を保存し、1回だけ再試行する。再現するなら unknown として手動確認へ回す。\",\n    )\n\n\ndef _build_result(\n    *,\n    payload: Mapping[str, Any],\n    ok: bool,\n    failure_type: str | None,\n    reason: str,\n    retryable: bool,\n    suggested_next_step: str,\n    raw_error: str,\n    status_code: int | None,\n    text_length: int,\n    signals: set[str],\n) -> dict[str, Any]:\n    result: dict[str, Any] = {\n        \"ok\": ok,\n        \"failureType\": failure_type,\n        \"reason\": reason,\n        \"retryable\": retryable,\n        \"suggestedNextStep\": suggested_next_step,\n        \"rawError\": raw_error,\n        \"statusCode\": status_code,\n        \"textLength\": text_length,\n        \"signals\": sorted(signals),\n    }\n    for field in URL_FIELDS:\n        value = _first_string(payload, {_normalize_key(field)})\n        if value:\n            result[field] = value\n    return result\n\n\ndef _fallback_raw_error(status_code: int | None, failure_type: str, text_length: int, min_text_chars: int) -> str:\n    if status_code is not None:\n        return f\"HTTP {status_code} classified as {failure_type}\"\n    if failure_type == \"text_too_short\":\n        return f\"extracted text length {text_length} is shorter than {min_text_chars}\"\n    return failure_type\n\n\ndef _iter_values_for_keys(value: Any, target_keys: set[str], depth: int = 0) -> list[Any]:\n    if depth > 6:\n        return []\n    found: list[Any] = []\n    normalized_targets = {_normalize_key(key) for key in target_keys}\n    if isinstance(value, Mapping):\n        for key, child in value.items():\n            if _normalize_key(str(key)) in normalized_targets:\n                found.append(child)\n            found.extend(_iter_values_for_keys(child, normalized_targets, depth + 1))\n    elif isinstance(value, list):\n        for child in value[:50]:\n            found.extend(_iter_values_for_keys(child, normalized_targets, depth + 1))\n    return found\n\n\ndef _first_string(payload: Mapping[str, Any], keys: set[str]) -> str:\n    for value in _iter_values_for_keys(payload, keys):\n        text = _safe_text(value)\n        if text:\n            return text\n    return \"\"\n\n\ndef _merge_context(*parts: str) -> str:\n    return \"\\n\".join(part for part in parts if part)[:12000]\n\n\ndef _matches_any(text: str, patterns: list[str]) -> bool:\n    return any(re.search(pattern, text, flags=re.I) for pattern in patterns)\n\n\ndef _safe_text(value: Any) -> str:\n    if value is None or isinstance(value, bool):\n        return \"\"\n    if isinstance(value, (dict, list, tuple)):\n        try:\n            return json.dumps(_json_safe(value), ensure_ascii=False)[:4000]\n        except Exception:\n            return str(value)[:4000]\n    return str(value).strip()\n\n\ndef _json_safe(value: Any) -> Any:\n    if value is None or isinstance(value, (str, int, float, bool)):\n        return value\n    if isinstance(value, Mapping):\n        return {str(k): _json_safe(v) for k, v in list(value.items())[:100]}\n    if isinstance(value, (list, tuple, set)):\n        return [_json_safe(v) for v in list(value)[:100]]\n    return str(value)\n\n\ndef _normalize_key(key: str) -> str:\n    return re.sub(r\"[^a-z0-9]\", \"\", (key or \"\").lower())\n\n\ndef _compact(text: str) -> str:\n    return re.sub(r\"\\s+\", \"\", text or \"\")\n\n\ndef _looks_like_html(text: str) -> bool:\n    sample = (text or \"\").lstrip()[:500].lower()\n    return sample.startswith(\"<!doctype\") or sample.startswith(\"<html\") or bool(re.search(r\"<(body|head|script|article|main)\\b\", sample))\n\n\ndef _looks_mojibake(text: str) -> bool:\n    if not text:\n        return False\n    sample = text[:2000]\n    replacement_count = sample.count(\"�\")\n    mojibake_marks = sum(sample.count(mark) for mark in (\"ã\", \"Ã\", \"縺\", \"繧\", \"譁\"))\n    return replacement_count >= 3 or mojibake_marks >= 5\n\n\ndef main() -> int:\n    raw = sys.stdin.read().strip()\n    payload: Any = json.loads(raw) if raw else {}\n    result = classify_news_fetch_failure(payload)\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
