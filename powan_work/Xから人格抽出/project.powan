        }
      },
      "userSized": true,
      "codeLanguage": "TypeScript"
    },
    {
      "id": "node-178838b20e",
      "title": "投稿関係判定ポワン",
      "body": "対象ポストを最初に見て、そのポストがリプ、リポスト、引用、独立投稿、不明のどれに当たるかを判定する臓器ポワン。本文の内容だけで判断せず、投稿オブジェクトが持つ返信先ID、リポスト元、引用元、参照カード、URLなどの構造情報を優先して見る。後続の到達ポワンがどの方向へたどればよいかを決めるため、relationType、targetRef、evidence、confidenceを返せる意味を持つ。コードは後で持つ。",
      "powanKind": "organ",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\ntype PathKey = string | number;\ntype PathSpec = readonly PathKey[];\ntype UrlCandidate = {\n  postId?: string;\n  url: string;\n  evidence: string;\n};\n\nconst POST_URL_RE = /https?:\\/\\/(?:www\\.)?(?:x\\.com|twitter\\.com)\\/(?:[^\\s/?#]+\\/status(?:es)?|i\\/web\\/status(?:es)?)\\/(\\d+)/i;\n\nconst RAW_REPLY_ID_PATHS: PathSpec[] = [\n  [\"in_reply_to_status_id_str\"],\n  [\"inReplyToPostId\"],\n  [\"inReplyToStatusId\"],\n  [\"reply\", \"inReplyToPostId\"],\n  [\"legacy\", \"in_reply_to_status_id_str\"],\n  [\"tweet\", \"legacy\", \"in_reply_to_status_id_str\"],\n  [\"result\", \"legacy\", \"in_reply_to_status_id_str\"],\n];\n\nconst RAW_REPOST_ID_PATHS: PathSpec[] = [\n  [\"retweeted_status_id_str\"],\n  [\"repostedPostId\"],\n  [\"retweetedStatusId\"],\n  [\"repost\", \"sourcePostId\"],\n  [\"legacy\", \"retweeted_status_id_str\"],\n  [\"retweeted_status\", \"id_str\"],\n  [\"retweeted_status\", \"rest_id\"],\n  [\"retweeted_status_result\", \"result\", \"rest_id\"],\n  [\"retweeted_status_result\", \"result\", \"legacy\", \"id_str\"],\n  [\"legacy\", \"retweeted_status_result\", \"result\", \"rest_id\"],\n];\n\nconst RAW_QUOTE_ID_PATHS: PathSpec[] = [\n  [\"quoted_status_id_str\"],\n  [\"quotedPostId\"],\n  [\"quotedStatusId\"],\n  [\"quote\", \"sourcePostId\"],\n  [\"legacy\", \"quoted_status_id_str\"],\n  [\"quoted_status\", \"id_str\"],\n  [\"quoted_status\", \"rest_id\"],\n  [\"quoted_status_result\", \"result\", \"rest_id\"],\n  [\"quoted_status_result\", \"result\", \"legacy\", \"id_str\"],\n  [\"legacy\", \"quoted_status_result\", \"result\", \"rest_id\"],\n];\n\nconst RAW_QUOTE_URL_PATHS: PathSpec[] = [\n  [\"quoted_status_permalink\"],\n  [\"quotedStatusPermalink\"],\n  [\"quote\", \"url\"],\n  [\"legacy\", \"quoted_status_permalink\"],\n  [\"quoted_status\", \"url\"],\n  [\"quoted_status_result\", \"result\", \"legacy\", \"quoted_status_permalink\"],\n];\n\nconst REF_PRIORITY: Record<RefKind, number> = {\n  repost_source: 0,\n  quote_source: 1,\n  reply_parent: 2,\n  url_post: 3,\n};\n\nexport function classifyPostRelation(post: PostLike): RelationDecision {\n  if (!isRecord(post)) {\n    return unknownDecision([\"input_is_not_post_object\"], 0.05);\n  }\n\n  const refs: PostRef[] = [];\n  const selfId = cleanString(post.id);\n  const selfUrl = cleanString(post.url);\n\n  addRef(refs, makeIdRef(\"reply_parent\", post.inReplyToPostId, \"post.inReplyToPostId\", 0.98), selfId, selfUrl);\n  addRef(refs, makeIdRef(\"repost_source\", post.repostedPostId, \"post.repostedPostId\", 0.98), selfId, selfUrl);\n  addRef(refs, makeIdRef(\"quote_source\", post.quotedPostId, \"post.quotedPostId\", 0.98), selfId, selfUrl);\n\n  addRawIdRefs(refs, post.raw, RAW_REPLY_ID_PATHS, \"reply_parent\", 0.9, selfId, selfUrl);\n  addRawIdRefs(refs, post.raw, RAW_REPOST_ID_PATHS, \"repost_source\", 0.9, selfId, selfUrl);\n  addRawIdRefs(refs, post.raw, RAW_QUOTE_ID_PATHS, \"quote_source\", 0.9, selfId, selfUrl);\n  addQuoteUrlRefs(refs, post.raw, selfId, selfUrl);\n  addUrlPostRefs(refs, post.urls, \"post.urls\", 0.68, selfId, selfUrl);\n  addCardPostRefs(refs, post.cards, selfId, selfUrl);\n\n  const sortedRefs = refs.slice().sort(compareRefs);\n  const primaryRef = sortedRefs[0];\n\n  if (primaryRef) {\n    const relationType = relationTypeForRef(primaryRef);\n    const kinds = new Set(sortedRefs.map((ref) => ref.kind));\n    const evidence = sortedRefs.map((ref) => ref.evidence);\n    evidence.unshift(`primaryRef:${primaryRef.kind}`);\n    if (kinds.size > 1) {\n      evidence.push(\"multiple_structural_refs_detected\");\n    }\n    return {\n      relationType,\n      refs: sortedRefs,\n      primaryRef,\n      evidence,\n      confidence: decisionConfidence(primaryRef, kinds.size),\n    };\n  }\n\n  if (hasPostIdentity(post)) {\n    return {\n      relationType: \"standalone\",\n      refs: [],\n      evidence: [\"no_supported_relation_refs_detected\", \"post_identity_present\"],\n      confidence: 0.74,\n    };\n  }\n\n  if (hasAnyPayload(post)) {\n    return unknownDecision([\"no_supported_relation_refs_detected\", \"insufficient_post_identity\"], 0.34);\n  }\n\n  return unknownDecision([\"empty_post_object\"], 0.1);\n}\n\nfunction addRawIdRefs(\n  refs: PostRef[],\n  raw: unknown,\n  paths: PathSpec[],\n  kind: RefKind,\n  confidence: number,\n  selfId?: string,\n  selfUrl?: string,\n): void {\n  for (const path of paths) {\n    const value = getAtPath(raw, path);\n    addRef(refs, makeIdRef(kind, value, `raw.${pathToString(path)}`, confidence), selfId, selfUrl);\n  }\n}\n\nfunction addQuoteUrlRefs(refs: PostRef[], raw: unknown, selfId?: string, selfUrl?: string): void {\n  for (const path of RAW_QUOTE_URL_PATHS) {\n    const value = getAtPath(raw, path);\n    const candidates = collectPostUrls(value, `raw.${pathToString(path)}`);\n    for (const candidate of candidates) {\n      addRef(\n        refs,\n        {\n          kind: \"quote_source\",\n          postId: candidate.postId,\n          url: candidate.url,\n          evidence: candidate.evidence,\n          confidence: 0.84,\n        },\n        selfId,\n        selfUrl,\n      );\n    }\n  }\n}\n\nfunction addUrlPostRefs(\n  refs: PostRef[],\n  urls: unknown,\n  evidenceBase: string,\n  confidence: number,\n  selfId?: string,\n  selfUrl?: string,\n): void {\n  if (!Array.isArray(urls)) {\n    return;\n  }\n  urls.forEach((value, index) => {\n    if (typeof value !== \"string\") {\n      return;\n    }\n    const candidate = postUrlCandidate(value, `${evidenceBase}[${index}]`);\n    if (!candidate) {\n      return;\n    }\n    addRef(\n      refs,\n      {\n        kind: \"url_post\",\n        postId: candidate.postId,\n        url: candidate.url,\n        evidence: candidate.evidence,\n        confidence,\n      },\n      selfId,\n      selfUrl,\n    );\n  });\n}\n\nfunction addCardPostRefs(refs: PostRef[], cards: unknown, selfId?: string, selfUrl?: string): void {\n  if (!Array.isArray(cards)) {\n    return;\n  }\n  cards.forEach((card, index) => {\n    const candidates = collectPostUrls(card, `post.cards[${index}]`);\n    for (const candidate of candidates) {\n      addRef(\n        refs,\n        {\n          kind: \"url_post\",\n          postId: candidate.postId,\n          url: candidate.url,\n          evidence: candidate.evidence,\n          confidence: 0.64,\n        },\n        selfId,\n        selfUrl,\n      );\n    }\n  });\n}\n\nfunction makeIdRef(kind: RefKind, value: unknown, evidence: string, confidence: number): PostRef | null {\n  const postId = cleanString(value);\n  if (!postId) {\n    return null;\n  }\n  return { kind, postId, evidence, confidence };\n}\n\nfunction addRef(refs: PostRef[], ref: PostRef | null, selfId?: string, selfUrl?: string): void {\n  if (!ref || (!ref.postId && !ref.url)) {\n    return;\n  }\n  if (isSelfReference(ref, selfId, selfUrl)) {\n    return;\n  }\n\n  const existing = refs.find((item) => refsMatch(item, ref));\n  if (!existing) {\n    refs.push({ ...ref, confidence: clampConfidence(ref.confidence) });\n    return;\n  }\n\n  if (!existing.postId && ref.postId) {\n    existing.postId = ref.postId;\n  }\n  if (!existing.url && ref.url) {\n    existing.url = ref.url;\n  }\n  existing.confidence = Math.max(existing.confidence, clampConfidence(ref.confidence));\n  existing.evidence = mergeEvidence(existing.evidence, ref.evidence);\n}\n\nfunction refsMatch(left: PostRef, right: PostRef): boolean {\n  if (left.kind !== right.kind) {\n    return false;\n  }\n  if (left.postId && right.postId && left.postId === right.postId) {\n    return true;\n  }\n  if (left.url && right.url && normalizePostUrl(left.url) === normalizePostUrl(right.url)) {\n    return true;\n  }\n  return false;\n}\n\nfunction isSelfReference(ref: PostRef, selfId?: string, selfUrl?: string): boolean {\n  if (selfId && ref.postId === selfId) {\n    return true;\n  }\n  if (selfId && ref.url && extractPostIdFromUrl(ref.url) === selfId) {\n    return true;\n  }\n  if (selfUrl && ref.url && normalizePostUrl(ref.url) === normalizePostUrl(selfUrl)) {\n    return true;\n  }\n  return false;\n}\n\nfunction compareRefs(left: PostRef, right: PostRef): number {\n  const priorityDelta = REF_PRIORITY[left.kind] - REF_PRIORITY[right.kind];\n  if (priorityDelta !== 0) {\n    return priorityDelta;\n  }\n  return right.confidence - left.confidence;\n}\n\nfunction relationTypeForRef(ref: PostRef): RelationType {\n  if (ref.kind === \"reply_parent\") {\n    return \"reply\";\n  }\n  if (ref.kind === \"repost_source\") {\n    return \"repost\";\n  }\n  return \"quote\";\n}\n\nfunction decisionConfidence(primaryRef: PostRef, distinctKindCount: number): number {\n  let confidence = clampConfidence(primaryRef.confidence);\n  if (primaryRef.kind === \"url_post\") {\n    confidence = Math.min(confidence, 0.68);\n  }\n  if (distinctKindCount > 1) {\n    confidence = Math.max(0.45, confidence - 0.06);\n  }\n  return clampConfidence(confidence);\n}\n\nfunction unknownDecision(evidence: string[], confidence: number): RelationDecision {\n  return {\n    relationType: \"unknown\",\n    refs: [],\n    evidence,\n    confidence: clampConfidence(confidence),\n  };\n}\n\nfunction hasPostIdentity(post: PostLike): boolean {\n  return Boolean(cleanString(post.id) || cleanString(post.authorId) || postUrlCandidate(post.url, \"post.url\"));\n}\n\nfunction hasAnyPayload(post: PostLike): boolean {\n  return Object.values(post).some((value) => {\n    if (value == null) {\n      return false;\n    }\n    if (typeof value === \"string\") {\n      return value.trim().length > 0;\n    }\n    if (Array.isArray(value)) {\n      return value.length > 0;\n    }\n    if (isRecord(value)) {\n      return Object.keys(value).length > 0;\n    }\n    return true;\n  });\n}\n\nfunction collectPostUrls(value: unknown, evidenceBase: string): UrlCandidate[] {\n  const found: UrlCandidate[] = [];\n  const seen = new Set<unknown>();\n\n  function visit(current: unknown, evidence: string, depth: number): void {\n    if (found.length >= 12 || depth > 5 || current == null) {\n      return;\n    }\n    if (typeof current === \"string\") {\n      const candidate = postUrlCandidate(current, evidence);\n      if (candidate) {\n        found.push(candidate);\n      }\n      return;\n    }\n    if (typeof current !== \"object\") {\n      return;\n    }\n    if (seen.has(current)) {\n      return;\n    }\n    seen.add(current);\n\n    if (Array.isArray(current)) {\n      current.slice(0, 25).forEach((item, index) => visit(item, `${evidence}[${index}]`, depth + 1));\n      return;\n    }\n\n    for (const [key, item] of Object.entries(current).slice(0, 50)) {\n      visit(item, `${evidence}.${key}`, depth + 1);\n    }\n  }\n\n  visit(value, evidenceBase, 0);\n  return dedupeUrlCandidates(found);\n}\n\nfunction dedupeUrlCandidates(candidates: UrlCandidate[]): UrlCandidate[] {\n  const result: UrlCandidate[] = [];\n  for (const candidate of candidates) {\n    const key = candidate.postId || normalizePostUrl(candidate.url);\n    const exists = result.some((item) => (item.postId || normalizePostUrl(item.url)) === key);\n    if (!exists) {\n      result.push(candidate);\n    }\n  }\n  return result;\n}\n\nfunction postUrlCandidate(value: unknown, evidence: string): UrlCandidate | null {\n  const text = cleanString(value);\n  if (!text) {\n    return null;\n  }\n  const match = POST_URL_RE.exec(text);\n  if (!match) {\n    return null;\n  }\n  const url = normalizePostUrl(match[0]);\n  return {\n    postId: match[1],\n    url,\n    evidence,\n  };\n}\n\nfunction extractPostIdFromUrl(url: string): string | undefined {\n  const match = POST_URL_RE.exec(url);\n  return match?.[1];\n}\n\nfunction normalizePostUrl(url: string): string {\n  const text = url.trim();\n  const match = POST_URL_RE.exec(text);\n  return (match?.[0] || text).replace(/\\/+$/, \"\");\n}\n\nfunction getAtPath(source: unknown, path: PathSpec): unknown {\n  let current = source;\n  for (const key of path) {\n    if (current == null) {\n      return undefined;\n    }\n    if (Array.isArray(current) && typeof key === \"number\") {\n      current = current[key];\n      continue;\n    }\n    if (isRecord(current) && typeof key === \"string\" && Object.prototype.hasOwnProperty.call(current, key)) {\n      current = current[key];\n      continue;\n    }\n    return undefined;\n  }\n  return current;\n}\n\nfunction pathToString(path: PathSpec): string {\n  return path.map((key) => String(key)).join(\".\");\n}\n\nfunction cleanString(value: unknown): string | undefined {\n  if (typeof value === \"string\") {\n    const trimmed = value.trim();\n    return trimmed || undefined;\n  }\n  if (typeof value === \"number\" && Number.isFinite(value)) {\n    return String(Math.trunc(value));\n  }\n  if (typeof value === \"bigint\") {\n    return value.toString();\n  }\n  return undefined;\n}\n\nfunction clampConfidence(value: number): number {\n  if (!Number.isFinite(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}\n\nfunction mergeEvidence(left: string, right: string): string {\n  if (!right || left === right || left.includes(right)) {\n    return left;\n  }\n  return `${left}; ${right}`;\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null;\n}",
      "parent": "node-2e4b5cd891",
