    {
      "id": "node-8fb94b5def",
      "title": "正解ラベル管理ポワン",
      "body": "ユーザーがGUI上で付けた正解ラベル、修正ラベル、期待する終端判定、期待する内容分類、期待する関係追跡結果を保存・読み出しする臓器ポワン。自動判定と人間の正解を分けて扱う。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport copy\nimport hashlib\nimport json\nimport os\nimport sys\nimport tempfile\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any, Mapping\n\n\nSCHEMA_VERSION = 1\nDEFAULT_STORE_PATH = \"x_post_test_expected_labels.json\"\nFORBIDDEN_WRITE_NAMES = {\"x_archive.db\"}\nTRACKED_LABEL_FIELDS = (\"expected\", \"auto_result_snapshot\", \"judge\", \"memo\")\nMISSING = object()\n\n\nclass LabelStoreError(ValueError):\n    pass\n\n\ndef run(payload: Mapping[str, Any] | None = None, **kwargs: Any) -> dict[str, Any]:\n    data = _merge_payload(payload, kwargs)\n    action = _clean_text(data.get(\"action\")) or \"upsert\"\n    store_path = data.get(\"store_path\") or data.get(\"storePath\") or DEFAULT_STORE_PATH\n\n    try:\n        if action in {\"upsert\", \"save\", \"update\", \"save-label\"}:\n            return upsert_label(\n                store_path=store_path,\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                expected=_optional_value(data, \"expected\"),\n                auto_result_snapshot=_optional_value(data, \"auto_result_snapshot\", \"autoResultSnapshot\"),\n                judge=_clean_text(data.get(\"judge\")),\n                memo=_optional_value(data, \"memo\"),\n                reason=_clean_text(data.get(\"reason\")),\n            )\n        if action in {\"get\", \"read\", \"load\"}:\n            return read_label(\n                store_path=store_path,\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                include_history=bool(data.get(\"include_history\", data.get(\"includeHistory\", True))),\n            )\n        if action in {\"list\", \"list-labels\"}:\n            return list_labels(\n                store_path=store_path,\n                include_history=bool(data.get(\"include_history\", data.get(\"includeHistory\", False))),\n            )\n        if action in {\"update-expected\", \"set-expected\"}:\n            expected = _optional_value(data, \"expected\")\n            if expected is MISSING:\n                raise LabelStoreError(\"expected is required\")\n            return update_expected(\n                expected,\n                store_path=store_path,\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                judge=_clean_text(data.get(\"judge\")),\n                memo=_optional_value(data, \"memo\"),\n                reason=_clean_text(data.get(\"reason\")) or \"update expected label\",\n            )\n        if action in {\"snapshot-auto\", \"update-auto\", \"set-auto-result-snapshot\"}:\n            snapshot = _optional_value(data, \"auto_result_snapshot\", \"autoResultSnapshot\")\n            if snapshot is MISSING:\n                snapshot = _optional_value(data, \"auto_result\", \"autoResult\", \"result\")\n            if snapshot is MISSING:\n                raise LabelStoreError(\"auto_result_snapshot is required\")\n            return update_auto_result_snapshot(\n                snapshot,\n                store_path=store_path,\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                judge=_clean_text(data.get(\"judge\")) or \"auto\",\n                reason=_clean_text(data.get(\"reason\")) or \"update auto result snapshot\",\n            )\n        if action in {\"compare\", \"judge\"}:\n            auto_result = _optional_value(data, \"auto_result\", \"autoResult\", \"result\")\n            if auto_result is MISSING:\n                auto_result = _optional_value(data, \"auto_result_snapshot\", \"autoResultSnapshot\")\n            return compare_label(\n                store_path=store_path,\n                test_id=_first_value(data, \"test_id\", \"testId\"),\n                test_input=_first_value(data, \"test_input\", \"testInput\", \"input\"),\n                auto_result=auto_result,\n                include_label=bool(data.get(\"include_label\", data.get(\"includeLabel\", True))),\n            )\n        raise LabelStoreError(f\"unknown action: {action}\")\n    except Exception as exc:\n        return {\n            \"ok\": False,\n            \"status\": \"error\",\n            \"error\": {\"type\": exc.__class__.__name__, \"message\": str(exc)},\n        }\n\n\ndef upsert_label(\n    *,\n    store_path: str | Path = DEFAULT_STORE_PATH,\n    test_id: Any = None,\n    test_input: Any = None,\n    expected: Any = MISSING,\n    auto_result_snapshot: Any = MISSING,\n    judge: str = \"\",\n    memo: Any = MISSING,\n    reason: str = \"\",\n) -> dict[str, Any]:\n    target = make_target(test_id=test_id, test_input=test_input)\n    store = load_label_store(store_path)\n    records = store[\"records\"]\n    old_record = records.get(target[\"key\"])\n    now = _now()\n\n    if old_record:\n        record = _json_clone(old_record)\n        record[\"target\"] = _merge_target(record.get(\"target\"), target)\n        record.setdefault(\"history\", [])\n        record.setdefault(\"created_at\", now)\n    else:\n        record = {\n            \"target\": target,\n            \"expected\": None,\n            \"auto_result_snapshot\": None,\n            \"history\": [],\n            \"judge\": \"\",\n            \"memo\": \"\",\n            \"created_at\": now,\n            \"updated_at\": now,\n        }\n\n    before = _tracked_state(record) if old_record else None\n\n    if expected is not MISSING:\n        record[\"expected\"] = _json_safe(expected)\n    if auto_result_snapshot is not MISSING:\n        record[\"auto_result_snapshot\"] = _json_safe(auto_result_snapshot)\n    if memo is not MISSING:\n        record[\"memo\"] = _clean_text(memo)\n    if judge:\n        record[\"judge\"] = judge\n\n    if not record.get(\"judge\"):\n        record[\"judge\"] = \"unknown\"\n\n    after = _tracked_state(record)\n    changed = before != after\n    if changed:\n        record[\"updated_at\"] = now\n        record[\"history\"].append(\n            {\n                \"changed_at\": now,\n                \"judge\": judge or record.get(\"judge\") or \"unknown\",\n                \"reason\": reason or (\"create label\" if before is None else \"update label\"),\n                \"before\": before,\n                \"after\": after,\n            }\n        )\n\n    records[target[\"key\"]] = record\n    if changed or old_record is None:\n        save_label_store(store, store_path)\n\n    return {\n        \"ok\": True,\n        \"status\": \"saved\" if changed else \"unchanged\",\n        \"target_key\": target[\"key\"],\n        \"label\": _public_record(record),\n    }\n\n\ndef update_expected(\n    expected: Any,\n    *,\n    store_path: str | Path = DEFAULT_STORE_PATH,\n    test_id: Any = None,\n    test_input: Any = None,\n    judge: str = \"\",\n    memo: Any = MISSING,\n    reason: str = \"update expected label\",\n) -> dict[str, Any]:\n    return upsert_label(\n        store_path=store_path,\n        test_id=test_id,\n        test_input=test_input,\n        expected=expected,\n        memo=memo,\n        judge=judge,\n        reason=reason,\n    )\n\n\ndef update_auto_result_snapshot(\n    snapshot: Any,\n    *,\n    store_path: str | Path = DEFAULT_STORE_PATH,\n    test_id: Any = None,\n    test_input: Any = None,\n    judge: str = \"auto\",\n    reason: str = \"update auto result snapshot\",\n) -> dict[str, Any]:\n    return upsert_label(\n        store_path=store_path,\n        test_id=test_id,\n        test_input=test_input,\n        auto_result_snapshot=snapshot,\n        judge=judge or \"auto\",\n        reason=reason,\n    )\n\n\ndef read_label(\n    *,\n    store_path: str | Path = DEFAULT_STORE_PATH,\n    test_id: Any = None,\n    test_input: Any = None,\n    include_history: bool = True,\n) -> dict[str, Any]:\n    target = make_target(test_id=test_id, test_input=test_input)\n    store = load_label_store(store_path)\n    record = store[\"records\"].get(target[\"key\"])\n    if not record:\n        return {\"ok\": True, \"status\": \"missing\", \"target_key\": target[\"key\"], \"label\": None}\n    return {\n        \"ok\": True,\n        \"status\": \"found\",\n        \"target_key\": target[\"key\"],\n        \"label\": _public_record(record, include_history=include_history),\n    }\n\n\ndef list_labels(\n    *,\n    store_path: str | Path = DEFAULT_STORE_PATH,\n    include_history: bool = False,\n) -> dict[str, Any]:\n    store = load_label_store(store_path)\n    labels = [\n        _public_record(record, include_history=include_history)\n        for _, record in sorted(store[\"records\"].items())\n    ]\n    return {\"ok\": True, \"status\": \"listed\", \"count\": len(labels), \"labels\": labels}\n\n\ndef compare_label(\n    *,\n    store_path: str | Path = DEFAULT_STORE_PATH,\n    test_id: Any = None,\n    test_input: Any = None,\n    auto_result: Any = MISSING,\n    include_label: bool = True,\n) -> dict[str, Any]:\n    target = make_target(test_id=test_id, test_input=test_input)\n    store = load_label_store(store_path)\n    record = store[\"records\"].get(target[\"key\"])\n    if not record:\n        return {\n            \"ok\": True,\n            \"status\": \"missing_label\",\n            \"target_key\": target[\"key\"],\n            \"comparison\": {\"status\": \"missing_label\", \"matches\": False, \"differences\": []},\n        }\n\n    actual = _json_safe(auto_result) if auto_result is not MISSING else record.get(\"auto_result_snapshot\")\n    comparison = compare_expected_to_actual(record.get(\"expected\"), actual)\n    result = {\n        \"ok\": True,\n        \"status\": \"compared\",\n        \"target_key\": target[\"key\"],\n        \"comparison\": comparison,\n    }\n    if include_label:\n        result[\"label\"] = _public_record(record)\n    return result\n\n\ndef compare_expected_to_actual(expected: Any, actual: Any) -> dict[str, Any]:\n    if expected is None:\n        return {\"status\": \"unlabeled\", \"matches\": False, \"differences\": []}\n    if actual is None:\n        return {\n            \"status\": \"missing_auto_result\",\n            \"matches\": False,\n            \"differences\": [{\"path\": \"$\", \"expected\": expected, \"actual\": None}],\n        }\n    differences: list[dict[str, Any]] = []\n    _collect_differences(expected, actual, \"$\", differences)\n    return {\n        \"status\": \"matched\" if not differences else \"different\",\n        \"matches\": not differences,\n        \"differences\": differences,\n    }\n\n\ndef make_target(*, test_id: Any = None, test_input: Any = None) -> dict[str, Any]:\n    clean_test_id = _clean_text(test_id)\n    normalized_input = _json_safe(test_input) if test_input is not None else None\n\n    if not clean_test_id and isinstance(normalized_input, Mapping):\n        clean_test_id = _clean_text(\n            normalized_input.get(\"test_id\")\n            or normalized_input.get(\"testId\")\n            or normalized_input.get(\"id\")\n        )\n\n    input_hash = _hash_json(normalized_input) if normalized_input is not None else \"\"\n    if clean_test_id:\n        key = f\"test_id:{clean_test_id}\"\n    elif normalized_input is not None:\n        key = f\"input_sha256:{input_hash}\"\n    else:\n        raise LabelStoreError(\"test_id or test_input is required\")\n\n    return {\n        \"key\": key,\n        \"test_id\": clean_test_id,\n        \"input_hash\": input_hash,\n        \"test_input\": normalized_input,\n    }\n\n\ndef load_label_store(store_path: str | Path = DEFAULT_STORE_PATH) -> dict[str, Any]:\n    path = _resolve_store_path(store_path)\n    if not path.exists():\n        return {\"schema_version\": SCHEMA_VERSION, \"records\": {}}\n\n    try:\n        loaded = json.loads(path.read_text(encoding=\"utf-8\"))\n    except json.JSONDecodeError as exc:\n        raise LabelStoreError(f\"label store is not valid JSON: {path}\") from exc\n\n    if not isinstance(loaded, Mapping):\n        raise LabelStoreError(\"label store root must be an object\")\n\n    records = loaded.get(\"records\", {})\n    if not isinstance(records, Mapping):\n        raise LabelStoreError(\"label store records must be an object\")\n\n    return {\n        \"schema_version\": int(loaded.get(\"schema_version\") or SCHEMA_VERSION),\n        \"records\": {str(key): _normalize_record(value, str(key)) for key, value in records.items()},\n    }\n\n\ndef save_label_store(store: Mapping[str, Any], store_path: str | Path = DEFAULT_STORE_PATH) -> None:\n    path = _resolve_store_path(store_path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    normalized = {\n        \"schema_version\": SCHEMA_VERSION,\n        \"records\": {\n            str(key): _normalize_record(value, str(key))\n            for key, value in dict(store.get(\"records\", {})).items()\n        },\n    }\n\n    tmp_path: Path | None = None\n    try:\n        with tempfile.NamedTemporaryFile(\n            \"w\",\n            encoding=\"utf-8\",\n            dir=str(path.parent),\n            prefix=f\".{path.name}.\",\n            suffix=\".tmp\",\n            delete=False,\n        ) as handle:\n            tmp_path = Path(handle.name)\n            json.dump(normalized, handle, ensure_ascii=False, indent=2, sort_keys=True)\n            handle.write(\"\\n\")\n        os.replace(tmp_path, path)\n    finally:\n        if tmp_path and tmp_path.exists():\n            try:\n                tmp_path.unlink()\n            except OSError:\n                pass\n\n\ndef _collect_differences(expected: Any, actual: Any, path: str, differences: list[dict[str, Any]]) -> None:\n    if isinstance(expected, Mapping):\n        if not isinstance(actual, Mapping):\n            differences.append({\"path\": path, \"expected\": expected, \"actual\": actual})\n            return\n        for key, expected_value in expected.items():\n            child_path = f\"{path}.{key}\"\n            if key not in actual:\n                differences.append({\"path\": child_path, \"expected\": expected_value, \"actual\": None})\n            else:\n                _collect_differences(expected_value, actual[key], child_path, differences)\n        return\n\n    if isinstance(expected, list):\n        if not isinstance(actual, list) or len(expected) != len(actual):\n            differences.append({\"path\": path, \"expected\": expected, \"actual\": actual})\n            return\n        for index, expected_value in enumerate(expected):\n            _collect_differences(expected_value, actual[index], f\"{path}[{index}]\", differences)\n        return\n\n    if expected != actual:\n        differences.append({\"path\": path, \"expected\": expected, \"actual\": actual})\n\n\ndef _normalize_record(value: Any, key: str) -> dict[str, Any]:\n    if not isinstance(value, Mapping):\n        raise LabelStoreError(f\"label record must be an object: {key}\")\n    target = value.get(\"target\") if isinstance(value.get(\"target\"), Mapping) else {\"key\": key}\n    history = value.get(\"history\") if isinstance(value.get(\"history\"), list) else []\n    return {\n        \"target\": _merge_target(target, {\"key\": key}),\n        \"expected\": _json_safe(value.get(\"expected\")),\n        \"auto_result_snapshot\": _json_safe(value.get(\"auto_result_snapshot\")),\n        \"history\": _json_safe(history),\n        \"judge\": _clean_text(value.get(\"judge\")) or \"unknown\",\n        \"memo\": _clean_text(value.get(\"memo\")),\n        \"created_at\": _clean_text(value.get(\"created_at\")) or _now(),\n        \"updated_at\": _clean_text(value.get(\"updated_at\")) or _now(),\n    }\n\n\ndef _public_record(record: Mapping[str, Any], *, include_history: bool = True) -> dict[str, Any]:\n    result = _json_clone(record)\n    if not include_history:\n        result.pop(\"history\", None)\n    return result\n\n\ndef _tracked_state(record: Mapping[str, Any]) -> dict[str, Any]:\n    return {field: _json_clone(record.get(field)) for field in TRACKED_LABEL_FIELDS}\n\n\ndef _merge_target(old_target: Any, new_target: Mapping[str, Any]) -> dict[str, Any]:\n    merged: dict[str, Any] = {}\n    if isinstance(old_target, Mapping):\n        merged.update(_json_safe(old_target))\n    merged.update({key: value for key, value in _json_safe(new_target).items() if value not in (None, \"\")})\n    return merged\n\n\ndef _resolve_store_path(store_path: str | Path) -> Path:\n    raw = str(store_path or DEFAULT_STORE_PATH)\n    path = Path(raw).expanduser()\n    if not path.is_absolute():\n        path = Path.cwd() / path\n    lowered_parts = {part.lower() for part in path.parts}\n    if lowered_parts & FORBIDDEN_WRITE_NAMES or path.suffix.lower() == \".db\":\n        raise LabelStoreError(\"labels must be stored in a separate JSON file, not x_archive.db or any .db file\")\n    return path\n\n\ndef _merge_payload(payload: Mapping[str, Any] | None, kwargs: Mapping[str, Any]) -> dict[str, Any]:\n    data: dict[str, Any] = {}\n    if payload is not None:\n        if not isinstance(payload, Mapping):\n            raise LabelStoreError(\"payload must be a JSON object\")\n        data.update(dict(payload))\n    data.update({key: value for key, value in kwargs.items() if value is not None})\n    return data\n\n\ndef _optional_value(data: Mapping[str, Any], *keys: str) -> Any:\n    for key in keys:\n        if key in data:\n            return data[key]\n    return MISSING\n\n\ndef _first_value(data: Mapping[str, Any], *keys: str) -> Any:\n    for key in keys:\n        value = data.get(key)\n        if value not in (None, \"\"):\n            return value\n    return None\n\n\ndef _json_safe(value: Any) -> Any:\n    return json.loads(json.dumps(value, ensure_ascii=False, sort_keys=True, default=str))\n\n\ndef _json_clone(value: Any) -> Any:\n    return copy.deepcopy(_json_safe(value))\n\n\ndef _hash_json(value: Any) -> str:\n    encoded = json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(\",\", \":\")).encode(\"utf-8\")\n    return hashlib.sha256(encoded).hexdigest()\n\n\ndef _clean_text(value: Any) -> str:\n    if value is None:\n        return \"\"\n    return str(value).strip()\n\n\ndef _now() -> str:\n    return datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n\n\ndef load_input_payload(input_json: str) -> Any:\n    if not input_json or input_json == \"-\":\n        raw = sys.stdin.read().strip()\n        return json.loads(raw) if raw else {}\n    path = Path(input_json)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(input_json)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Manage human expected labels for first-stage X post tests.\")\n    parser.add_argument(\"--action\", default=\"\", help=\"upsert, get, list, update-expected, update-auto, compare\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--store-path\", default=DEFAULT_STORE_PATH)\n    parser.add_argument(\"--pretty\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    payload = load_input_payload(args.input_json)\n    if not isinstance(payload, Mapping):\n        payload = {\"input\": payload}\n    payload = dict(payload)\n    if args.action:\n        payload[\"action\"] = args.action\n    payload[\"store_path\"] = args.store_path\n\n    result = run(payload)\n    print(json.dumps(result, ensure_ascii=False, indent=2 if args.pretty else None))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
