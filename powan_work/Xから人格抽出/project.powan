    {
      "id": "node-2ba5053393",
      "title": "X動画URL抽出ポワン",
      "body": "X投稿ページまたは現在表示中の投稿から動画候補を探し、video要素、blob再生、video.twimg.com、再生カード、メタ情報などから保存対象の動画URLや参照情報を抽出する臓器ポワン。保存や読解は行わず、post_id、post_url、media_index、動画候補URL、poster画像、duration、取得根拠をJSONで返す。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport html\nimport json\nimport re\nimport time\nfrom typing import Any\nfrom urllib.parse import urlparse, urlunparse\n\n\nSTATUS_RE = re.compile(r\"/status(?:es)?/(\\d+)\")\nVIDEO_HINT_RE = re.compile(\n    r\"(video\\.twimg\\.com/|\\.m3u8(?:$|\\?)|\\.mp4(?:$|\\?)|/ext_tw_video/|\"\n    r\"/amplify_video/|/tweet_video/|/vid/)\",\n    re.IGNORECASE,\n)\n\n\nclass XVideoExtractionError(RuntimeError):\n    pass\n\n\ndef connect_debug_chrome(*, port: int = 9221, wait: float = 15.0) -> Any:\n    \"\"\"Attach Selenium to an already running Chrome remote debugging port.\"\"\"\n    try:\n        from scripts.chrome_debug import get_driver  # type: ignore\n\n        return get_driver(port=port, wait=wait)\n    except Exception:\n        pass\n\n    try:\n        from selenium import webdriver\n        from selenium.webdriver.chrome.options import Options\n    except Exception as exc:  # pragma: no cover - depends on runtime packages\n        raise XVideoExtractionError(\"selenium is required to connect to Chrome\") from exc\n\n    last_error: Exception | None = None\n    deadline = time.monotonic() + max(0.0, wait)\n    while True:\n        try:\n            options = Options()\n            options.add_experimental_option(\"debuggerAddress\", f\"127.0.0.1:{port}\")\n            return webdriver.Chrome(options=options)\n        except Exception as exc:  # pragma: no cover - depends on live Chrome state\n            last_error = exc\n            if time.monotonic() >= deadline:\n                break\n            time.sleep(0.5)\n    raise XVideoExtractionError(f\"could not connect to Chrome debug port {port}\") from last_error\n\n\ndef normalize_input_url(url: str | None) -> str | None:\n    clean = (url or \"\").strip()\n    if not clean:\n        return None\n    if clean.startswith((\"x.com/\", \"twitter.com/\")):\n        return f\"https://{clean}\"\n    return clean\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    match = STATUS_RE.search(url or \"\")\n    return match.group(1) if match else None\n\n\ndef normalize_status_url(url: str | None) -> str:\n    if not url:\n        return \"\"\n    parsed = urlparse(url)\n    path = re.sub(r\"/(?:photo|video)/\\d+$\", \"\", parsed.path.rstrip(\"/\"))\n    return urlunparse((parsed.scheme or \"https\", parsed.netloc, path, \"\", \"\", \"\"))\n\n\ndef clean_url(value: Any) -> str:\n    if not value:\n        return \"\"\n    text = html.unescape(str(value)).replace(\"\\\\u002F\", \"/\").replace(\"\\\\/\", \"/\")\n    text = text.strip().strip(\"\\\"'\")\n    while text and text[-1] in \")]}>.,;\":\n        text = text[:-1]\n    return f\"https:{text}\" if text.startswith(\"//\") else text\n\n\ndef is_video_url(url: str) -> bool:\n    clean = clean_url(url)\n    return bool(clean) and (\n        clean.lower().startswith(\"blob:http\") or bool(VIDEO_HINT_RE.search(clean))\n    )\n\n\ndef is_direct_video_url(url: str) -> bool:\n    clean = clean_url(url).lower()\n    return bool(clean) and not clean.startswith(\"blob:\") and bool(VIDEO_HINT_RE.search(clean))\n\n\ndef unique_urls(values: list[Any], *, video_only: bool = False) -> list[str]:\n    seen: set[str] = set()\n    output: list[str] = []\n    for value in values:\n        clean = clean_url(value)\n        if not clean or clean in seen or (video_only and not is_video_url(clean)):\n            continue\n        seen.add(clean)\n        output.append(clean)\n    return output\n\n\ndef unique_text(values: list[Any]) -> list[str]:\n    seen: set[str] = set()\n    output: list[str] = []\n    for value in values:\n        text = str(value or \"\").strip()\n        if text and text not in seen:\n            seen.add(text)\n            output.append(text)\n    return output\n\n\ndef positive_float(value: Any) -> float | None:\n    try:\n        number = float(value)\n    except (TypeError, ValueError):\n        return None\n    return number if number > 0 else None\n\n\ndef positive_int(value: Any) -> int | None:\n    try:\n        number = int(float(value))\n    except (TypeError, ValueError):\n        return None\n    return number if number > 0 else None\n\n\ndef choose_source_url(urls: list[str]) -> str:\n    for predicate in (\n        lambda value: is_direct_video_url(value) and \".mp4\" in value.lower(),\n        is_direct_video_url,\n        lambda value: value.lower().startswith(\"blob:http\"),\n    ):\n        for url in urls:\n            if predicate(url):\n                return url\n    return urls[0] if urls else \"\"\n\n\ndef wait_for_video_surface(driver: Any, wait: float) -> None:\n    deadline = time.monotonic() + max(0.0, wait)\n    selectors = [\n        \"article[data-testid='tweet'] video\",\n        \"article[data-testid='tweet'] [data-testid='videoPlayer']\",\n        \"article[data-testid='tweet'] [data-testid='card.wrapper']\",\n        \"video\",\n        \"meta[property*='video']\",\n        \"meta[name*='player']\",\n    ]\n    while True:\n        try:\n            found = driver.execute_script(\n                \"return arguments[0].some(s => document.querySelector(s));\",\n                selectors,\n            )\n            if found:\n                return\n            if driver.execute_script(\"return document.readyState\") == \"complete\":\n                if time.monotonic() >= deadline:\n                    return\n        except Exception:\n            if time.monotonic() >= deadline:\n                return\n        if time.monotonic() >= deadline:\n            return\n        time.sleep(0.25)\n\n\nEXTRACT_SCRIPT = r\"\"\"\nconst requestedUrl = String(arguments[0] || \"\");\nconst pageUrl = location.href;\nconst abs = v => { try { return v ? new URL(v, pageUrl).toString() : \"\"; } catch { return String(v || \"\"); } };\nconst clean = v => String(v || \"\").replace(/\\\\u002F/g, \"/\").replace(/\\\\\\//g, \"/\").replace(/&amp;/g, \"&\").trim().replace(/^[\\\\\"']+|[\\\\\"']+$/g, \"\").replace(/[)\\]}>.,;]+$/g, \"\");\nconst statusId = v => (String(v || \"\").match(/\\/status(?:es)?\\/(\\d+)/) || [\"\", \"\"])[1];\nconst isVideo = v => {\n  const lower = clean(v).toLowerCase();\n  return lower.startsWith(\"blob:http\") || lower.includes(\"video.twimg.com/\") || lower.includes(\".m3u8\") || lower.includes(\".mp4\") || lower.includes(\"/ext_tw_video/\") || lower.includes(\"/amplify_video/\") || lower.includes(\"/tweet_video/\") || lower.includes(\"/vid/\");\n};\nconst isPoster = v => {\n  const lower = clean(v).toLowerCase();\n  return lower.includes(\"pbs.twimg.com/\") || lower.includes(\"twimg.com/ext_tw_video_thumb/\") || lower.includes(\"twimg.com/amplify_video_thumb/\");\n};\nfunction collector() {\n  const seen = new Set(), urls = [], evidence = [];\n  return {urls, evidence, push(v, why) {\n    const url = clean(abs(clean(v)));\n    if (!url || !isVideo(url) || seen.has(url)) return;\n    seen.add(url); urls.push(url); evidence.push(why);\n  }};\n}\nfunction scanText(text, out, why) {\n  const body = String(text || \"\").replace(/\\\\u002F/g, \"/\").replace(/\\\\\\//g, \"/\").replace(/&amp;/g, \"&\");\n  const patterns = [/https?:\\/\\/video\\.twimg\\.com\\/[^\"'\\s<>)]+/gi, /blob:https?:\\/\\/[^\"'\\s<>)]+/gi, /https?:\\/\\/[^\"'\\s<>)]+?\\.(?:m3u8|mp4)(?:\\?[^\"'\\s<>)]+)?/gi];\n  for (const pattern of patterns) for (const match of body.matchAll(pattern)) out.push(match[0], why);\n}\nfunction scanNode(node, out, why) {\n  if (!node) return;\n  const nodes = [node, ...Array.from(node.querySelectorAll(\"video,source,a[href],[src],[href],[poster]\"))];\n  for (const el of nodes) {\n    const tag = String(el.tagName || \"node\").toLowerCase();\n    for (const prop of [\"currentSrc\", \"src\", \"href\", \"poster\"]) {\n      try { if (el[prop]) out.push(el[prop], `${why}.${tag}.${prop}`); } catch {}\n    }\n    if (el.attributes) for (const attr of Array.from(el.attributes)) out.push(attr.value, `${why}.${tag}.attr.${attr.name}`);\n  }\n  scanText(node.innerHTML || \"\", out, `${why}.html`);\n}\nfunction posterOf(box, video) {\n  const posters = [];\n  const push = v => { const url = clean(abs(clean(v))); if (url && isPoster(url) && !posters.includes(url)) posters.push(url); };\n  if (video) push(video.getAttribute(\"poster\") || video.poster || \"\");\n  if (box) {\n    for (const img of Array.from(box.querySelectorAll(\"img[src]\"))) push(img.currentSrc || img.src || img.getAttribute(\"src\"));\n    for (const node of Array.from(box.querySelectorAll(\"[poster]\"))) push(node.getAttribute(\"poster\"));\n  }\n  return posters[0] || \"\";\n}\nfunction seconds(text) {\n  const m = String(text || \"\").replace(/\\s+/g, \" \").match(/(?:^|\\s)(?:(\\d{1,2}):)?(\\d{1,2}):(\\d{2})(?:\\s|$)/);\n  return m ? (Number(m[1] || 0) * 3600 + Number(m[2]) * 60 + Number(m[3])) : null;\n}\nfunction dims(video, box) {\n  const rect = (video || box || document.body).getBoundingClientRect();\n  return {width: Number(video && video.videoWidth) || Math.round(rect.width) || null, height: Number(video && video.videoHeight) || Math.round(rect.height) || null};\n}\nconst targetId = statusId(requestedUrl) || statusId(pageUrl);\nfunction articleScore(article) {\n  const links = Array.from(article.querySelectorAll(\"a[href*='/status/']\"));\n  const hit = targetId && links.some(link => statusId(link.href) === targetId);\n  const rect = article.getBoundingClientRect();\n  const center = rect ? Math.abs(((rect.top + rect.bottom) / 2) - innerHeight / 2) / Math.max(1, innerHeight) : 0;\n  return (hit ? 1000 : 0) + article.querySelectorAll(\"video\").length * 120 + article.querySelectorAll(\"[data-testid='videoPlayer'],[data-testid='card.wrapper']\").length * 40 - center;\n}\nconst articles = Array.from(document.querySelectorAll(\"article[data-testid='tweet']\"));\nconst root = articles.length ? articles.map(a => ({a, s: articleScore(a)})).sort((x, y) => y.s - x.s)[0].a : document;\nconst statusLinks = Array.from(root.querySelectorAll(\"a[href*='/status/']\")).map(a => abs(a.href)).filter(Boolean);\nconst items = [];\nlet index = 1;\nfor (const video of Array.from(root.querySelectorAll(\"video\"))) {\n  const box = video.closest(\"[data-testid='videoPlayer']\") || video.closest(\"[data-testid='card.wrapper']\") || video.closest(\"article\") || video.parentElement;\n  const out = collector();\n  scanNode(video, out, \"video\");\n  if (box && box !== video) scanNode(box, out, \"player\");\n  const size = dims(video, box);\n  items.push({index: index++, pageUrl, sourceUrl: clean(video.currentSrc || video.src || video.getAttribute(\"src\") || \"\"), candidateUrls: out.urls, posterUrl: posterOf(box, video), duration: Number.isFinite(video.duration) && video.duration > 0 ? video.duration : seconds(box ? box.innerText : \"\"), width: size.width, height: size.height, evidence: out.evidence.length ? out.evidence : [\"video.element\"]});\n}\nfor (const card of Array.from(root.querySelectorAll(\"[data-testid='videoPlayer'],[data-testid='card.wrapper'],[data-testid='videoComponent']\"))) {\n  if (card.querySelector(\"video\")) continue;\n  const out = collector(), size = dims(null, card), poster = posterOf(card, null);\n  scanNode(card, out, \"card\");\n  if (out.urls.length || poster) items.push({index: index++, pageUrl, sourceUrl: \"\", candidateUrls: out.urls, posterUrl: poster, duration: seconds(card.innerText || card.getAttribute(\"aria-label\") || \"\"), width: size.width, height: size.height, evidence: out.evidence.length ? out.evidence : [\"card.videoSurface\"]});\n}\nconst global = collector();\nfor (const entry of performance.getEntries()) global.push(entry.name, `performance.${entry.initiatorType || entry.entryType || \"entry\"}`);\nfor (const meta of Array.from(document.querySelectorAll(\"meta[property],meta[name]\"))) {\n  const key = String(meta.getAttribute(\"property\") || meta.getAttribute(\"name\") || \"\").toLowerCase();\n  if (/(video|player|stream|card)/.test(key)) global.push(meta.getAttribute(\"content\") || \"\", `meta.${key}`);\n}\nfor (const link of Array.from(root.querySelectorAll(\"a[href]\"))) global.push(link.href, \"link.href\");\nscanText(root.innerHTML || \"\", global, \"article.html\");\nconst posters = [];\nconst pushPoster = v => { const url = clean(abs(clean(v))); if (url && isPoster(url) && !posters.includes(url)) posters.push(url); };\nfor (const img of Array.from(root.querySelectorAll(\"img[src]\"))) pushPoster(img.currentSrc || img.src || img.getAttribute(\"src\"));\nfor (const meta of Array.from(document.querySelectorAll(\"meta[property],meta[name]\"))) {\n  const key = String(meta.getAttribute(\"property\") || meta.getAttribute(\"name\") || \"\").toLowerCase();\n  if (/(image|thumbnail)/.test(key)) pushPoster(meta.getAttribute(\"content\") || \"\");\n}\nreturn {pageUrl, pageStatusId: statusId(pageUrl), statusLinks, items, globalUrls: global.urls, globalEvidence: global.evidence, posters};\n\"\"\"\n\n\ndef raw_extract_from_page(driver: Any, requested_url: str | None) -> dict[str, Any]:\n    raw = driver.execute_script(EXTRACT_SCRIPT, requested_url or \"\")\n    if not isinstance(raw, dict):\n        raise XVideoExtractionError(\"browser did not return extraction data\")\n    return raw\n\n\ndef build_post_context(raw: dict[str, Any], requested_url: str | None) -> tuple[str, str]:\n    page_url = str(raw.get(\"pageUrl\") or \"\")\n    post_id = status_id_from_url(requested_url) or str(raw.get(\"pageStatusId\") or \"\")\n    preferred: list[str] = []\n    for value in [requested_url, page_url, *(raw.get(\"statusLinks\") or [])]:\n        candidate_id = status_id_from_url(str(value or \"\"))\n        if post_id and candidate_id == post_id:\n            preferred.append(str(value))\n        elif not post_id and candidate_id:\n            post_id = candidate_id\n            preferred.append(str(value))\n    return post_id or \"\", normalize_status_url(preferred[0] if preferred else page_url)\n\n\ndef item_to_video(\n    item: dict[str, Any],\n    *,\n    page_url: str,\n    global_urls: list[str],\n    global_evidence: list[str],\n    posters: list[str],\n    attach_global: bool,\n) -> dict[str, Any] | None:\n    local_urls = unique_urls([item.get(\"sourceUrl\"), *(item.get(\"candidateUrls\") or [])], video_only=True)\n    urls = unique_urls([*local_urls, *(global_urls if attach_global else [])], video_only=True)\n    poster = clean_url(item.get(\"posterUrl\") or \"\") or (posters[0] if posters else \"\")\n    if not urls and not poster:\n        return None\n    evidence = unique_text([*(item.get(\"evidence\") or []), *(global_evidence if attach_global else [])])\n    raw_index = item.get(\"index\")\n    return {\n        \"index\": raw_index if isinstance(raw_index, int) and raw_index > 0 else None,\n        \"pageUrl\": str(item.get(\"pageUrl\") or page_url),\n        \"sourceUrl\": choose_source_url(urls),\n        \"candidateUrls\": urls,\n        \"posterUrl\": poster,\n        \"duration\": positive_float(item.get(\"duration\")),\n        \"width\": positive_int(item.get(\"width\")),\n        \"height\": positive_int(item.get(\"height\")),\n        \"evidence\": evidence or [\"video.candidate\"],\n    }\n\n\ndef video_key(video: dict[str, Any]) -> str:\n    for url in video[\"candidateUrls\"]:\n        if is_direct_video_url(url):\n            return f\"direct:{url}\"\n    if video[\"sourceUrl\"]:\n        return f\"source:{video['sourceUrl']}\"\n    if video[\"posterUrl\"]:\n        parsed = urlparse(video[\"posterUrl\"])\n        return f\"poster:{parsed.netloc}{parsed.path}\"\n    if video[\"candidateUrls\"]:\n        return f\"url:{video['candidateUrls'][0]}\"\n    return f\"page:{video['pageUrl']}:{video.get('index') or 0}\"\n\n\ndef merge_videos(left: dict[str, Any], right: dict[str, Any]) -> dict[str, Any]:\n    urls = unique_urls([*left[\"candidateUrls\"], *right[\"candidateUrls\"]], video_only=True)\n    return {\n        \"index\": left.get(\"index\") or right.get(\"index\"),\n        \"pageUrl\": left.get(\"pageUrl\") or right.get(\"pageUrl\") or \"\",\n        \"sourceUrl\": left.get(\"sourceUrl\") or right.get(\"sourceUrl\") or choose_source_url(urls),\n        \"candidateUrls\": urls,\n        \"posterUrl\": left.get(\"posterUrl\") or right.get(\"posterUrl\") or \"\",\n        \"duration\": left.get(\"duration\") or right.get(\"duration\"),\n        \"width\": left.get(\"width\") or right.get(\"width\"),\n        \"height\": left.get(\"height\") or right.get(\"height\"),\n        \"evidence\": unique_text([*left.get(\"evidence\", []), *right.get(\"evidence\", [])]),\n    }\n\n\ndef finalize_videos(candidates: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    merged: dict[str, dict[str, Any]] = {}\n    order: list[str] = []\n    for candidate in candidates:\n        key = video_key(candidate)\n        if key in merged:\n            merged[key] = merge_videos(merged[key], candidate)\n        else:\n            merged[key] = candidate\n            order.append(key)\n    videos = [merged[key] for key in order]\n    videos.sort(key=lambda item: item[\"index\"] if item[\"index\"] is not None else 9999)\n    for fallback_index, video in enumerate(videos, start=1):\n        video[\"index\"] = video[\"index\"] or fallback_index\n        video[\"sourceUrl\"] = video[\"sourceUrl\"] or choose_source_url(video[\"candidateUrls\"])\n    return videos\n\n\ndef extract_x_video_urls(\n    *,\n    driver: Any | None = None,\n    url: str | None = None,\n    port: int = 9221,\n    wait: float = 15.0,\n) -> dict[str, Any]:\n    requested_url = normalize_input_url(url)\n    owns_driver = driver is None\n    if driver is None:\n        driver = connect_debug_chrome(port=port, wait=wait)\n    try:\n        if requested_url:\n            driver.get(requested_url)\n        wait_for_video_surface(driver, wait)\n        raw = raw_extract_from_page(driver, requested_url)\n        post_id, post_url = build_post_context(raw, requested_url)\n        page_url = post_url or str(raw.get(\"pageUrl\") or \"\")\n        global_urls = unique_urls(raw.get(\"globalUrls\") or [], video_only=True)\n        global_evidence = unique_text(raw.get(\"globalEvidence\") or [])\n        posters = unique_urls(raw.get(\"posters\") or [])\n        items = [item for item in raw.get(\"items\") or [] if isinstance(item, dict)]\n        candidates = [\n            video\n            for item in items\n            if (\n                video := item_to_video(\n                    item,\n                    page_url=page_url,\n                    global_urls=global_urls,\n                    global_evidence=global_evidence,\n                    posters=posters,\n                    attach_global=len(items) <= 1,\n                )\n            )\n        ]\n        if not candidates and (global_urls or posters):\n            candidates.append(\n                {\n                    \"index\": 1,\n                    \"pageUrl\": page_url,\n                    \"sourceUrl\": choose_source_url(global_urls),\n                    \"candidateUrls\": global_urls,\n                    \"posterUrl\": posters[0] if posters else \"\",\n                    \"duration\": None,\n                    \"width\": None,\n                    \"height\": None,\n                    \"evidence\": global_evidence or [\"page.videoCandidate\"],\n                }\n            )\n        return {\"ok\": True, \"postId\": post_id, \"postUrl\": post_url, \"videos\": finalize_videos(candidates)}\n    finally:\n        if owns_driver:\n            try:\n                driver.quit()\n            except Exception:\n                pass\n\n\ndef parse_args(argv: list[str] | None = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Extract video candidates from an X post page.\")\n    parser.add_argument(\"--url\", default=\"\", help=\"X post URL to open before extraction.\")\n    parser.add_argument(\"--port\", type=int, default=9221, help=\"Chrome remote debugging port.\")\n    parser.add_argument(\"--wait\", type=float, default=15.0, help=\"Seconds to wait for tweet video surfaces.\")\n    return parser.parse_args(argv)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = parse_args(argv)\n    try:\n        result = extract_x_video_urls(url=args.url or None, port=args.port, wait=args.wait)\n    except Exception as exc:\n        result = {\n            \"ok\": False,\n            \"postId\": status_id_from_url(args.url) or \"\",\n            \"postUrl\": normalize_status_url(args.url),\n            \"videos\": [],\n            \"error\": str(exc),\n        }\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
