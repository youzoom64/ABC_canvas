    {
      "id": "node-b0a80c8495",
      "title": "終端内容分類ポワン",
      "body": "根まで追跡ポワンがX上の根に到達したあと、その最終投稿の中に何が含まれているかを分類する神経ポワン。本文だけなのか、画像、動画、YouTube、ニュース、外部リンク、複合素材なのかを見分け、必要な確認ポワンへ渡す。ここではコードを持たず、終端投稿の内容分類と後続確認の入口を束ねる。",
      "powanKind": "nerve",
      "code": "",
      "parent": "node-c01f6488d7",
      "children": [
        "node-5cd6c85247",
        "node-9575d22dbe",
        "node-de37593461",
        "node-50607708e4"
      ],
      "style": {
        "shape": "cloud",
        "color": "#ffffff",
        "accent": "#8ddcff",
        "glow": true,
        "blur": true,
        "motion": "soft"
      },
      "layout": {
        "x": 4650,
        "y": 4986,
        "width": 350,
        "height": 210
      },
      "nestedLayoutByParent": {
        "node-c01f6488d7": {
          "x": 0,
          "y": 87,
          "width": 128,
          "height": 51
        }
      },
      "userSized": true
    },
    {
      "id": "node-5cd6c85247",
      "title": "画像内容確認ポワン",
      "body": "終端投稿に画像が含まれている時、その画像をDBへ残せる確認結果にするための神経ポワン。X上の画像URLを抽出し、画像ファイルを保存し、LM Studioの画像対応モデルで内容を読み取り、その読解結果をDBに保存する流れを束ねる。自分自身はコードを持たず、下位の臓器ポワンへ処理を分ける。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nimport types\nfrom collections.abc import Callable, Mapping\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nX_IMAGE_EXTRACT_TITLE = \"X画像URL抽出ポワン\"\nIMAGE_FILE_SAVE_TITLE = \"画像ファイル保存ポワン\"\nLMSTUDIO_IMAGE_READ_TITLE = \"LMStudio画像読解ポワン\"\nIMAGE_READING_DB_SAVE_TITLE = \"画像読解結果DB保存ポワン\"\n\nDEFAULT_PROJECT_PATH = Path(\"project.powan\")\nDEFAULT_OUT_DIR = Path(\"data/x_media/images\")\nDEFAULT_DB_PATH = Path(\"data/x_posts.sqlite\")\nDEFAULT_LMSTUDIO_API_URL = \"http://localhost:1234/v1/chat/completions\"\nDEFAULT_PROMPT_VERSION = \"lmstudio-image-reading-v1\"\nDEFAULT_DOWNLOAD_TIMEOUT = 30.0\nDEFAULT_MAX_BYTES = 50 * 1024 * 1024\n\nPOST_ID_KEYS = (\n    \"post_id\",\n    \"postId\",\n    \"tweet_id\",\n    \"tweetId\",\n    \"status_id\",\n    \"statusId\",\n    \"x_post_id\",\n    \"xPostId\",\n)\nMEDIA_INDEX_KEYS = (\"media_index\", \"mediaIndex\", \"image_index\", \"imageIndex\", \"photo_index\", \"photoIndex\", \"index\")\nURL_KEYS = (\n    \"url\",\n    \"post_url\",\n    \"postUrl\",\n    \"tweet_url\",\n    \"tweetUrl\",\n    \"status_url\",\n    \"statusUrl\",\n    \"x_url\",\n    \"xUrl\",\n)\nIMAGE_URL_KEYS = (\n    \"imageUrlLarge\",\n    \"image_url_large\",\n    \"largeImageUrl\",\n    \"large_image_url\",\n    \"largeUrl\",\n    \"large_url\",\n    \"imageUrlSmall\",\n    \"image_url_small\",\n    \"smallImageUrl\",\n    \"small_image_url\",\n    \"smallUrl\",\n    \"small_url\",\n    \"imageUrl\",\n    \"image_url\",\n    \"media_url\",\n    \"mediaUrl\",\n    \"source_url\",\n    \"sourceUrl\",\n    \"url\",\n)\nLOCAL_PATH_KEYS = (\"local_path\", \"localPath\", \"path\", \"file_path\", \"filePath\", \"saved_path\", \"savedPath\")\n\nCHILD_RESULT_KEYS = {\n    \"extract\": (\n        \"extract\",\n        \"extraction\",\n        \"x_image_extract\",\n        \"xImageExtract\",\n        \"x_image_url_extract\",\n        \"xImageUrlExtract\",\n        \"image_url_extract\",\n        \"imageUrlExtract\",\n        X_IMAGE_EXTRACT_TITLE,\n    ),\n    \"save\": (\n        \"save\",\n        \"image_save\",\n        \"imageSave\",\n        \"file_save\",\n        \"fileSave\",\n        \"image_file_save\",\n        \"imageFileSave\",\n        IMAGE_FILE_SAVE_TITLE,\n    ),\n    \"lmstudio\": (\n        \"lmstudio\",\n        \"lmstudio_result\",\n        \"lmstudioResult\",\n        \"image_reading\",\n        \"imageReading\",\n        \"vision\",\n        \"vision_result\",\n        \"visionResult\",\n        LMSTUDIO_IMAGE_READ_TITLE,\n    ),\n    \"db\": (\n        \"db\",\n        \"db_result\",\n        \"dbResult\",\n        \"save_to_db\",\n        \"saveToDb\",\n        \"image_reading_db_save\",\n        \"imageReadingDbSave\",\n        IMAGE_READING_DB_SAVE_TITLE,\n    ),\n}\n\n\nclass ImageContentConfirmationError(RuntimeError):\n    pass\n\n\n@dataclass(frozen=True)\nclass ChildFunctions:\n    extract_x_image_urls: Callable[..., dict[str, Any]]\n    save_images: Callable[..., dict[str, Any]]\n    analyze_image_with_lmstudio: Callable[..., dict[str, Any]]\n    store_payload: Callable[..., dict[str, Any]]\n\n\ndef confirm_image_contents(\n    input_json: Any | None = None,\n    *,\n    child_functions: ChildFunctions | None = None,\n    child_results: Mapping[str, Any] | None = None,\n    project_path: str | Path = DEFAULT_PROJECT_PATH,\n    execute_missing: bool = True,\n    driver: Any | None = None,\n    url: str = \"\",\n    port: int = 9221,\n    wait: float = 15.0,\n    out_dir: str | Path = DEFAULT_OUT_DIR,\n    download_timeout: float = DEFAULT_DOWNLOAD_TIMEOUT,\n    max_bytes: int = DEFAULT_MAX_BYTES,\n    model: str = \"\",\n    lmstudio_api_url: str = DEFAULT_LMSTUDIO_API_URL,\n    lmstudio_timeout: float = 120.0,\n    max_tokens: int = 1200,\n    temperature: float = 0.0,\n    prompt_version: str = DEFAULT_PROMPT_VERSION,\n    db_path: str | Path = DEFAULT_DB_PATH,\n) -> dict[str, Any]:\n    \"\"\"Run the image confirmation flow by delegating every real job to child powans.\"\"\"\n    source_input = input_json if input_json is not None else {}\n    provided_results = normalize_child_results(child_results)\n    errors: list[dict[str, Any]] = []\n    loaded_functions = child_functions\n\n    result: dict[str, Any] = {\n        \"ok\": False,\n        \"input_json\": json_safe(source_input),\n        \"post_id\": first_text_from_any(source_input, POST_ID_KEYS),\n        \"media_index\": [],\n        \"image_urls\": [],\n        \"local_paths\": [],\n        \"lmstudio_result\": [],\n        \"db_result\": None,\n        \"save_result\": None,\n        \"child_results\": {},\n        \"media_items\": [],\n        \"errors\": errors,\n        \"failure_reasons\": errors,\n    }\n\n    def ensure_children() -> ChildFunctions:\n        nonlocal loaded_functions\n        if loaded_functions is None:\n            if not execute_missing:\n                raise ImageContentConfirmationError(\"child execution is disabled and a required child result is missing\")\n            loaded_functions = load_child_functions_from_project(project_path)\n        return loaded_functions\n\n    extract_result = provided_child_result(provided_results, \"extract\")\n    if extract_result is None:\n        try:\n            children = ensure_children()\n            extract_result = children.extract_x_image_urls(\n                driver=driver,\n                url=url or first_text_from_any(source_input, URL_KEYS) or None,\n                port=port,\n                wait=wait,\n            )\n        except Exception as exc:  # noqa: BLE001 - orchestration returns structured child failures.\n            add_error(errors, \"x_image_url_extract\", str(exc), error_type=exc.__class__.__name__)\n            extract_result = {\"ok\": False, \"images\": [], \"error\": str(exc)}\n    extract_result = json_safe(extract_result)\n    result[\"child_results\"][\"x_image_url_extract\"] = extract_result\n    collect_child_errors(errors, \"x_image_url_extract\", extract_result)\n\n    post_id = first_text_from_any(extract_result, POST_ID_KEYS) or result[\"post_id\"]\n    if post_id:\n        result[\"post_id\"] = post_id\n\n    extract_images = image_records_from_result(extract_result)\n    result[\"image_urls\"] = [url for url in (first_text(item, IMAGE_URL_KEYS) for item in extract_images) if url]\n    if not extract_images:\n        add_error(errors, \"x_image_url_extract\", \"no image records were returned\")\n        return finalize_result(result)\n\n    save_result = provided_child_result(provided_results, \"save\")\n    if save_result is None:\n        try:\n            children = ensure_children()\n            save_payload = build_save_payload(extract_result, post_id=post_id)\n            save_result = children.save_images(\n                save_payload,\n                out_dir=Path(out_dir),\n                timeout=download_timeout,\n                max_bytes=max_bytes,\n            )\n        except Exception as exc:  # noqa: BLE001\n            add_error(errors, \"image_file_save\", str(exc), error_type=exc.__class__.__name__)\n            save_result = {\"ok\": False, \"images\": [], \"errors\": [{\"error\": str(exc)}]}\n    save_result = json_safe(save_result)\n    result[\"save_result\"] = save_result\n    result[\"child_results\"][\"image_file_save\"] = save_result\n    collect_child_errors(errors, \"image_file_save\", save_result)\n\n    saved_images = image_records_from_result(save_result)\n    result[\"local_paths\"] = [path for path in (first_text(item, LOCAL_PATH_KEYS) for item in saved_images) if path]\n    result[\"media_index\"] = [index for index in (media_index_value(item) for item in saved_images) if index is not None]\n    if not saved_images:\n        add_error(errors, \"image_file_save\", \"no local image files were saved\")\n        return finalize_result(result)\n\n    lmstudio_result = provided_child_result(provided_results, \"lmstudio\")\n    lmstudio_results: list[dict[str, Any]]\n    if lmstudio_result is not None:\n        lmstudio_results = normalize_lmstudio_results(lmstudio_result)\n    else:\n        lmstudio_results = []\n        if not model:\n            add_error(errors, \"lmstudio_image_read\", \"model is required to run LM Studio image reading\")\n        else:\n            try:\n                children = ensure_children()\n                for image in saved_images:\n                    media_index = media_index_value(image)\n                    try:\n                        reading = children.analyze_image_with_lmstudio(\n                            image,\n                            model=model,\n                            local_path=first_text(image, LOCAL_PATH_KEYS),\n                            api_url=lmstudio_api_url,\n                            timeout=lmstudio_timeout,\n                            max_tokens=max_tokens,\n                            temperature=temperature,\n                            prompt_version=prompt_version,\n                        )\n                        reading = json_safe(reading)\n                        if isinstance(reading, dict):\n                            reading.setdefault(\"post_id\", first_text(image, POST_ID_KEYS) or post_id)\n                            if media_index is not None:\n                                reading.setdefault(\"media_index\", media_index)\n                            lmstudio_results.append(reading)\n                            collect_child_errors(errors, \"lmstudio_image_read\", reading, media_index=media_index)\n                        else:\n                            add_error(errors, \"lmstudio_image_read\", \"LM Studio child returned a non-object result\", media_index=media_index)\n                    except Exception as exc:  # noqa: BLE001\n                        add_error(\n                            errors,\n                            \"lmstudio_image_read\",\n                            str(exc),\n                            error_type=exc.__class__.__name__,\n                            media_index=media_index,\n                        )\n            except Exception as exc:  # noqa: BLE001\n                add_error(errors, \"lmstudio_image_read\", str(exc), error_type=exc.__class__.__name__)\n    result[\"lmstudio_result\"] = lmstudio_results\n    result[\"child_results\"][\"lmstudio_image_read\"] = lmstudio_results\n\n    db_result = provided_child_result(provided_results, \"db\")\n    if db_result is None:\n        db_items = build_db_items(saved_images, lmstudio_results, post_id=post_id, prompt_version=prompt_version)\n        if not db_items:\n            add_error(errors, \"image_reading_db_save\", \"no successful image reading results were available for DB save\")\n            db_result = {\"ok\": False, \"saved_count\": 0, \"saved\": [], \"errors\": [{\"error\": \"no analysis to save\"}]}\n        else:\n            try:\n                children = ensure_children()\n                db_result = children.store_payload({\"items\": db_items}, db_path=Path(db_path))\n            except Exception as exc:  # noqa: BLE001\n                add_error(errors, \"image_reading_db_save\", str(exc), error_type=exc.__class__.__name__)\n                db_result = {\"ok\": False, \"saved_count\": 0, \"saved\": [], \"errors\": [{\"error\": str(exc)}]}\n    db_result = json_safe(db_result)\n    result[\"db_result\"] = db_result\n    result[\"child_results\"][\"image_reading_db_save\"] = db_result\n    collect_child_errors(errors, \"image_reading_db_save\", db_result)\n\n    result[\"media_items\"] = build_media_items(extract_images, saved_images, lmstudio_results, db_result, post_id=post_id)\n    return finalize_result(result)\n\n\ndef load_child_functions_from_project(project_path: str | Path = DEFAULT_PROJECT_PATH) -> ChildFunctions:\n    modules = load_child_modules(project_path)\n    return ChildFunctions(\n        extract_x_image_urls=required_callable(modules[X_IMAGE_EXTRACT_TITLE], \"extract_x_image_urls\", X_IMAGE_EXTRACT_TITLE),\n        save_images=required_callable(modules[IMAGE_FILE_SAVE_TITLE], \"save_images\", IMAGE_FILE_SAVE_TITLE),\n        analyze_image_with_lmstudio=required_callable(\n            modules[LMSTUDIO_IMAGE_READ_TITLE],\n            \"analyze_image_with_lmstudio\",\n            LMSTUDIO_IMAGE_READ_TITLE,\n        ),\n        store_payload=required_callable(modules[IMAGE_READING_DB_SAVE_TITLE], \"store_payload\", IMAGE_READING_DB_SAVE_TITLE),\n    )\n\n\ndef load_child_modules(project_path: str | Path) -> dict[str, types.ModuleType]:\n    path = Path(project_path)\n    project = json.loads(path.read_text(encoding=\"utf-8\"))\n    nodes = project.get(\"nodes\")\n    if not isinstance(nodes, list):\n        raise ImageContentConfirmationError(f\"project.powan has no nodes array: {path}\")\n\n    by_title = {node.get(\"title\"): node for node in nodes if isinstance(node, dict)}\n    modules: dict[str, types.ModuleType] = {}\n    for index, title in enumerate(\n        (X_IMAGE_EXTRACT_TITLE, IMAGE_FILE_SAVE_TITLE, LMSTUDIO_IMAGE_READ_TITLE, IMAGE_READING_DB_SAVE_TITLE),\n        start=1,\n    ):\n        node = by_title.get(title)\n        if not isinstance(node, dict):\n            raise ImageContentConfirmationError(f\"child powan was not found: {title}\")\n        code = node.get(\"code\")\n        if not isinstance(code, str) or not code.strip():\n            raise ImageContentConfirmationError(f\"child powan has no Python code: {title}\")\n        module_name = f\"_powan_child_{index}_{abs(hash(title))}\"\n        module = types.ModuleType(module_name)\n        module.__dict__[\"__file__\"] = str(path.resolve())\n        module.__dict__[\"__package__\"] = \"\"\n        sys.modules[module_name] = module\n        exec(compile(code, f\"<powan child {title}>\", \"exec\"), module.__dict__)\n        modules[title] = module\n    return modules\n\n\ndef required_callable(module: types.ModuleType, name: str, title: str) -> Callable[..., dict[str, Any]]:\n    value = getattr(module, name, None)\n    if not callable(value):\n        raise ImageContentConfirmationError(f\"{title} does not expose callable {name}\")\n    return value\n\n\ndef normalize_child_results(child_results: Mapping[str, Any] | None) -> Mapping[str, Any]:\n    if not isinstance(child_results, Mapping):\n        return {}\n    nested = child_results.get(\"child_results\") or child_results.get(\"childResults\")\n    if isinstance(nested, Mapping):\n        return nested\n    return child_results\n\n\ndef provided_child_result(child_results: Mapping[str, Any], stage: str) -> Any | None:\n    for key in CHILD_RESULT_KEYS[stage]:\n        if key in child_results and child_results[key] is not None:\n            return child_results[key]\n    return None\n\n\ndef build_save_payload(extract_result: Any, *, post_id: str) -> dict[str, Any]:\n    payload = dict(extract_result) if isinstance(extract_result, Mapping) else {\"images\": extract_result}\n    payload[\"post_id\"] = first_text(payload, POST_ID_KEYS) or post_id\n    images = []\n    for item in image_records_from_result(extract_result):\n        record = dict(item)\n        if payload[\"post_id\"]:\n            record.setdefault(\"post_id\", payload[\"post_id\"])\n            record.setdefault(\"postId\", payload[\"post_id\"])\n        index = media_index_value(record)\n        if index is not None:\n            record.setdefault(\"media_index\", index)\n            record.setdefault(\"mediaIndex\", index)\n        images.append(record)\n    payload[\"images\"] = images\n    return payload\n\n\ndef build_db_items(\n    saved_images: list[dict[str, Any]],\n    lmstudio_results: list[dict[str, Any]],\n    *,\n    post_id: str,\n    prompt_version: str,\n) -> list[dict[str, Any]]:\n    items: list[dict[str, Any]] = []\n    for index, media_asset in enumerate(saved_images):\n        analysis = analysis_for_index(lmstudio_results, media_asset, fallback_index=index)\n        if analysis is None or explicit_failure(analysis):\n            continue\n        media = dict(media_asset)\n        if post_id:\n            media.setdefault(\"post_id\", post_id)\n            media.setdefault(\"postId\", post_id)\n        media_index = media_index_value(media)\n        if media_index is not None:\n            media.setdefault(\"media_index\", media_index)\n            media.setdefault(\"mediaIndex\", media_index)\n        items.append({\"media_asset\": media, \"analysis\": normalize_analysis_for_db(analysis, prompt_version=prompt_version)})\n    return items\n\n\ndef normalize_analysis_for_db(analysis: Mapping[str, Any], *, prompt_version: str) -> dict[str, Any]:\n    normalized = dict(analysis)\n    if \"visible_objects\" in normalized and \"objects\" not in normalized:\n        normalized[\"objects\"] = normalized[\"visible_objects\"]\n    if \"raw_response\" in normalized and \"raw_response_json\" not in normalized:\n        normalized[\"raw_response_json\"] = normalized[\"raw_response\"]\n    if prompt_version and not first_text(normalized, (\"prompt_version\", \"promptVersion\")):\n        normalized[\"prompt_version\"] = prompt_version\n    return normalized\n\n\ndef analysis_for_index(\n    lmstudio_results: list[dict[str, Any]],\n    media_asset: Mapping[str, Any],\n    *,\n    fallback_index: int,\n) -> dict[str, Any] | None:\n    media_index = media_index_value(media_asset)\n    if media_index is not None:\n        for item in lmstudio_results:\n            if media_index_value(item) == media_index:\n                return item\n    return lmstudio_results[fallback_index] if fallback_index < len(lmstudio_results) else None\n\n\ndef build_media_items(\n    extract_images: list[dict[str, Any]],\n    saved_images: list[dict[str, Any]],\n    lmstudio_results: list[dict[str, Any]],\n    db_result: Any,\n    *,\n    post_id: str,\n) -> list[dict[str, Any]]:\n    saved_rows = db_saved_rows(db_result)\n    items: list[dict[str, Any]] = []\n    for index, saved_image in enumerate(saved_images):\n        media_index = media_index_value(saved_image)\n        extracted = record_for_media_index(extract_images, media_index, fallback_index=index)\n        reading = analysis_for_index(lmstudio_results, saved_image, fallback_index=index)\n        db_saved = record_for_media_index(saved_rows, media_index, fallback_index=index)\n        items.append(\n            {\n                \"post_id\": first_text(saved_image, POST_ID_KEYS) or post_id,\n                \"media_index\": media_index,\n                \"image_url\": first_text(extracted or saved_image, IMAGE_URL_KEYS),\n                \"local_path\": first_text(saved_image, LOCAL_PATH_KEYS),\n                \"sha256\": first_text(saved_image, (\"sha256\", \"hash\")),\n                \"lmstudio_result\": reading,\n                \"db_saved\": db_saved,\n            }\n        )\n    return items\n\n\ndef image_records_from_result(value: Any) -> list[dict[str, Any]]:\n    if isinstance(value, list):\n        return [dict(item) for item in value if isinstance(item, Mapping)]\n    if not isinstance(value, Mapping):\n        return []\n    for key in (\"images\", \"media\", \"items\", \"results\", \"photos\", \"attachments\", \"saved\"):\n        items = value.get(key)\n        if isinstance(items, list):\n            return [dict(item) for item in items if isinstance(item, Mapping)]\n    data = value.get(\"data\")\n    if isinstance(data, list):\n        return [dict(item) for item in data if isinstance(item, Mapping)]\n    if isinstance(data, Mapping):\n        return [dict(data)]\n    if first_text(value, IMAGE_URL_KEYS) or first_text(value, LOCAL_PATH_KEYS):\n        return [dict(value)]\n    return []\n\n\ndef normalize_lmstudio_results(value: Any) -> list[dict[str, Any]]:\n    if isinstance(value, list):\n        return [json_safe(item) for item in value if isinstance(item, Mapping)]\n    if isinstance(value, Mapping):\n        for key in (\"lmstudio_result\", \"lmstudioResult\", \"results\", \"items\", \"analyses\", \"image_analyses\", \"imageAnalyses\"):\n            items = value.get(key)\n            if isinstance(items, list):\n                return [json_safe(item) for item in items if isinstance(item, Mapping)]\n        return [json_safe(value)]\n    return []\n\n\ndef db_saved_rows(value: Any) -> list[dict[str, Any]]:\n    if not isinstance(value, Mapping):\n        return []\n    for key in (\"saved\", \"results\", \"items\"):\n        items = value.get(key)\n        if isinstance(items, list):\n            return [dict(item) for item in items if isinstance(item, Mapping)]\n    return []\n\n\ndef record_for_media_index(records: list[dict[str, Any]], media_index: int | None, *, fallback_index: int) -> dict[str, Any] | None:\n    if media_index is not None:\n        for item in records:\n            if media_index_value(item) == media_index:\n                return item\n    return records[fallback_index] if fallback_index < len(records) else None\n\n\ndef collect_child_errors(\n    errors: list[dict[str, Any]],\n    stage: str,\n    child_result: Any,\n    *,\n    media_index: int | None = None,\n) -> None:\n    if isinstance(child_result, Mapping):\n        if child_result.get(\"ok\") is False:\n            message = first_text(child_result, (\"error\", \"reason\", \"message\")) or f\"{stage} returned ok=false\"\n            add_error(errors, stage, message, media_index=media_index)\n        child_errors = child_result.get(\"errors\")\n        if isinstance(child_errors, list):\n            for child_error in child_errors:\n                if isinstance(child_error, Mapping):\n                    add_error(\n                        errors,\n                        stage,\n                        first_text(child_error, (\"error\", \"reason\", \"message\")) or json.dumps(child_error, ensure_ascii=False),\n                        post_id=first_text(child_error, POST_ID_KEYS),\n                        media_index=media_index_value(child_error),\n                    )\n                elif child_error:\n                    add_error(errors, stage, str(child_error), media_index=media_index)\n    elif isinstance(child_result, list):\n        for item in child_result:\n            collect_child_errors(errors, stage, item)\n\n\ndef add_error(\n    errors: list[dict[str, Any]],\n    stage: str,\n    message: str,\n    *,\n    error_type: str = \"\",\n    post_id: str = \"\",\n    media_index: int | None = None,\n) -> None:\n    entry: dict[str, Any] = {\"stage\": stage, \"message\": message}\n    if error_type:\n        entry[\"type\"] = error_type\n    if post_id:\n        entry[\"post_id\"] = post_id\n    if media_index is not None:\n        entry[\"media_index\"] = media_index\n    if entry not in errors:\n        errors.append(entry)\n\n\ndef finalize_result(result: dict[str, Any]) -> dict[str, Any]:\n    db_result = result.get(\"db_result\")\n    db_ok = isinstance(db_result, Mapping) and db_result.get(\"ok\") is not False and db_result is not None\n    result[\"ok\"] = not result[\"errors\"] and bool(result.get(\"local_paths\")) and bool(result.get(\"lmstudio_result\")) and db_ok\n    return json_safe(result)\n\n\ndef explicit_failure(value: Mapping[str, Any]) -> bool:\n    if value.get(\"ok\") is False:\n        return True\n    if first_text(value, (\"error\", \"reason\", \"failure\")):\n        return True\n    return False\n\n\ndef first_text_from_any(value: Any, keys: tuple[str, ...]) -> str:\n    if isinstance(value, Mapping):\n        direct = first_text(value, keys)\n        if direct:\n            return direct\n        for nested_key in (\"input\", \"input_json\", \"inputJson\", \"post\", \"tweet\", \"status\", \"data\"):\n            nested = value.get(nested_key)\n            if isinstance(nested, Mapping):\n                found = first_text_from_any(nested, keys)\n                if found:\n                    return found\n    return \"\"\n\n\ndef first_text(record: Mapping[str, Any] | None, keys: tuple[str, ...]) -> str:\n    if not isinstance(record, Mapping):\n        return \"\"\n    for key in keys:\n        value = record.get(key)\n        if value is None:\n            continue\n        text = str(value).strip()\n        if text:\n            return text\n    return \"\"\n\n\ndef media_index_value(record: Mapping[str, Any] | None) -> int | None:\n    text = first_text(record, MEDIA_INDEX_KEYS)\n    if not text:\n        return None\n    try:\n        return int(text)\n    except ValueError:\n        return None\n\n\ndef json_safe(value: Any) -> Any:\n    if isinstance(value, Path):\n        return str(value)\n    if isinstance(value, Mapping):\n        return {str(key): json_safe(item) for key, item in value.items()}\n    if isinstance(value, list):\n        return [json_safe(item) for item in value]\n    if isinstance(value, tuple):\n        return [json_safe(item) for item in value]\n    if isinstance(value, (str, int, float, bool)) or value is None:\n        return value\n    return str(value)\n\n\ndef load_json_source(source: str) -> Any:\n    if source == \"-\":\n        text = sys.stdin.read()\n    else:\n        path = Path(source)\n        text = path.read_text(encoding=\"utf-8\")\n    if not text.strip():\n        return {}\n    return json.loads(text)\n\n\ndef load_optional_json(value: str) -> Any | None:\n    if not value:\n        return None\n    if value == \"-\":\n        text = sys.stdin.read()\n    else:\n        path = Path(value)\n        text = path.read_text(encoding=\"utf-8\") if path.exists() else value\n    return json.loads(text) if text.strip() else None\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=\"Orchestrate X image URL extraction, local save, LM Studio reading, and DB save.\")\n    parser.add_argument(\"--input\", default=\"-\", help=\"Input JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results-json\", default=\"\", help=\"Child results JSON string/file. Provided stages are reused.\")\n    parser.add_argument(\"--project-powan\", default=str(DEFAULT_PROJECT_PATH), help=\"project.powan path used to load child code.\")\n    parser.add_argument(\"--no-execute-missing\", action=\"store_true\", help=\"Do not run missing child stages; only merge supplied child results.\")\n    parser.add_argument(\"--url\", default=\"\", help=\"X post URL. Overrides URL found in input JSON for extraction.\")\n    parser.add_argument(\"--port\", type=int, default=9221, help=\"Chrome remote debugging port for the extraction child.\")\n    parser.add_argument(\"--wait\", type=float, default=15.0, help=\"Seconds for the extraction child to wait for images.\")\n    parser.add_argument(\"--out-dir\", default=str(DEFAULT_OUT_DIR), help=\"Directory passed to the image-save child.\")\n    parser.add_argument(\"--download-timeout\", type=float, default=DEFAULT_DOWNLOAD_TIMEOUT)\n    parser.add_argument(\"--max-bytes\", type=int, default=DEFAULT_MAX_BYTES)\n    parser.add_argument(\"--model\", default=\"\", help=\"Vision-capable LM Studio model name. Required when LM Studio stage is executed.\")\n    parser.add_argument(\"--lmstudio-api-url\", default=DEFAULT_LMSTUDIO_API_URL)\n    parser.add_argument(\"--lmstudio-timeout\", type=float, default=120.0)\n    parser.add_argument(\"--max-tokens\", type=int, default=1200)\n    parser.add_argument(\"--temperature\", type=float, default=0.0)\n    parser.add_argument(\"--prompt-version\", default=DEFAULT_PROMPT_VERSION)\n    parser.add_argument(\"--db\", default=str(DEFAULT_DB_PATH), help=\"SQLite path passed to the DB-save child.\")\n    parser.add_argument(\"--compact\", action=\"store_true\", help=\"Print compact JSON.\")\n    return parser\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = build_parser().parse_args(argv)\n    try:\n        input_json = load_json_source(args.input)\n        child_results = load_optional_json(args.child_results_json)\n        if child_results is None and isinstance(input_json, Mapping):\n            embedded = input_json.get(\"child_results\") or input_json.get(\"childResults\")\n            child_results = embedded if isinstance(embedded, Mapping) else None\n        result = confirm_image_contents(\n            input_json,\n            child_results=child_results,\n            project_path=args.project_powan,\n            execute_missing=not args.no_execute_missing,\n            url=args.url,\n            port=args.port,\n            wait=args.wait,\n            out_dir=args.out_dir,\n            download_timeout=args.download_timeout,\n            max_bytes=args.max_bytes,\n            model=args.model,\n            lmstudio_api_url=args.lmstudio_api_url,\n            lmstudio_timeout=args.lmstudio_timeout,\n            max_tokens=args.max_tokens,\n            temperature=args.temperature,\n            prompt_version=args.prompt_version,\n            db_path=args.db,\n        )\n    except Exception as exc:  # noqa: BLE001 - CLI output should remain structured JSON.\n        result = {\n            \"ok\": False,\n            \"input_json\": {},\n            \"post_id\": \"\",\n            \"media_index\": [],\n            \"image_urls\": [],\n            \"local_paths\": [],\n            \"lmstudio_result\": [],\n            \"db_result\": None,\n            \"child_results\": {},\n            \"errors\": [{\"stage\": \"orchestrator\", \"type\": exc.__class__.__name__, \"message\": str(exc)}],\n            \"failure_reasons\": [{\"stage\": \"orchestrator\", \"type\": exc.__class__.__name__, \"message\": str(exc)}],\n        }\n    print(json.dumps(result, ensure_ascii=False, indent=None if args.compact else 2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
