    {
      "id": "node-df886766f4",
      "title": "Seleniumページスクロールポワン",
      "body": "起動済みのSelenium driverを受け取り、現在表示中のページ内を指定ピクセル分だけスクロールする臓器ポワン。X専用の投稿解析やページ遷移は行わず、window.scrollByで単純にスクロールし、スクロール前後の位置と差分だけを返す。単体実行時は既存の9221デバッグChromeへ接続して現在ページをスクロールできる。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport logging\nimport time\nfrom typing import Any\n\nfrom selenium.webdriver.remote.webdriver import WebDriver\n\nlog = logging.getLogger(\"selenium_page_scroll\")\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef get_scroll_state(driver: WebDriver) -> dict[str, Any]:\n    return driver.execute_script(\n        \"\"\"\n        return {\n          x: window.scrollX || window.pageXOffset || 0,\n          y: window.scrollY || window.pageYOffset || 0,\n          innerHeight: window.innerHeight || 0,\n          scrollHeight: document.documentElement.scrollHeight || document.body.scrollHeight || 0\n        };\n        \"\"\"\n    )\n\n\ndef scroll_page(\n    driver: WebDriver,\n    *,\n    pixels: int = 800,\n    times: int = 1,\n    pause_seconds: float = 0.2,\n) -> dict[str, Any]:\n    \"\"\"Scroll the current page by a fixed pixel amount.\"\"\"\n    if times < 1:\n        raise ValueError(\"times must be 1 or greater\")\n\n    before = get_scroll_state(driver)\n    log.info(\"scroll.start pixels=%s times=%s before_y=%s\", pixels, times, before.get(\"y\"))\n\n    for index in range(times):\n        driver.execute_script(\"window.scrollBy(0, arguments[0]);\", int(pixels))\n        log.debug(\"scroll.step index=%s pixels=%s\", index + 1, pixels)\n        if pause_seconds > 0:\n            time.sleep(pause_seconds)\n\n    after = get_scroll_state(driver)\n    result = {\n        \"pixels\": pixels,\n        \"times\": times,\n        \"before\": before,\n        \"after\": after,\n        \"delta_y\": int(after.get(\"y\") or 0) - int(before.get(\"y\") or 0),\n    }\n    log.info(\"scroll.done before_y=%s after_y=%s delta_y=%s\", before.get(\"y\"), after.get(\"y\"), result[\"delta_y\"])\n    return result\n\n\ndef get_debug_driver(*, port: int = 9221):\n    from scripts.chrome_debug import get_driver\n\n    log.info(\"driver.connect port=%s\", port)\n    return get_driver(port=port)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Scroll the current Selenium debug Chrome page.\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--pixels\", type=int, default=800)\n    parser.add_argument(\"--times\", type=int, default=1)\n    parser.add_argument(\"--pause-seconds\", type=float, default=0.2)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n    driver = get_debug_driver(port=args.port)\n    result = scroll_page(\n        driver,\n        pixels=args.pixels,\n        times=args.times,\n        pause_seconds=args.pause_seconds,\n    )\n    print(f\"before_y={result['before'].get('y')}\")\n    print(f\"after_y={result['after'].get('y')}\")\n    print(f\"delta_y={result['delta_y']}\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
      "parent": "node-12d93ab587",
      "children": [],
      "style": {
