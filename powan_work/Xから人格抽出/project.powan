    {
      "id": "node-64e227b6fd",
      "title": "LMStudio動画読解ポワン",
      "body": "動画代表フレーム抽出ポワンのフレーム群をLM StudioのOpenAI互換APIへ送り、動画の内容を読解する臓器ポワン。フレーム単位の観察、全体要約、画面内テキスト、登場物、主張や文脈上重要な点、信頼度、model、raw_responseをDB保存向けJSONに正規化して返す。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\nimport argparse\nimport base64\nimport json\nimport mimetypes\nimport re\nimport sys\nimport urllib.error\nimport urllib.request\nfrom collections.abc import Mapping\nfrom pathlib import Path\nfrom typing import Any\nDEFAULT_API_URL = \"http://localhost:1234/v1/chat/completions\"\nDEFAULT_PROMPT_VERSION = \"lmstudio-video-reading-v1\"\nFRAME_COLLECTION_KEYS = (\n    \"frames\", \"representative_frames\", \"representativeFrames\", \"video_frames\",\n    \"videoFrames\", \"images\", \"saved_images\", \"savedImages\", \"items\", \"results\",\n)\nFRAME_PATH_KEYS = (\n    \"localPath\", \"local_path\", \"framePath\", \"frame_path\", \"savedPath\", \"saved_path\",\n    \"filePath\", \"file_path\", \"imagePath\", \"image_path\", \"path\",\n)\nFRAME_INDEX_KEYS = (\"frameIndex\", \"frame_index\", \"index\", \"ordinal\", \"position\")\nTIMESTAMP_KEYS = (\"timestamp\", \"time\", \"timeSeconds\", \"time_seconds\", \"seconds\", \"sec\")\nTOP_LEVEL_SOURCE_KEYS = (\n    \"postId\", \"post_id\", \"tweetId\", \"tweet_id\", \"statusId\", \"status_id\",\n    \"mediaIndex\", \"media_index\", \"videoPath\", \"video_path\", \"sourceUrl\", \"source_url\",\n    \"videoUrl\", \"video_url\",\n)\nSYSTEM_PROMPT = (\n    \"You read representative video frames for a downstream database record. \"\n    \"Return only valid JSON. Do not invent text that is not visible. \"\n    \"Use frame order and timestamps when describing changes over time. \"\n    \"When unsure, state the uncertainty in limitations or notable_details.\"\n)\nUSER_PROMPT = \"\"\"Analyze the attached representative frames from one video.\nReturn only a JSON object with these keys:\n- summary: short factual summary of what the video appears to show.\n- timeline: array of frame observations. Each item should include frame_index, timestamp, observation, ocr_text, visible_objects, notable_details, confidence.\n- ocr_text: readable text across frames, preserving line breaks when useful.\n- visible_objects: important people, objects, logos, UI parts, places, or visual elements.\n- scene: object with description, setting, and visual_progression.\n- notable_details: specific visual details useful for later verification.\n- possible_claim_relevance: object with summary, visual_evidence array, and limitations array.\n- confidence: number from 0.0 to 1.0.\nDo not describe audio unless it is visible as subtitles or on-screen text.\"\"\"\nclass VideoReadError(RuntimeError):\n    pass\ndef analyze_video_frames_with_lmstudio(\n    frame_input: Any,\n    *,\n    model: str,\n    api_url: str = DEFAULT_API_URL,\n    timeout: float = 180.0,\n    max_tokens: int = 2400,\n    temperature: float = 0.0,\n    prompt_version: str = DEFAULT_PROMPT_VERSION,\n    max_frames: int = 0,\n) -> dict[str, Any]:\n    records = find_frame_records(frame_input)\n    if max_frames > 0:\n        records = records[:max_frames]\n    frames = [prepare_frame(record, order) for order, record in enumerate(records)]\n    if not frames:\n        raise VideoReadError(\"input JSON did not contain representative frame paths\")\n    raw_response = post_json(\n        api_url,\n        build_payload(model=model, frames=frames, max_tokens=max_tokens, temperature=temperature),\n        timeout=timeout,\n    )\n    parsed = parse_json_object(extract_message_content(raw_response))\n    result = normalize_reading(parsed, raw_response=raw_response, model=model, frames=frames)\n    result[\"source\"] = compact_source(frame_input, frames)\n    result[\"prompt_version\"] = prompt_version\n    return result\ndef find_frame_records(value: Any) -> list[dict[str, Any]]:\n    if isinstance(value, str):\n        return [{\"localPath\": value}]\n    if isinstance(value, list):\n        out: list[dict[str, Any]] = []\n        for item in value:\n            out.extend(find_frame_records(item))\n        return out\n    if not isinstance(value, Mapping):\n        return []\n    record = dict(value)\n    out = []\n    for key in FRAME_COLLECTION_KEYS:\n        nested = record.get(key)\n        if isinstance(nested, (list, Mapping)):\n            out.extend(find_frame_records(nested))\n    if out:\n        return out\n    if first_path(record):\n        return [record]\n    for nested in record.values():\n        if isinstance(nested, (list, Mapping)):\n            out.extend(find_frame_records(nested))\n    return out\ndef first_path(record: Mapping[str, Any]) -> str:\n    for key in FRAME_PATH_KEYS:\n        value = record.get(key)\n        if isinstance(value, str):\n            clean = value.strip()\n            if clean and not clean.lower().startswith((\"http://\", \"https://\", \"data:\")):\n                return clean\n    return \"\"\ndef prepare_frame(record: Mapping[str, Any], order: int) -> dict[str, Any]:\n    path = require_frame_path(record)\n    mime = guess_image_mime(path)\n    return {\n        \"order\": order,\n        \"frame_index\": opt_int(first_value(record, FRAME_INDEX_KEYS), default=order),\n        \"timestamp\": opt_float(first_value(record, TIMESTAMP_KEYS)),\n        \"local_path\": display_path(path),\n        \"absolute_path\": str(path),\n        \"mime\": mime,\n        \"width\": opt_int(record.get(\"width\")),\n        \"height\": opt_int(record.get(\"height\")),\n        \"sha256\": opt_text(record.get(\"sha256\")),\n        \"data_url\": image_data_url(path, mime),\n    }\ndef require_frame_path(record: Mapping[str, Any]) -> Path:\n    value = first_path(record)\n    if not value:\n        raise VideoReadError(\"frame localPath is required\")\n    path = Path(value).expanduser()\n    if not path.is_absolute():\n        path = (Path.cwd() / path).resolve()\n    if not path.exists():\n        raise VideoReadError(f\"frame file does not exist: {path}\")\n    if not path.is_file():\n        raise VideoReadError(f\"frame path is not a file: {path}\")\n    return path\ndef guess_image_mime(path: Path) -> str:\n    guessed, _ = mimetypes.guess_type(str(path))\n    if guessed and guessed.startswith(\"image/\"):\n        return guessed\n    return {\".jpg\": \"image/jpeg\", \".jpeg\": \"image/jpeg\", \".png\": \"image/png\", \".webp\": \"image/webp\", \".gif\": \"image/gif\"}.get(path.suffix.lower(), \"application/octet-stream\")\ndef image_data_url(path: Path, mime: str) -> str:\n    encoded = base64.b64encode(path.read_bytes()).decode(\"ascii\")\n    return f\"data:{mime};base64,{encoded}\"\ndef build_payload(*, model: str, frames: list[dict[str, Any]], max_tokens: int, temperature: float) -> dict[str, Any]:\n    content: list[dict[str, Any]] = [\n        {\"type\": \"text\", \"text\": USER_PROMPT},\n        {\"type\": \"text\", \"text\": \"Frame manifest:\\n\" + json.dumps({\"frames\": [compact_frame(frame) for frame in frames]}, ensure_ascii=False)},\n    ]\n    for frame in frames:\n        content.append({\"type\": \"text\", \"text\": frame_label(frame)})\n        content.append({\"type\": \"image_url\", \"image_url\": {\"url\": frame[\"data_url\"]}})\n    return {\n        \"model\": model,\n        \"messages\": [\n            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n            {\"role\": \"user\", \"content\": content},\n        ],\n        \"temperature\": temperature,\n        \"max_tokens\": max_tokens,\n        \"stream\": False,\n    }\ndef frame_label(frame: Mapping[str, Any]) -> str:\n    parts = [f\"Frame order {frame.get('order')}\"]\n    if frame.get(\"frame_index\") is not None:\n        parts.append(f\"frame_index={frame.get('frame_index')}\")\n    if frame.get(\"timestamp\") is not None:\n        parts.append(f\"timestamp={frame.get('timestamp')} seconds\")\n    if frame.get(\"local_path\"):\n        parts.append(f\"path={frame.get('local_path')}\")\n    return \"; \".join(parts)\ndef post_json(url: str, payload: dict[str, Any], *, timeout: float) -> dict[str, Any]:\n    request = urllib.request.Request(\n        url,\n        data=json.dumps(payload, ensure_ascii=False).encode(\"utf-8\"),\n        method=\"POST\",\n        headers={\"Content-Type\": \"application/json; charset=utf-8\", \"Accept\": \"application/json\"},\n    )\n    try:\n        with urllib.request.urlopen(request, timeout=timeout) as response:\n            text = response.read().decode(\"utf-8\", errors=\"replace\")\n    except urllib.error.HTTPError as exc:\n        detail = exc.read().decode(\"utf-8\", errors=\"replace\")\n        raise VideoReadError(f\"LM Studio returned HTTP {exc.code}: {detail}\") from exc\n    except urllib.error.URLError as exc:\n        raise VideoReadError(f\"LM Studio request failed: {exc}\") from exc\n    try:\n        value = json.loads(text)\n    except json.JSONDecodeError as exc:\n        raise VideoReadError(f\"LM Studio returned non-JSON response: {text[:500]}\") from exc\n    if not isinstance(value, dict):\n        raise VideoReadError(\"LM Studio response was not a JSON object\")\n    return value\ndef extract_message_content(response: Mapping[str, Any]) -> str:\n    choices = response.get(\"choices\")\n    if not isinstance(choices, list) or not choices:\n        raise VideoReadError(\"LM Studio response did not contain choices\")\n    choice = choices[0]\n    message = choice.get(\"message\") if isinstance(choice, Mapping) else None\n    if not isinstance(message, Mapping):\n        raise VideoReadError(\"LM Studio response did not contain a message\")\n    content = message.get(\"content\", \"\")\n    if isinstance(content, str):\n        return content.strip()\n    if isinstance(content, list):\n        parts = []\n        for item in content:\n            if isinstance(item, Mapping):\n                part = item.get(\"text\") or item.get(\"content\") or \"\"\n                if isinstance(part, str):\n                    parts.append(part)\n            elif isinstance(item, str):\n                parts.append(item)\n        return \"\\n\".join(parts).strip()\n    return str(content).strip()\ndef parse_json_object(text: str) -> dict[str, Any]:\n    if not text:\n        raise VideoReadError(\"model response content was empty\")\n    candidates = [strip_fence(text), text]\n    embedded = embedded_json(text)\n    if embedded:\n        candidates.append(embedded)\n    for candidate in candidates:\n        try:\n            value = json.loads(candidate)\n        except json.JSONDecodeError:\n            continue\n        if isinstance(value, dict):\n            return value\n    raise VideoReadError(f\"model response was not parseable JSON: {text[:500]}\")\ndef strip_fence(text: str) -> str:\n    match = re.fullmatch(r\"```(?:json)?\\s*(.*?)\\s*```\", text.strip(), flags=re.DOTALL | re.IGNORECASE)\n    return match.group(1).strip() if match else text.strip()\ndef embedded_json(text: str) -> str:\n    start = text.find(\"{\")\n    if start < 0:\n        return \"\"\n    depth = 0\n    in_string = False\n    escape = False\n    for index in range(start, len(text)):\n        char = text[index]\n        if in_string:\n            if escape:\n                escape = False\n            elif char == \"\\\\\":\n                escape = True\n            elif char == '\"':\n                in_string = False\n            continue\n        if char == '\"':\n            in_string = True\n        elif char == \"{\":\n            depth += 1\n        elif char == \"}\":\n            depth -= 1\n            if depth == 0:\n                return text[start : index + 1]\n    return \"\"\ndef normalize_reading(parsed: Mapping[str, Any], *, raw_response: Mapping[str, Any], model: str, frames: list[dict[str, Any]]) -> dict[str, Any]:\n    return {\n        \"summary\": as_text(parsed.get(\"summary\")),\n        \"timeline\": as_timeline(parsed.get(\"timeline\"), frames),\n        \"ocr_text\": as_multiline_text(parsed.get(\"ocr_text\")),\n        \"visible_objects\": as_list(parsed.get(\"visible_objects\")),\n        \"scene\": as_scene(parsed.get(\"scene\")),\n        \"notable_details\": as_list(parsed.get(\"notable_details\")),\n        \"possible_claim_relevance\": as_claim(parsed.get(\"possible_claim_relevance\", parsed.get(\"claim_relevance\"))),\n        \"confidence\": as_confidence(parsed.get(\"confidence\")),\n        \"model\": as_text(raw_response.get(\"model\")) or model,\n        \"raw_response\": safe(raw_response),\n    }\ndef as_timeline(value: Any, frames: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    if isinstance(value, Mapping):\n        value = next((value.get(key) for key in (\"frames\", \"items\", \"timeline\") if isinstance(value.get(key), list)), [])\n    if not isinstance(value, list):\n        return []\n    out = []\n    for index, item in enumerate(value):\n        frame = frames[index] if index < len(frames) else {}\n        if isinstance(item, Mapping):\n            out.append({\n                \"frame_index\": opt_int(first_value(item, (\"frame_index\", \"frameIndex\", \"index\")), default=frame.get(\"frame_index\")),\n                \"timestamp\": opt_float(first_value(item, TIMESTAMP_KEYS), default=frame.get(\"timestamp\")),\n                \"observation\": first_text(item, (\"observation\", \"summary\", \"description\", \"caption\", \"text\")),\n                \"ocr_text\": first_text(item, (\"ocr_text\", \"ocrText\", \"readable_text\", \"visible_text\")),\n                \"visible_objects\": as_list(item.get(\"visible_objects\", item.get(\"objects\"))),\n                \"notable_details\": as_list(item.get(\"notable_details\", item.get(\"details\"))),\n                \"confidence\": as_confidence(item.get(\"confidence\")),\n            })\n        else:\n            out.append({\n                \"frame_index\": opt_int(frame.get(\"frame_index\"), default=index),\n                \"timestamp\": opt_float(frame.get(\"timestamp\")),\n                \"observation\": as_text(item),\n                \"ocr_text\": \"\",\n                \"visible_objects\": [],\n                \"notable_details\": [],\n                \"confidence\": 0.0,\n            })\n    return out\ndef as_text(value: Any) -> str:\n    if value is None:\n        return \"\"\n    if isinstance(value, str):\n        return value.strip()\n    if isinstance(value, (Mapping, list)):\n        return json.dumps(safe(value), ensure_ascii=False, separators=(\",\", \":\"))\n    return str(value).strip()\ndef first_text(record: Mapping[str, Any], aliases: tuple[str, ...]) -> str:\n    for alias in aliases:\n        text = as_text(record.get(alias))\n        if text:\n            return text\n    return \"\"\ndef as_multiline_text(value: Any) -> str:\n    if isinstance(value, list):\n        return \"\\n\".join(as_text(item) for item in value if as_text(item))\n    return as_text(value)\ndef as_list(value: Any) -> list[Any]:\n    if value is None:\n        return []\n    if isinstance(value, list):\n        return [safe(item) for item in value if safe(item) not in (\"\", None)]\n    if isinstance(value, str):\n        return [line for line in (line.strip(\" -\\t\") for line in value.splitlines()) if line]\n    return [safe(value)]\ndef as_scene(value: Any) -> dict[str, Any]:\n    if isinstance(value, Mapping):\n        scene = safe(value)\n        scene.setdefault(\"description\", \"\")\n        scene.setdefault(\"setting\", \"\")\n        scene.setdefault(\"visual_progression\", \"\")\n        return scene\n    text = as_text(value)\n    return {\"description\": text, \"setting\": \"\", \"visual_progression\": \"\"} if text else {}\ndef as_claim(value: Any) -> dict[str, Any]:\n    if isinstance(value, Mapping):\n        claim = safe(value)\n        claim.setdefault(\"summary\", \"\")\n        claim[\"visual_evidence\"] = as_list(claim.get(\"visual_evidence\"))\n        claim[\"limitations\"] = as_list(claim.get(\"limitations\"))\n        return claim\n    return {\"summary\": as_text(value), \"visual_evidence\": [], \"limitations\": []}\ndef as_confidence(value: Any) -> float:\n    if value is None:\n        return 0.0\n    if isinstance(value, (int, float)) and not isinstance(value, bool):\n        number = float(value)\n    else:\n        match = re.search(r\"-?\\d+(?:\\.\\d+)?\", str(value))\n        if not match:\n            return 0.0\n        number = float(match.group(0))\n        if \"%\" in str(value):\n            number /= 100.0\n    if 1.0 < number <= 100.0:\n        number /= 100.0\n    return max(0.0, min(1.0, number))\ndef compact_source(frame_input: Any, frames: list[dict[str, Any]]) -> dict[str, Any]:\n    source = {}\n    if isinstance(frame_input, Mapping):\n        source.update({key: safe(frame_input[key]) for key in TOP_LEVEL_SOURCE_KEYS if frame_input.get(key) not in (None, \"\")})\n    source[\"frames\"] = [compact_frame(frame) for frame in frames]\n    return source\ndef compact_frame(frame: Mapping[str, Any]) -> dict[str, Any]:\n    keys = (\"order\", \"frame_index\", \"timestamp\", \"local_path\", \"mime\", \"width\", \"height\", \"sha256\")\n    return {key: safe(frame.get(key)) for key in keys if frame.get(key) not in (None, \"\")}\ndef safe(value: Any) -> Any:\n    if value is None or isinstance(value, (str, int, float, bool)):\n        return value\n    if isinstance(value, list):\n        return [safe(item) for item in value]\n    if isinstance(value, Mapping):\n        return {str(key): safe(item) for key, item in value.items()}\n    return str(value)\ndef first_value(record: Mapping[str, Any], aliases: tuple[str, ...]) -> Any:\n    for alias in aliases:\n        value = record.get(alias)\n        if value is not None and value != \"\":\n            return value\n    return None\ndef opt_text(value: Any) -> str | None:\n    text = \"\" if value is None else str(value).strip()\n    return text or None\ndef opt_int(value: Any, default: Any = None) -> int | None:\n    value = default if value is None or isinstance(value, bool) else value\n    if value is None or isinstance(value, bool):\n        return None\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return None\ndef opt_float(value: Any, default: Any = None) -> float | None:\n    value = default if value is None or isinstance(value, bool) else value\n    if value is None or isinstance(value, bool):\n        return None\n    try:\n        return float(value)\n    except (TypeError, ValueError):\n        match = re.search(r\"-?\\d+(?:\\.\\d+)?\", str(value))\n        return float(match.group(0)) if match else None\ndef display_path(path: Path) -> str:\n    resolved = path.resolve()\n    try:\n        return str(resolved.relative_to(Path.cwd().resolve()))\n    except ValueError:\n        return str(resolved)\ndef load_input(args: argparse.Namespace) -> Any:\n    if args.stdin_json:\n        text = sys.stdin.read()\n        if not text.strip():\n            raise VideoReadError(\"stdin JSON was empty\")\n        return json.loads(text)\n    if args.input_json:\n        return json.loads(args.input_json)\n    if args.input_json_file:\n        return json.loads(Path(args.input_json_file).read_text(encoding=\"utf-8\"))\n    if args.frame_path:\n        return {\"frames\": [{\"localPath\": path} for path in args.frame_path]}\n    raise VideoReadError(\"--stdin-json, --input-json, --input-json-file, or --frame-path is required\")\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=\"Read representative video frames through LM Studio vision chat completions.\")\n    parser.add_argument(\"--model\", required=True, help=\"Vision-capable LM Studio model name.\")\n    parser.add_argument(\"--stdin-json\", action=\"store_true\", help=\"Read frame-extraction JSON from stdin.\")\n    parser.add_argument(\"--input-json\", default=\"\", help=\"Frame-extraction JSON as a string.\")\n    parser.add_argument(\"--input-json-file\", default=\"\", help=\"Path to frame-extraction JSON file.\")\n    parser.add_argument(\"--frame-path\", action=\"append\", default=[], help=\"Representative frame image path. Repeatable.\")\n    parser.add_argument(\"--api-url\", default=DEFAULT_API_URL)\n    parser.add_argument(\"--timeout\", type=float, default=180.0)\n    parser.add_argument(\"--max-tokens\", type=int, default=2400)\n    parser.add_argument(\"--temperature\", type=float, default=0.0)\n    parser.add_argument(\"--prompt-version\", default=DEFAULT_PROMPT_VERSION)\n    parser.add_argument(\"--max-frames\", type=int, default=0, help=\"Maximum frames to send; 0 means all input frames.\")\n    parser.add_argument(\"--pretty\", action=\"store_true\")\n    return parser\ndef error_result(error: str, model: str = \"\") -> dict[str, Any]:\n    return {\n        \"ok\": False, \"error\": error, \"summary\": \"\", \"timeline\": [], \"ocr_text\": \"\",\n        \"visible_objects\": [], \"scene\": {}, \"notable_details\": [],\n        \"possible_claim_relevance\": {\"summary\": \"\", \"visual_evidence\": [], \"limitations\": [error]},\n        \"confidence\": 0.0, \"model\": model, \"raw_response\": None,\n    }\ndef main(argv: list[str] | None = None) -> int:\n    parser = build_parser()\n    args = parser.parse_args(argv)\n    try:\n        result = analyze_video_frames_with_lmstudio(\n            load_input(args),\n            model=args.model,\n            api_url=args.api_url,\n            timeout=args.timeout,\n            max_tokens=args.max_tokens,\n            temperature=args.temperature,\n            prompt_version=args.prompt_version,\n            max_frames=args.max_frames,\n        )\n    except Exception as exc:\n        print(json.dumps(error_result(str(exc), getattr(args, \"model\", \"\")), ensure_ascii=False, indent=2), file=sys.stderr)\n        return 2\n    print(json.dumps(result, ensure_ascii=False, indent=2 if args.pretty else None))\n    return 0\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
