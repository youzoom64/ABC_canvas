    {
      "id": "node-f7a6a14a4b",
      "title": "YouTube内容DB保存ポワン",
      "body": "YouTube URL抽出、字幕取得、動画保存、音声文字起こし、代表フレーム抽出、コメント取得の結果を受け取り、SQLite DBへ保存する臓器ポワン。X終端投稿とYouTube動画IDを紐づけ、字幕、文字起こし、動画ファイル、代表フレーム、コメント、取得不能理由を後から参照できるように保存する。取得処理そのものは行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport sqlite3\nimport sys\nimport uuid\nfrom collections.abc import Mapping, Sequence\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\nURL_EXTRACTOR = \"YouTube URL抽出ポワン\"\nSUBTITLE_FETCHER = \"YouTube字幕取得ポワン\"\nVIDEO_SAVER = \"YouTube動画保存ポワン\"\nTRANSCRIBER = \"YouTube音声文字起こしポワン\"\nFRAME_EXTRACTOR = \"YouTube代表フレーム抽出ポワン\"\nCOMMENT_FETCHER = \"YouTubeコメント取得ポワン\"\n\nAPI_SCRIPT_PROVENANCE = {\n    \"youtube_subtitles\": {\n        \"script\": r\"C:\\project_root\\app_workspaces\\API\\scripts\\youtube_subtitle.py\",\n        \"functions\": [\"download_subtitle\", \"download_subtitle_as_text\", \"list_available_subtitles\"],\n        \"observedResult\": \"download_subtitle_as_text returns a text path; download_subtitle returns a VTT path.\",\n    },\n    \"youtube_comments\": {\n        \"script\": r\"C:\\project_root\\app_workspaces\\API\\scripts\\youtube_comments.py\",\n        \"functions\": [\"download_comments\", \"download_comments_as_text\"],\n        \"observedResult\": \"download_comments_as_text returns a text path and may leave JSON/info files in output_dir.\",\n    },\n    \"video_download\": {\n        \"script\": r\"C:\\project_root\\app_workspaces\\API\\scripts\\video_downloader.py\",\n        \"functions\": [\"download\"],\n        \"observedResult\": \"download returns the saved video file path string.\",\n    },\n    \"transcript\": {\n        \"script\": r\"C:\\project_root\\app_workspaces\\API\\scripts\\transcriber.py\",\n        \"functions\": [\"transcribe\"],\n        \"observedResult\": \"transcribe returns the transcript text file path.\",\n    },\n    \"frames\": {\n        \"script\": r\"C:\\project_root\\app_workspaces\\API\\scripts\\video_thumbnails.py\",\n        \"functions\": [\"generate\"],\n        \"observedResult\": \"generate returns one thumbnail image path or a list of paths.\",\n    },\n    \"last_frame\": {\n        \"script\": r\"C:\\project_root\\app_workspaces\\API\\scripts\\video_last_frame.py\",\n        \"functions\": [\"extract_last_frame\"],\n        \"observedResult\": \"extract_last_frame returns the saved image path.\",\n    },\n}\n\nDEFAULT_OPTIONS = {\"readMaterialFiles\": True, \"maxFileChars\": 250_000, \"replaceMaterial\": True}\nMATERIAL_TABLES = (\n    \"x_youtube_subtitles\",\n    \"x_youtube_transcripts\",\n    \"x_youtube_videos\",\n    \"x_youtube_frames\",\n    \"x_youtube_comments\",\n    \"x_youtube_failures\",\n)\n\nSCHEMA_SQL = \"\"\"\nPRAGMA foreign_keys = ON;\nCREATE TABLE IF NOT EXISTS x_youtube_sources (\n    source_key TEXT PRIMARY KEY,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    normalized_url TEXT,\n    original_url TEXT,\n    media_index INTEGER,\n    source_text TEXT,\n    source_payload_json TEXT NOT NULL DEFAULT '{}',\n    primary_evidence TEXT,\n    subtitle_adequate INTEGER NOT NULL DEFAULT 0,\n    comments_role TEXT,\n    created_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL\n);\nCREATE TABLE IF NOT EXISTS x_youtube_runs (\n    run_id TEXT PRIMARY KEY,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    status TEXT NOT NULL,\n    raw_payload_json TEXT NOT NULL,\n    api_scripts_json TEXT NOT NULL,\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE TABLE IF NOT EXISTS x_youtube_videos (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    local_path TEXT,\n    file_path TEXT,\n    output_dir TEXT,\n    title TEXT,\n    duration_seconds REAL,\n    size_bytes INTEGER,\n    sha256 TEXT,\n    metadata_json TEXT NOT NULL DEFAULT '{}',\n    ok INTEGER NOT NULL DEFAULT 0,\n    failure_reason TEXT,\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE TABLE IF NOT EXISTS x_youtube_subtitles (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    language TEXT,\n    is_auto_generated INTEGER,\n    text TEXT,\n    char_count INTEGER NOT NULL DEFAULT 0,\n    text_path TEXT,\n    vtt_path TEXT,\n    saved_path TEXT,\n    segments_json TEXT NOT NULL DEFAULT '[]',\n    metadata_json TEXT NOT NULL DEFAULT '{}',\n    ok INTEGER NOT NULL DEFAULT 0,\n    failure_reason TEXT,\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE TABLE IF NOT EXISTS x_youtube_transcripts (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    language TEXT,\n    model TEXT,\n    text TEXT,\n    char_count INTEGER NOT NULL DEFAULT 0,\n    text_path TEXT,\n    segments_json TEXT NOT NULL DEFAULT '[]',\n    metadata_json TEXT NOT NULL DEFAULT '{}',\n    ok INTEGER NOT NULL DEFAULT 0,\n    failure_reason TEXT,\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE TABLE IF NOT EXISTS x_youtube_frames (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    frame_kind TEXT,\n    frame_index INTEGER,\n    timestamp_seconds REAL,\n    path TEXT,\n    width INTEGER,\n    height INTEGER,\n    size_bytes INTEGER,\n    metadata_json TEXT NOT NULL DEFAULT '{}',\n    ok INTEGER NOT NULL DEFAULT 0,\n    failure_reason TEXT,\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE TABLE IF NOT EXISTS x_youtube_comments (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    comment_index INTEGER,\n    comment_id TEXT,\n    author TEXT,\n    text TEXT,\n    likes INTEGER,\n    time_text TEXT,\n    published_at TEXT,\n    is_reply INTEGER NOT NULL DEFAULT 0,\n    json_path TEXT,\n    text_path TEXT,\n    metadata_json TEXT NOT NULL DEFAULT '{}',\n    ok INTEGER NOT NULL DEFAULT 0,\n    failure_reason TEXT,\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE TABLE IF NOT EXISTS x_youtube_failures (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    source_key TEXT NOT NULL,\n    post_id TEXT,\n    video_id TEXT,\n    url TEXT,\n    child TEXT,\n    status TEXT,\n    reason TEXT,\n    detail_json TEXT NOT NULL DEFAULT '{}',\n    created_at TEXT NOT NULL,\n    FOREIGN KEY(source_key) REFERENCES x_youtube_sources(source_key) ON DELETE CASCADE\n);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_sources_post ON x_youtube_sources(post_id);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_sources_video ON x_youtube_sources(video_id);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_subtitles_source ON x_youtube_subtitles(source_key);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_transcripts_source ON x_youtube_transcripts(source_key);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_videos_source ON x_youtube_videos(source_key);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_frames_source ON x_youtube_frames(source_key);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_comments_source ON x_youtube_comments(source_key);\nCREATE INDEX IF NOT EXISTS idx_x_youtube_failures_source ON x_youtube_failures(source_key);\n\"\"\"\n\n\ndef save_youtube_content(\n    payload: Mapping[str, Any] | None = None,\n    *,\n    db_path: str | Path | None = None,\n    read_material_files: bool | None = None,\n    max_file_chars: int | None = None,\n    replace_material: bool | None = None,\n) -> dict[str, Any]:\n    \"\"\"Persist already-fetched YouTube materials for an X terminal post.\n\n    This organ does not call yt-dlp, transcription, thumbnail extraction,\n    comment downloaders, or any other acquisition step. It receives sibling\n    organ results and saves their JSON-ready material/content to SQLite.\n    \"\"\"\n    data = _json_safe(dict(payload or {}))\n    options = _merge_options(data, read_material_files, max_file_chars, replace_material)\n    db_file = _resolve_db_path(data, db_path)\n    now = _utc_now()\n    run_id = str(uuid.uuid4())\n\n    try:\n        db_file.parent.mkdir(parents=True, exist_ok=True)\n        child_results = _normalize_child_results(data.get(\"childResults\") or data.get(\"children\") or data.get(\"results\"))\n        url_result = _child_info(child_results, URL_EXTRACTOR)[\"result\"]\n        context = _build_context(data, url_result)\n        sources = _normalize_sources(data, context, url_result, now)\n        selected = sources[0]\n        selected[\"source_key\"] = _source_key(selected)\n\n        with sqlite3.connect(str(db_file)) as conn:\n            conn.execute(\"PRAGMA foreign_keys = ON\")\n            conn.executescript(SCHEMA_SQL)\n            for source in sources:\n                source[\"source_key\"] = _source_key(source)\n                _upsert_source(conn, source, data, now)\n\n            if options[\"replaceMaterial\"]:\n                for table in MATERIAL_TABLES:\n                    conn.execute(f\"DELETE FROM {table} WHERE source_key = ?\", (selected[\"source_key\"],))\n\n            counts = {\n                \"sources\": len(sources),\n                \"subtitles\": _insert_subtitles(conn, selected, _child_info(child_results, SUBTITLE_FETCHER), options, now),\n                \"transcripts\": _insert_transcripts(conn, selected, _child_info(child_results, TRANSCRIBER), options, now),\n                \"videos\": _insert_videos(conn, selected, _child_info(child_results, VIDEO_SAVER), now),\n                \"frames\": _insert_frames(conn, selected, _child_info(child_results, FRAME_EXTRACTOR), now),\n                \"comments\": _insert_comments(conn, selected, _child_info(child_results, COMMENT_FETCHER), options, now),\n                \"failures\": _insert_failures(conn, selected, data, child_results, now),\n            }\n            status = \"saved\" if selected.get(\"url\") else \"saved_without_youtube_url\"\n            conn.execute(\n                \"\"\"\n                INSERT INTO x_youtube_runs(\n                    run_id, source_key, post_id, video_id, url, status,\n                    raw_payload_json, api_scripts_json, created_at\n                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n                \"\"\",\n                (\n                    run_id,\n                    selected[\"source_key\"],\n                    selected.get(\"post_id\"),\n                    selected.get(\"video_id\"),\n                    selected.get(\"url\"),\n                    status,\n                    _json_text(data),\n                    _json_text(API_SCRIPT_PROVENANCE),\n                    now,\n                ),\n            )\n\n        return {\n            \"ok\": True,\n            \"status\": status,\n            \"dbPath\": str(db_file),\n            \"runId\": run_id,\n            \"sourceKey\": selected[\"source_key\"],\n            \"postId\": selected.get(\"post_id\"),\n            \"post_id\": selected.get(\"post_id\"),\n            \"videoId\": selected.get(\"video_id\"),\n            \"video_id\": selected.get(\"video_id\"),\n            \"url\": selected.get(\"url\"),\n            \"counts\": counts,\n            \"tables\": [\"x_youtube_sources\", *MATERIAL_TABLES, \"x_youtube_runs\"],\n            \"externalExecution\": {\n                \"ran\": False,\n                \"reason\": \"This DB organ only persists supplied child results; it does not fetch YouTube content.\",\n            },\n            \"apiScriptsVerified\": API_SCRIPT_PROVENANCE,\n            \"failureReason\": \"\",\n        }\n    except Exception as exc:\n        return {\n            \"ok\": False,\n            \"status\": \"save_failed\",\n            \"dbPath\": str(db_file),\n            \"error\": str(exc),\n            \"failureReason\": str(exc),\n            \"externalExecution\": {\"ran\": False, \"reason\": \"Failure happened during SQLite persistence.\"},\n        }\n\n\ndef run(payload: Mapping[str, Any] | None = None, **kwargs: Any) -> dict[str, Any]:\n    data = dict(payload or {})\n    db_path = kwargs.pop(\"db_path\", kwargs.pop(\"dbPath\", data.pop(\"db_path\", data.pop(\"dbPath\", None))))\n    if kwargs:\n        data.update(kwargs)\n    return save_youtube_content(data, db_path=db_path)\n\n\ndef _merge_options(\n    data: Mapping[str, Any],\n    read_material_files: bool | None,\n    max_file_chars: int | None,\n    replace_material: bool | None,\n) -> dict[str, Any]:\n    options = dict(DEFAULT_OPTIONS)\n    for key in (\"options\", \"saveOptions\", \"dbOptions\"):\n        value = data.get(key)\n        if isinstance(value, Mapping):\n            options.update(value)\n    if read_material_files is not None:\n        options[\"readMaterialFiles\"] = bool(read_material_files)\n    if max_file_chars is not None:\n        options[\"maxFileChars\"] = int(max_file_chars)\n    if replace_material is not None:\n        options[\"replaceMaterial\"] = bool(replace_material)\n    options[\"maxFileChars\"] = max(0, int(options.get(\"maxFileChars\") or 0))\n    options[\"readMaterialFiles\"] = bool(options.get(\"readMaterialFiles\"))\n    options[\"replaceMaterial\"] = bool(options.get(\"replaceMaterial\"))\n    return options\n\n\ndef _resolve_db_path(data: Mapping[str, Any], explicit: str | Path | None) -> Path:\n    candidates = [explicit, data.get(\"dbPath\"), data.get(\"db_path\"), data.get(\"sqlitePath\"), data.get(\"databasePath\")]\n    input_value = data.get(\"input\")\n    if isinstance(input_value, Mapping):\n        candidates.extend([input_value.get(\"dbPath\"), input_value.get(\"db_path\")])\n    options = data.get(\"options\")\n    if isinstance(options, Mapping):\n        candidates.extend([options.get(\"dbPath\"), options.get(\"db_path\")])\n    for value in candidates:\n        if value:\n            return Path(str(value)).expanduser().resolve(strict=False)\n    return (Path.cwd() / \"x_youtube_content.sqlite3\").resolve(strict=False)\n\n\ndef _build_context(data: Mapping[str, Any], url_result: Any) -> dict[str, Any]:\n    youtube = _first_mapping(data.get(\"youtube\"), data.get(\"youtubeContext\"))\n    original_input = _first_mapping(data.get(\"input\"), data.get(\"source\"))\n    url_map = _first_mapping(url_result)\n    post_id = (\n        _first_text(youtube, \"postId\", \"post_id\")\n        or _first_text(data, \"postId\", \"post_id\")\n        or _first_text(original_input, \"postId\", \"post_id\")\n        or _first_text(url_map, \"postId\", \"post_id\")\n    )\n    media_index = _first_value(youtube, \"mediaIndex\", \"media_index\")\n    if media_index in (None, \"\"):\n        media_index = _first_value(data, \"mediaIndex\", \"media_index\")\n    if media_index in (None, \"\"):\n        media_index = _first_value(original_input, \"mediaIndex\", \"media_index\")\n    if media_index in (None, \"\"):\n        media_index = _first_value(url_map, \"mediaIndex\", \"media_index\")\n\n    url = (\n        _first_text(youtube, \"normalizedUrl\", \"canonicalUrl\", \"url\")\n        or _first_text(data, \"normalizedUrl\", \"canonicalUrl\", \"url\")\n        or _first_text(url_map, \"normalizedUrl\", \"canonicalUrl\", \"url\")\n    )\n    original_url = _first_text(youtube, \"originalUrl\", \"url\") or _first_text(url_map, \"originalUrl\", \"url\") or url\n    normalized_url = _first_text(youtube, \"normalizedUrl\", \"canonicalUrl\") or _first_text(url_map, \"normalizedUrl\", \"canonicalUrl\") or url\n    video_id = _first_text(youtube, \"videoId\", \"video_id\") or _first_text(data, \"videoId\", \"video_id\") or _first_text(url_map, \"videoId\", \"video_id\")\n\n    return {\n        \"post_id\": post_id,\n        \"video_id\": video_id,\n        \"url\": url,\n        \"normalized_url\": normalized_url,\n        \"original_url\": original_url,\n        \"media_index\": _coerce_int(media_index),\n        \"source_text\": _first_text(youtube, \"sourceText\", \"source_text\") or _first_text(url_map, \"sourceText\", \"source_text\"),\n        \"primary_evidence\": _first_text(data, \"primaryEvidence\", \"primary_evidence\"),\n        \"subtitle_adequate\": _truthy(data.get(\"subtitleAdequate\", data.get(\"subtitle_adequate\"))),\n        \"comments_role\": _first_text(data, \"commentsRole\", \"comments_role\"),\n    }\n\n\ndef _normalize_sources(data: Mapping[str, Any], context: Mapping[str, Any], url_result: Any, now: str) -> list[dict[str, Any]]:\n    records: list[dict[str, Any]] = []\n\n    def add(raw: Mapping[str, Any] | None, fallback: Mapping[str, Any]) -> None:\n        raw = raw or {}\n        url = _first_text(raw, \"normalizedUrl\", \"normalized_url\", \"canonicalUrl\", \"url\") or str(fallback.get(\"url\") or \"\")\n        media_index = _first_value(raw, \"mediaIndex\", \"media_index\")\n        record = {\n            \"post_id\": _first_text(raw, \"postId\", \"post_id\") or str(fallback.get(\"post_id\") or \"\"),\n            \"video_id\": _first_text(raw, \"videoId\", \"video_id\") or str(fallback.get(\"video_id\") or \"\"),\n            \"url\": url,\n            \"normalized_url\": _first_text(raw, \"normalizedUrl\", \"normalized_url\", \"canonicalUrl\") or str(fallback.get(\"normalized_url\") or url),\n            \"original_url\": _first_text(raw, \"originalUrl\", \"original_url\", \"url\") or str(fallback.get(\"original_url\") or url),\n            \"media_index\": _coerce_int(media_index) if media_index not in (None, \"\") else fallback.get(\"media_index\"),\n            \"source_text\": _first_text(raw, \"sourceText\", \"source_text\") or str(fallback.get(\"source_text\") or \"\"),\n            \"primary_evidence\": str(fallback.get(\"primary_evidence\") or \"\"),\n            \"subtitle_adequate\": bool(fallback.get(\"subtitle_adequate\")),\n            \"comments_role\": str(fallback.get(\"comments_role\") or \"\"),\n            \"created_at\": now,\n            \"updated_at\": now,\n        }\n        records.append(record)\n\n    add(None, context)\n    url_map = _first_mapping(url_result)\n    for found in _as_list(url_map.get(\"foundUrls\") or url_map.get(\"sources\") or data.get(\"sources\") or data.get(\"youtubeSources\")):\n        if isinstance(found, Mapping):\n            add(found, context)\n\n    unique: list[dict[str, Any]] = []\n    seen: set[str] = set()\n    for record in records:\n        key = _source_key(record)\n        if key in seen:\n            continue\n        seen.add(key)\n        record[\"source_key\"] = key\n        unique.append(record)\n    if not unique:\n        fallback = dict(context)\n        fallback.update({\"created_at\": now, \"updated_at\": now})\n        fallback[\"source_key\"] = _source_key(fallback)\n        unique.append(fallback)\n    return unique\n\n\ndef _upsert_source(conn: sqlite3.Connection, source: Mapping[str, Any], payload: Mapping[str, Any], now: str) -> None:\n    conn.execute(\n        \"\"\"\n        INSERT INTO x_youtube_sources(\n            source_key, post_id, video_id, url, normalized_url, original_url, media_index,\n            source_text, source_payload_json, primary_evidence, subtitle_adequate,\n            comments_role, created_at, updated_at\n        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n        ON CONFLICT(source_key) DO UPDATE SET\n            post_id = excluded.post_id,\n            video_id = excluded.video_id,\n            url = excluded.url,\n            normalized_url = excluded.normalized_url,\n            original_url = excluded.original_url,\n            media_index = excluded.media_index,\n            source_text = excluded.source_text,\n            source_payload_json = excluded.source_payload_json,\n            primary_evidence = excluded.primary_evidence,\n            subtitle_adequate = excluded.subtitle_adequate,\n            comments_role = excluded.comments_role,\n            updated_at = excluded.updated_at\n        \"\"\",\n        (\n            source.get(\"source_key\"),\n            _blank_to_none(source.get(\"post_id\")),\n            _blank_to_none(source.get(\"video_id\")),\n            _blank_to_none(source.get(\"url\")),\n            _blank_to_none(source.get(\"normalized_url\")),\n            _blank_to_none(source.get(\"original_url\")),\n            source.get(\"media_index\"),\n            _blank_to_none(source.get(\"source_text\")),\n            _json_text(payload),\n            _blank_to_none(source.get(\"primary_evidence\")),\n            1 if source.get(\"subtitle_adequate\") else 0,\n            _blank_to_none(source.get(\"comments_role\")),\n            now,\n            now,\n        ),\n    )\n\n\ndef _insert_subtitles(conn: sqlite3.Connection, source: Mapping[str, Any], child: Mapping[str, Any], options: Mapping[str, Any], now: str) -> int:\n    count = 0\n    for item in _subtitle_candidates(child.get(\"result\")):\n        text_path = _first_text(item, \"textPath\", \"text_path\")\n        saved_path = _first_text(item, \"savedPath\", \"saved_path\", \"localPath\", \"path\", \"filePath\") or text_path\n        text = _first_text(item, \"subtitleText\", \"subtitle_text\", \"text\", \"content\", \"body\")\n        if not text and options.get(\"readMaterialFiles\"):\n            text = _read_text_file(text_path or saved_path, int(options[\"maxFileChars\"]))\n        segments = _first_value(item, \"segments\", \"captions\", \"subtitles\")\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_youtube_subtitles(\n                source_key, post_id, video_id, url, language, is_auto_generated, text,\n                char_count, text_path, vtt_path, saved_path, segments_json, metadata_json,\n                ok, failure_reason, created_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            \"\"\",\n            (\n                source[\"source_key\"], source.get(\"post_id\"), source.get(\"video_id\"), source.get(\"url\"),\n                _first_text(item, \"language\", \"lang\"), _nullable_bool(_first_value(item, \"isAutoGenerated\", \"autoGenerated\", \"automatic\", \"auto_generated\")),\n                text or None, len(text or \"\"), _blank_to_none(text_path), _blank_to_none(_first_text(item, \"vttPath\", \"vtt_path\")),\n                _blank_to_none(saved_path), _json_text(segments if segments is not None else []), _json_text(item),\n                1 if _child_or_item_ok(child, item) else 0, _blank_to_none(child.get(\"failureReason\") or _failure_reason(item)), now,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef _insert_transcripts(conn: sqlite3.Connection, source: Mapping[str, Any], child: Mapping[str, Any], options: Mapping[str, Any], now: str) -> int:\n    count = 0\n    for item in _transcript_candidates(child.get(\"result\")):\n        text_path = _first_text(item, \"textPath\", \"text_path\", \"path\", \"filePath\", \"savedPath\")\n        text = _first_text(item, \"transcript\", \"transcriptText\", \"transcript_text\", \"text\", \"content\", \"body\")\n        if not text and options.get(\"readMaterialFiles\"):\n            text = _read_text_file(text_path, int(options[\"maxFileChars\"]))\n        segments = _first_value(item, \"segments\", \"utterances\")\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_youtube_transcripts(\n                source_key, post_id, video_id, url, language, model, text, char_count,\n                text_path, segments_json, metadata_json, ok, failure_reason, created_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            \"\"\",\n            (\n                source[\"source_key\"], source.get(\"post_id\"), source.get(\"video_id\"), source.get(\"url\"),\n                _first_text(item, \"language\", \"lang\"), _first_text(item, \"model\", \"modelSize\", \"model_size\"),\n                text or None, len(text or \"\"), _blank_to_none(text_path), _json_text(segments if segments is not None else []),\n                _json_text(item), 1 if _child_or_item_ok(child, item) else 0, _blank_to_none(child.get(\"failureReason\") or _failure_reason(item)), now,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef _insert_videos(conn: sqlite3.Connection, source: Mapping[str, Any], child: Mapping[str, Any], now: str) -> int:\n    count = 0\n    for item in _video_candidates(child.get(\"result\")):\n        path = _first_text(item, \"localPath\", \"local_path\", \"filePath\", \"file_path\", \"videoPath\", \"path\", \"savedPath\")\n        size_bytes = _coerce_int(_first_value(item, \"sizeBytes\", \"size_bytes\", \"bytes\", \"byteCount\", \"fileSize\"))\n        if size_bytes is None and path:\n            size_bytes = _stat_size(path)\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_youtube_videos(\n                source_key, post_id, video_id, url, local_path, file_path, output_dir,\n                title, duration_seconds, size_bytes, sha256, metadata_json, ok,\n                failure_reason, created_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            \"\"\",\n            (\n                source[\"source_key\"], source.get(\"post_id\"), source.get(\"video_id\"), source.get(\"url\"),\n                _blank_to_none(path), _blank_to_none(path), _blank_to_none(_first_text(item, \"outputDir\", \"output_dir\")),\n                _blank_to_none(_first_text(item, \"title\")), _coerce_float(_first_value(item, \"duration\", \"durationSeconds\", \"duration_seconds\")),\n                size_bytes, _blank_to_none(_first_text(item, \"sha256\")), _json_text(item),\n                1 if _child_or_item_ok(child, item) else 0, _blank_to_none(child.get(\"failureReason\") or _failure_reason(item)), now,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef _insert_frames(conn: sqlite3.Connection, source: Mapping[str, Any], child: Mapping[str, Any], now: str) -> int:\n    count = 0\n    for item in _frame_candidates(child.get(\"result\")):\n        path = _first_text(item, \"path\", \"filePath\", \"file_path\", \"savedPath\", \"imagePath\")\n        size_bytes = _coerce_int(_first_value(item, \"sizeBytes\", \"size_bytes\", \"bytes\"))\n        if size_bytes is None and path:\n            size_bytes = _stat_size(path)\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_youtube_frames(\n                source_key, post_id, video_id, url, frame_kind, frame_index,\n                timestamp_seconds, path, width, height, size_bytes, metadata_json,\n                ok, failure_reason, created_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            \"\"\",\n            (\n                source[\"source_key\"], source.get(\"post_id\"), source.get(\"video_id\"), source.get(\"url\"),\n                _first_text(item, \"kind\", \"frameKind\", \"type\") or \"representative_frame\",\n                _coerce_int(_first_value(item, \"index\", \"frameIndex\", \"frame_index\")),\n                _coerce_float(_first_value(item, \"timestamp\", \"timestampSeconds\", \"timestamp_seconds\", \"time\")),\n                _blank_to_none(path), _coerce_int(_first_value(item, \"width\")), _coerce_int(_first_value(item, \"height\")),\n                size_bytes, _json_text(item), 1 if _child_or_item_ok(child, item) else 0,\n                _blank_to_none(child.get(\"failureReason\") or _failure_reason(item)), now,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef _insert_comments(conn: sqlite3.Connection, source: Mapping[str, Any], child: Mapping[str, Any], options: Mapping[str, Any], now: str) -> int:\n    result = _first_mapping(child.get(\"result\"))\n    text_path = _first_text(result, \"textPath\", \"text_path\")\n    json_path = _first_text(result, \"jsonPath\", \"json_path\")\n    comments = _as_list(result.get(\"comments\"))\n    if not comments and json_path and options.get(\"readMaterialFiles\"):\n        comments = _read_comments_json(json_path)\n    if not comments and text_path and options.get(\"readMaterialFiles\"):\n        raw_text = _read_text_file(text_path, int(options[\"maxFileChars\"]))\n        if raw_text:\n            comments = [{\"index\": 0, \"id\": \"__raw_text__\", \"text\": raw_text, \"kind\": \"raw_text\"}]\n\n    count = 0\n    for index, item in enumerate(comments, 1):\n        item = item if isinstance(item, Mapping) else {\"text\": str(item)}\n        comment_index = _coerce_int(_first_value(item, \"index\", \"commentIndex\", \"comment_index\"))\n        if comment_index is None:\n            comment_index = index\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_youtube_comments(\n                source_key, post_id, video_id, url, comment_index, comment_id, author,\n                text, likes, time_text, published_at, is_reply, json_path, text_path,\n                metadata_json, ok, failure_reason, created_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            \"\"\",\n            (\n                source[\"source_key\"], source.get(\"post_id\"), source.get(\"video_id\"), source.get(\"url\"),\n                comment_index, _blank_to_none(_first_text(item, \"id\", \"commentId\", \"comment_id\")),\n                _blank_to_none(_first_text(item, \"author\", \"authorName\", \"author_name\", \"user\", \"userName\")),\n                _blank_to_none(_first_text(item, \"text\", \"body\", \"content\")),\n                _coerce_int(_first_value(item, \"likes\", \"likeCount\", \"like_count\")),\n                _blank_to_none(_first_text(item, \"time\", \"timeText\", \"time_text\")),\n                _blank_to_none(_first_text(item, \"publishedAt\", \"published_at\", \"timestamp\")),\n                1 if _truthy(_first_value(item, \"isReply\", \"is_reply\", \"reply\")) else 0,\n                _blank_to_none(json_path), _blank_to_none(text_path), _json_text(item),\n                1 if _child_or_item_ok(child, item) else 0, _blank_to_none(child.get(\"failureReason\") or _failure_reason(item)), now,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef _insert_failures(conn: sqlite3.Connection, source: Mapping[str, Any], data: Mapping[str, Any], child_results: Mapping[str, Any], now: str) -> int:\n    failures: list[dict[str, Any]] = []\n    for item in _as_list(data.get(\"failures\")):\n        failures.append(dict(item) if isinstance(item, Mapping) else {\"reason\": str(item)})\n    for title, raw in child_results.items():\n        info = _child_info(child_results, title)\n        reason = info.get(\"failureReason\") or _failure_reason(info.get(\"result\"))\n        if reason:\n            failures.append({\"child\": title, \"status\": info.get(\"status\"), \"reason\": reason, \"detail\": raw})\n    if not source.get(\"url\"):\n        failures.append({\"child\": URL_EXTRACTOR, \"status\": \"no_url\", \"reason\": \"No YouTube URL was available to save.\"})\n\n    count = 0\n    seen: set[str] = set()\n    for failure in failures:\n        child = _first_text(failure, \"child\", \"title\", \"name\")\n        reason = _first_text(failure, \"reason\", \"failureReason\", \"error\", \"message\") or \"failed\"\n        status = _first_text(failure, \"status\", \"state\")\n        key = f\"{child}\\0{status}\\0{reason}\"\n        if key in seen:\n            continue\n        seen.add(key)\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_youtube_failures(\n                source_key, post_id, video_id, url, child, status, reason, detail_json, created_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n            \"\"\",\n            (\n                source[\"source_key\"], source.get(\"post_id\"), source.get(\"video_id\"), source.get(\"url\"),\n                _blank_to_none(child), _blank_to_none(status), reason, _json_text(failure), now,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef _subtitle_candidates(result: Any) -> list[Mapping[str, Any]]:\n    return _material_candidates(result, list_keys=(\"subtitleTracks\", \"tracks\", \"materials\"), scalar_path_keys=(\"textPath\", \"path\", \"savedPath\"))\n\n\ndef _transcript_candidates(result: Any) -> list[Mapping[str, Any]]:\n    return _material_candidates(result, list_keys=(\"transcripts\", \"materials\"), scalar_path_keys=(\"textPath\", \"path\", \"savedPath\"))\n\n\ndef _video_candidates(result: Any) -> list[Mapping[str, Any]]:\n    if isinstance(result, (str, Path)):\n        return [{\"localPath\": str(result), \"ok\": bool(str(result))}]\n    return _material_candidates(result, list_keys=(\"videos\", \"files\", \"materials\"), scalar_path_keys=(\"localPath\", \"filePath\", \"videoPath\", \"path\", \"savedPath\"))\n\n\ndef _frame_candidates(result: Any) -> list[Mapping[str, Any]]:\n    if isinstance(result, (str, Path)):\n        return [{\"path\": str(result), \"kind\": \"representative_frame\", \"ok\": bool(str(result))}]\n    if isinstance(result, Sequence) and not isinstance(result, (str, bytes, bytearray)):\n        rows = []\n        for item in result:\n            rows.extend(_frame_candidates(item))\n        return rows\n    data = _first_mapping(result)\n    rows: list[Mapping[str, Any]] = []\n    for key in (\"frames\", \"representativeFrames\", \"images\", \"generatedImages\"):\n        for item in _as_list(data.get(key)):\n            rows.append(item if isinstance(item, Mapping) else {\"path\": str(item), \"kind\": key})\n    for key in (\"generatedPaths\", \"savedPaths\", \"paths\", \"files\"):\n        for path in _as_list(data.get(key)):\n            rows.append({\"path\": str(path), \"kind\": key})\n    for key in (\"contactSheetPath\", \"lastFramePath\", \"framePath\", \"path\", \"savedPath\", \"imagePath\"):\n        value = data.get(key)\n        if value:\n            rows.append({\"path\": str(value), \"kind\": key, **data})\n    return rows\n\n\ndef _material_candidates(result: Any, *, list_keys: Sequence[str], scalar_path_keys: Sequence[str]) -> list[Mapping[str, Any]]:\n    if result is None:\n        return []\n    if isinstance(result, Mapping):\n        rows: list[Mapping[str, Any]] = []\n        for key in list_keys:\n            for item in _as_list(result.get(key)):\n                rows.append(item if isinstance(item, Mapping) else {\"value\": item})\n        if rows:\n            return rows\n        if any(result.get(key) not in (None, \"\", []) for key in scalar_path_keys) or _first_text(result, \"text\", \"content\", \"body\", \"transcript\", \"subtitleText\"):\n            return [result]\n        return [result] if result else []\n    if isinstance(result, Sequence) and not isinstance(result, (str, bytes, bytearray)):\n        rows = []\n        for item in result:\n            rows.extend(_material_candidates(item, list_keys=list_keys, scalar_path_keys=scalar_path_keys))\n        return rows\n    if isinstance(result, (str, Path)):\n        return [{\"path\": str(result), \"ok\": bool(str(result))}]\n    return [{\"value\": result}]\n\n\ndef _normalize_child_results(value: Any) -> dict[str, Any]:\n    if not value:\n        return {}\n    if isinstance(value, Mapping):\n        if isinstance(value.get(\"childResults\"), Mapping):\n            return dict(value[\"childResults\"])\n        return {str(key): item for key, item in value.items()}\n    if isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray)):\n        out: dict[str, Any] = {}\n        for item in value:\n            if isinstance(item, Mapping):\n                title = _first_text(item, \"title\", \"childTitle\", \"name\")\n                if title:\n                    out[title] = item\n        return out\n    return {}\n\n\ndef _child_info(children: Mapping[str, Any], title: str) -> dict[str, Any]:\n    raw = children.get(title)\n    if raw is None:\n        raw = _find_child_by_suffix(children, title)\n    wrapper = raw if isinstance(raw, Mapping) else {}\n    result = _unwrap_result(raw)\n    ok_value = wrapper.get(\"ok\") if isinstance(wrapper.get(\"ok\"), bool) else None\n    return {\n        \"title\": title,\n        \"raw\": raw,\n        \"result\": result,\n        \"status\": _first_text(wrapper, \"status\", \"state\"),\n        \"ok\": ok_value if ok_value is not None else _result_looks_ok(result),\n        \"failureReason\": _first_text(wrapper, \"failureReason\", \"failure_reason\", \"error\", \"reason\") or _failure_reason(result),\n    }\n\n\ndef _find_child_by_suffix(children: Mapping[str, Any], title: str) -> Any:\n    for key, value in children.items():\n        if str(key).endswith(title) or title.endswith(str(key)):\n            return value\n    return None\n\n\ndef _unwrap_result(value: Any) -> Any:\n    current = value\n    for _ in range(3):\n        if isinstance(current, Mapping) and \"result\" in current and (\"title\" in current or \"status\" in current or \"ok\" in current):\n            current = current.get(\"result\")\n            continue\n        break\n    return _json_safe(current)\n\n\ndef _result_looks_ok(value: Any) -> bool:\n    if isinstance(value, Mapping):\n        if isinstance(value.get(\"ok\"), bool):\n            return bool(value[\"ok\"])\n        status = str(value.get(\"status\") or value.get(\"state\") or \"\").lower()\n        if status in {\"ok\", \"success\", \"succeeded\", \"completed\", \"saved\"}:\n            return True\n        if status in {\"error\", \"failed\", \"failure\", \"skipped\", \"missing_runner\"}:\n            return False\n        if _failure_reason(value):\n            return False\n        return bool(value)\n    if isinstance(value, (str, Path)):\n        return bool(str(value))\n    return value is not None\n\n\ndef _child_or_item_ok(child: Mapping[str, Any], item: Mapping[str, Any]) -> bool:\n    if isinstance(item.get(\"ok\"), bool):\n        return bool(item[\"ok\"])\n    return bool(child.get(\"ok\"))\n\n\ndef _failure_reason(value: Any) -> str:\n    data = _first_mapping(value)\n    return _first_text(data, \"failureReason\", \"failure_reason\", \"error\", \"reason\", \"message\")\n\n\ndef _read_text_file(path_value: Any, max_chars: int) -> str:\n    if not path_value or max_chars <= 0:\n        return \"\"\n    path = Path(str(path_value)).expanduser()\n    try:\n        if not path.exists() or not path.is_file():\n            return \"\"\n        return path.read_text(encoding=\"utf-8\", errors=\"replace\")[:max_chars]\n    except OSError:\n        return \"\"\n\n\ndef _read_comments_json(path_value: Any) -> list[Any]:\n    if not path_value:\n        return []\n    path = Path(str(path_value)).expanduser()\n    try:\n        if not path.exists() or not path.is_file():\n            return []\n        data = json.loads(path.read_text(encoding=\"utf-8\", errors=\"replace\"))\n    except (OSError, json.JSONDecodeError):\n        return []\n    if isinstance(data, Mapping):\n        return _as_list(data.get(\"comments\") or data.get(\"items\") or data.get(\"data\"))\n    return _as_list(data)\n\n\ndef _stat_size(path_value: Any) -> int | None:\n    try:\n        path = Path(str(path_value)).expanduser()\n        if path.exists() and path.is_file():\n            return path.stat().st_size\n    except OSError:\n        return None\n    return None\n\n\ndef _source_key(source: Mapping[str, Any]) -> str:\n    parts = [\n        str(source.get(\"post_id\") or \"\"),\n        str(source.get(\"video_id\") or \"\"),\n        str(source.get(\"normalized_url\") or source.get(\"url\") or \"\"),\n        str(source.get(\"media_index\") if source.get(\"media_index\") is not None else \"\"),\n    ]\n    if not any(parts):\n        parts = [\"empty-youtube-source\"]\n    return hashlib.sha256(\"\\x1f\".join(parts).encode(\"utf-8\", errors=\"replace\")).hexdigest()[:32]\n\n\ndef _first_mapping(*values: Any) -> dict[str, Any]:\n    for value in values:\n        if isinstance(value, Mapping):\n            return dict(value)\n    return {}\n\n\ndef _first_value(data: Mapping[str, Any] | Any, *keys: str) -> Any:\n    if not isinstance(data, Mapping):\n        return None\n    for key in keys:\n        value = data.get(key)\n        if value not in (None, \"\"):\n            return value\n    return None\n\n\ndef _first_text(data: Mapping[str, Any] | Any, *keys: str) -> str:\n    value = _first_value(data, *keys)\n    if value is None or isinstance(value, (dict, list, tuple)):\n        return \"\"\n    return str(value).strip()\n\n\ndef _as_list(value: Any) -> list[Any]:\n    if value is None or value == \"\":\n        return []\n    if isinstance(value, list):\n        return value\n    if isinstance(value, tuple):\n        return list(value)\n    return [value]\n\n\ndef _coerce_int(value: Any) -> int | None:\n    if value is None or value == \"\" or isinstance(value, bool):\n        return None\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef _coerce_float(value: Any) -> float | None:\n    if value is None or value == \"\" or isinstance(value, bool):\n        return None\n    try:\n        return float(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef _nullable_bool(value: Any) -> int | None:\n    if value is None or value == \"\":\n        return None\n    return 1 if _truthy(value) else 0\n\n\ndef _truthy(value: Any) -> bool:\n    if isinstance(value, str):\n        return value.strip().lower() in {\"1\", \"true\", \"yes\", \"y\", \"on\", \"ok\", \"success\"}\n    return bool(value)\n\n\ndef _blank_to_none(value: Any) -> Any:\n    return None if value == \"\" else value\n\n\ndef _json_safe(value: Any) -> Any:\n    if isinstance(value, Mapping):\n        return {str(key): _json_safe(item) for key, item in value.items()}\n    if isinstance(value, (list, tuple)):\n        return [_json_safe(item) for item in value]\n    if isinstance(value, Path):\n        return str(value)\n    if isinstance(value, (str, int, float, bool)) or value is None:\n        return value\n    return str(value)\n\n\ndef _json_text(value: Any) -> str:\n    return json.dumps(_json_safe(value), ensure_ascii=False, sort_keys=True, separators=(\",\", \":\"))\n\n\ndef _utc_now() -> str:\n    return datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n\n\ndef _load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        raw = sys.stdin.read()\n        return json.loads(raw) if raw.strip() else {}\n    path = Path(value)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Persist fetched YouTube/X terminal-post materials to SQLite.\")\n    parser.add_argument(\"--payload-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--db-path\", default=None)\n    parser.add_argument(\"--no-read-material-files\", action=\"store_true\")\n    parser.add_argument(\"--max-file-chars\", type=int, default=None)\n    parser.add_argument(\"--keep-existing-material\", action=\"store_true\")\n    parser.add_argument(\"--indent\", type=int, default=2)\n    args = parser.parse_args(argv)\n\n    payload = _load_json_arg(args.payload_json)\n    result = save_youtube_content(\n        payload,\n        db_path=args.db_path,\n        read_material_files=not args.no_read_material_files,\n        max_file_chars=args.max_file_chars,\n        replace_material=not args.keep_existing_material,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
