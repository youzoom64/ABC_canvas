    {
      "id": "node-5cd6c85247",
      "title": "画像内容確認ポワン",
      "body": "終端投稿に画像が含まれている時、その画像をDBへ残せる確認結果にするための神経ポワン。X上の画像URLを抽出し、画像ファイルを保存し、LM Studioの画像対応モデルで内容を読み取り、その読解結果をDBに保存する流れを束ねる。自分自身はコードを持たず、下位の臓器ポワンへ処理を分ける。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nimport types\nfrom collections.abc import Callable, Mapping\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\nX_IMAGE_EXTRACT_TITLE = \"X画像URL抽出ポワン\"\nIMAGE_FILE_SAVE_TITLE = \"画像ファイル保存ポワン\"\nLMSTUDIO_IMAGE_READ_TITLE = \"LMStudio画像読解ポワン\"\nIMAGE_READING_DB_SAVE_TITLE = \"画像読解結果DB保存ポワン\"\nSELF_TITLE = \"画像内容確認ポワン\"\nCOMPONENT_TYPE = \"image\"\n\nDEFAULT_PROJECT_PATH = Path(\"project.powan\")\nDEFAULT_OUT_DIR = Path(\"data/x_media/images\")\nDEFAULT_DB_PATH = Path(\"data/x_posts.sqlite\")\nDEFAULT_LMSTUDIO_API_URL = \"http://localhost:1234/v1/chat/completions\"\nDEFAULT_PROMPT_VERSION = \"lmstudio-image-reading-v1\"\nDEFAULT_DOWNLOAD_TIMEOUT = 30.0\nDEFAULT_MAX_BYTES = 50 * 1024 * 1024\n\nPOST_ID_KEYS = (\"terminal_post_id\", \"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\")\nMEDIA_INDEX_KEYS = (\"media_index\", \"mediaIndex\", \"source_entity_index\", \"sourceEntityIndex\", \"image_index\", \"imageIndex\", \"photo_index\", \"photoIndex\", \"index\")\nURL_KEYS = (\"terminal_post_url\", \"post_url\", \"postUrl\", \"tweet_url\", \"tweetUrl\", \"status_url\", \"statusUrl\", \"url\")\nIMAGE_URL_KEYS = (\n    \"original_url\",\n    \"originalUrl\",\n    \"imageUrlLarge\",\n    \"image_url_large\",\n    \"largeImageUrl\",\n    \"large_image_url\",\n    \"imageUrlSmall\",\n    \"image_url_small\",\n    \"imageUrl\",\n    \"image_url\",\n    \"media_url\",\n    \"mediaUrl\",\n    \"source_url\",\n    \"sourceUrl\",\n    \"url\",\n)\nLOCAL_PATH_KEYS = (\"local_path\", \"localPath\", \"path\", \"file_path\", \"filePath\", \"saved_path\", \"savedPath\")\nSHA_KEYS = (\"sha256\", \"file_sha256\", \"fileSha256\", \"hash\")\nALT_KEYS = (\"alt_text\", \"altText\", \"alt\", \"description\")\nMEDIA_KEY_KEYS = (\"x_media_key\", \"xMediaKey\", \"media_key\", \"mediaKey\")\n\nCHILD_RESULT_KEYS = {\n    \"extract\": (\"extract\", \"extraction\", \"x_image_extract\", \"xImageExtract\", \"x_image_url_extract\", \"xImageUrlExtract\", X_IMAGE_EXTRACT_TITLE),\n    \"save\": (\"save\", \"image_save\", \"imageSave\", \"file_save\", \"fileSave\", \"image_file_save\", \"imageFileSave\", IMAGE_FILE_SAVE_TITLE),\n    \"lmstudio\": (\"lmstudio\", \"lmstudio_result\", \"lmstudioResult\", \"image_reading\", \"imageReading\", \"vision\", \"vision_result\", \"visionResult\", LMSTUDIO_IMAGE_READ_TITLE),\n    \"db\": (\"db\", \"db_result\", \"dbResult\", \"save_to_db\", \"saveToDb\", \"image_reading_db_save\", \"imageReadingDbSave\", IMAGE_READING_DB_SAVE_TITLE),\n}\n\nRETRYABLE_BY_TYPE = {\n    \"image_url_missing\": False,\n    \"image_download_failed\": True,\n    \"unsupported_image_type\": False,\n    \"image_decode_failed\": False,\n    \"lmstudio_unavailable\": True,\n    \"vision_read_failed\": True,\n    \"db_write_failed\": True,\n}\n\n\nclass ImageContentConfirmationError(RuntimeError):\n    pass\n\n\nclass ChildFunctions:\n    def __init__(\n        self,\n        *,\n        extract_x_image_urls: Callable[..., dict[str, Any]],\n        save_images: Callable[..., dict[str, Any]],\n        analyze_image_with_lmstudio: Callable[..., dict[str, Any]],\n        store_payload: Callable[..., dict[str, Any]],\n    ) -> None:\n        self.extract_x_image_urls = extract_x_image_urls\n        self.save_images = save_images\n        self.analyze_image_with_lmstudio = analyze_image_with_lmstudio\n        self.store_payload = store_payload\n\n\ndef confirm_image_contents(input_json: Any | None = None, **kwargs: Any) -> dict[str, Any]:\n    return confirm_image_component(input_json, **kwargs)\n\n\ndef confirm_image_component(\n    input_json: Any | None = None,\n    *,\n    child_functions: ChildFunctions | None = None,\n    child_results: Mapping[str, Any] | None = None,\n    project_path: str | Path = DEFAULT_PROJECT_PATH,\n    execute_missing: bool = True,\n    driver: Any | None = None,\n    port: int = 9221,\n    wait: float = 15.0,\n    out_dir: str | Path = DEFAULT_OUT_DIR,\n    download_timeout: float = DEFAULT_DOWNLOAD_TIMEOUT,\n    max_bytes: int = DEFAULT_MAX_BYTES,\n    model: str = \"\",\n    lmstudio_api_url: str = DEFAULT_LMSTUDIO_API_URL,\n    lmstudio_timeout: float = 120.0,\n    max_tokens: int = 1200,\n    temperature: float = 0.0,\n    prompt_version: str = DEFAULT_PROMPT_VERSION,\n    db_path: str | Path = DEFAULT_DB_PATH,\n    jsonl_path: str | Path | None = None,\n    runs_log_path: str | Path | None = None,\n    write_logs: bool = True,\n) -> dict[str, Any]:\n    source_input = input_json if input_json is not None else {}\n    envelope, image_items = split_component_input(source_input)\n    context = build_context(envelope, source_input)\n    provided_results = normalize_child_results(child_results)\n    errors: list[dict[str, Any]] = []\n    loaded_functions = child_functions\n    child_result_json: dict[str, Any] = {}\n\n    def ensure_children() -> ChildFunctions:\n        nonlocal loaded_functions\n        if loaded_functions is None:\n            if not execute_missing:\n                raise ImageContentConfirmationError(\"child execution is disabled and a required child result is missing\")\n            loaded_functions = load_child_functions_from_project(project_path)\n        return loaded_functions\n\n    seed_images = image_records_from_image_items(image_items, context)\n    for item in seed_images:\n        if not first_text(item, IMAGE_URL_KEYS):\n            add_component_error(errors, \"image_url_missing\", \"url_extract\", \"image_item has no original_url\", context, item)\n\n    extract_result = provided_child_result(provided_results, \"extract\")\n    should_reconfirm = bool(context[\"terminal_post_url\"]) or not seed_images\n    if extract_result is None and should_reconfirm:\n        try:\n            children = ensure_children()\n            extract_result = children.extract_x_image_urls(\n                driver=driver,\n                url=context[\"terminal_post_url\"] or None,\n                port=port,\n                wait=wait,\n            )\n        except Exception as exc:  # noqa: BLE001\n            add_component_error(errors, \"image_url_missing\", \"url_extract\", str(exc), context, error_type_detail=exc.__class__.__name__)\n            extract_result = {\"ok\": False, \"images\": [], \"error\": str(exc)}\n    elif extract_result is None:\n        extract_result = {\"ok\": True, \"images\": seed_images, \"skipped\": \"terminal_post_url was not available\"}\n    extract_result = json_safe(extract_result)\n    child_result_json[\"x_image_url_extract\"] = extract_result\n    collect_child_errors(errors, \"url_extract\", extract_result, context)\n\n    extracted_images = image_records_from_result(extract_result)\n    all_candidates = merge_image_records(seed_images, extracted_images, context)\n    downloadable_candidates = [item for item in all_candidates if first_text(item, IMAGE_URL_KEYS)]\n    image_count = max(len(seed_images), len(all_candidates), len(downloadable_candidates))\n    if not downloadable_candidates:\n        add_component_error(errors, \"image_url_missing\", \"url_extract\", \"no image URL was available for this image component\", context)\n\n    save_result = provided_child_result(provided_results, \"save\")\n    if save_result is None and downloadable_candidates:\n        try:\n            children = ensure_children()\n            save_result = children.save_images(\n                {\"post_id\": context[\"terminal_post_id\"], \"postId\": context[\"terminal_post_id\"], \"images\": downloadable_candidates},\n                out_dir=Path(out_dir),\n                timeout=download_timeout,\n                max_bytes=max_bytes,\n            )\n        except Exception as exc:  # noqa: BLE001\n            mapped = classify_error(\"image_file_save\", str(exc))\n            add_component_error(errors, mapped, \"download\", str(exc), context, error_type_detail=exc.__class__.__name__)\n            save_result = {\"ok\": False, \"images\": [], \"errors\": [{\"error\": str(exc)}]}\n    elif save_result is None:\n        save_result = {\"ok\": False, \"images\": [], \"errors\": [{\"error\": \"no image URL to download\"}]}\n    save_result = json_safe(save_result)\n    child_result_json[\"image_file_save\"] = save_result\n    collect_child_errors(errors, \"download\", save_result, context)\n    downloaded_images = image_records_from_result(save_result)\n\n    lmstudio_result = provided_child_result(provided_results, \"lmstudio\")\n    if lmstudio_result is not None:\n        vision_results = normalize_lmstudio_results(lmstudio_result)\n    else:\n        vision_results: list[dict[str, Any]] = []\n        if downloaded_images and not model:\n            add_component_error(errors, \"lmstudio_unavailable\", \"vision_read\", \"model is required to run LM Studio image reading\", context)\n        elif downloaded_images:\n            try:\n                children = ensure_children()\n                for image in downloaded_images:\n                    try:\n                        reading = children.analyze_image_with_lmstudio(\n                            image,\n                            model=model,\n                            local_path=first_text(image, LOCAL_PATH_KEYS),\n                            api_url=lmstudio_api_url,\n                            timeout=lmstudio_timeout,\n                            max_tokens=max_tokens,\n                            temperature=temperature,\n                            prompt_version=prompt_version,\n                        )\n                        normalized = normalize_vision_result(reading, image, context, prompt_version)\n                        vision_results.append(normalized)\n                        collect_child_errors(errors, \"vision_read\", normalized, context, image)\n                    except Exception as exc:  # noqa: BLE001\n                        mapped = classify_error(\"lmstudio_image_read\", str(exc))\n                        add_component_error(errors, mapped, \"vision_read\", str(exc), context, image, error_type_detail=exc.__class__.__name__)\n            except Exception as exc:  # noqa: BLE001\n                mapped = classify_error(\"lmstudio_image_read\", str(exc))\n                add_component_error(errors, mapped, \"vision_read\", str(exc), context, error_type_detail=exc.__class__.__name__)\n    child_result_json[\"lmstudio_image_read\"] = vision_results\n\n    db_result = provided_child_result(provided_results, \"db\")\n    if db_result is None:\n        db_items = build_db_items(downloaded_images, vision_results, context, prompt_version)\n        if db_items:\n            try:\n                children = ensure_children()\n                db_result = children.store_payload({\"items\": db_items}, db_path=Path(db_path))\n            except Exception as exc:  # noqa: BLE001\n                add_component_error(errors, \"db_write_failed\", \"db_write\", str(exc), context, error_type_detail=exc.__class__.__name__)\n                db_result = {\"ok\": False, \"saved_count\": 0, \"saved\": [], \"errors\": [{\"error\": str(exc)}]}\n        else:\n            db_result = {\"ok\": False, \"saved_count\": 0, \"saved\": [], \"skipped\": \"no successful vision result to save\"}\n            if downloaded_images:\n                add_component_error(errors, \"vision_read_failed\", \"vision_read\", \"no successful vision result to save\", context)\n    db_result = json_safe(db_result)\n    child_result_json[\"image_reading_db_save\"] = db_result\n    collect_child_errors(errors, \"db_write\", db_result, context)\n\n    local_paths = [path for path in (first_text(item, LOCAL_PATH_KEYS) for item in downloaded_images) if path]\n    image_urls = [url for url in (first_text(item, IMAGE_URL_KEYS) for item in downloadable_candidates) if url]\n    media_indexes = [index for index in (media_index_value(item) for item in downloaded_images or downloadable_candidates) if index is not None]\n    artifact_paths = list(dict.fromkeys(local_paths))\n\n    child_result = build_child_result(\n        context=context,\n        image_count=image_count,\n        downloaded_images=downloaded_images,\n        vision_results=vision_results,\n        db_result=db_result,\n        model_name=model_name_from_results(vision_results, model),\n        prompt_version=prompt_version,\n        evidence_json=build_evidence_json(context, image_items, downloadable_candidates, child_result_json),\n        artifact_paths=artifact_paths,\n        errors=errors,\n        lmstudio_api_url=lmstudio_api_url,\n        db_path=db_path,\n    )\n\n    if write_logs:\n        artifact_targets = resolve_artifact_targets(context, jsonl_path=jsonl_path, runs_log_path=runs_log_path)\n        for path in artifact_targets.values():\n            if str(path) not in child_result[\"artifact_paths\"]:\n                child_result[\"artifact_paths\"].append(str(path))\n        try:\n            append_jsonl_events(child_result, artifact_targets[\"jsonl\"])\n            append_runs_log(child_result, artifact_targets[\"runs_log\"])\n        except Exception as exc:  # noqa: BLE001\n            add_component_error(errors, \"db_write_failed\", \"artifact_write\", str(exc), context, error_type_detail=exc.__class__.__name__)\n            child_result = build_child_result(\n                context=context,\n                image_count=image_count,\n                downloaded_images=downloaded_images,\n                vision_results=vision_results,\n                db_result=db_result,\n                model_name=model_name_from_results(vision_results, model),\n                prompt_version=prompt_version,\n                evidence_json=build_evidence_json(context, image_items, downloadable_candidates, child_result_json),\n                artifact_paths=child_result[\"artifact_paths\"],\n                errors=errors,\n                lmstudio_api_url=lmstudio_api_url,\n                db_path=db_path,\n            )\n\n    return json_safe(\n        {\n            \"ok\": child_result[\"status\"] == \"success\",\n            \"status\": child_result[\"status\"],\n            \"component_type\": COMPONENT_TYPE,\n            \"run_id\": context[\"run_id\"],\n            \"trace_id\": context[\"trace_id\"],\n            \"terminal_post_id\": context[\"terminal_post_id\"],\n            \"post_id\": context[\"terminal_post_id\"],\n            \"source_url\": context[\"terminal_post_url\"],\n            \"media_index\": media_indexes,\n            \"image_urls\": image_urls,\n            \"local_paths\": local_paths,\n            \"downloaded_images\": downloaded_images,\n            \"vision_results\": vision_results,\n            \"lmstudio_result\": vision_results,\n            \"db_result\": db_result,\n            \"child_result\": child_result,\n            \"child_results\": child_result_json,\n            \"save_result\": save_result,\n            \"input_json\": source_input,\n            \"errors\": errors,\n            \"failure_reasons\": errors,\n        }\n    )\n\n\ndef split_component_input(value: Any) -> tuple[dict[str, Any], list[Any]]:\n    if not isinstance(value, Mapping):\n        return {}, []\n    envelope = value.get(\"terminal_post_envelope\") or value.get(\"terminalPostEnvelope\") or value.get(\"envelope\")\n    if not isinstance(envelope, Mapping):\n        envelope = value\n    image_items = value.get(\"image_items\") or value.get(\"imageItems\")\n    if image_items is None and isinstance(envelope, Mapping):\n        image_items = envelope.get(\"image_items\") or envelope.get(\"imageItems\") or envelope.get(\"media_items\") or envelope.get(\"mediaItems\")\n    return dict(envelope), list(image_items) if isinstance(image_items, list) else []\n\n\ndef build_context(envelope: Mapping[str, Any], source_input: Any) -> dict[str, Any]:\n    author = envelope.get(\"author\") or envelope.get(\"author_id\") or envelope.get(\"screen_name\") or \"\"\n    evidence_urls = envelope.get(\"evidence_urls\") or envelope.get(\"evidenceUrls\") or []\n    if not isinstance(evidence_urls, list):\n        evidence_urls = [evidence_urls]\n    return {\n        \"run_id\": first_text(envelope, (\"run_id\", \"runId\")),\n        \"trace_id\": first_text(envelope, (\"trace_id\", \"traceId\")),\n        \"terminal_post_id\": first_text_from_any(envelope, POST_ID_KEYS),\n        \"terminal_post_url\": first_text_from_any(envelope, URL_KEYS),\n        \"author\": json_safe(author),\n        \"text_excerpt\": first_text(envelope, (\"text_excerpt\", \"textExcerpt\", \"text\")),\n        \"parent_trace\": json_safe(envelope.get(\"parent_trace\") or envelope.get(\"parentTrace\") or []),\n        \"discovery_path\": json_safe(envelope.get(\"discovery_path\") or envelope.get(\"discoveryPath\") or []),\n        \"component_flags\": json_safe(envelope.get(\"component_flags\") or envelope.get(\"componentFlags\") or {}),\n        \"evidence_urls\": [str(item) for item in evidence_urls if item],\n        \"fetch_status\": first_text(envelope, (\"fetch_status\", \"fetchStatus\")),\n        \"content_class\": first_text(envelope, (\"content_class\", \"contentClass\")) or \"image\",\n        \"source_input\": json_safe(source_input),\n    }\n\n\ndef image_records_from_image_items(image_items: list[Any], context: Mapping[str, Any]) -> list[dict[str, Any]]:\n    records: list[dict[str, Any]] = []\n    for fallback_index, raw in enumerate(image_items, start=1):\n        if isinstance(raw, str):\n            raw_item: dict[str, Any] = {\"original_url\": raw}\n        elif isinstance(raw, Mapping):\n            raw_item = dict(raw)\n        else:\n            continue\n        url = first_text(raw_item, IMAGE_URL_KEYS)\n        media_index = media_index_value(raw_item)\n        if media_index is None:\n            media_index = fallback_index\n        record = {\n            **raw_item,\n            \"post_id\": first_text(raw_item, POST_ID_KEYS) or context.get(\"terminal_post_id\", \"\"),\n            \"postId\": first_text(raw_item, POST_ID_KEYS) or context.get(\"terminal_post_id\", \"\"),\n            \"media_index\": media_index,\n            \"mediaIndex\": media_index,\n            \"source_entity_index\": media_index,\n            \"component_type\": COMPONENT_TYPE,\n            \"source_url\": url,\n            \"imageUrlLarge\": raw_item.get(\"imageUrlLarge\") or raw_item.get(\"image_url_large\") or url,\n            \"alt\": first_text(raw_item, ALT_KEYS),\n            \"evidence_url\": first_text(raw_item, (\"evidence_url\", \"evidenceUrl\")) or context.get(\"terminal_post_url\", \"\"),\n            \"x_media_key\": first_text(raw_item, MEDIA_KEY_KEYS),\n        }\n        records.append(record)\n    return records\n\n\ndef merge_image_records(seed_images: list[dict[str, Any]], extracted_images: list[dict[str, Any]], context: Mapping[str, Any]) -> list[dict[str, Any]]:\n    merged: dict[str, dict[str, Any]] = {}\n    order: list[str] = []\n    for source in (seed_images, extracted_images):\n        for raw in source:\n            item = dict(raw)\n            post_id = first_text(item, POST_ID_KEYS) or context.get(\"terminal_post_id\", \"\")\n            if post_id:\n                item.setdefault(\"post_id\", post_id)\n                item.setdefault(\"postId\", post_id)\n            index = media_index_value(item)\n            if index is not None:\n                item.setdefault(\"media_index\", index)\n                item.setdefault(\"mediaIndex\", index)\n            key = image_dedupe_key(item)\n            if key not in merged:\n                merged[key] = item\n                order.append(key)\n            else:\n                merged[key] = merge_missing(merged[key], item)\n    return [merged[key] for key in order]\n\n\ndef image_dedupe_key(item: Mapping[str, Any]) -> str:\n    for keys in (IMAGE_URL_KEYS, MEDIA_KEY_KEYS):\n        value = first_text(item, keys)\n        if value:\n            return value\n    index = media_index_value(item)\n    if index is not None:\n        return f\"index:{index}\"\n    return json.dumps(json_safe(item), ensure_ascii=False, sort_keys=True)\n\n\ndef merge_missing(base: Mapping[str, Any], extra: Mapping[str, Any]) -> dict[str, Any]:\n    merged = dict(base)\n    for key, value in extra.items():\n        if key not in merged or merged[key] in (None, \"\", [], {}):\n            merged[key] = value\n    return merged\n\n\ndef build_db_items(\n    downloaded_images: list[dict[str, Any]],\n    vision_results: list[dict[str, Any]],\n    context: Mapping[str, Any],\n    prompt_version: str,\n) -> list[dict[str, Any]]:\n    items: list[dict[str, Any]] = []\n    for index, media_asset in enumerate(downloaded_images):\n        analysis = analysis_for_media(vision_results, media_asset, fallback_index=index)\n        if analysis is None or explicit_failure(analysis):\n            continue\n        media = dict(media_asset)\n        media.setdefault(\"post_id\", context.get(\"terminal_post_id\", \"\"))\n        media.setdefault(\"postId\", context.get(\"terminal_post_id\", \"\"))\n        items.append({\"media_asset\": media, \"analysis\": normalize_analysis_for_db(analysis, prompt_version=prompt_version)})\n    return items\n\n\ndef normalize_vision_result(value: Any, image: Mapping[str, Any], context: Mapping[str, Any], prompt_version: str) -> dict[str, Any]:\n    result = dict(value) if isinstance(value, Mapping) else {\"raw_response\": value}\n    result.setdefault(\"post_id\", first_text(image, POST_ID_KEYS) or context.get(\"terminal_post_id\", \"\"))\n    result.setdefault(\"postId\", result.get(\"post_id\", \"\"))\n    index = media_index_value(image)\n    if index is not None:\n        result.setdefault(\"media_index\", index)\n        result.setdefault(\"mediaIndex\", index)\n    result.setdefault(\"source_url\", first_text(image, IMAGE_URL_KEYS))\n    result.setdefault(\"local_path\", first_text(image, LOCAL_PATH_KEYS))\n    if prompt_version:\n        result.setdefault(\"prompt_version\", prompt_version)\n    return json_safe(result)\n\n\ndef normalize_analysis_for_db(analysis: Mapping[str, Any], *, prompt_version: str) -> dict[str, Any]:\n    normalized = dict(analysis)\n    if \"visible_objects\" in normalized and \"objects\" not in normalized:\n        normalized[\"objects\"] = normalized[\"visible_objects\"]\n    if \"raw_response\" in normalized and \"raw_response_json\" not in normalized:\n        normalized[\"raw_response_json\"] = normalized[\"raw_response\"]\n    if prompt_version and not first_text(normalized, (\"prompt_version\", \"promptVersion\")):\n        normalized[\"prompt_version\"] = prompt_version\n    return normalized\n\n\ndef build_child_result(\n    *,\n    context: Mapping[str, Any],\n    image_count: int,\n    downloaded_images: list[dict[str, Any]],\n    vision_results: list[dict[str, Any]],\n    db_result: Any,\n    model_name: str,\n    prompt_version: str,\n    evidence_json: dict[str, Any],\n    artifact_paths: list[str],\n    errors: list[dict[str, Any]],\n    lmstudio_api_url: str,\n    db_path: str | Path,\n) -> dict[str, Any]:\n    status = component_status(image_count, downloaded_images, vision_results, db_result, errors)\n    primary = errors[0] if errors else {}\n    db_refs = db_artifact_paths(db_result)\n    artifact_refs = list(dict.fromkeys(str(path) for path in [*artifact_paths, *db_refs] if path))\n    return {\n        \"status\": status,\n        \"component_type\": COMPONENT_TYPE,\n        \"content_class\": context.get(\"content_class\", \"image\"),\n        \"run_id\": context.get(\"run_id\", \"\"),\n        \"trace_id\": context.get(\"trace_id\", \"\"),\n        \"terminal_post_id\": context.get(\"terminal_post_id\", \"\"),\n        \"terminal_post_url\": context.get(\"terminal_post_url\", \"\"),\n        \"source_url\": context.get(\"terminal_post_url\", \"\"),\n        \"image_count\": image_count,\n        \"downloaded_images\": downloaded_images,\n        \"vision_results\": vision_results,\n        \"model_name\": model_name,\n        \"prompt_version\": prompt_version,\n        \"artifact_paths\": artifact_refs,\n        \"extracted_metadata\": {\n            \"image_count\": image_count,\n            \"post_id\": context.get(\"terminal_post_id\", \"\"),\n            \"media_index\": [index for index in (media_index_value(item) for item in downloaded_images) if index is not None],\n            \"image_urls\": [url for url in (first_text(item, IMAGE_URL_KEYS) for item in downloaded_images) if url],\n            \"local_paths\": [path for path in (first_text(item, LOCAL_PATH_KEYS) for item in downloaded_images) if path],\n            \"downloaded_images\": downloaded_images,\n            \"dimensions\": image_dimensions(downloaded_images),\n            \"mime\": [mime for mime in (first_text(item, (\"mime\", \"mime_type\", \"mimeType\", \"content_type\", \"contentType\")) for item in downloaded_images) if mime],\n            \"sha256\": [sha for sha in (first_text(item, SHA_KEYS) for item in downloaded_images) if sha],\n            \"vision_results\": vision_results,\n            \"model_name\": model_name,\n            \"prompt_version\": prompt_version,\n            \"db_references\": db_refs,\n        },\n        \"model_or_tool_info\": {\n            \"url_extractor\": X_IMAGE_EXTRACT_TITLE,\n            \"file_saver\": IMAGE_FILE_SAVE_TITLE,\n            \"vision_reader\": LMSTUDIO_IMAGE_READ_TITLE,\n            \"db_saver\": IMAGE_READING_DB_SAVE_TITLE,\n            \"lmstudio_api_url\": lmstudio_api_url,\n            \"db_path\": str(db_path),\n        },\n        \"evidence_json\": evidence_json,\n        \"error_type\": primary.get(\"error_type\", \"\"),\n        \"error_message\": primary.get(\"error_message\", \"\"),\n        \"retryable\": any(bool(error.get(\"retryable\")) for error in errors),\n        \"finished_at\": now_utc_iso(),\n        \"errors\": errors,\n    }\n\n\ndef image_dimensions(images: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    dimensions: list[dict[str, Any]] = []\n    for image in images:\n        width = first_text(image, (\"width\", \"image_width\", \"imageWidth\"))\n        height = first_text(image, (\"height\", \"image_height\", \"imageHeight\"))\n        if not width and not height:\n            continue\n        dimensions.append(\n            {\n                \"media_index\": media_index_value(image),\n                \"width\": to_int(width),\n                \"height\": to_int(height),\n            }\n        )\n    return dimensions\n\n\ndef db_artifact_paths(db_result: Any) -> list[str]:\n    if not isinstance(db_result, Mapping):\n        return []\n    db_path = first_text(db_result, (\"db\", \"db_path\", \"dbPath\", \"path\"))\n    refs: list[str] = []\n    if db_path:\n        refs.append(f\"db:{db_path}\")\n    for row in db_saved_rows(db_result):\n        analysis_id = first_text(row, (\"analysis_id\", \"analysisId\"))\n        media_asset_id = first_text(row, (\"media_asset_id\", \"mediaAssetId\"))\n        if db_path and analysis_id:\n            refs.append(f\"db:{db_path}#analysis_id={analysis_id}\")\n        elif db_path and media_asset_id:\n            refs.append(f\"db:{db_path}#media_asset_id={media_asset_id}\")\n    return refs\n\n\ndef component_status(\n    image_count: int,\n    downloaded_images: list[dict[str, Any]],\n    vision_results: list[dict[str, Any]],\n    db_result: Any,\n    errors: list[dict[str, Any]],\n) -> str:\n    if image_count <= 0:\n        return \"failed\"\n    saved_count = 0\n    if isinstance(db_result, Mapping):\n        saved_count = int(db_result.get(\"saved_count\") or len(db_saved_rows(db_result)))\n    successful_vision = len([item for item in vision_results if not explicit_failure(item)])\n    completed = saved_count if saved_count else successful_vision\n    if not errors and completed >= image_count:\n        return \"success\"\n    if completed > 0 or downloaded_images or successful_vision:\n        return \"partial\"\n    return \"failed\"\n\n\ndef build_evidence_json(\n    context: Mapping[str, Any],\n    image_items: list[Any],\n    candidates: list[dict[str, Any]],\n    child_stage_results: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    media = evidence_media_records(image_items, candidates)\n    return {\n        \"terminal_post_url\": context.get(\"terminal_post_url\", \"\"),\n        \"evidence_urls\": context.get(\"evidence_urls\", []),\n        \"parent_trace\": context.get(\"parent_trace\", []),\n        \"discovery_path\": context.get(\"discovery_path\", []),\n        \"component_flags\": context.get(\"component_flags\", {}),\n        \"fetch_status\": context.get(\"fetch_status\", \"\"),\n        \"text_excerpt\": context.get(\"text_excerpt\", \"\"),\n        \"raw_url\": first_text_from_records(media, \"raw_url\") or context.get(\"terminal_post_url\", \"\"),\n        \"expanded_url\": first_text_from_records(media, \"expanded_url\") or context.get(\"terminal_post_url\", \"\"),\n        \"source_entity_index\": [item.get(\"source_entity_index\") for item in media if item.get(\"source_entity_index\") is not None],\n        \"media\": media,\n        \"image_items\": json_safe(image_items),\n        \"candidate_images\": candidates,\n        \"child_stage_results\": json_safe(child_stage_results or {}),\n    }\n\n\ndef evidence_media_records(image_items: list[Any], candidates: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    records: list[dict[str, Any]] = []\n    for raw in [*image_items, *candidates]:\n        if isinstance(raw, str):\n            item: dict[str, Any] = {\"original_url\": raw}\n        elif isinstance(raw, Mapping):\n            item = dict(raw)\n        else:\n            continue\n        raw_url = first_text(item, (\"raw_url\", \"rawUrl\", \"original_url\", \"originalUrl\")) or first_text(item, IMAGE_URL_KEYS)\n        expanded_url = first_text(item, (\"expanded_url\", \"expandedUrl\", \"final_url\", \"finalUrl\", \"canonical_url\", \"canonicalUrl\")) or first_text(item, IMAGE_URL_KEYS)\n        record = {\n            \"raw_url\": raw_url,\n            \"expanded_url\": expanded_url,\n            \"source_url\": first_text(item, IMAGE_URL_KEYS),\n            \"media_key\": first_text(item, MEDIA_KEY_KEYS),\n            \"source_entity_index\": media_index_value(item),\n            \"media_index\": media_index_value(item),\n            \"evidence_url\": first_text(item, (\"evidence_url\", \"evidenceUrl\")),\n        }\n        if record not in records:\n            records.append(record)\n    return records\n\n\ndef first_text_from_records(records: list[dict[str, Any]], key: str) -> str:\n    for record in records:\n        value = record.get(key)\n        if value:\n            return str(value)\n    return \"\"\n\n\ndef append_jsonl_events(child_result: Mapping[str, Any], jsonl_path: str | Path) -> None:\n    path = Path(jsonl_path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    base = {\n        \"event_ts\": now_utc_iso(),\n        \"run_id\": child_result.get(\"run_id\", \"\"),\n        \"trace_id\": child_result.get(\"trace_id\", \"\"),\n        \"terminal_post_id\": child_result.get(\"terminal_post_id\", \"\"),\n        \"content_class\": child_result.get(\"content_class\", \"image\"),\n        \"components\": [COMPONENT_TYPE],\n        \"component_type\": COMPONENT_TYPE,\n        \"child_title\": SELF_TITLE,\n        \"status\": child_result.get(\"status\", \"\"),\n        \"error_type\": child_result.get(\"error_type\", \"\"),\n        \"retryable\": child_result.get(\"retryable\", False),\n        \"artifact_paths\": child_result.get(\"artifact_paths\", []),\n        \"evidence_urls\": child_result.get(\"evidence_json\", {}).get(\"evidence_urls\", []),\n    }\n    events = [{**base, \"event_type\": \"child_result_recorded\"}]\n    for error in child_result.get(\"errors\", []):\n        if isinstance(error, Mapping):\n            events.append({**base, \"event_type\": \"image_component_error\", **json_safe(error)})\n    with path.open(\"a\", encoding=\"utf-8\", newline=\"\\n\") as handle:\n        for event in events:\n            handle.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + \"\\n\")\n\n\ndef append_runs_log(child_result: Mapping[str, Any], runs_log_path: str | Path) -> None:\n    path = Path(runs_log_path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    summary = {\n        \"ts\": now_utc_iso(),\n        \"event_type\": \"child_result_recorded\",\n        \"component\": COMPONENT_TYPE,\n        \"component_type\": COMPONENT_TYPE,\n        \"status\": child_result.get(\"status\", \"\"),\n        \"run_id\": child_result.get(\"run_id\", \"\"),\n        \"trace_id\": child_result.get(\"trace_id\", \"\"),\n        \"post_id\": child_result.get(\"terminal_post_id\", \"\"),\n        \"post_url\": child_result.get(\"terminal_post_url\", child_result.get(\"source_url\", \"\")),\n        \"terminal_post_id\": child_result.get(\"terminal_post_id\", \"\"),\n        \"source_url\": child_result.get(\"source_url\", \"\"),\n        \"image_count\": child_result.get(\"image_count\", 0),\n        \"downloaded\": len(child_result.get(\"downloaded_images\", [])),\n        \"vision_results\": len(child_result.get(\"vision_results\", [])),\n        \"failure_phase\": first_error_phase(child_result),\n        \"error_type\": child_result.get(\"error_type\", \"\"),\n        \"artifact_paths\": child_result.get(\"artifact_paths\", []),\n    }\n    with path.open(\"a\", encoding=\"utf-8\", newline=\"\\n\") as handle:\n        handle.write(\"image_component \" + json.dumps(summary, ensure_ascii=False, separators=(\",\", \":\")) + \"\\n\")\n\n\ndef first_error_phase(child_result: Mapping[str, Any]) -> str:\n    errors = child_result.get(\"errors\")\n    if isinstance(errors, list):\n        for error in errors:\n            if isinstance(error, Mapping):\n                phase = first_text(error, (\"phase\",))\n                if phase:\n                    return phase\n    return \"\"\n\n\ndef resolve_artifact_targets(\n    context: Mapping[str, Any],\n    *,\n    jsonl_path: str | Path | None,\n    runs_log_path: str | Path | None,\n) -> dict[str, Path]:\n    run_id = str(context.get(\"run_id\") or \"untracked\")\n    safe_run_id = \"\".join(ch if ch.isalnum() or ch in \"-_\" else \"_\" for ch in run_id) or \"untracked\"\n    root = Path(\"data/runs\") / safe_run_id\n    return {\n        \"jsonl\": Path(jsonl_path) if jsonl_path else root / \"terminal_content_events.jsonl\",\n        \"runs_log\": Path(runs_log_path) if runs_log_path else root / \"runs.log\",\n    }\n\n\ndef collect_child_errors(\n    errors: list[dict[str, Any]],\n    phase: str,\n    child_result: Any,\n    context: Mapping[str, Any],\n    image: Mapping[str, Any] | None = None,\n) -> None:\n    if isinstance(child_result, Mapping):\n        child_errors = child_result.get(\"errors\")\n        has_child_errors = isinstance(child_errors, list) and bool(child_errors)\n        if child_result.get(\"ok\") is False and not has_child_errors:\n            message = first_text(child_result, (\"error\", \"reason\", \"message\")) or f\"{phase} returned ok=false\"\n            add_component_error(errors, classify_error(phase, message), phase, message, context, image)\n        if isinstance(child_errors, list):\n            for child_error in child_errors:\n                if isinstance(child_error, Mapping):\n                    message = first_text(child_error, (\"error\", \"reason\", \"message\")) or json.dumps(child_error, ensure_ascii=False)\n                    merged_image = merge_missing(image or {}, child_error)\n                    add_component_error(errors, classify_error(phase, message), phase, message, context, merged_image)\n                elif child_error:\n                    add_component_error(errors, classify_error(phase, str(child_error)), phase, str(child_error), context, image)\n    elif isinstance(child_result, list):\n        for item in child_result:\n            collect_child_errors(errors, phase, item, context, image)\n\n\ndef add_component_error(\n    errors: list[dict[str, Any]],\n    error_type: str,\n    phase: str,\n    message: str,\n    context: Mapping[str, Any],\n    image: Mapping[str, Any] | None = None,\n    *,\n    error_type_detail: str = \"\",\n) -> None:\n    image = image or {}\n    entry = {\n        \"run_id\": context.get(\"run_id\", \"\"),\n        \"trace_id\": context.get(\"trace_id\", \"\"),\n        \"terminal_post_id\": context.get(\"terminal_post_id\", \"\"),\n        \"component_type\": COMPONENT_TYPE,\n        \"source_url\": first_text(image, IMAGE_URL_KEYS) or context.get(\"terminal_post_url\", \"\"),\n        \"media_index\": media_index_value(image),\n        \"phase\": phase,\n        \"error_type\": error_type,\n        \"error_message\": message,\n        \"retryable\": RETRYABLE_BY_TYPE.get(error_type, False),\n    }\n    if error_type_detail:\n        entry[\"exception_type\"] = error_type_detail\n    if entry not in errors:\n        errors.append(entry)\n\n\ndef classify_error(stage_or_phase: str, message: str) -> str:\n    text = f\"{stage_or_phase} {message}\".lower()\n    if \"unsupported\" in text or \"scheme\" in text or \"mime\" in text or \"content-type\" in text:\n        return \"unsupported_image_type\"\n    if \"decode\" in text or \"dimension\" in text or \"identify\" in text:\n        return \"image_decode_failed\"\n    if \"lm studio\" in text or \"connection\" in text or \"refused\" in text or \"timeout\" in text or \"unavailable\" in text:\n        return \"lmstudio_unavailable\"\n    if \"db\" in text or \"sqlite\" in text or \"database\" in text:\n        return \"db_write_failed\"\n    if \"download\" in text or \"http\" in text or \"urlopen\" in text:\n        return \"image_download_failed\"\n    if \"vision\" in text or \"read\" in text or \"model\" in text:\n        return \"vision_read_failed\"\n    if \"extract\" in text or \"url\" in text:\n        return \"image_url_missing\"\n    return \"vision_read_failed\"\n\n\ndef load_child_functions_from_project(project_path: str | Path = DEFAULT_PROJECT_PATH) -> ChildFunctions:\n    modules = load_child_modules(project_path)\n    return ChildFunctions(\n        extract_x_image_urls=required_callable(modules[X_IMAGE_EXTRACT_TITLE], \"extract_x_image_urls\", X_IMAGE_EXTRACT_TITLE),\n        save_images=required_callable(modules[IMAGE_FILE_SAVE_TITLE], \"save_images\", IMAGE_FILE_SAVE_TITLE),\n        analyze_image_with_lmstudio=required_callable(modules[LMSTUDIO_IMAGE_READ_TITLE], \"analyze_image_with_lmstudio\", LMSTUDIO_IMAGE_READ_TITLE),\n        store_payload=required_callable(modules[IMAGE_READING_DB_SAVE_TITLE], \"store_payload\", IMAGE_READING_DB_SAVE_TITLE),\n    )\n\n\ndef load_child_modules(project_path: str | Path) -> dict[str, types.ModuleType]:\n    path = Path(project_path)\n    project = json.loads(path.read_text(encoding=\"utf-8\"))\n    nodes = project.get(\"nodes\")\n    if not isinstance(nodes, list):\n        raise ImageContentConfirmationError(f\"project.powan has no nodes array: {path}\")\n    by_title = {node.get(\"title\"): node for node in nodes if isinstance(node, dict)}\n    modules: dict[str, types.ModuleType] = {}\n    for index, title in enumerate((X_IMAGE_EXTRACT_TITLE, IMAGE_FILE_SAVE_TITLE, LMSTUDIO_IMAGE_READ_TITLE, IMAGE_READING_DB_SAVE_TITLE), start=1):\n        node = by_title.get(title)\n        if not isinstance(node, dict):\n            raise ImageContentConfirmationError(f\"child powan was not found: {title}\")\n        code = node.get(\"code\")\n        if not isinstance(code, str) or not code.strip():\n            raise ImageContentConfirmationError(f\"child powan has no Python code: {title}\")\n        module_name = f\"_powan_child_{index}_{abs(hash(title))}\"\n        module = types.ModuleType(module_name)\n        module.__dict__[\"__file__\"] = str(path.resolve())\n        module.__dict__[\"__package__\"] = \"\"\n        sys.modules[module_name] = module\n        exec(compile(code, f\"<powan child {title}>\", \"exec\"), module.__dict__)\n        modules[title] = module\n    return modules\n\n\ndef required_callable(module: types.ModuleType, name: str, title: str) -> Callable[..., dict[str, Any]]:\n    value = getattr(module, name, None)\n    if not callable(value):\n        raise ImageContentConfirmationError(f\"{title} does not expose callable {name}\")\n    return value\n\n\ndef normalize_child_results(child_results: Mapping[str, Any] | None) -> Mapping[str, Any]:\n    if not isinstance(child_results, Mapping):\n        return {}\n    nested = child_results.get(\"child_results\") or child_results.get(\"childResults\")\n    return nested if isinstance(nested, Mapping) else child_results\n\n\ndef provided_child_result(child_results: Mapping[str, Any], stage: str) -> Any | None:\n    for key in CHILD_RESULT_KEYS[stage]:\n        if key in child_results and child_results[key] is not None:\n            return child_results[key]\n    return None\n\n\ndef image_records_from_result(value: Any) -> list[dict[str, Any]]:\n    if isinstance(value, list):\n        return [dict(item) for item in value if isinstance(item, Mapping)]\n    if not isinstance(value, Mapping):\n        return []\n    for key in (\"images\", \"media\", \"items\", \"results\", \"photos\", \"attachments\", \"saved\", \"downloaded_images\", \"downloadedImages\"):\n        items = value.get(key)\n        if isinstance(items, list):\n            return [dict(item) for item in items if isinstance(item, Mapping)]\n    data = value.get(\"data\")\n    if isinstance(data, list):\n        return [dict(item) for item in data if isinstance(item, Mapping)]\n    if isinstance(data, Mapping):\n        return [dict(data)]\n    if first_text(value, IMAGE_URL_KEYS) or first_text(value, LOCAL_PATH_KEYS):\n        return [dict(value)]\n    return []\n\n\ndef normalize_lmstudio_results(value: Any) -> list[dict[str, Any]]:\n    if isinstance(value, list):\n        return [json_safe(item) for item in value if isinstance(item, Mapping)]\n    if isinstance(value, Mapping):\n        for key in (\"vision_results\", \"visionResults\", \"lmstudio_result\", \"lmstudioResult\", \"results\", \"items\", \"analyses\", \"image_analyses\", \"imageAnalyses\"):\n            items = value.get(key)\n            if isinstance(items, list):\n                return [json_safe(item) for item in items if isinstance(item, Mapping)]\n        return [json_safe(value)]\n    return []\n\n\ndef analysis_for_media(vision_results: list[dict[str, Any]], media_asset: Mapping[str, Any], *, fallback_index: int) -> dict[str, Any] | None:\n    media_index = media_index_value(media_asset)\n    if media_index is not None:\n        for item in vision_results:\n            if media_index_value(item) == media_index:\n                return item\n    return vision_results[fallback_index] if fallback_index < len(vision_results) else None\n\n\ndef db_saved_rows(value: Any) -> list[dict[str, Any]]:\n    if not isinstance(value, Mapping):\n        return []\n    for key in (\"saved\", \"results\", \"items\"):\n        items = value.get(key)\n        if isinstance(items, list):\n            return [dict(item) for item in items if isinstance(item, Mapping)]\n    return []\n\n\ndef model_name_from_results(vision_results: list[dict[str, Any]], fallback: str) -> str:\n    for item in vision_results:\n        value = first_text(item, (\"model\", \"model_name\", \"modelName\"))\n        if value:\n            return value\n    return fallback\n\n\ndef explicit_failure(value: Mapping[str, Any]) -> bool:\n    return value.get(\"ok\") is False or bool(first_text(value, (\"error\", \"reason\", \"failure\", \"error_message\", \"errorMessage\")))\n\n\ndef first_text_from_any(value: Any, keys: tuple[str, ...]) -> str:\n    if isinstance(value, Mapping):\n        direct = first_text(value, keys)\n        if direct:\n            return direct\n        for nested_key in (\"terminal_post_envelope\", \"terminalPostEnvelope\", \"input\", \"input_json\", \"post\", \"tweet\", \"status\", \"data\"):\n            nested = value.get(nested_key)\n            if isinstance(nested, Mapping):\n                found = first_text_from_any(nested, keys)\n                if found:\n                    return found\n    return \"\"\n\n\ndef first_text(record: Mapping[str, Any] | None, keys: tuple[str, ...]) -> str:\n    if not isinstance(record, Mapping):\n        return \"\"\n    for key in keys:\n        value = record.get(key)\n        if value is None:\n            continue\n        text = str(value).strip()\n        if text:\n            return text\n    return \"\"\n\n\ndef media_index_value(record: Mapping[str, Any] | None) -> int | None:\n    text = first_text(record, MEDIA_INDEX_KEYS)\n    if not text:\n        return None\n    try:\n        return int(text)\n    except ValueError:\n        return None\n\n\ndef to_int(value: Any) -> int | None:\n    if value is None or value == \"\":\n        return None\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef json_safe(value: Any) -> Any:\n    if isinstance(value, Path):\n        return str(value)\n    if isinstance(value, Mapping):\n        return {str(key): json_safe(item) for key, item in value.items()}\n    if isinstance(value, list):\n        return [json_safe(item) for item in value]\n    if isinstance(value, tuple):\n        return [json_safe(item) for item in value]\n    if isinstance(value, (str, int, float, bool)) or value is None:\n        return value\n    return str(value)\n\n\ndef now_utc_iso() -> str:\n    return datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n\n\ndef load_json_source(source: str) -> Any:\n    text = sys.stdin.read() if source == \"-\" else Path(source).read_text(encoding=\"utf-8\")\n    return json.loads(text) if text.strip() else {}\n\n\ndef load_optional_json(value: str) -> Any | None:\n    if not value:\n        return None\n    text = sys.stdin.read() if value == \"-\" else (Path(value).read_text(encoding=\"utf-8\") if Path(value).exists() else value)\n    return json.loads(text) if text.strip() else None\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=\"Confirm only the image component of a terminal X post envelope.\")\n    parser.add_argument(\"--input\", default=\"-\", help=\"terminal_post_envelope JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results-json\", default=\"\", help=\"Child results JSON string/file. Provided stages are reused.\")\n    parser.add_argument(\"--project-powan\", default=str(DEFAULT_PROJECT_PATH), help=\"project.powan path used to load child code.\")\n    parser.add_argument(\"--no-execute-missing\", action=\"store_true\", help=\"Do not run missing child stages; only merge supplied child results.\")\n    parser.add_argument(\"--no-write-logs\", action=\"store_true\", help=\"Do not append JSONL events or runs log summary.\")\n    parser.add_argument(\"--jsonl\", default=\"\", help=\"JSONL event path. Defaults to data/runs/<run_id>/terminal_content_events.jsonl.\")\n    parser.add_argument(\"--runs-log\", default=\"\", help=\"Runs log path. Defaults to data/runs/<run_id>/runs.log.\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--wait\", type=float, default=15.0)\n    parser.add_argument(\"--out-dir\", default=str(DEFAULT_OUT_DIR))\n    parser.add_argument(\"--download-timeout\", type=float, default=DEFAULT_DOWNLOAD_TIMEOUT)\n    parser.add_argument(\"--max-bytes\", type=int, default=DEFAULT_MAX_BYTES)\n    parser.add_argument(\"--model\", default=\"\", help=\"Vision-capable LM Studio model name. Required when vision stage is executed.\")\n    parser.add_argument(\"--lmstudio-api-url\", default=DEFAULT_LMSTUDIO_API_URL)\n    parser.add_argument(\"--lmstudio-timeout\", type=float, default=120.0)\n    parser.add_argument(\"--max-tokens\", type=int, default=1200)\n    parser.add_argument(\"--temperature\", type=float, default=0.0)\n    parser.add_argument(\"--prompt-version\", default=DEFAULT_PROMPT_VERSION)\n    parser.add_argument(\"--db\", default=str(DEFAULT_DB_PATH))\n    parser.add_argument(\"--compact\", action=\"store_true\")\n    return parser\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = build_parser().parse_args(argv)\n    try:\n        input_json = load_json_source(args.input)\n        child_results = load_optional_json(args.child_results_json)\n        if child_results is None and isinstance(input_json, Mapping):\n            embedded = input_json.get(\"child_results\") or input_json.get(\"childResults\")\n            child_results = embedded if isinstance(embedded, Mapping) else None\n        result = confirm_image_component(\n            input_json,\n            child_results=child_results,\n            project_path=args.project_powan,\n            execute_missing=not args.no_execute_missing,\n            port=args.port,\n            wait=args.wait,\n            out_dir=args.out_dir,\n            download_timeout=args.download_timeout,\n            max_bytes=args.max_bytes,\n            model=args.model,\n            lmstudio_api_url=args.lmstudio_api_url,\n            lmstudio_timeout=args.lmstudio_timeout,\n            max_tokens=args.max_tokens,\n            temperature=args.temperature,\n            prompt_version=args.prompt_version,\n            db_path=args.db,\n            jsonl_path=args.jsonl or None,\n            runs_log_path=args.runs_log or None,\n            write_logs=not args.no_write_logs,\n        )\n    except Exception as exc:  # noqa: BLE001\n        result = {\n            \"ok\": False,\n            \"status\": \"failed\",\n            \"component_type\": COMPONENT_TYPE,\n            \"child_result\": {\n                \"status\": \"failed\",\n                \"component_type\": COMPONENT_TYPE,\n                \"error_type\": \"vision_read_failed\",\n                \"error_message\": str(exc),\n                \"retryable\": False,\n                \"finished_at\": now_utc_iso(),\n            },\n            \"errors\": [{\"phase\": \"orchestrator\", \"error_type\": \"vision_read_failed\", \"error_message\": str(exc), \"retryable\": False}],\n            \"failure_reasons\": [{\"phase\": \"orchestrator\", \"error_type\": \"vision_read_failed\", \"error_message\": str(exc), \"retryable\": False}],\n        }\n    print(json.dumps(result, ensure_ascii=False, indent=None if args.compact else 2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n\r\n",
