    {
      "id": "node-b026c710b0",
      "title": "画像読解結果DB保存ポワン",
      "body": "LMStudio画像読解ポワンが返した画像読解結果をDBへ保存する臓器候補ポワン。media_asset_id、model、prompt_version、summary、ocr_text、objects_json、scene_json、raw_response_json、confidence、created_atを記録し、追跡した画像内容を後から検索・検証できるようにする。まだコードは持たない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport sqlite3\nimport sys\nfrom collections.abc import Mapping\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\nDEFAULT_DB_PATH = Path(\"data\") / \"x_posts.sqlite\"\n\nMEDIA_CONTAINER_KEYS = (\n    \"media_asset\",\n    \"mediaAsset\",\n    \"image_save_result\",\n    \"imageSaveResult\",\n    \"file_save_result\",\n    \"fileSaveResult\",\n    \"save_result\",\n    \"saveResult\",\n    \"saved_image\",\n    \"savedImage\",\n    \"image_file\",\n    \"imageFile\",\n    \"media\",\n    \"file\",\n)\n\nANALYSIS_CONTAINER_KEYS = (\n    \"analysis\",\n    \"image_analysis\",\n    \"imageAnalysis\",\n    \"analysis_result\",\n    \"analysisResult\",\n    \"lmstudio_result\",\n    \"lmstudioResult\",\n    \"vision_result\",\n    \"visionResult\",\n    \"reader_result\",\n    \"readerResult\",\n    \"read_result\",\n    \"readResult\",\n    \"llm_result\",\n    \"llmResult\",\n)\n\n\ndef now_utc_iso() -> str:\n    return datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n\n\ndef is_blank(value: Any) -> bool:\n    return value is None or (isinstance(value, str) and value.strip() == \"\")\n\n\ndef clean_text(value: Any) -> str | None:\n    if is_blank(value):\n        return None\n    if isinstance(value, str):\n        return value.strip()\n    return str(value)\n\n\ndef to_int(value: Any) -> int | None:\n    if is_blank(value) or isinstance(value, bool):\n        return None\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef to_float(value: Any) -> float | None:\n    if is_blank(value) or isinstance(value, bool):\n        return None\n    try:\n        return float(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef json_blob(value: Any) -> str | None:\n    if is_blank(value):\n        return None\n    if isinstance(value, str):\n        stripped = value.strip()\n        try:\n            json.loads(stripped)\n            return stripped\n        except json.JSONDecodeError:\n            return json.dumps(stripped, ensure_ascii=False)\n    return json.dumps(value, ensure_ascii=False, sort_keys=True)\n\n\ndef nested_mappings(item: Mapping[str, Any], keys: tuple[str, ...]) -> list[Mapping[str, Any]]:\n    found: list[Mapping[str, Any]] = []\n    for key in keys:\n        value = item.get(key)\n        if isinstance(value, Mapping):\n            found.append(value)\n    return found\n\n\ndef first_value(candidates: list[Mapping[str, Any]], aliases: tuple[str, ...]) -> Any:\n    for candidate in candidates:\n        for alias in aliases:\n            if alias in candidate and not is_blank(candidate[alias]):\n                return candidate[alias]\n    return None\n\n\ndef normalize_media_asset(item: Mapping[str, Any]) -> dict[str, Any]:\n    nested = nested_mappings(item, MEDIA_CONTAINER_KEYS)\n    candidates = [*nested, item]\n\n    media_asset_id = first_value(\n        candidates,\n        (\"media_asset_id\", \"mediaAssetId\", \"asset_id\", \"assetId\"),\n    )\n    if media_asset_id is None and nested:\n        media_asset_id = first_value(nested, (\"id\",))\n\n    return {\n        \"media_asset_id\": to_int(media_asset_id),\n        \"post_id\": clean_text(\n            first_value(candidates, (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\", \"x_post_id\", \"xPostId\"))\n        ),\n        \"media_index\": to_int(first_value(candidates, (\"media_index\", \"mediaIndex\", \"index\", \"ordinal\", \"position\"))),\n        \"source_url\": clean_text(\n            first_value(\n                candidates,\n                (\"source_url\", \"sourceUrl\", \"url\", \"media_url\", \"mediaUrl\", \"image_url\", \"imageUrl\", \"original_url\", \"originalUrl\"),\n            )\n        ),\n        \"local_path\": clean_text(\n            first_value(candidates, (\"local_path\", \"localPath\", \"path\", \"file_path\", \"filePath\", \"saved_path\", \"savedPath\", \"image_path\", \"imagePath\"))\n        ),\n        \"sha256\": clean_text(first_value(candidates, (\"sha256\", \"file_sha256\", \"fileSha256\", \"hash\"))),\n        \"width\": to_int(first_value(candidates, (\"width\", \"image_width\", \"imageWidth\"))),\n        \"height\": to_int(first_value(candidates, (\"height\", \"image_height\", \"imageHeight\"))),\n        \"mime\": clean_text(first_value(candidates, (\"mime\", \"mime_type\", \"mimeType\", \"content_type\", \"contentType\"))),\n        \"created_at\": clean_text(first_value(candidates, (\"created_at\", \"createdAt\", \"saved_at\", \"savedAt\", \"downloaded_at\", \"downloadedAt\"))),\n    }\n\n\ndef normalize_analysis_result(item: Mapping[str, Any]) -> dict[str, Any]:\n    nested = nested_mappings(item, ANALYSIS_CONTAINER_KEYS)\n    candidates = [*nested, item]\n\n    raw_response = first_value(\n        candidates,\n        (\"raw_response_json\", \"rawResponseJson\", \"raw_response\", \"rawResponse\", \"response_json\", \"responseJson\", \"response\", \"lmstudio_response\", \"lmstudioResponse\"),\n    )\n    if raw_response is None and nested:\n        raw_response = dict(nested[0])\n\n    return {\n        \"model\": clean_text(first_value(candidates, (\"model\", \"model_name\", \"modelName\"))),\n        \"prompt_version\": clean_text(first_value(candidates, (\"prompt_version\", \"promptVersion\", \"prompt\", \"version\"))),\n        \"summary\": clean_text(first_value(candidates, (\"summary\", \"caption\", \"description\"))),\n        \"ocr_text\": clean_text(first_value(candidates, (\"ocr_text\", \"ocrText\", \"extracted_text\", \"extractedText\", \"text\"))),\n        \"objects_json\": json_blob(first_value(candidates, (\"objects_json\", \"objectsJson\", \"objects\", \"detected_objects\", \"detectedObjects\"))),\n        \"scene_json\": json_blob(first_value(candidates, (\"scene_json\", \"sceneJson\", \"scene\", \"scene_graph\", \"sceneGraph\"))),\n        \"raw_response_json\": json_blob(raw_response),\n        \"confidence\": to_float(first_value(candidates, (\"confidence\", \"score\"))),\n        \"created_at\": clean_text(first_value(candidates, (\"created_at\", \"createdAt\", \"analyzed_at\", \"analyzedAt\", \"analysis_created_at\", \"analysisCreatedAt\"))),\n    }\n\n\ndef input_items(payload: Any) -> list[Mapping[str, Any]]:\n    if isinstance(payload, list):\n        items = payload\n    elif isinstance(payload, Mapping):\n        for key in (\"items\", \"results\", \"images\"):\n            value = payload.get(key)\n            if isinstance(value, list):\n                items = value\n                break\n        else:\n            media_items = first_value([payload], (\"media_assets\", \"mediaAssets\", \"saved_images\", \"savedImages\"))\n            analysis_items = first_value([payload], (\"analyses\", \"image_analyses\", \"imageAnalyses\", \"analysis_results\", \"analysisResults\"))\n            if isinstance(media_items, list):\n                analysis_list = analysis_items if isinstance(analysis_items, list) else []\n                paired = []\n                for index, media_item in enumerate(media_items):\n                    item: dict[str, Any] = {\"media_asset\": media_item}\n                    if index < len(analysis_list):\n                        item[\"analysis\"] = analysis_list[index]\n                    paired.append(item)\n                items = paired\n            else:\n                items = [payload]\n    else:\n        raise ValueError(\"input JSON must be an object, an array, or an object with an items array\")\n\n    checked: list[Mapping[str, Any]] = []\n    for index, item in enumerate(items):\n        if not isinstance(item, Mapping):\n            raise ValueError(f\"item {index} must be a JSON object\")\n        checked.append(item)\n    return checked\n\n\ndef has_media_identity(media: Mapping[str, Any]) -> bool:\n    has_post_slot = media.get(\"post_id\") is not None and media.get(\"media_index\") is not None\n    return bool(\n        media.get(\"media_asset_id\") is not None\n        or has_post_slot\n        or media.get(\"source_url\")\n        or media.get(\"local_path\")\n        or media.get(\"sha256\")\n    )\n\n\ndef ensure_schema(conn: sqlite3.Connection) -> None:\n    conn.executescript(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS x_media_assets (\n            media_asset_id INTEGER PRIMARY KEY AUTOINCREMENT,\n            post_id TEXT,\n            media_index INTEGER,\n            source_url TEXT,\n            local_path TEXT,\n            sha256 TEXT,\n            width INTEGER,\n            height INTEGER,\n            mime TEXT,\n            created_at TEXT NOT NULL\n        );\n\n        CREATE TABLE IF NOT EXISTS x_image_analyses (\n            analysis_id INTEGER PRIMARY KEY AUTOINCREMENT,\n            media_asset_id INTEGER NOT NULL,\n            model TEXT,\n            prompt_version TEXT,\n            summary TEXT,\n            ocr_text TEXT,\n            objects_json TEXT,\n            scene_json TEXT,\n            raw_response_json TEXT,\n            confidence REAL,\n            created_at TEXT NOT NULL,\n            FOREIGN KEY (media_asset_id) REFERENCES x_media_assets(media_asset_id) ON DELETE CASCADE\n        );\n\n        CREATE INDEX IF NOT EXISTS idx_x_media_assets_post_slot\n            ON x_media_assets(post_id, media_index);\n        CREATE INDEX IF NOT EXISTS idx_x_media_assets_sha256\n            ON x_media_assets(sha256);\n        CREATE INDEX IF NOT EXISTS idx_x_image_analyses_media_asset_id\n            ON x_image_analyses(media_asset_id);\n        CREATE INDEX IF NOT EXISTS idx_x_image_analyses_model\n            ON x_image_analyses(model, prompt_version);\n        \"\"\"\n    )\n\n\ndef find_existing_media_asset(conn: sqlite3.Connection, media: Mapping[str, Any]) -> int | None:\n    media_asset_id = media.get(\"media_asset_id\")\n    if media_asset_id is not None:\n        row = conn.execute(\n            \"SELECT media_asset_id FROM x_media_assets WHERE media_asset_id = ?\",\n            (media_asset_id,),\n        ).fetchone()\n        if row:\n            return int(row[0])\n\n    post_id = media.get(\"post_id\")\n    media_index = media.get(\"media_index\")\n    if post_id is not None and media_index is not None:\n        row = conn.execute(\n            \"\"\"\n            SELECT media_asset_id FROM x_media_assets\n            WHERE post_id = ? AND media_index = ?\n            ORDER BY media_asset_id LIMIT 1\n            \"\"\",\n            (post_id, media_index),\n        ).fetchone()\n        if row:\n            return int(row[0])\n\n    sha256 = media.get(\"sha256\")\n    local_path = media.get(\"local_path\")\n    if sha256 and local_path:\n        row = conn.execute(\n            \"\"\"\n            SELECT media_asset_id FROM x_media_assets\n            WHERE sha256 = ? AND local_path = ?\n            ORDER BY media_asset_id LIMIT 1\n            \"\"\",\n            (sha256, local_path),\n        ).fetchone()\n        if row:\n            return int(row[0])\n\n    source_url = media.get(\"source_url\")\n    if post_id and source_url:\n        row = conn.execute(\n            \"\"\"\n            SELECT media_asset_id FROM x_media_assets\n            WHERE post_id = ? AND source_url = ?\n            ORDER BY media_asset_id LIMIT 1\n            \"\"\",\n            (post_id, source_url),\n        ).fetchone()\n        if row:\n            return int(row[0])\n\n    return None\n\n\ndef upsert_media_asset(conn: sqlite3.Connection, media: Mapping[str, Any]) -> int:\n    existing_id = find_existing_media_asset(conn, media)\n    columns = (\"post_id\", \"media_index\", \"source_url\", \"local_path\", \"sha256\", \"width\", \"height\", \"mime\")\n\n    if existing_id is not None:\n        updates = [(column, media.get(column)) for column in columns if media.get(column) is not None]\n        if media.get(\"created_at\") is not None:\n            updates.append((\"created_at\", media.get(\"created_at\")))\n        if updates:\n            assignments = \", \".join(f\"{column} = ?\" for column, _ in updates)\n            values = [value for _, value in updates]\n            values.append(existing_id)\n            conn.execute(f\"UPDATE x_media_assets SET {assignments} WHERE media_asset_id = ?\", values)\n        return existing_id\n\n    created_at = media.get(\"created_at\") or now_utc_iso()\n    insert_columns = [*columns, \"created_at\"]\n    insert_values = [media.get(column) for column in columns]\n    insert_values.append(created_at)\n\n    explicit_id = media.get(\"media_asset_id\")\n    if explicit_id is not None:\n        insert_columns = [\"media_asset_id\", *insert_columns]\n        insert_values = [explicit_id, *insert_values]\n\n    placeholders = \", \".join(\"?\" for _ in insert_columns)\n    column_sql = \", \".join(insert_columns)\n    cursor = conn.execute(\n        f\"INSERT INTO x_media_assets ({column_sql}) VALUES ({placeholders})\",\n        insert_values,\n    )\n    return int(explicit_id if explicit_id is not None else cursor.lastrowid)\n\n\ndef insert_image_analysis(conn: sqlite3.Connection, media_asset_id: int, analysis: Mapping[str, Any]) -> int:\n    columns = (\n        \"media_asset_id\",\n        \"model\",\n        \"prompt_version\",\n        \"summary\",\n        \"ocr_text\",\n        \"objects_json\",\n        \"scene_json\",\n        \"raw_response_json\",\n        \"confidence\",\n        \"created_at\",\n    )\n    values = [\n        media_asset_id,\n        analysis.get(\"model\"),\n        analysis.get(\"prompt_version\"),\n        analysis.get(\"summary\"),\n        analysis.get(\"ocr_text\"),\n        analysis.get(\"objects_json\"),\n        analysis.get(\"scene_json\"),\n        analysis.get(\"raw_response_json\"),\n        analysis.get(\"confidence\"),\n        analysis.get(\"created_at\") or now_utc_iso(),\n    ]\n    placeholders = \", \".join(\"?\" for _ in columns)\n    cursor = conn.execute(\n        f\"INSERT INTO x_image_analyses ({', '.join(columns)}) VALUES ({placeholders})\",\n        values,\n    )\n    return int(cursor.lastrowid)\n\n\ndef store_payload(payload: Any, db_path: str | Path = DEFAULT_DB_PATH) -> dict[str, Any]:\n    path = Path(db_path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n    saved: list[dict[str, Any]] = []\n    with sqlite3.connect(path) as conn:\n        conn.execute(\"PRAGMA foreign_keys = ON\")\n        ensure_schema(conn)\n\n        for index, item in enumerate(input_items(payload)):\n            media = normalize_media_asset(item)\n            if not has_media_identity(media):\n                raise ValueError(f\"item {index} is missing media identity fields\")\n            analysis = normalize_analysis_result(item)\n\n            media_asset_id = upsert_media_asset(conn, media)\n            analysis_id = insert_image_analysis(conn, media_asset_id, analysis)\n            saved.append(\n                {\n                    \"media_asset_id\": media_asset_id,\n                    \"analysis_id\": analysis_id,\n                    \"post_id\": media.get(\"post_id\"),\n                    \"media_index\": media.get(\"media_index\"),\n                    \"source_url\": media.get(\"source_url\"),\n                    \"local_path\": media.get(\"local_path\"),\n                    \"sha256\": media.get(\"sha256\"),\n                    \"model\": analysis.get(\"model\"),\n                    \"prompt_version\": analysis.get(\"prompt_version\"),\n                    \"created_at\": analysis.get(\"created_at\") or now_utc_iso(),\n                }\n            )\n\n        conn.commit()\n\n    return {\n        \"ok\": True,\n        \"db\": str(path),\n        \"saved_count\": len(saved),\n        \"saved\": saved,\n    }\n\n\ndef save_image_analysis_to_db(\n    media_save_result: Mapping[str, Any],\n    image_analysis_result: Mapping[str, Any],\n    db_path: str | Path = DEFAULT_DB_PATH,\n) -> dict[str, Any]:\n    result = store_payload(\n        {\"media_asset\": dict(media_save_result), \"analysis\": dict(image_analysis_result)},\n        db_path=db_path,\n    )\n    return result[\"saved\"][0]\n\n\ndef load_json_input(input_path: str) -> Any:\n    if input_path in (\"\", \"-\"):\n        text = sys.stdin.read()\n    else:\n        text = Path(input_path).read_text(encoding=\"utf-8\")\n    if not text.strip():\n        raise ValueError(\"input JSON is empty\")\n    return json.loads(text)\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(\n        description=\"Store saved X image metadata and LM Studio image analysis results into SQLite.\"\n    )\n    parser.add_argument(\"--db\", default=str(DEFAULT_DB_PATH), help=\"SQLite DB path. Defaults to ./data/x_posts.sqlite\")\n    parser.add_argument(\"--input\", default=\"-\", help=\"Input JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--compact\", action=\"store_true\", help=\"Print compact JSON output.\")\n    return parser\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = build_parser().parse_args(argv)\n    try:\n        payload = load_json_input(args.input)\n        result = store_payload(payload, db_path=args.db)\n    except Exception as exc:  # noqa: BLE001 - CLI should return JSON errors.\n        print(json.dumps({\"ok\": False, \"error\": str(exc)}, ensure_ascii=False), file=sys.stderr)\n        return 1\n\n    indent = None if args.compact else 2\n    print(json.dumps(result, ensure_ascii=False, indent=indent))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
