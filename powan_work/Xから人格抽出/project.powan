    {
      "id": "node-0c5efc20ca",
      "title": "Seleniumデバッグ起動ポワン",
      "body": "Seleniumで使うChromeをデバッグモードで用意する臓器ポワン。既定ではChromeデバッグポート9221とProfile 4を使い、既に起動済みのデバッグChromeがあれば再利用し、なければlaunch_chromeで起動してget_driverでSelenium driverを取得する。投稿収集そのものは行わず、X投稿収集ポワンの入口としてブラウザ操作面だけを担当する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport logging\nfrom typing import Any\n\nlog = logging.getLogger(\"selenium_debug_start\")\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef start_selenium_debug_chrome(\n    *,\n    port: int = 9221,\n    profile_dir: str = \"Profile 4\",\n    headless: bool = False,\n    reuse_existing: bool = True,\n    wait: float = 15.0,\n) -> Any:\n    \"\"\"Return a Selenium driver backed by Chrome remote debugging.\n\n    This organ only prepares the browser/driver surface. Account collection\n    stays in the higher X投稿収集ポワン flow.\n    \"\"\"\n    log.info(\"selenium_debug.import.start module=scripts.chrome_debug\")\n    from scripts.chrome_debug import get_driver, launch_chrome\n\n    log.info(\n        \"selenium_debug.start port=%s profile_dir=%s headless=%s reuse_existing=%s\",\n        port,\n        profile_dir,\n        headless,\n        reuse_existing,\n    )\n\n    if reuse_existing:\n        try:\n            log.info(\"selenium_debug.reuse.try port=%s\", port)\n            driver = get_driver(port=port)\n            log.info(\n                \"selenium_debug.reuse.ok session_id=%s current_url=%s title=%s\",\n                getattr(driver, \"session_id\", None),\n                driver.current_url,\n                driver.title,\n            )\n            return driver\n        except Exception as exc:\n            log.warning(\"selenium_debug.reuse.failed port=%s error=%s\", port, exc)\n\n    log.info(\"selenium_debug.launch.start port=%s profile_dir=%s headless=%s\", port, profile_dir, headless)\n    launch_chrome(profile_dir=profile_dir, port=port, headless=headless)\n    log.info(\"selenium_debug.launch.done port=%s\", port)\n\n    log.info(\"selenium_debug.connect.start port=%s wait=%s\", port, wait)\n    driver = get_driver(port=port, wait=wait)\n    capabilities = getattr(driver, \"capabilities\", {}) or {}\n    log.info(\n        \"selenium_debug.ready session_id=%s browser=%s version=%s current_url=%s title=%s\",\n        getattr(driver, \"session_id\", None),\n        capabilities.get(\"browserName\"),\n        capabilities.get(\"browserVersion\"),\n        driver.current_url,\n        driver.title,\n    )\n    return driver\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Start or reuse Chrome debug mode for Selenium.\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--profile-dir\", default=\"Profile 4\")\n    parser.add_argument(\"--headless\", action=\"store_true\")\n    parser.add_argument(\"--no-reuse\", action=\"store_true\")\n    parser.add_argument(\"--wait\", type=float, default=15.0)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n    log.info(\n        \"selenium_debug.cli.start port=%s profile_dir=%s headless=%s reuse_existing=%s wait=%s verbose=%s\",\n        args.port,\n        args.profile_dir,\n        args.headless,\n        not args.no_reuse,\n        args.wait,\n        args.verbose,\n    )\n\n    try:\n        log.info(\"selenium_debug.cli.driver.request\")\n        driver = start_selenium_debug_chrome(\n            port=args.port,\n            profile_dir=args.profile_dir,\n            headless=args.headless,\n            reuse_existing=not args.no_reuse,\n            wait=args.wait,\n        )\n        log.info(\n            \"selenium_debug.cli.driver.ok session_id=%s current_url=%s title=%s\",\n            getattr(driver, \"session_id\", None),\n            driver.current_url,\n            driver.title,\n        )\n    except Exception:\n        log.exception(\"selenium_debug.cli.failed\")\n        return 1\n\n    print(\"driver_ok=true\")\n    print(f\"current_url={driver.current_url}\")\n    print(f\"title={driver.title}\")\n    log.info(\"selenium_debug.cli.done\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
