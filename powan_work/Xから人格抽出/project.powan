    {
      "id": "node-166aba25e3",
      "title": "YouTube代表フレーム抽出ポワン",
      "body": "保存済みYouTube動画を受け取り、既存のC:\\project_root\\app_workspaces\\API\\scripts\\video_thumbnails.pyを使って代表フレームやサムネイルシートを抽出する臓器ポワン。映像内容確認やLMStudio読解へ渡せる画像ファイル群を返す。動画保存やDB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport importlib.util\nimport inspect\nimport json\nimport math\nimport re\nimport sys\nimport traceback\nfrom pathlib import Path\nfrom typing import Any\n\n\nAPI_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\")\nSCRIPTS_DIR = API_ROOT / \"scripts\"\nSCRIPTS_JSON = API_ROOT / \"scripts.json\"\nSOURCE_SCRIPT = SCRIPTS_DIR / \"video_thumbnails.py\"\n\nGENERATE_OPTION_KEYS = {\n    \"interval\",\n    \"frame_count\",\n    \"page_count\",\n    \"items_per_page\",\n    \"thumbnail_width\",\n    \"thumbnail_scale\",\n    \"output_width\",\n    \"output_height\",\n    \"start_time\",\n    \"end_time\",\n    \"font_size\",\n}\n\nDEFAULT_OPTIONS: dict[str, Any] = {\n    \"interval\": 10.0,\n    \"frame_count\": 12,\n    \"page_count\": None,\n    \"items_per_page\": None,\n    \"thumbnail_width\": None,\n    \"thumbnail_scale\": None,\n    \"output_width\": 1920,\n    \"output_height\": 1080,\n    \"start_time\": 0.0,\n    \"end_time\": None,\n    \"font_size\": 16,\n    \"save_frames\": True,\n    \"representative_frame_count\": None,\n    \"max_frame_files\": 24,\n    \"frame_output_width\": 1280,\n    \"frame_format\": \"jpg\",\n    \"frame_jpeg_quality\": 90,\n    \"collect_progress\": True,\n}\n\n\ndef run(\n    payload: dict[str, Any] | str | Path | None = None,\n    *,\n    video_path: str | Path | None = None,\n    output_dir: str | Path | None = None,\n    url: str | None = None,\n    video_id: str | None = None,\n    post_id: str | None = None,\n    media_index: int | str | None = None,\n    options: dict[str, Any] | None = None,\n) -> dict[str, Any]:\n    \"\"\"Extract YouTube thumbnail materials from an already-saved video file.\n\n    This organ does not download videos and does not write to any database. It\n    calls the existing API script video_thumbnails.generate, then returns a\n    JSON-safe material bundle for the later DB-saving organ.\n    \"\"\"\n\n    progress_events: list[dict[str, Any]] = []\n    executions: list[dict[str, Any]] = []\n    warnings: list[str] = []\n\n    result: dict[str, Any] = {\n        \"ok\": False,\n        \"videoPath\": None,\n        \"sheets\": [],\n        \"frames\": [],\n        \"outputDir\": None,\n        \"sourceScript\": str(SOURCE_SCRIPT),\n        \"options\": {},\n        \"sourceUrl\": None,\n        \"videoId\": None,\n        \"postId\": None,\n        \"mediaIndex\": None,\n        \"source\": {\n            \"url\": None,\n            \"video_id\": None,\n            \"post_id\": None,\n            \"media_index\": None,\n        },\n        \"execution\": executions,\n        \"progress\": progress_events,\n        \"warnings\": warnings,\n        \"error\": None,\n    }\n\n    try:\n        request = _coerce_request(\n            payload=payload,\n            video_path=video_path,\n            output_dir=output_dir,\n            url=url,\n            video_id=video_id,\n            post_id=post_id,\n            media_index=media_index,\n            options=options,\n        )\n        merged_options = _merge_options(request.get(\"options\"))\n        video = _resolve_path(request.get(\"videoPath\"))\n        out_dir = _choose_output_dir(\n            video,\n            request.get(\"outputDir\"),\n            request.get(\"videoId\"),\n            request.get(\"postId\"),\n            request.get(\"mediaIndex\"),\n        )\n        result.update(\n            {\n                \"videoPath\": str(video),\n                \"outputDir\": str(out_dir),\n                \"options\": _json_safe(merged_options),\n                \"sourceUrl\": request.get(\"sourceUrl\"),\n                \"videoId\": request.get(\"videoId\"),\n                \"postId\": request.get(\"postId\"),\n                \"mediaIndex\": request.get(\"mediaIndex\"),\n                \"source\": {\n                    \"url\": request.get(\"sourceUrl\"),\n                    \"video_id\": request.get(\"videoId\"),\n                    \"post_id\": request.get(\"postId\"),\n                    \"media_index\": request.get(\"mediaIndex\"),\n                },\n            }\n        )\n\n        _validate_video_path(video)\n        _validate_source_script()\n        out_dir.mkdir(parents=True, exist_ok=True)\n\n        registry_entry = _read_scripts_json_entry()\n        if registry_entry:\n            result[\"scriptRegistry\"] = registry_entry\n        else:\n            warnings.append(\"scripts.json did not expose video_thumbnails.py; source file will still be loaded directly\")\n\n        generate = _load_generate_function()\n        generate_kwargs = _build_generate_kwargs(\n            merged_options,\n            out_dir,\n            progress_events if merged_options.get(\"collect_progress\") else None,\n        )\n        executions.append(\n            {\n                \"step\": \"video_thumbnails.generate\",\n                \"kind\": \"in_process_python_call\",\n                \"sourceScript\": str(SOURCE_SCRIPT),\n                \"kwargs\": _json_safe(generate_kwargs, hide_callables=True),\n            }\n        )\n\n        generated = generate(str(video), **generate_kwargs)\n        sheet_paths = _normalize_generated_paths(generated)\n        result[\"sheets\"] = [_image_record(path, \"thumbnail_sheet\") for path in sheet_paths]\n\n        if merged_options.get(\"save_frames\"):\n            frame_records, frame_warnings = _save_representative_frames(\n                video_path=video,\n                output_dir=out_dir,\n                options=merged_options,\n            )\n            result[\"frames\"] = frame_records\n            warnings.extend(frame_warnings)\n            executions.append(\n                {\n                    \"step\": \"save_representative_frame_files\",\n                    \"kind\": \"opencv_python_frame_export\",\n                    \"outputDir\": str(out_dir),\n                    \"frameCount\": len(frame_records),\n                }\n            )\n\n        result[\"ok\"] = True\n        return result\n    except Exception as exc:  # Keep this organ JSON-shaped even on failure.\n        result[\"error\"] = {\n            \"type\": type(exc).__name__,\n            \"message\": str(exc),\n            \"traceback\": traceback.format_exc(),\n        }\n        executions.append(\n            {\n                \"step\": \"failure\",\n                \"kind\": \"exception\",\n                \"errorType\": type(exc).__name__,\n                \"message\": str(exc),\n            }\n        )\n        return result\n\n\ndef extract_youtube_representative_frames(*args: Any, **kwargs: Any) -> dict[str, Any]:\n    return run(*args, **kwargs)\n\n\ndef handle(payload: dict[str, Any] | str | Path | None = None, **kwargs: Any) -> dict[str, Any]:\n    return run(payload, **kwargs)\n\n\ndef _coerce_request(\n    *,\n    payload: dict[str, Any] | str | Path | None,\n    video_path: str | Path | None,\n    output_dir: str | Path | None,\n    url: str | None,\n    video_id: str | None,\n    post_id: str | None,\n    media_index: int | str | None,\n    options: dict[str, Any] | None,\n) -> dict[str, Any]:\n    if isinstance(payload, (str, Path)):\n        request: dict[str, Any] = {\"videoPath\": str(payload)}\n    elif isinstance(payload, dict):\n        request = dict(payload)\n    elif payload is None:\n        request = {}\n    else:\n        raise TypeError(\"payload must be a dict, path string, Path, or None\")\n\n    if video_path is not None:\n        request[\"videoPath\"] = str(video_path)\n    if output_dir is not None:\n        request[\"outputDir\"] = str(output_dir)\n    if url is not None:\n        request[\"sourceUrl\"] = url\n    if video_id is not None:\n        request[\"videoId\"] = video_id\n    if post_id is not None:\n        request[\"postId\"] = post_id\n    if media_index is not None:\n        request[\"mediaIndex\"] = media_index\n    if options is not None:\n        request[\"options\"] = options\n\n    request[\"videoPath\"] = _first_present(\n        request,\n        \"videoPath\",\n        \"video_path\",\n        \"path\",\n        \"filePath\",\n        \"file_path\",\n    )\n    request[\"outputDir\"] = _first_present(request, \"outputDir\", \"output_dir\")\n    request[\"sourceUrl\"] = _first_present(request, \"sourceUrl\", \"source_url\", \"url\", \"originalUrl\", \"original_url\")\n    request[\"videoId\"] = _first_present(request, \"videoId\", \"video_id\")\n    request[\"postId\"] = _first_present(request, \"postId\", \"post_id\")\n    request[\"mediaIndex\"] = _first_present(request, \"mediaIndex\", \"media_index\")\n\n    raw_options = request.get(\"options\")\n    if raw_options is None:\n        request[\"options\"] = {}\n    elif not isinstance(raw_options, dict):\n        raise TypeError(\"options must be a dict when provided\")\n    return request\n\n\ndef _first_present(data: dict[str, Any], *keys: str) -> Any:\n    for key in keys:\n        value = data.get(key)\n        if value is not None and value != \"\":\n            return value\n    return None\n\n\ndef _merge_options(raw_options: dict[str, Any] | None) -> dict[str, Any]:\n    options = dict(DEFAULT_OPTIONS)\n    for key, value in (raw_options or {}).items():\n        if key in options or key in GENERATE_OPTION_KEYS:\n            options[key] = value\n    options[\"interval\"] = _positive_float(options.get(\"interval\"), 10.0)\n    options[\"frame_count\"] = _optional_positive_int(options.get(\"frame_count\"))\n    options[\"page_count\"] = _optional_positive_int(options.get(\"page_count\"))\n    options[\"items_per_page\"] = _optional_positive_int(options.get(\"items_per_page\"))\n    options[\"thumbnail_width\"] = _optional_positive_int(options.get(\"thumbnail_width\"))\n    options[\"output_width\"] = _positive_int(options.get(\"output_width\"), 1920)\n    options[\"output_height\"] = _positive_int(options.get(\"output_height\"), 1080)\n    options[\"start_time\"] = _non_negative_float(options.get(\"start_time\"), 0.0)\n    options[\"end_time\"] = _optional_non_negative_float(options.get(\"end_time\"))\n    options[\"font_size\"] = _positive_int(options.get(\"font_size\"), 16)\n    options[\"save_frames\"] = bool(options.get(\"save_frames\"))\n    options[\"representative_frame_count\"] = _optional_positive_int(options.get(\"representative_frame_count\"))\n    options[\"max_frame_files\"] = _positive_int(options.get(\"max_frame_files\"), 24)\n    options[\"frame_output_width\"] = _optional_positive_int(options.get(\"frame_output_width\"))\n    options[\"frame_format\"] = _clean_frame_format(options.get(\"frame_format\"))\n    options[\"frame_jpeg_quality\"] = min(100, max(1, _positive_int(options.get(\"frame_jpeg_quality\"), 90)))\n    options[\"collect_progress\"] = bool(options.get(\"collect_progress\"))\n    return options\n\n\ndef _build_generate_kwargs(\n    options: dict[str, Any],\n    output_dir: Path,\n    progress_events: list[dict[str, Any]] | None,\n) -> dict[str, Any]:\n    signature = inspect.signature(_load_generate_function())\n    kwargs: dict[str, Any] = {\"output_dir\": str(output_dir)}\n\n    for key in GENERATE_OPTION_KEYS:\n        if key in signature.parameters and key in options:\n            value = options.get(key)\n            if value is not None:\n                kwargs[key] = value\n\n    if progress_events is not None and \"progress_callback\" in signature.parameters:\n        kwargs[\"progress_callback\"] = lambda value: progress_events.append({\"percent\": int(value)})\n\n    return kwargs\n\n\ndef _load_generate_function():\n    _validate_source_script()\n    api_root = str(API_ROOT)\n    if api_root not in sys.path:\n        sys.path.insert(0, api_root)\n\n    spec = importlib.util.spec_from_file_location(\"_powan_video_thumbnails\", SOURCE_SCRIPT)\n    if spec is None or spec.loader is None:\n        raise RuntimeError(f\"cannot load module spec: {SOURCE_SCRIPT}\")\n\n    module = importlib.util.module_from_spec(spec)\n    spec.loader.exec_module(module)\n    generate = getattr(module, \"generate\", None)\n    if not callable(generate):\n        raise RuntimeError(f\"generate is not callable in {SOURCE_SCRIPT}\")\n    return generate\n\n\ndef _read_scripts_json_entry() -> dict[str, Any] | None:\n    if not SCRIPTS_JSON.exists():\n        return None\n    data = json.loads(SCRIPTS_JSON.read_text(encoding=\"utf-8\"))\n    for entry in data.get(\"scripts\", []):\n        if entry.get(\"file\") == \"video_thumbnails.py\":\n            return {\n                \"file\": entry.get(\"file\"),\n                \"function\": entry.get(\"function\"),\n                \"functions\": entry.get(\"functions\"),\n                \"params\": entry.get(\"params\", {}),\n            }\n    return None\n\n\ndef _save_representative_frames(\n    *,\n    video_path: Path,\n    output_dir: Path,\n    options: dict[str, Any],\n) -> tuple[list[dict[str, Any]], list[str]]:\n    import cv2\n\n    warnings: list[str] = []\n    frame_dir = output_dir / \"frames\"\n    frame_dir.mkdir(parents=True, exist_ok=True)\n\n    cap = cv2.VideoCapture(str(video_path))\n    if not cap.isOpened():\n        return [], [f\"cannot open video for representative frames: {video_path}\"]\n\n    fps = float(cap.get(cv2.CAP_PROP_FPS) or 0.0)\n    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT) or 0)\n    duration = (total_frames / fps) if fps > 0 and total_frames > 0 else 0.0\n    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH) or 0)\n    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT) or 0)\n\n    start_time = max(0.0, float(options.get(\"start_time\") or 0.0))\n    end_time = options.get(\"end_time\")\n    end_time = duration if end_time is None else min(float(end_time), duration)\n    if duration <= 0 or end_time <= start_time:\n        cap.release()\n        return [], [f\"invalid video duration for representative frames: duration={duration:.3f}\"]\n\n    count = _choose_representative_frame_count(options)\n    timestamps = _sample_timestamps(start_time, end_time, count)\n    frame_format = str(options.get(\"frame_format\") or \"jpg\")\n    extension = \".jpg\" if frame_format in {\"jpg\", \"jpeg\"} else \".png\"\n    output_width = options.get(\"frame_output_width\")\n    records: list[dict[str, Any]] = []\n\n    for index, timestamp in enumerate(timestamps, start=1):\n        frame_index = int(timestamp * fps) if fps > 0 else 0\n        if total_frames > 0:\n            frame_index = max(0, min(frame_index, total_frames - 1))\n        cap.set(cv2.CAP_PROP_POS_FRAMES, frame_index)\n        ok, frame = cap.read()\n        if not ok or frame is None:\n            warnings.append(f\"frame read failed at {timestamp:.3f}s\")\n            continue\n\n        frame = _resize_frame_if_needed(frame, output_width)\n        file_name = f\"frame_{index:03d}_{_timestamp_label(timestamp)}{extension}\"\n        frame_path = frame_dir / file_name\n        _write_cv2_image(frame_path, frame, frame_format, int(options.get(\"frame_jpeg_quality\") or 90))\n\n        records.append(\n            {\n                **_image_record(frame_path, \"representative_frame\"),\n                \"index\": index,\n                \"timestamp\": round(timestamp, 3),\n                \"frameIndex\": frame_index,\n                \"sourceVideoSize\": {\"width\": width, \"height\": height},\n            }\n        )\n\n    cap.release()\n    return records, warnings\n\n\ndef _choose_representative_frame_count(options: dict[str, Any]) -> int:\n    explicit = options.get(\"representative_frame_count\")\n    if explicit:\n        desired = int(explicit)\n    elif options.get(\"frame_count\"):\n        desired = int(options[\"frame_count\"])\n    elif options.get(\"page_count\") and options.get(\"items_per_page\"):\n        desired = int(options[\"page_count\"]) * int(options[\"items_per_page\"])\n    else:\n        desired = 12\n    return max(1, min(desired, int(options.get(\"max_frame_files\") or 24)))\n\n\ndef _sample_timestamps(start_time: float, end_time: float, count: int) -> list[float]:\n    span = max(0.001, end_time - start_time)\n    if count <= 1:\n        return [start_time + (span / 2.0)]\n    step = span / count\n    return [start_time + (step * (index + 0.5)) for index in range(count)]\n\n\ndef _resize_frame_if_needed(frame: Any, target_width: int | None) -> Any:\n    if not target_width or target_width <= 0:\n        return frame\n    height, width = frame.shape[:2]\n    if width <= target_width:\n        return frame\n\n    import cv2\n\n    target_height = max(1, int(height * (target_width / width)))\n    return cv2.resize(frame, (target_width, target_height), interpolation=cv2.INTER_AREA)\n\n\ndef _write_cv2_image(path: Path, frame: Any, frame_format: str, jpeg_quality: int) -> None:\n    import cv2\n\n    suffix = \".jpg\" if frame_format in {\"jpg\", \"jpeg\"} else \".png\"\n    params = []\n    if suffix == \".jpg\":\n        params = [int(cv2.IMWRITE_JPEG_QUALITY), int(jpeg_quality)]\n\n    ok, buffer = cv2.imencode(suffix, frame, params)\n    if not ok:\n        raise RuntimeError(f\"failed to encode frame image: {path}\")\n    path.write_bytes(buffer.tobytes())\n\n\ndef _normalize_generated_paths(generated: Any) -> list[Path]:\n    if generated is None:\n        return []\n    if isinstance(generated, (str, Path)):\n        return [_resolve_path(generated)]\n    if isinstance(generated, (list, tuple)):\n        return [_resolve_path(item) for item in generated if item]\n    raise TypeError(f\"unexpected generate result type: {type(generated).__name__}\")\n\n\ndef _image_record(path: Path, kind: str) -> dict[str, Any]:\n    resolved = _resolve_path(path)\n    record = {\n        \"kind\": kind,\n        \"path\": str(resolved),\n        \"exists\": resolved.exists(),\n        \"sizeBytes\": None,\n    }\n    if resolved.exists():\n        record[\"sizeBytes\"] = resolved.stat().st_size\n    return record\n\n\ndef _choose_output_dir(\n    video_path: Path,\n    requested_output_dir: str | Path | None,\n    video_id: str | None,\n    post_id: str | None,\n    media_index: int | str | None,\n) -> Path:\n    if requested_output_dir:\n        return _resolve_path(requested_output_dir)\n\n    parts = [\"youtube_frames\"]\n    if post_id:\n        parts.append(_slug(str(post_id)))\n    if video_id:\n        parts.append(_slug(str(video_id)))\n    if media_index is not None:\n        parts.append(f\"media_{_slug(str(media_index))}\")\n    if len(parts) == 1:\n        parts.append(_slug(video_path.stem) or \"video\")\n\n    return _resolve_path(video_path.parent / \"_\".join(parts))\n\n\ndef _resolve_path(value: str | Path | None) -> Path:\n    if value is None or str(value).strip() == \"\":\n        raise ValueError(\"videoPath is required\")\n    return Path(value).expanduser().resolve(strict=False)\n\n\ndef _validate_video_path(path: Path) -> None:\n    if not path.exists():\n        raise FileNotFoundError(f\"video file does not exist: {path}\")\n    if not path.is_file():\n        raise ValueError(f\"videoPath is not a file: {path}\")\n\n\ndef _validate_source_script() -> None:\n    if not SOURCE_SCRIPT.exists():\n        raise FileNotFoundError(f\"source script does not exist: {SOURCE_SCRIPT}\")\n\n\ndef _json_safe(value: Any, *, hide_callables: bool = False) -> Any:\n    if isinstance(value, Path):\n        return str(value)\n    if isinstance(value, dict):\n        return {str(key): _json_safe(item, hide_callables=hide_callables) for key, item in value.items()}\n    if isinstance(value, (list, tuple)):\n        return [_json_safe(item, hide_callables=hide_callables) for item in value]\n    if callable(value):\n        return \"<callable>\" if hide_callables else None\n    try:\n        json.dumps(value)\n        return value\n    except TypeError:\n        return str(value)\n\n\ndef _slug(value: str) -> str:\n    cleaned = re.sub(r\"[^A-Za-z0-9_.-]+\", \"_\", value.strip())\n    cleaned = cleaned.strip(\"._-\")\n    return cleaned[:80] or \"item\"\n\n\ndef _timestamp_label(seconds: float) -> str:\n    total = max(0, int(math.floor(seconds)))\n    millis = int(round((seconds - total) * 1000))\n    minutes, sec = divmod(total, 60)\n    hours, minutes = divmod(minutes, 60)\n    return f\"{hours:02d}h{minutes:02d}m{sec:02d}s{millis:03d}ms\"\n\n\ndef _positive_int(value: Any, default: int) -> int:\n    try:\n        parsed = int(value)\n    except (TypeError, ValueError):\n        return default\n    return parsed if parsed > 0 else default\n\n\ndef _optional_positive_int(value: Any) -> int | None:\n    if value is None or value == \"\":\n        return None\n    try:\n        parsed = int(value)\n    except (TypeError, ValueError):\n        return None\n    return parsed if parsed > 0 else None\n\n\ndef _positive_float(value: Any, default: float) -> float:\n    try:\n        parsed = float(value)\n    except (TypeError, ValueError):\n        return default\n    return parsed if parsed > 0 else default\n\n\ndef _non_negative_float(value: Any, default: float) -> float:\n    try:\n        parsed = float(value)\n    except (TypeError, ValueError):\n        return default\n    return parsed if parsed >= 0 else default\n\n\ndef _optional_non_negative_float(value: Any) -> float | None:\n    if value is None or value == \"\":\n        return None\n    try:\n        parsed = float(value)\n    except (TypeError, ValueError):\n        return None\n    return parsed if parsed >= 0 else None\n\n\ndef _clean_frame_format(value: Any) -> str:\n    clean = str(value or \"jpg\").lower().strip(\". \")\n    if clean == \"jpeg\":\n        return \"jpg\"\n    return clean if clean in {\"jpg\", \"png\"} else \"jpg\"\n\n\ndef _load_payload_from_cli(args: argparse.Namespace) -> dict[str, Any]:\n    payload: dict[str, Any] = {}\n    if args.payload_json:\n        payload.update(json.loads(args.payload_json))\n    if args.payload_file:\n        payload.update(json.loads(Path(args.payload_file).read_text(encoding=\"utf-8\")))\n    if args.video_path:\n        payload[\"videoPath\"] = args.video_path\n    if args.output_dir:\n        payload[\"outputDir\"] = args.output_dir\n    if args.url:\n        payload[\"sourceUrl\"] = args.url\n    if args.video_id:\n        payload[\"videoId\"] = args.video_id\n    if args.post_id:\n        payload[\"postId\"] = args.post_id\n    if args.media_index is not None:\n        payload[\"mediaIndex\"] = args.media_index\n\n    option_overrides: dict[str, Any] = {}\n    if args.options_json:\n        option_overrides.update(json.loads(args.options_json))\n    for key in (\"frame_count\", \"interval\", \"start_time\", \"end_time\"):\n        value = getattr(args, key)\n        if value is not None:\n            option_overrides[key] = value\n    if args.no_frames:\n        option_overrides[\"save_frames\"] = False\n    if option_overrides:\n        payload[\"options\"] = {**payload.get(\"options\", {}), **option_overrides}\n    return payload\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Extract YouTube representative frame materials from a saved video\")\n    parser.add_argument(\"video_path\", nargs=\"?\")\n    parser.add_argument(\"--payload-json\")\n    parser.add_argument(\"--payload-file\")\n    parser.add_argument(\"--output-dir\")\n    parser.add_argument(\"--url\")\n    parser.add_argument(\"--video-id\")\n    parser.add_argument(\"--post-id\")\n    parser.add_argument(\"--media-index\")\n    parser.add_argument(\"--options-json\")\n    parser.add_argument(\"--frame-count\", type=int)\n    parser.add_argument(\"--interval\", type=float)\n    parser.add_argument(\"--start-time\", type=float)\n    parser.add_argument(\"--end-time\", type=float)\n    parser.add_argument(\"--no-frames\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    result = run(_load_payload_from_cli(args))\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
