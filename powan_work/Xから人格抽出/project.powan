    {
      "id": "node-c01f6488d7",
      "title": "根まで追跡ポワン",
      "body": "引用、返信、リポストなどで発言が他の投稿にぶら下がっている時に、本人の発言や話題の起点へ向かって追跡する神経ポワン。自分自身は巨大な処理を持たず、投稿出どころ判定ポワンで現在地を見分け、引用連鎖追跡ポワンや返信連鎖追跡ポワンなどの臓器へ渡して、辿れるところまで根を探す。引用や返信の枝で止まった投稿がさらに外部ニュース、動画、画像を含む場合は、後続の外部確認ポワンへ渡せる形にする。",
      "powanKind": "nerve",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\ntype MaybePromise<T> = T | Promise<T>;\n\nconst DEFAULT_MAX_DEPTH = 32;\nconst HARD_MAX_DEPTH = 1000;\n\nconst RELATION_TYPES: readonly RelationType[] = [\"reply\", \"repost\", \"quote\", \"standalone\", \"unknown\"];\nconst REF_KINDS: readonly RefKind[] = [\"reply_parent\", \"repost_source\", \"quote_source\", \"url_post\"];\nconst FETCH_STATUSES: readonly FetchStatus[] = [\n  \"ok\",\n  \"not_found\",\n  \"private\",\n  \"deleted\",\n  \"rate_limited\",\n  \"invalid_ref\",\n  \"error\",\n];\n\nexport async function traceUntilRoot(\n  startPost: PostLike,\n  tools: {\n    classifyPostRelation: (post: PostLike) => RelationDecision | Promise<RelationDecision>;\n    fetchNextPost: (ref: PostRef) => FetchResult | Promise<FetchResult>;\n  },\n  options: { maxDepth?: number } = {},\n): Promise<TraceResult> {\n  const maxDepth = normalizeMaxDepth(options.maxDepth);\n  const path: TraceStep[] = [];\n  const topicOriginCandidates: PostRef[] = [];\n  const seenPostKeys = new Set<string>();\n  const seenRefKeys = new Set<string>();\n  let currentPost = normalizePost(startPost);\n\n  if (!isUsableTools(tools)) {\n    return buildTraceResult(currentPost, path, \"error\", topicOriginCandidates);\n  }\n\n  for (let index = 0; index <= maxDepth; index += 1) {\n    const currentPostKey = postIdentityKey(currentPost);\n    if (currentPostKey) {\n      if (seenPostKeys.has(currentPostKey)) {\n        return buildTraceResult(currentPost, path, \"cycle\", topicOriginCandidates);\n      }\n      seenPostKeys.add(currentPostKey);\n    }\n\n    const classified = await classifySafely(currentPost, tools.classifyPostRelation);\n    const step: TraceStep = {\n      index,\n      post: currentPost,\n      decision: classified.decision,\n    };\n    path.push(step);\n    addTopicOriginRefs(topicOriginCandidates, step.decision);\n\n    if (!classified.ok) {\n      step.reason = \"error\";\n      return buildTraceResult(currentPost, path, \"error\", topicOriginCandidates);\n    }\n\n    if (step.decision.relationType === \"standalone\") {\n      step.reason = \"standalone\";\n      return buildTraceResult(currentPost, path, \"standalone\", topicOriginCandidates);\n    }\n\n    const primaryRef = normalizeRef(step.decision.primaryRef);\n    if (!primaryRef) {\n      step.reason = \"no_primary_ref\";\n      return buildTraceResult(currentPost, path, \"no_primary_ref\", topicOriginCandidates);\n    }\n\n    step.followedRef = primaryRef;\n    addTopicOriginRef(topicOriginCandidates, primaryRef);\n\n    const primaryRefKey = refIdentityKey(primaryRef);\n    if (primaryRefKey) {\n      if (seenRefKeys.has(primaryRefKey)) {\n        step.reason = \"cycle\";\n        return buildTraceResult(currentPost, path, \"cycle\", topicOriginCandidates);\n      }\n      seenRefKeys.add(primaryRefKey);\n    }\n\n    if (index >= maxDepth) {\n      step.reason = \"max_depth\";\n      return buildTraceResult(currentPost, path, \"max_depth\", topicOriginCandidates);\n    }\n\n    const fetched = await fetchSafely(primaryRef, tools.fetchNextPost);\n    step.fetchStatus = fetched.status;\n\n    if (fetched.status !== \"ok\") {\n      step.reason = fetched.status;\n      return buildTraceResult(currentPost, path, fetched.status, topicOriginCandidates);\n    }\n\n    if (!fetched.post) {\n      step.fetchStatus = \"error\";\n      step.reason = \"error\";\n      return buildTraceResult(currentPost, path, \"error\", topicOriginCandidates);\n    }\n\n    const nextPost = normalizePost(fetched.post);\n    const nextPostKey = postIdentityKey(nextPost);\n    if (nextPostKey && seenPostKeys.has(nextPostKey)) {\n      step.reason = \"cycle\";\n      return buildTraceResult(currentPost, path, \"cycle\", topicOriginCandidates);\n    }\n\n    currentPost = nextPost;\n  }\n\n  return buildTraceResult(currentPost, path, \"max_depth\", topicOriginCandidates);\n}\n\nasync function classifySafely(\n  post: PostLike,\n  classifyPostRelation: (post: PostLike) => MaybePromise<RelationDecision>,\n): Promise<{ ok: true; decision: RelationDecision } | { ok: false; decision: RelationDecision }> {\n  try {\n    return { ok: true, decision: normalizeDecision(await classifyPostRelation(post)) };\n  } catch {\n    return {\n      ok: false,\n      decision: {\n        relationType: \"unknown\",\n        refs: [],\n        evidence: [\"classifyPostRelation failed\"],\n        confidence: 0,\n      },\n    };\n  }\n}\n\nasync function fetchSafely(\n  ref: PostRef,\n  fetchNextPost: (ref: PostRef) => MaybePromise<FetchResult>,\n): Promise<FetchResult> {\n  try {\n    return normalizeFetchResult(await fetchNextPost(ref));\n  } catch {\n    return { status: \"error\", reason: \"fetchNextPost failed\" };\n  }\n}\n\nfunction normalizeDecision(value: unknown): RelationDecision {\n  if (!isRecord(value)) {\n    return {\n      relationType: \"unknown\",\n      refs: [],\n      evidence: [\"classifyPostRelation returned invalid decision\"],\n      confidence: 0,\n    };\n  }\n\n  const refs = Array.isArray(value.refs) ? uniqueRefs(value.refs.map(normalizeRef).filter(isDefined)) : [];\n  const primaryRef = normalizeRef(value.primaryRef);\n  const normalizedRefs = primaryRef ? uniqueRefs([primaryRef, ...refs]) : refs;\n  const fallbackConfidence = primaryRef\n    ? primaryRef.confidence\n    : normalizedRefs.reduce((best, ref) => Math.max(best, ref.confidence), 0);\n  const result: RelationDecision = {\n    relationType: isRelationType(value.relationType) ? value.relationType : \"unknown\",\n    refs: normalizedRefs,\n    evidence: Array.isArray(value.evidence) ? value.evidence.map(cleanString).filter(isDefined) : [],\n    confidence: clampConfidence(numberOrDefault(value.confidence, fallbackConfidence)),\n  };\n\n  if (primaryRef) {\n    result.primaryRef = primaryRef;\n  }\n\n  return result;\n}\n\nfunction normalizeFetchResult(value: unknown): FetchResult {\n  if (!isRecord(value)) {\n    return { status: \"error\", reason: \"fetchNextPost returned invalid result\" };\n  }\n\n  const status = isFetchStatus(value.status) ? value.status : \"error\";\n  const reason = cleanString(value.reason);\n\n  if (status !== \"ok\") {\n    return reason ? { status, reason } : { status };\n  }\n\n  if (!isRecord(value.post)) {\n    return { status: \"error\", reason: \"fetchNextPost returned ok without post\" };\n  }\n\n  return reason ? { status: \"ok\", post: value.post as PostLike, reason } : { status: \"ok\", post: value.post as PostLike };\n}\n\nfunction normalizeRef(value: unknown): PostRef | undefined {\n  if (!isRecord(value) || !isRefKind(value.kind)) {\n    return undefined;\n  }\n\n  const postId = cleanString(value.postId);\n  const url = cleanString(value.url);\n  if (!postId && !url) {\n    return undefined;\n  }\n\n  const ref: PostRef = {\n    kind: value.kind,\n    evidence: cleanString(value.evidence) ?? `${value.kind} reference`,\n    confidence: clampConfidence(numberOrDefault(value.confidence, 0.5)),\n  };\n\n  if (postId) {\n    ref.postId = postId;\n  }\n  if (url) {\n    ref.url = url;\n  }\n\n  return ref;\n}\n\nfunction buildTraceResult(\n  rootPost: PostLike | undefined,\n  path: TraceStep[],\n  stopReason: string,\n  topicOriginCandidates: PostRef[],\n): TraceResult {\n  const result: TraceResult = {\n    path,\n    stopReason,\n    topicOriginCandidates: uniqueRefs(topicOriginCandidates.filter(isTopicOriginRef)),\n  };\n\n  if (rootPost) {\n    result.rootPost = rootPost;\n  }\n\n  return result;\n}\n\nfunction addTopicOriginRefs(target: PostRef[], decision: RelationDecision): void {\n  addTopicOriginRef(target, decision.primaryRef);\n  for (const ref of decision.refs) {\n    addTopicOriginRef(target, ref);\n  }\n}\n\nfunction addTopicOriginRef(target: PostRef[], ref: PostRef | undefined): void {\n  if (ref && isTopicOriginRef(ref)) {\n    target.push(ref);\n  }\n}\n\nfunction isTopicOriginRef(ref: PostRef): boolean {\n  return ref.kind === \"quote_source\" || ref.kind === \"repost_source\" || ref.kind === \"url_post\";\n}\n\nfunction isUsableTools(value: unknown): value is {\n  classifyPostRelation: (post: PostLike) => MaybePromise<RelationDecision>;\n  fetchNextPost: (ref: PostRef) => MaybePromise<FetchResult>;\n} {\n  return (\n    isRecord(value) &&\n    typeof value.classifyPostRelation === \"function\" &&\n    typeof value.fetchNextPost === \"function\"\n  );\n}\n\nfunction normalizePost(value: unknown): PostLike {\n  return isRecord(value) ? (value as PostLike) : {};\n}\n\nfunction postIdentityKey(post: PostLike): string | undefined {\n  const id = cleanString(post.id);\n  if (id) {\n    return `post:${id}`;\n  }\n\n  const url = normalizeUrlKey(post.url);\n  return url ? `url:${url}` : undefined;\n}\n\nfunction refIdentityKey(ref: PostRef): string | undefined {\n  const id = cleanString(ref.postId);\n  if (id) {\n    return `post:${id}`;\n  }\n\n  const url = normalizeUrlKey(ref.url);\n  return url ? `url:${url}` : undefined;\n}\n\nfunction normalizeUrlKey(value: unknown): string | undefined {\n  const text = cleanString(value);\n  if (!text) {\n    return undefined;\n  }\n\n  const hashIndex = text.indexOf(\"#\");\n  const withoutHash = hashIndex >= 0 ? text.slice(0, hashIndex) : text;\n  return withoutHash.replace(/\\/+$/, \"\");\n}\n\nfunction normalizeMaxDepth(value: unknown): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) {\n    return DEFAULT_MAX_DEPTH;\n  }\n\n  return Math.max(0, Math.min(HARD_MAX_DEPTH, Math.floor(value)));\n}\n\nfunction uniqueRefs(refs: PostRef[]): PostRef[] {\n  const result: PostRef[] = [];\n  const seen = new Set<string>();\n\n  for (const ref of refs) {\n    const key = refIdentityKey(ref) ?? `${ref.kind}:${ref.evidence}`;\n    if (seen.has(key)) {\n      continue;\n    }\n    seen.add(key);\n    result.push(ref);\n  }\n\n  return result;\n}\n\nfunction isRelationType(value: unknown): value is RelationType {\n  return typeof value === \"string\" && RELATION_TYPES.includes(value as RelationType);\n}\n\nfunction isRefKind(value: unknown): value is RefKind {\n  return typeof value === \"string\" && REF_KINDS.includes(value as RefKind);\n}\n\nfunction isFetchStatus(value: unknown): value is FetchStatus {\n  return typeof value === \"string\" && FETCH_STATUSES.includes(value as FetchStatus);\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n}\n\nfunction cleanString(value: unknown): string | undefined {\n  if (typeof value === \"string\") {\n    const trimmed = value.trim();\n    return trimmed.length > 0 ? trimmed : undefined;\n  }\n  if (typeof value === \"number\" && Number.isFinite(value)) {\n    return String(Math.trunc(value));\n  }\n  if (typeof value === \"bigint\") {\n    return value.toString();\n  }\n  return undefined;\n}\n\nfunction numberOrDefault(value: unknown, fallback: number): number {\n  return typeof value === \"number\" && Number.isFinite(value) ? value : fallback;\n}\n\nfunction clampConfidence(value: number): number {\n  if (!Number.isFinite(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}\n\nfunction isDefined<T>(value: T | undefined): value is T {\n  return value !== undefined;\n}",
