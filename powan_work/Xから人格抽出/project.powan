    {
      "id": "node-9b38ba7342",
      "title": "Selenium疎通確認ポワン",
      "body": "Seleniumが本当にデバッグChromeへ接続できているかを最初に確認する臓器ポワン。9221へ接続し、必要ならChromeを起動し、ページ遷移、document.readyState取得、CSSセレクタ検索、JavaScript実行、スクロール差分をログとJSONで返す。X固有の解析に進む前に、driverが実際に動いていることを証明する。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport time\nfrom typing import Any\nfrom urllib.parse import quote\n\nfrom selenium.common.exceptions import TimeoutException\nfrom selenium.webdriver.common.by import By\nfrom selenium.webdriver.remote.webdriver import WebDriver\nfrom selenium.webdriver.support.ui import WebDriverWait\n\nlog = logging.getLogger(\"selenium_probe\")\n\nDEFAULT_PROBE_HTML = \"\"\"<!doctype html><html><head><meta charset='utf-8'><title>selenium-probe</title></head><body style='height:3000px'><main id='probe-root'><h1>Selenium Probe</h1><p>scroll target</p></main></body></html>\"\"\"\nDEFAULT_PROBE_URL = \"data:text/html;charset=utf-8,\" + quote(DEFAULT_PROBE_HTML)\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef connect_or_launch_driver(\n    *,\n    port: int = 9221,\n    profile_dir: str = \"Profile 4\",\n    headless: bool = False,\n    launch_if_needed: bool = True,\n    wait: float = 15.0,\n) -> WebDriver:\n    from scripts.chrome_debug import get_driver, launch_chrome\n\n    try:\n        log.info(\"probe.connect.try port=%s\", port)\n        driver = get_driver(port=port)\n        log.info(\"probe.connect.ok current_url=%s\", driver.current_url)\n        return driver\n    except Exception as exc:\n        log.warning(\"probe.connect.failed port=%s error=%s\", port, exc)\n        if not launch_if_needed:\n            raise\n\n    log.info(\"probe.launch port=%s profile_dir=%s headless=%s\", port, profile_dir, headless)\n    launch_chrome(profile_dir=profile_dir, port=port, headless=headless)\n    driver = get_driver(port=port, wait=wait)\n    log.info(\"probe.launch.connect.ok current_url=%s\", driver.current_url)\n    return driver\n\n\ndef _scroll_y(driver: WebDriver) -> int:\n    return int(driver.execute_script(\"return window.scrollY || window.pageYOffset || 0;\") or 0)\n\n\ndef probe_selenium(\n    driver: WebDriver,\n    *,\n    url: str = DEFAULT_PROBE_URL,\n    selector: str = \"body\",\n    wait_seconds: float = 10.0,\n    scroll_pixels: int = 600,\n    settle_seconds: float = 0.2,\n) -> dict[str, Any]:\n    result: dict[str, Any] = {\n        \"ok\": False,\n        \"requested_url\": url,\n        \"selector\": selector,\n        \"errors\": [],\n    }\n    caps = getattr(driver, \"capabilities\", {}) or {}\n    result[\"browser\"] = caps.get(\"browserName\")\n    result[\"browser_version\"] = caps.get(\"browserVersion\")\n    result[\"window_count\"] = len(getattr(driver, \"window_handles\", []) or [])\n    result[\"start_url\"] = driver.current_url\n    result[\"start_title\"] = driver.title\n    log.info(\"probe.start browser=%s version=%s start_url=%s\", result[\"browser\"], result[\"browser_version\"], result[\"start_url\"])\n\n    log.info(\"probe.navigate url=%s\", url)\n    driver.get(url)\n    wait = WebDriverWait(driver, wait_seconds)\n    try:\n        wait.until(lambda d: d.execute_script(\"return document.readyState\") in {\"interactive\", \"complete\"})\n    except TimeoutException as exc:\n        result[\"errors\"].append(f\"document_ready_timeout: {exc}\")\n        log.warning(\"probe.ready.timeout wait_seconds=%s\", wait_seconds)\n\n    ready_state = driver.execute_script(\"return document.readyState\")\n    user_agent = driver.execute_script(\"return navigator.userAgent\")\n    elements = driver.find_elements(By.CSS_SELECTOR, selector)\n    before_y = _scroll_y(driver)\n    driver.execute_script(\"window.scrollBy(0, arguments[0]);\", int(scroll_pixels))\n    if settle_seconds > 0:\n        time.sleep(settle_seconds)\n    after_y = _scroll_y(driver)\n\n    result.update(\n        {\n            \"current_url\": driver.current_url,\n            \"title\": driver.title,\n            \"ready_state\": ready_state,\n            \"user_agent\": user_agent,\n            \"selector_count\": len(elements),\n            \"scroll_before_y\": before_y,\n            \"scroll_after_y\": after_y,\n            \"scroll_delta_y\": after_y - before_y,\n        }\n    )\n    result[\"ok\"] = bool(ready_state in {\"interactive\", \"complete\"} and len(elements) > 0)\n    log.info(\n        \"probe.done ok=%s ready_state=%s selector_count=%s scroll_delta_y=%s current_url=%s\",\n        result[\"ok\"],\n        ready_state,\n        len(elements),\n        result[\"scroll_delta_y\"],\n        result[\"current_url\"],\n    )\n    return result\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Verify Selenium debug Chrome connectivity and basic page control.\")\n    parser.add_argument(\"--url\", default=DEFAULT_PROBE_URL)\n    parser.add_argument(\"--selector\", default=\"body\")\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--profile-dir\", default=\"Profile 4\")\n    parser.add_argument(\"--headless\", action=\"store_true\")\n    parser.add_argument(\"--no-launch\", action=\"store_true\")\n    parser.add_argument(\"--wait\", type=float, default=15.0)\n    parser.add_argument(\"--wait-seconds\", type=float, default=10.0)\n    parser.add_argument(\"--scroll-pixels\", type=int, default=600)\n    parser.add_argument(\"--settle-seconds\", type=float, default=0.2)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n    driver = connect_or_launch_driver(\n        port=args.port,\n        profile_dir=args.profile_dir,\n        headless=args.headless,\n        launch_if_needed=not args.no_launch,\n        wait=args.wait,\n    )\n    result = probe_selenium(\n        driver,\n        url=args.url,\n        selector=args.selector,\n        wait_seconds=args.wait_seconds,\n        scroll_pixels=args.scroll_pixels,\n        settle_seconds=args.settle_seconds,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
