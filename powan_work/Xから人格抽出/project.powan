    {
      "id": "node-71bf9b8081",
      "title": "リポスト元到達ポワン",
      "body": "対象ポストがリポストや再投稿として扱える時、誰のどの元ポストを運んでいるのかを取り出す臓器ポワン。リポスト元ID、元投稿者、元投稿URL、再掲元らしい本文一致情報を参照し、次に取得すべき元ポスト参照を作る。通常のリプ親とは区別しつつ、発端追跡では同じ上流移動として扱える形にする。削除済み、非公開、取得不能の場合は理由を残す。コードは後で持つ。",
      "powanKind": "organ",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\ntype PathSegment = string | number;\ntype RawPath = readonly PathSegment[];\n\ntype RepostCandidate = {\n  postId?: string;\n  url?: string;\n  sourceAuthorId?: string;\n  sourceText?: string;\n  evidence: string;\n  confidence: number;\n  rank: number;\n  order: number;\n};\n\ntype CandidateInput = Omit<RepostCandidate, \"rank\" | \"order\">;\n\ntype TextMatch = \"exact\" | \"contained\" | \"none\";\n\ntype ParsedPostUrl = {\n  postId: string;\n  url: string;\n};\n\nconst REPOST_ID_PATHS: readonly RawPath[] = [\n  [\"repostedPostId\"],\n  [\"reposted_post_id\"],\n  [\"repostPostId\"],\n  [\"repost_post_id\"],\n  [\"retweetedPostId\"],\n  [\"retweeted_post_id\"],\n  [\"retweetId\"],\n  [\"retweet_id\"],\n  [\"retweetedStatusId\"],\n  [\"retweetedStatusIdStr\"],\n  [\"retweeted_status_id\"],\n  [\"retweeted_status_id_str\"],\n  [\"repost\", \"postId\"],\n  [\"repost\", \"id\"],\n  [\"reposted\", \"postId\"],\n  [\"reposted\", \"id\"],\n  [\"retweet\", \"postId\"],\n  [\"retweet\", \"id\"],\n  [\"legacy\", \"retweeted_status_id\"],\n  [\"legacy\", \"retweeted_status_id_str\"],\n  [\"tweet\", \"legacy\", \"retweeted_status_id\"],\n  [\"tweet\", \"legacy\", \"retweeted_status_id_str\"],\n  [\"data\", \"retweeted_status_id\"],\n  [\"data\", \"retweeted_status_id_str\"],\n  [\"data\", \"repostedPostId\"],\n];\n\nconst REPOST_URL_PATHS: readonly RawPath[] = [\n  [\"repostedPostUrl\"],\n  [\"reposted_post_url\"],\n  [\"repostPostUrl\"],\n  [\"repost_post_url\"],\n  [\"repostUrl\"],\n  [\"repost_url\"],\n  [\"retweetedStatusUrl\"],\n  [\"retweeted_status_url\"],\n  [\"retweetUrl\"],\n  [\"retweet_url\"],\n  [\"repost\", \"url\"],\n  [\"reposted\", \"url\"],\n  [\"retweet\", \"url\"],\n  [\"display\", \"repostUrl\"],\n  [\"view\", \"repostUrl\"],\n];\n\nconst REFERENCED_TWEET_PATHS: readonly RawPath[] = [\n  [\"referenced_tweets\"],\n  [\"referencedTweets\"],\n  [\"data\", \"referenced_tweets\"],\n  [\"data\", \"referencedTweets\"],\n  [\"tweet\", \"referenced_tweets\"],\n  [\"tweet\", \"referencedTweets\"],\n  [\"raw\", \"referenced_tweets\"],\n];\n\nconst REPOST_OBJECT_PATHS: readonly RawPath[] = [\n  [\"repostedPost\"],\n  [\"reposted_post\"],\n  [\"repostPost\"],\n  [\"repost_post\"],\n  [\"repost\", \"post\"],\n  [\"reposted\", \"post\"],\n  [\"retweet\", \"post\"],\n  [\"retweet\", \"status\"],\n  [\"retweetedStatus\"],\n  [\"retweeted_status\"],\n  [\"retweeted_status_result\", \"result\"],\n  [\"legacy\", \"retweeted_status\"],\n  [\"legacy\", \"retweeted_status_result\", \"result\"],\n  [\"tweet\", \"retweeted_status\"],\n  [\"tweet\", \"legacy\", \"retweeted_status\"],\n  [\"tweet\", \"legacy\", \"retweeted_status_result\", \"result\"],\n  [\"tweet_results\", \"result\", \"legacy\", \"retweeted_status\"],\n  [\"tweet_results\", \"result\", \"legacy\", \"retweeted_status_result\", \"result\"],\n  [\"result\", \"legacy\", \"retweeted_status\"],\n  [\"result\", \"legacy\", \"retweeted_status_result\", \"result\"],\n  [\"data\", \"repostedPost\"],\n  [\"data\", \"retweeted_status\"],\n];\n\nconst SOURCE_ID_PATHS: readonly RawPath[] = [\n  [\"id\"],\n  [\"id_str\"],\n  [\"postId\"],\n  [\"post_id\"],\n  [\"statusId\"],\n  [\"status_id\"],\n  [\"status_id_str\"],\n  [\"rest_id\"],\n  [\"tweetId\"],\n  [\"tweet_id\"],\n  [\"legacy\", \"id\"],\n  [\"legacy\", \"id_str\"],\n  [\"tweet\", \"id\"],\n  [\"tweet\", \"id_str\"],\n  [\"tweet\", \"rest_id\"],\n];\n\nconst SOURCE_URL_PATHS: readonly RawPath[] = [\n  [\"url\"],\n  [\"permalink\"],\n  [\"expanded_url\"],\n  [\"expandedUrl\"],\n  [\"display_url\"],\n  [\"legacy\", \"url\"],\n  [\"tweet\", \"url\"],\n  [\"core\", \"url\"],\n];\n\nconst SOURCE_AUTHOR_ID_PATHS: readonly RawPath[] = [\n  [\"authorId\"],\n  [\"author_id\"],\n  [\"userId\"],\n  [\"user_id\"],\n  [\"user\", \"id\"],\n  [\"user\", \"id_str\"],\n  [\"author\", \"id\"],\n  [\"author\", \"id_str\"],\n  [\"core\", \"user_results\", \"result\", \"rest_id\"],\n  [\"tweet\", \"core\", \"user_results\", \"result\", \"rest_id\"],\n];\n\nconst SOURCE_TEXT_PATHS: readonly RawPath[] = [\n  [\"text\"],\n  [\"full_text\"],\n  [\"body\"],\n  [\"note_tweet\", \"note_tweet_results\", \"result\", \"text\"],\n  [\"legacy\", \"full_text\"],\n  [\"legacy\", \"text\"],\n  [\"tweet\", \"legacy\", \"full_text\"],\n  [\"tweet\", \"legacy\", \"text\"],\n];\n\nconst CARD_HINT_PATHS: readonly RawPath[] = [\n  [\"type\"],\n  [\"cardType\"],\n  [\"kind\"],\n  [\"name\"],\n  [\"title\"],\n];\n\n/**\n * Returns the original post carried by a repost/retweet-shaped post.\n * This organ only reads the provided object; it never fetches or follows refs.\n */\nexport function getRepostSourceRef(post: PostLike): PostRef | null {\n  const safePost = isRecord(post) ? post : {};\n  const candidates: RepostCandidate[] = [];\n  const addCandidate = createCandidateCollector(candidates);\n\n  addCandidate(candidateFromId(safePost.repostedPostId, \"post.repostedPostId\", 1), 100);\n  collectReferencedReposts(safePost.raw, addCandidate);\n  collectIdPathCandidates(safePost.raw, REPOST_ID_PATHS, \"raw\", 0.9, 82, addCandidate);\n  collectUrlPathCandidates(safePost.raw, REPOST_URL_PATHS, \"raw\", 0.8, 74, addCandidate);\n  collectEmbeddedSourcePosts(safePost.raw, safePost.text, addCandidate);\n  collectCardCandidates(safePost.cards, safePost.text, addCandidate);\n\n  const best = chooseBestCandidate(candidates, safePost);\n  if (!best) {\n    return null;\n  }\n\n  const ref: PostRef = {\n    kind: \"repost_source\",\n    evidence: best.evidence,\n    confidence: clampConfidence(best.confidence),\n  };\n  if (best.postId) {\n    ref.postId = best.postId;\n  }\n  if (best.url) {\n    ref.url = best.url;\n  }\n  return ref;\n}\n\nfunction collectReferencedReposts(raw: unknown, addCandidate: (candidate: CandidateInput | null, rank: number) => void): void {\n  for (const path of REFERENCED_TWEET_PATHS) {\n    const value = valueAtPath(raw, path);\n    if (!Array.isArray(value)) {\n      continue;\n    }\n\n    value.forEach((item, index) => {\n      if (!isRecord(item)) {\n        return;\n      }\n      const type = normalizeLowerText(item.type ?? item.kind ?? item.relationType);\n      if (!isRepostRelationType(type)) {\n        return;\n      }\n\n      const postId = normalizePostId(item.id ?? item.postId ?? item.post_id);\n      const parsedUrl = parsePostUrl(item.url ?? item.expanded_url ?? item.expandedUrl);\n      addCandidate({\n        postId: postId ?? parsedUrl?.postId,\n        url: parsedUrl?.url,\n        evidence: `${formatPath(\"raw\", path)}[${index}] declares ${type}`,\n        confidence: postId ? 0.94 : 0.78,\n      }, 92);\n    });\n  }\n}\n\nfunction collectIdPathCandidates(\n  source: unknown,\n  paths: readonly RawPath[],\n  rootName: string,\n  confidence: number,\n  rank: number,\n  addCandidate: (candidate: CandidateInput | null, rank: number) => void,\n): void {\n  for (const path of paths) {\n    const postId = normalizePostId(valueAtPath(source, path));\n    addCandidate(postId ? {\n      postId,\n      evidence: `${formatPath(rootName, path)} points to a repost source id`,\n      confidence,\n    } : null, rank);\n  }\n}\n\nfunction collectUrlPathCandidates(\n  source: unknown,\n  paths: readonly RawPath[],\n  rootName: string,\n  confidence: number,\n  rank: number,\n  addCandidate: (candidate: CandidateInput | null, rank: number) => void,\n): void {\n  for (const path of paths) {\n    const parsedUrl = parsePostUrl(valueAtPath(source, path));\n    addCandidate(parsedUrl ? {\n      postId: parsedUrl.postId,\n      url: parsedUrl.url,\n      evidence: `${formatPath(rootName, path)} points to a repost source URL`,\n      confidence,\n    } : null, rank);\n  }\n}\n\nfunction collectEmbeddedSourcePosts(\n  raw: unknown,\n  wrapperText: unknown,\n  addCandidate: (candidate: CandidateInput | null, rank: number) => void,\n): void {\n  for (const path of REPOST_OBJECT_PATHS) {\n    const record = asRecord(valueAtPath(raw, path));\n    if (!record) {\n      continue;\n    }\n\n    addCandidate(candidateFromSourcePost(record, formatPath(\"raw\", path), wrapperText, 0.87), 86);\n  }\n}\n\nfunction collectCardCandidates(\n  cards: unknown,\n  wrapperText: unknown,\n  addCandidate: (candidate: CandidateInput | null, rank: number) => void,\n): void {\n  if (!Array.isArray(cards)) {\n    return;\n  }\n\n  cards.forEach((card, index) => {\n    const record = asRecord(card);\n    if (!record) {\n      return;\n    }\n\n    const hintText = firstTextAtPaths(record, CARD_HINT_PATHS)?.value;\n    if (!hasRepostHint(hintText)) {\n      return;\n    }\n\n    addCandidate(\n      candidateFromSourcePost(record, `post.cards[${index}]`, wrapperText, 0.72),\n      62,\n    );\n  });\n}\n\nfunction candidateFromSourcePost(\n  record: Record<string, unknown>,\n  evidenceRoot: string,\n  wrapperText: unknown,\n  baseConfidence: number,\n): CandidateInput | null {\n  const idCandidate = firstIdAtPaths(record, SOURCE_ID_PATHS);\n  const urlCandidate = firstUrlAtPaths(record, SOURCE_URL_PATHS);\n  const postId = idCandidate?.value ?? urlCandidate?.value.postId;\n  const url = urlCandidate?.value.url;\n  if (!postId && !url) {\n    return null;\n  }\n\n  const sourceAuthorId = firstIdAtPaths(record, SOURCE_AUTHOR_ID_PATHS)?.value;\n  const sourceText = firstTextAtPaths(record, SOURCE_TEXT_PATHS)?.value;\n  const textMatch = compareTexts(wrapperText, sourceText);\n  const confidence = confidenceWithTextMatch(baseConfidence, textMatch, Boolean(postId));\n  const details = [\n    idCandidate ? `id:${idCandidate.evidence}` : \"\",\n    urlCandidate ? `url:${urlCandidate.evidence}` : \"\",\n    sourceAuthorId ? \"source_author_id_present\" : \"\",\n    sourceText ? `source_text_${textMatch === \"none\" ? \"present\" : `match_${textMatch}`}` : \"\",\n  ].filter(Boolean);\n\n  return {\n    postId,\n    url,\n    sourceAuthorId,\n    sourceText,\n    evidence: `${evidenceRoot} contains repost source post${details.length ? ` (${details.join(\", \")})` : \"\"}`,\n    confidence,\n  };\n}\n\nfunction candidateFromId(value: unknown, evidence: string, confidence: number): CandidateInput | null {\n  const postId = normalizePostId(value);\n  if (!postId) {\n    return null;\n  }\n\n  return { postId, evidence, confidence };\n}\n\nfunction createCandidateCollector(candidates: RepostCandidate[]): (candidate: CandidateInput | null, rank: number) => void {\n  let order = 0;\n  const seen = new Map<string, number>();\n\n  return (candidate: CandidateInput | null, rank: number): void => {\n    const normalized = normalizeCandidate(candidate);\n    if (!normalized) {\n      return;\n    }\n\n    const key = normalized.postId ? `id:${normalized.postId}` : `url:${normalized.url}`;\n    const existingIndex = seen.get(key);\n    if (existingIndex === undefined) {\n      candidates.push({ ...normalized, rank, order });\n      seen.set(key, candidates.length - 1);\n      order += 1;\n      return;\n    }\n\n    const existing = candidates[existingIndex];\n    if (rank > existing.rank || (rank === existing.rank && normalized.confidence > existing.confidence)) {\n      candidates[existingIndex] = { ...normalized, rank, order: existing.order };\n    }\n  };\n}\n\nfunction normalizeCandidate(candidate: CandidateInput | null): CandidateInput | null {\n  if (!candidate) {\n    return null;\n  }\n\n  const parsedUrl = parsePostUrl(candidate.url);\n  const postId = normalizePostId(candidate.postId) ?? parsedUrl?.postId;\n  const url = parsedUrl?.url;\n  if (!postId && !url) {\n    return null;\n  }\n\n  const normalized: CandidateInput = {\n    evidence: cleanEvidence(candidate.evidence),\n    confidence: clampConfidence(candidate.confidence),\n  };\n  if (postId) {\n    normalized.postId = postId;\n  }\n  if (url) {\n    normalized.url = url;\n  }\n  if (candidate.sourceAuthorId) {\n    normalized.sourceAuthorId = normalizePostId(candidate.sourceAuthorId);\n  }\n  if (candidate.sourceText) {\n    normalized.sourceText = candidate.sourceText;\n  }\n  return normalized;\n}\n\nfunction chooseBestCandidate(candidates: readonly RepostCandidate[], post: PostLike): RepostCandidate | null {\n  const currentId = normalizePostId(post.id) ?? parsePostUrl(post.url)?.postId;\n  const currentUrl = parsePostUrl(post.url)?.url;\n  const filtered = candidates.filter((candidate) => {\n    if (!candidate.postId && !candidate.url) {\n      return false;\n    }\n    if (candidate.postId && currentId && candidate.postId === currentId) {\n      return false;\n    }\n    if (candidate.url && currentUrl && candidate.url === currentUrl) {\n      return false;\n    }\n    return true;\n  });\n\n  filtered.sort((left, right) => {\n    if (right.rank !== left.rank) return right.rank - left.rank;\n    if (right.confidence !== left.confidence) return right.confidence - left.confidence;\n    return left.order - right.order;\n  });\n  return filtered[0] ?? null;\n}\n\nfunction firstIdAtPaths(source: unknown, paths: readonly RawPath[]): { value: string; evidence: string } | null {\n  for (const path of paths) {\n    const value = normalizePostId(valueAtPath(source, path));\n    if (value) {\n      return { value, evidence: formatPath(\"source\", path) };\n    }\n  }\n  return null;\n}\n\nfunction firstUrlAtPaths(source: unknown, paths: readonly RawPath[]): { value: ParsedPostUrl; evidence: string } | null {\n  for (const path of paths) {\n    const value = parsePostUrl(valueAtPath(source, path));\n    if (value) {\n      return { value, evidence: formatPath(\"source\", path) };\n    }\n  }\n  return null;\n}\n\nfunction firstTextAtPaths(source: unknown, paths: readonly RawPath[]): { value: string; evidence: string } | null {\n  for (const path of paths) {\n    const value = valueAtPath(source, path);\n    if (typeof value !== \"string\") {\n      continue;\n    }\n    const text = value.trim();\n    if (text) {\n      return { value: text, evidence: formatPath(\"source\", path) };\n    }\n  }\n  return null;\n}\n\nfunction valueAtPath(source: unknown, path: RawPath): unknown {\n  let current = source;\n  for (const segment of path) {\n    if (typeof segment === \"number\") {\n      if (!Array.isArray(current)) {\n        return undefined;\n      }\n      current = current[segment];\n      continue;\n    }\n\n    if (!isRecord(current)) {\n      return undefined;\n    }\n    current = current[segment];\n  }\n  return current;\n}\n\nfunction parsePostUrl(value: unknown): ParsedPostUrl | undefined {\n  const url = normalizeUrl(value);\n  if (!url) {\n    return undefined;\n  }\n\n  const parsed = parseWithUrl(url) ?? parseWithRegex(url);\n  return parsed ? { postId: parsed.postId, url } : undefined;\n}\n\nfunction parseWithUrl(url: string): { postId: string } | null {\n  try {\n    const parsed = new URL(url);\n    const host = parsed.hostname.toLowerCase();\n    const supportedHost = host === \"x.com\"\n      || host === \"twitter.com\"\n      || host === \"mobile.x.com\"\n      || host === \"mobile.twitter.com\"\n      || host.endsWith(\".x.com\")\n      || host.endsWith(\".twitter.com\");\n    if (!supportedHost) {\n      return null;\n    }\n\n    const match = parsed.pathname.match(/^\\/[^/]+\\/status(?:es)?\\/(\\d+)/i)\n      ?? parsed.pathname.match(/^\\/i\\/web\\/status(?:es)?\\/(\\d+)/i);\n    return match ? { postId: match[1] } : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction parseWithRegex(url: string): { postId: string } | null {\n  const match = url.match(/(?:https?:\\/\\/)?(?:www\\.|mobile\\.)?(?:x|twitter)\\.com\\/[^\\s/?#]+\\/status(?:es)?\\/(\\d+)/i)\n    ?? url.match(/(?:https?:\\/\\/)?(?:www\\.|mobile\\.)?(?:x|twitter)\\.com\\/i\\/web\\/status(?:es)?\\/(\\d+)/i);\n  return match ? { postId: match[1] } : null;\n}\n\nfunction normalizePostId(value: unknown): string | undefined {\n  if (typeof value === \"string\") {\n    const trimmed = value.trim();\n    return trimmed ? trimmed : undefined;\n  }\n  if (typeof value === \"number\" && Number.isSafeInteger(value) && value > 0) {\n    return String(value);\n  }\n  if (typeof value === \"bigint\" && value > 0n) {\n    return value.toString();\n  }\n  return undefined;\n}\n\nfunction normalizeUrl(value: unknown): string | undefined {\n  if (typeof value !== \"string\") {\n    return undefined;\n  }\n  const trimmed = value.trim();\n  if (!trimmed || !/^https?:\\/\\//i.test(trimmed)) {\n    return undefined;\n  }\n  return trimmed;\n}\n\nfunction compareTexts(left: unknown, right: unknown): TextMatch {\n  const leftText = normalizeComparableText(left);\n  const rightText = normalizeComparableText(right);\n  if (!leftText || !rightText) {\n    return \"none\";\n  }\n  if (leftText === rightText) {\n    return \"exact\";\n  }\n  if (leftText.length >= 16 && rightText.length >= 16 && (leftText.includes(rightText) || rightText.includes(leftText))) {\n    return \"contained\";\n  }\n  return \"none\";\n}\n\nfunction confidenceWithTextMatch(baseConfidence: number, textMatch: TextMatch, hasPostId: boolean): number {\n  const idPenalty = hasPostId ? 0 : -0.08;\n  const textBoost = textMatch === \"exact\" ? 0.06 : textMatch === \"contained\" ? 0.04 : 0;\n  return clampConfidence(baseConfidence + idPenalty + textBoost);\n}\n\nfunction normalizeComparableText(value: unknown): string {\n  if (typeof value !== \"string\") {\n    return \"\";\n  }\n  return value\n    .replace(/^RT\\s+@[^:]+:\\s*/i, \"\")\n    .replace(/https?:\\/\\/\\S+/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .toLowerCase();\n}\n\nfunction normalizeLowerText(value: unknown): string {\n  return typeof value === \"string\" ? value.trim().toLowerCase() : \"\";\n}\n\nfunction isRepostRelationType(value: string): boolean {\n  return value === \"retweeted\"\n    || value === \"retweet\"\n    || value === \"repost\"\n    || value === \"reposted\"\n    || value === \"repost_source\";\n}\n\nfunction hasRepostHint(value: unknown): boolean {\n  const text = normalizeLowerText(value);\n  return text.includes(\"repost\") || text.includes(\"retweet\") || text.includes(\"retweeted\") || text.includes(\"retweeted_status\");\n}\n\nfunction cleanEvidence(value: string): string {\n  const text = value.trim();\n  return text || \"unknown_repost_source_signal\";\n}\n\nfunction formatPath(rootName: string, path: RawPath): string {\n  return path.reduce<string>((text, segment) => {\n    if (typeof segment === \"number\") {\n      return `${text}[${segment}]`;\n    }\n    return `${text}.${segment}`;\n  }, rootName);\n}\n\nfunction clampConfidence(value: number): number {\n  if (!Number.isFinite(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}\n\nfunction asRecord(value: unknown): Record<string, unknown> | null {\n  return isRecord(value) ? value : null;\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n}",
