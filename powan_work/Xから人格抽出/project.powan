    {
      "id": "node-27fb9b066d",
      "title": "テスト対象選択ポワン",
      "body": "テスト対象を選ぶ臓器ポワン。既存のx_archive.dbからアカウント、投稿ID、投稿URL、type、raw_jsonの概要を一覧し、単発URL入力やrun_id指定にも対応する。テストGUIポワンへ対象候補を渡し、選ばれた投稿を共通のテスト入力形式に整える。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport sqlite3\nimport sys\nfrom collections.abc import Mapping, Sequence\nfrom pathlib import Path\nfrom typing import Any\nfrom urllib.parse import urlparse, urlunparse\n\nDEFAULT_LIMIT = 50\nDEFAULT_TEXT_PREVIEW_CHARS = 220\n\nPOST_ID_KEYS = {\n    \"id\",\n    \"postid\",\n    \"tweetid\",\n    \"tweetidstr\",\n    \"statusid\",\n    \"statusidstr\",\n    \"restid\",\n}\nACCOUNT_KEYS = {\n    \"account\",\n    \"handle\",\n    \"username\",\n    \"screenname\",\n    \"authorhandle\",\n    \"userhandle\",\n}\nURL_KEYS = {\n    \"url\",\n    \"posturl\",\n    \"tweeturl\",\n    \"statusurl\",\n    \"canonicalurl\",\n    \"expandedurl\",\n    \"permalink\",\n}\nTYPE_KEYS = {\"type\", \"posttype\", \"tweettype\", \"kind\", \"relationtype\"}\nRUN_ID_KEYS = {\"runid\", \"run\"}\nTEXT_KEYS = {\"text\", \"fulltext\", \"body\", \"content\", \"description\", \"note\"}\nRAW_JSON_KEYS = {\"rawjson\", \"raw\", \"sourcejson\", \"payload\"}\nNESTED_MAP_KEYS = {\n    \"rawjson\",\n    \"raw\",\n    \"tweet\",\n    \"post\",\n    \"legacy\",\n    \"data\",\n    \"result\",\n    \"item\",\n    \"content\",\n    \"metadata\",\n    \"author\",\n    \"user\",\n}\nX_HOSTS = {\"x.com\", \"twitter.com\", \"mobile.twitter.com\", \"www.x.com\", \"www.twitter.com\"}\nAPI_HISTORY_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\\ai_agent_team_runtime\\artifacts\\x\\account_history\")\n\n\ndef normalize_test_input(input_value: Any = None, **kwargs: Any) -> dict[str, Any]:\n    \"\"\"Return one common test input, or a selector result when only account/run_id is given.\"\"\"\n    warnings: list[str] = []\n    record = _record_from_input(input_value, warnings)\n    record.update({key: value for key, value in kwargs.items() if value not in (None, \"\")})\n\n    raw_json_value = record.get(\"raw_json\", None)\n    if raw_json_value is None:\n        raw_json_value = _first_value(_candidate_maps(record), RAW_JSON_KEYS)\n    raw_json = _coerce_raw_json(raw_json_value, warnings)\n\n    maps = _candidate_maps(record)\n    raw_maps = _candidate_maps(raw_json) if isinstance(raw_json, Mapping) else []\n    all_maps = [*maps, *raw_maps]\n\n    url = _first_text(all_maps, URL_KEYS)\n    post_id = _clean_id(record.get(\"post_id\") or _first_text(all_maps, POST_ID_KEYS))\n    account = _clean_account(record.get(\"account\") or _first_text(all_maps, ACCOUNT_KEYS))\n    run_id = _clean_text(record.get(\"run_id\") or _first_text(all_maps, RUN_ID_KEYS))\n    source_type = _clean_text(record.get(\"source_type\")) or _detect_source_type(record, raw_json, url, post_id, account, run_id)\n\n    canonical_url, parsed_account, parsed_post_id, url_warnings = canonicalize_post_url(\n        url,\n        account=account,\n        post_id=post_id,\n    )\n    warnings.extend(url_warnings)\n    account = account or parsed_account\n    post_id = post_id or parsed_post_id\n\n    db_path: Path | None = None\n    if _should_try_db(record, source_type, raw_json, canonical_url, post_id, account, run_id):\n        db_path, db_path_warnings = resolve_db_path(record.get(\"db_path\") or record.get(\"db\"), account=account)\n        warnings.extend(db_path_warnings)\n\n    if db_path and post_id:\n        db_post = fetch_db_post(db_path, post_id=post_id, account=account)\n        warnings.extend(db_post.get(\"warnings\", []))\n        row = db_post.get(\"row\")\n        if row:\n            return common_from_db_row(\n                row,\n                db_path=db_path,\n                run_id=run_id,\n                include_raw_json=True,\n                selector_note=\"existing x_archive.db posts row selected by post_id\",\n                warnings=warnings,\n            )\n\n    if db_path and run_id and not post_id:\n        return selector_from_db(\n            db_path,\n            source_type=\"run_id\",\n            target_kind=\"run_posts_selector\",\n            account=account,\n            run_id=run_id,\n            limit=int(record.get(\"limit\") or DEFAULT_LIMIT),\n            offset=int(record.get(\"offset\") or 0),\n            warnings=warnings,\n        )\n\n    has_selector_only_account = account and not post_id and not canonical_url and raw_json is None\n    if db_path and has_selector_only_account:\n        return selector_from_db(\n            db_path,\n            source_type=\"account\",\n            target_kind=\"account_posts_selector\",\n            account=account,\n            run_id=run_id,\n            limit=int(record.get(\"limit\") or DEFAULT_LIMIT),\n            offset=int(record.get(\"offset\") or 0),\n            warnings=warnings,\n        )\n\n    return common_from_known_values(\n        source_type=source_type,\n        target_kind=_target_kind_for_partial(source_type, raw_json, canonical_url, post_id),\n        canonical_url=canonical_url,\n        post_id=post_id,\n        account=account,\n        run_id=run_id,\n        db_ref=_normalize_db_ref(record.get(\"db_ref\"), db_path=db_path),\n        raw_json=raw_json,\n        text_preview=_preview_text(_first_text(all_maps, TEXT_KEYS)),\n        selector_note=_selector_note_for_partial(source_type, raw_json, canonical_url, post_id),\n        warnings=warnings,\n    )\n\n\ndef list_db_candidates(\n    db_path: str | Path | None = None,\n    *,\n    account: str = \"\",\n    post_id: str = \"\",\n    run_id: str = \"\",\n    limit: int = DEFAULT_LIMIT,\n    offset: int = 0,\n    include_raw_json: bool = False,\n) -> dict[str, Any]:\n    warnings: list[str] = []\n    resolved, db_warnings = resolve_db_path(db_path, account=account)\n    warnings.extend(db_warnings)\n    if not resolved:\n        return {\n            \"ok\": False,\n            \"candidates\": [],\n            \"warnings\": warnings or [\"x_archive.db was not found; pass db_path explicitly\"],\n            \"db_read_scope\": {\"mode\": \"read_only\", \"tables\": [], \"filters\": _filters(account, post_id, run_id)},\n        }\n\n    rows_result = _query_post_rows(\n        resolved,\n        account=account,\n        post_id=post_id,\n        run_id=run_id,\n        limit=limit,\n        offset=offset,\n    )\n    warnings.extend(rows_result.get(\"warnings\", []))\n    candidates = [\n        common_from_db_row(\n            row,\n            db_path=resolved,\n            run_id=run_id,\n            include_raw_json=include_raw_json,\n            selector_note=\"candidate listed from x_archive.db posts\",\n            warnings=[],\n        )\n        for row in rows_result.get(\"rows\", [])\n    ]\n    return {\n        \"ok\": True,\n        \"candidates\": candidates,\n        \"warnings\": warnings,\n        \"db_read_scope\": rows_result.get(\"db_read_scope\", {}),\n    }\n\n\ndef selector_from_db(\n    db_path: Path,\n    *,\n    source_type: str,\n    target_kind: str,\n    account: str = \"\",\n    run_id: str = \"\",\n    limit: int = DEFAULT_LIMIT,\n    offset: int = 0,\n    warnings: list[str] | None = None,\n) -> dict[str, Any]:\n    own_warnings = list(warnings or [])\n    listed = list_db_candidates(\n        db_path,\n        account=account,\n        run_id=run_id,\n        limit=limit,\n        offset=offset,\n        include_raw_json=False,\n    )\n    own_warnings.extend(listed.get(\"warnings\", []))\n    candidates = listed.get(\"candidates\", [])\n    return {\n        \"source_type\": source_type,\n        \"target_kind\": target_kind,\n        \"canonical_url\": \"\",\n        \"post_id\": \"\",\n        \"account\": account,\n        \"run_id\": run_id,\n        \"db_ref\": {\"db_path\": str(db_path), \"table\": \"posts\", \"mode\": \"read_only\"},\n        \"raw_json\": None,\n        \"text_preview\": f\"{len(candidates)} candidate posts\",\n        \"selector_note\": \"select one candidate, then pass its post_id/db_ref back for a common test input\",\n        \"needs_browser\": False,\n        \"warnings\": _dedupe(own_warnings),\n        \"candidates\": candidates,\n        \"db_read_scope\": listed.get(\"db_read_scope\", {}),\n    }\n\n\ndef common_from_db_row(\n    row: Mapping[str, Any],\n    *,\n    db_path: str | Path,\n    run_id: str = \"\",\n    include_raw_json: bool = True,\n    selector_note: str = \"selected from x_archive.db\",\n    warnings: list[str] | None = None,\n) -> dict[str, Any]:\n    own_warnings = list(warnings or [])\n    raw_json = _coerce_raw_json(row.get(\"raw_json\"), own_warnings)\n    post_id = _clean_id(row.get(\"id\") or row.get(\"post_id\"))\n    account = _clean_account(row.get(\"account\") or row.get(\"author_handle\"))\n    canonical_url, parsed_account, parsed_post_id, url_warnings = canonicalize_post_url(\n        _clean_text(row.get(\"url\")),\n        account=account,\n        post_id=post_id,\n    )\n    own_warnings.extend(url_warnings)\n    account = account or parsed_account\n    post_id = post_id or parsed_post_id\n    text_preview = _preview_text(_clean_text(row.get(\"text\")) or _first_text(_candidate_maps(raw_json), TEXT_KEYS))\n    result = {\n        \"source_type\": \"db\",\n        \"target_kind\": \"existing_db_post\",\n        \"canonical_url\": canonical_url,\n        \"post_id\": post_id,\n        \"account\": account,\n        \"run_id\": run_id,\n        \"db_ref\": {\n            \"db_path\": str(Path(db_path)),\n            \"table\": \"posts\",\n            \"primary_key\": post_id,\n            \"account\": account,\n            \"mode\": \"read_only\",\n        },\n        \"raw_json\": raw_json if include_raw_json else None,\n        \"text_preview\": text_preview,\n        \"selector_note\": selector_note,\n        \"needs_browser\": False,\n        \"warnings\": _dedupe(own_warnings),\n        \"type\": _clean_text(row.get(\"type\")),\n        \"created_at\": _clean_text(row.get(\"created_at\")),\n        \"collected_at\": _clean_text(row.get(\"collected_at\")),\n        \"raw_json_summary\": summarize_raw_json(raw_json),\n    }\n    if not canonical_url:\n        result[\"needs_browser\"] = True\n        result[\"warnings\"].append(\"canonical_url could not be built from DB row\")\n    return result\n\n\ndef common_from_known_values(\n    *,\n    source_type: str,\n    target_kind: str,\n    canonical_url: str,\n    post_id: str,\n    account: str,\n    run_id: str,\n    db_ref: dict[str, Any] | None,\n    raw_json: Any,\n    text_preview: str,\n    selector_note: str,\n    warnings: list[str],\n) -> dict[str, Any]:\n    needs_browser = not bool(raw_json) or not bool(post_id and canonical_url)\n    if not canonical_url:\n        warnings.append(\"canonical_url is missing; pass a post URL or DB row when possible\")\n    if not post_id:\n        warnings.append(\"post_id is missing; browser or DB confirmation may be required\")\n    if raw_json is None:\n        warnings.append(\"raw_json is missing; downstream readers may need browser confirmation\")\n    return {\n        \"source_type\": source_type,\n        \"target_kind\": target_kind,\n        \"canonical_url\": canonical_url,\n        \"post_id\": post_id,\n        \"account\": account,\n        \"run_id\": run_id,\n        \"db_ref\": db_ref,\n        \"raw_json\": raw_json,\n        \"text_preview\": text_preview,\n        \"selector_note\": selector_note,\n        \"needs_browser\": needs_browser,\n        \"warnings\": _dedupe(warnings),\n        \"raw_json_summary\": summarize_raw_json(raw_json),\n    }\n\n\ndef fetch_db_post(db_path: str | Path, *, post_id: str, account: str = \"\") -> dict[str, Any]:\n    rows = _query_post_rows(db_path, post_id=post_id, account=account, limit=1, offset=0)\n    row_list = rows.get(\"rows\", [])\n    warnings = list(rows.get(\"warnings\", []))\n    if not row_list:\n        warnings.append(\"no posts row matched post_id/account in x_archive.db\")\n    return {\"row\": row_list[0] if row_list else None, \"warnings\": warnings, \"db_read_scope\": rows.get(\"db_read_scope\", {})}\n\n\ndef _query_post_rows(\n    db_path: str | Path,\n    *,\n    account: str = \"\",\n    post_id: str = \"\",\n    run_id: str = \"\",\n    limit: int = DEFAULT_LIMIT,\n    offset: int = 0,\n) -> dict[str, Any]:\n    warnings: list[str] = []\n    limit = max(1, min(int(limit or DEFAULT_LIMIT), 500))\n    offset = max(0, int(offset or 0))\n    path = Path(db_path)\n    with _connect_read_only(path) as conn:\n        tables = _table_names(conn)\n        if \"posts\" not in tables:\n            return {\"rows\": [], \"warnings\": [\"posts table was not found\"], \"db_read_scope\": _scope(path, tables, account, post_id, run_id, limit, offset)}\n        post_columns = _table_columns(conn, \"posts\")\n        select_cols = [col for col in (\"id\", \"account\", \"type\", \"author_handle\", \"author_name\", \"url\", \"created_at\", \"text\", \"raw_json\", \"collected_at\") if col in post_columns]\n        where: list[str] = []\n        params: list[Any] = []\n        if post_id and \"id\" in post_columns:\n            where.append(\"id = ?\")\n            params.append(post_id)\n        if account and \"account\" in post_columns:\n            where.append(\"account = ?\")\n            params.append(account)\n\n        if run_id:\n            run_filter = _run_post_filter(conn, run_id, post_columns, warnings)\n            if run_filter:\n                where.extend(run_filter[0])\n                params.extend(run_filter[1])\n\n        order_parts = [col + \" DESC\" for col in (\"collected_at\", \"created_at\", \"id\") if col in post_columns]\n        sql = \"SELECT \" + \", \".join(select_cols or [\"*\"]) + \" FROM posts\"\n        if where:\n            sql += \" WHERE \" + \" AND \".join(where)\n        if order_parts:\n            sql += \" ORDER BY \" + \", \".join(order_parts)\n        sql += \" LIMIT ? OFFSET ?\"\n        params.extend([limit, offset])\n        rows = [dict(row) for row in conn.execute(sql, params).fetchall()]\n        return {\"rows\": rows, \"warnings\": warnings, \"db_read_scope\": _scope(path, tables, account, post_id, run_id, limit, offset, select_cols)}\n\n\ndef _run_post_filter(conn: sqlite3.Connection, run_id: str, post_columns: set[str], warnings: list[str]) -> tuple[list[str], list[Any]] | None:\n    if \"runs\" not in _table_names(conn):\n        warnings.append(\"run_id was given, but runs table was not found\")\n        return None\n    run = conn.execute(\"SELECT * FROM runs WHERE id = ?\", (run_id,)).fetchone()\n    if run is None:\n        warnings.append(\"run_id was not found in runs table\")\n        return None\n    run_dict = dict(run)\n    filters: list[str] = []\n    params: list[Any] = []\n    if run_dict.get(\"account\") and \"account\" in post_columns:\n        filters.append(\"account = ?\")\n        params.append(run_dict[\"account\"])\n    if \"collected_at\" in post_columns and run_dict.get(\"started_at\"):\n        filters.append(\"collected_at >= ?\")\n        params.append(run_dict[\"started_at\"])\n    if \"collected_at\" in post_columns and run_dict.get(\"finished_at\"):\n        filters.append(\"collected_at <= ?\")\n        params.append(run_dict[\"finished_at\"])\n    warnings.append(\"posts table has no direct run_id column; run_id selection is approximated by account and collected_at window\")\n    return filters, params\n\n\ndef resolve_db_path(db_path: Any = None, *, account: str = \"\") -> tuple[Path | None, list[str]]:\n    warnings: list[str] = []\n    explicit = _clean_text(db_path) or os.environ.get(\"X_ARCHIVE_DB\", \"\")\n    if explicit:\n        path = Path(explicit).expanduser()\n        if not path.is_absolute():\n            path = (Path.cwd() / path).resolve()\n        if path.exists():\n            return path, warnings\n        return None, [f\"x_archive.db was not found: {path}\"]\n\n    clean_account = _clean_account(account)\n    if clean_account:\n        exact = API_HISTORY_ROOT / clean_account / \"x_archive.db\"\n        if exact.exists():\n            return exact, warnings\n\n    candidates = _default_db_candidates(clean_account)\n    existing = [path for path in candidates if path.exists()]\n    unique = []\n    seen = set()\n    for path in existing:\n        key = str(path.resolve()).lower()\n        if key not in seen:\n            seen.add(key)\n            unique.append(path)\n    if len(unique) == 1:\n        return unique[0], warnings\n    if len(unique) > 1:\n        warnings.append(\"multiple x_archive.db files were found; pass db_path explicitly\")\n        warnings.extend(str(path) for path in unique[:8])\n    return None, warnings\n\n\ndef _default_db_candidates(account: str = \"\") -> list[Path]:\n    roots = [Path.cwd(), Path.cwd().parent]\n    if account:\n        roots.append(API_HISTORY_ROOT / account)\n    roots.append(API_HISTORY_ROOT)\n    candidates: list[Path] = []\n    for root in roots:\n        candidates.append(root / \"x_archive.db\")\n        if root.exists() and root.name == \"account_history\" and not account:\n            candidates.extend(sorted(root.glob(\"*/x_archive.db\")))\n    return candidates\n\n\ndef _should_try_db(record: Mapping[str, Any], source_type: str, raw_json: Any, canonical_url: str, post_id: str, account: str, run_id: str) -> bool:\n    if record.get(\"db_path\") or record.get(\"db\") or record.get(\"db_ref\") or source_type == \"db\":\n        return True\n    if run_id:\n        return True\n    if post_id and not canonical_url and raw_json is None:\n        return True\n    if account and not post_id and not canonical_url and raw_json is None:\n        return True\n    return False\n\n\ndef canonicalize_post_url(url: Any, *, account: str = \"\", post_id: str = \"\") -> tuple[str, str, str, list[str]]:\n    warnings: list[str] = []\n    text = _clean_text(url)\n    if text and \"://\" not in text and (\"x.com\" in text or \"twitter.com\" in text):\n        text = \"https://\" + text\n    parsed_account = \"\"\n    parsed_post_id = \"\"\n    canonical = \"\"\n    if text:\n        parsed = urlparse(text)\n        host = parsed.netloc.lower()\n        if host in X_HOSTS:\n            parts = [part for part in parsed.path.split(\"/\") if part]\n            for index, part in enumerate(parts):\n                if part.lower() == \"status\" and index + 1 < len(parts):\n                    parsed_post_id = _clean_id(parts[index + 1])\n                    if index > 0 and parts[index - 1].lower() not in {\"i\", \"web\"}:\n                        parsed_account = _clean_account(parts[index - 1])\n                    break\n            account = account or parsed_account\n            post_id = post_id or parsed_post_id\n            if post_id:\n                canonical = _canonical_url_from_parts(account, post_id, fallback=text)\n            else:\n                warnings.append(\"X/Twitter URL did not contain /status/{post_id}\")\n        elif parsed.scheme in {\"http\", \"https\"}:\n            canonical = urlunparse((parsed.scheme, parsed.netloc, parsed.path.rstrip(\"/\"), \"\", \"\", \"\"))\n            warnings.append(\"URL is not an X/Twitter status URL\")\n    elif post_id:\n        canonical = _canonical_url_from_parts(account, post_id, fallback=\"\")\n    return canonical, account or parsed_account, post_id or parsed_post_id, warnings\n\n\ndef summarize_raw_json(value: Any) -> dict[str, Any] | None:\n    if value is None:\n        return None\n    if isinstance(value, Mapping):\n        maps = _candidate_maps(value)\n        return {\n            \"kind\": \"object\",\n            \"top_keys\": list(value.keys())[:20],\n            \"post_id\": _clean_id(_first_text(maps, POST_ID_KEYS)),\n            \"account\": _clean_account(_first_text(maps, ACCOUNT_KEYS)),\n            \"url\": _first_text(maps, URL_KEYS),\n            \"type\": _first_text(maps, TYPE_KEYS),\n            \"text_preview\": _preview_text(_first_text(maps, TEXT_KEYS)),\n        }\n    if isinstance(value, list):\n        return {\"kind\": \"array\", \"length\": len(value)}\n    text = str(value)\n    return {\"kind\": type(value).__name__, \"preview\": _preview_text(text)}\n\n\ndef _connect_read_only(path: Path) -> sqlite3.Connection:\n    uri = \"file:\" + path.resolve().as_posix() + \"?mode=ro\"\n    conn = sqlite3.connect(uri, uri=True)\n    conn.row_factory = sqlite3.Row\n    conn.execute(\"PRAGMA query_only = ON\")\n    return conn\n\n\ndef _table_names(conn: sqlite3.Connection) -> set[str]:\n    return {str(row[0]) for row in conn.execute(\"SELECT name FROM sqlite_master WHERE type IN ('table','view')\")}\n\n\ndef _table_columns(conn: sqlite3.Connection, table: str) -> set[str]:\n    return {str(row[1]) for row in conn.execute(f\"PRAGMA table_info({table})\")}\n\n\ndef _scope(path: Path, tables: set[str], account: str, post_id: str, run_id: str, limit: int, offset: int, columns: Sequence[str] | None = None) -> dict[str, Any]:\n    return {\n        \"db_path\": str(path),\n        \"mode\": \"read_only\",\n        \"tables\": sorted(tables.intersection({\"accounts\", \"posts\", \"runs\"})),\n        \"filters\": _filters(account, post_id, run_id),\n        \"limit\": limit,\n        \"offset\": offset,\n        \"selected_columns\": list(columns or []),\n    }\n\n\ndef _filters(account: str, post_id: str, run_id: str) -> dict[str, str]:\n    return {\"account\": account or \"\", \"post_id\": post_id or \"\", \"run_id\": run_id or \"\"}\n\n\ndef _record_from_input(value: Any, warnings: list[str]) -> dict[str, Any]:\n    if value is None:\n        return {}\n    if isinstance(value, Mapping):\n        return dict(value)\n    if isinstance(value, str):\n        text = value.strip()\n        if not text:\n            return {}\n        if _looks_like_json(text):\n            loaded = json.loads(text)\n            if isinstance(loaded, Mapping):\n                return dict(loaded)\n            return {\"raw_json\": loaded, \"source_type\": \"raw_json\"}\n        return {\"url\": text, \"source_type\": \"url\"}\n    warnings.append(\"input_value was not a mapping/string; keeping it as raw_json\")\n    return {\"raw_json\": value, \"source_type\": \"raw_json\"}\n\n\ndef _candidate_maps(value: Any, *, max_depth: int = 4) -> list[Mapping[str, Any]]:\n    maps: list[Mapping[str, Any]] = []\n    seen: set[int] = set()\n\n    def visit(current: Any, depth: int) -> None:\n        if depth > max_depth or not isinstance(current, Mapping):\n            return\n        marker = id(current)\n        if marker in seen:\n            return\n        seen.add(marker)\n        maps.append(current)\n        for key, child in current.items():\n            token = _key_token(key)\n            if token in NESTED_MAP_KEYS:\n                if isinstance(child, Mapping):\n                    visit(child, depth + 1)\n                elif isinstance(child, str) and _looks_like_json(child):\n                    try:\n                        loaded = json.loads(child)\n                    except json.JSONDecodeError:\n                        continue\n                    if isinstance(loaded, Mapping):\n                        visit(loaded, depth + 1)\n    visit(value, 0)\n    return maps\n\n\ndef _first_value(maps: Sequence[Mapping[str, Any]], key_tokens: set[str]) -> Any:\n    for item in maps:\n        for key, value in item.items():\n            if _key_token(key) in key_tokens and value not in (None, \"\"):\n                return value\n    return None\n\n\ndef _first_text(maps: Sequence[Mapping[str, Any]], key_tokens: set[str]) -> str:\n    value = _first_value(maps, key_tokens)\n    if value is None or isinstance(value, (Mapping, list, tuple, set)):\n        return \"\"\n    return _clean_text(value)\n\n\ndef _coerce_raw_json(value: Any, warnings: list[str]) -> Any:\n    if value in (None, \"\"):\n        return None\n    if isinstance(value, str):\n        text = value.strip()\n        if _looks_like_json(text):\n            try:\n                return json.loads(text)\n            except json.JSONDecodeError as exc:\n                warnings.append(f\"raw_json could not be parsed: {exc}\")\n        return text\n    return value\n\n\ndef _normalize_db_ref(value: Any, *, db_path: Path | None) -> dict[str, Any] | None:\n    if isinstance(value, Mapping):\n        ref = dict(value)\n    else:\n        ref = {}\n    if db_path:\n        ref.setdefault(\"db_path\", str(db_path))\n        ref.setdefault(\"mode\", \"read_only\")\n    return ref or None\n\n\ndef _detect_source_type(record: Mapping[str, Any], raw_json: Any, url: str, post_id: str, account: str, run_id: str) -> str:\n    if record.get(\"db_ref\") or record.get(\"db_path\"):\n        return \"db\"\n    if run_id:\n        return \"run_id\"\n    if url:\n        return \"url\"\n    if raw_json is not None:\n        return \"raw_json\"\n    if post_id:\n        return \"post_id\"\n    if account:\n        return \"account\"\n    return \"unknown\"\n\n\ndef _target_kind_for_partial(source_type: str, raw_json: Any, canonical_url: str, post_id: str) -> str:\n    if source_type == \"url\":\n        return \"single_post_url\"\n    if source_type == \"raw_json\":\n        return \"raw_json_post\"\n    if post_id and canonical_url:\n        return \"single_post\"\n    if post_id:\n        return \"post_id_lookup\"\n    return \"unresolved_target\"\n\n\ndef _selector_note_for_partial(source_type: str, raw_json: Any, canonical_url: str, post_id: str) -> str:\n    if source_type == \"url\":\n        return \"single URL normalized without browser access\"\n    if source_type == \"raw_json\":\n        return \"raw_json normalized without DB or browser access\"\n    if post_id and not canonical_url:\n        return \"post_id received, but account/url is missing\"\n    return \"partial target normalized from provided values\"\n\n\ndef _canonical_url_from_parts(account: str, post_id: str, *, fallback: str = \"\") -> str:\n    clean_post_id = _clean_id(post_id)\n    clean_account = _clean_account(account)\n    if clean_account and clean_post_id:\n        return f\"https://x.com/{clean_account}/status/{clean_post_id}\"\n    if clean_post_id:\n        return f\"https://x.com/i/web/status/{clean_post_id}\"\n    return fallback\n\n\ndef _preview_text(value: Any, limit: int = DEFAULT_TEXT_PREVIEW_CHARS) -> str:\n    text = re.sub(r\"\\s+\", \" \", _clean_text(value)).strip()\n    if len(text) <= limit:\n        return text\n    return text[: max(0, limit - 1)].rstrip() + \"...\"\n\n\ndef _clean_text(value: Any) -> str:\n    if value is None:\n        return \"\"\n    return str(value).strip()\n\n\ndef _clean_id(value: Any) -> str:\n    text = _clean_text(value)\n    match = re.search(r\"\\d{5,}\", text)\n    return match.group(0) if match else text\n\n\ndef _clean_account(value: Any) -> str:\n    text = _clean_text(value)\n    if text.startswith(\"@\"):\n        text = text[1:]\n    return re.sub(r\"[^A-Za-z0-9_]\", \"\", text)\n\n\ndef _key_token(key: Any) -> str:\n    return \"\".join(ch for ch in str(key or \"\").lower() if ch.isalnum())\n\n\ndef _looks_like_json(text: str) -> bool:\n    stripped = (text or \"\").strip()\n    return (stripped.startswith(\"{\") and stripped.endswith(\"}\")) or (stripped.startswith(\"[\") and stripped.endswith(\"]\"))\n\n\ndef _dedupe(items: Sequence[str]) -> list[str]:\n    output: list[str] = []\n    seen: set[str] = set()\n    for item in items:\n        text = _clean_text(item)\n        if text and text not in seen:\n            seen.add(text)\n            output.append(text)\n    return output\n\n\ndef load_input_payload(input_json: str) -> Any:\n    if not input_json or input_json == \"-\":\n        raw = sys.stdin.read().strip()\n        return json.loads(raw) if raw else {}\n    path = Path(input_json)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(input_json)\n\n\ndef run(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return normalize_test_input(payload, **kwargs)\n\n\ndef select(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return normalize_test_input(payload, **kwargs)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Normalize X collection test targets without browser or DB writes.\")\n    parser.add_argument(\"--input-json\", default=\"\", help=\"JSON string, JSON file path, or '-' for stdin\")\n    parser.add_argument(\"--url\", default=\"\")\n    parser.add_argument(\"--post-id\", default=\"\")\n    parser.add_argument(\"--account\", default=\"\")\n    parser.add_argument(\"--run-id\", default=\"\")\n    parser.add_argument(\"--db-path\", default=\"\")\n    parser.add_argument(\"--list-candidates\", action=\"store_true\")\n    parser.add_argument(\"--limit\", type=int, default=DEFAULT_LIMIT)\n    parser.add_argument(\"--offset\", type=int, default=0)\n    parser.add_argument(\"--include-raw-json\", action=\"store_true\")\n    parser.add_argument(\"--pretty\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    payload = load_input_payload(args.input_json) if args.input_json else {}\n    if args.list_candidates:\n        result = list_db_candidates(\n            args.db_path or None,\n            account=args.account,\n            post_id=args.post_id,\n            run_id=args.run_id,\n            limit=args.limit,\n            offset=args.offset,\n            include_raw_json=args.include_raw_json,\n        )\n    else:\n        result = normalize_test_input(\n            payload,\n            url=args.url,\n            post_id=args.post_id,\n            account=args.account,\n            run_id=args.run_id,\n            db_path=args.db_path,\n            limit=args.limit,\n            offset=args.offset,\n        )\n    print(json.dumps(result, ensure_ascii=False, indent=2 if args.pretty else None, default=str))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
