    {
      "id": "node-0a87aba08d",
      "title": "Seleniumページ遷移ポワン",
      "body": "起動済みのSelenium driverを受け取り、指定URLへ遷移して、document.readyStateや任意CSSセレクタの出現を待つ臓器ポワン。X投稿収集では、デバッグChrome起動後に検索URL、プロフィールURL、投稿URLへ移動し、次の投稿取得処理が読める状態までページを整える。単体実行時は既存の9221デバッグChromeへ接続して遷移確認できる。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport logging\nimport time\nfrom typing import Any\n\nfrom selenium.common.exceptions import TimeoutException\nfrom selenium.webdriver.common.by import By\nfrom selenium.webdriver.remote.webdriver import WebDriver\nfrom selenium.webdriver.support import expected_conditions as EC\nfrom selenium.webdriver.support.ui import WebDriverWait\n\nlog = logging.getLogger(\"selenium_page_navigation\")\n\n\ndef configure_logging(*, verbose: bool = False) -> None:\n    level = logging.DEBUG if verbose else logging.INFO\n    logging.basicConfig(\n        level=level,\n        format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n        force=True,\n    )\n\n\ndef navigate_page(\n    driver: WebDriver,\n    url: str,\n    *,\n    wait_seconds: float = 20.0,\n    wait_for_selector: str | None = None,\n    require_selector: bool = False,\n    settle_seconds: float = 0.5,\n) -> dict[str, Any]:\n    \"\"\"Navigate an existing Selenium driver and wait for a usable page state.\"\"\"\n    clean_url = (url or \"\").strip()\n    if not clean_url:\n        raise ValueError(\"url is required\")\n\n    log.info(\"navigate.start url=%s\", clean_url)\n    driver.get(clean_url)\n\n    wait = WebDriverWait(driver, wait_seconds)\n    try:\n        wait.until(lambda d: d.execute_script(\"return document.readyState\") in {\"interactive\", \"complete\"})\n        log.info(\"navigate.document_ready state=%s\", driver.execute_script(\"return document.readyState\"))\n    except TimeoutException:\n        log.warning(\"navigate.document_ready.timeout wait_seconds=%s\", wait_seconds)\n        if require_selector is False and wait_for_selector is None:\n            raise\n\n    selector_found = False\n    if wait_for_selector:\n        try:\n            wait.until(EC.presence_of_element_located((By.CSS_SELECTOR, wait_for_selector)))\n            selector_found = True\n            log.info(\"navigate.selector.ok selector=%s\", wait_for_selector)\n        except TimeoutException:\n            log.warning(\"navigate.selector.timeout selector=%s wait_seconds=%s\", wait_for_selector, wait_seconds)\n            if require_selector:\n                raise\n\n    if settle_seconds > 0:\n        log.debug(\"navigate.settle seconds=%s\", settle_seconds)\n        time.sleep(settle_seconds)\n\n    result = {\n        \"requested_url\": clean_url,\n        \"current_url\": driver.current_url,\n        \"title\": driver.title,\n        \"selector\": wait_for_selector or \"\",\n        \"selector_found\": selector_found,\n    }\n    log.info(\"navigate.done current_url=%s title=%s\", result[\"current_url\"], result[\"title\"])\n    return result\n\n\ndef get_debug_driver(*, port: int = 9221):\n    from scripts.chrome_debug import get_driver\n\n    log.info(\"driver.connect port=%s\", port)\n    return get_driver(port=port)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Navigate an existing Selenium debug Chrome page.\")\n    parser.add_argument(\"--url\", required=True)\n    parser.add_argument(\"--port\", type=int, default=9221)\n    parser.add_argument(\"--wait-seconds\", type=float, default=20.0)\n    parser.add_argument(\"--wait-for-selector\", default=\"\")\n    parser.add_argument(\"--require-selector\", action=\"store_true\")\n    parser.add_argument(\"--settle-seconds\", type=float, default=0.5)\n    parser.add_argument(\"--verbose\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    configure_logging(verbose=args.verbose)\n    driver = get_debug_driver(port=args.port)\n    result = navigate_page(\n        driver,\n        args.url,\n        wait_seconds=args.wait_seconds,\n        wait_for_selector=args.wait_for_selector or None,\n        require_selector=args.require_selector,\n        settle_seconds=args.settle_seconds,\n    )\n    for key, value in result.items():\n        print(f\"{key}={value}\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
      "parent": "node-12d93ab587",
