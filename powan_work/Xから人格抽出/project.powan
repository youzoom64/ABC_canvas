    {
      "id": "node-9575d22dbe",
      "title": "動画内容確認ポワン",
      "body": "X上の終端投稿に含まれる動画を確認し、動画URLの抽出、動画ファイル保存、代表フレーム抽出、音声文字起こし、LMStudioによる映像内容読解、読解結果と文字起こし結果のDB保存へ振り分ける神経ポワン。本文だけでは分からない動画内の映像・音声・字幕相当の内容も追跡結果としてDBへ残すため、実処理は配下の臓器ポワンに分担させる。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom collections.abc import Callable, Mapping, Sequence\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\n\nJsonMap = dict[str, Any]\nChildHandler = Callable[[JsonMap], Any]\n\n\n@dataclass(frozen=True)\nclass ChildStep:\n    key: str\n    title: str\n\n\nEXTRACT = ChildStep(\"x_video_url_extract\", \"X動画URL抽出ポワン\")\nSAVE_VIDEO = ChildStep(\"video_file_save\", \"動画ファイル保存ポワン\")\nEXTRACT_FRAMES = ChildStep(\"video_frame_extract\", \"動画代表フレーム抽出ポワン\")\nTRANSCRIBE_AUDIO = ChildStep(\"video_audio_transcript\", \"動画音声文字起こしポワン\")\nREAD_VIDEO = ChildStep(\"lmstudio_video_read\", \"LMStudio動画読解ポワン\")\nSAVE_DB = ChildStep(\"video_read_result_db_save\", \"動画読解結果DB保存ポワン\")\n\nPIPELINE_STEPS = (\n    EXTRACT,\n    SAVE_VIDEO,\n    EXTRACT_FRAMES,\n    TRANSCRIBE_AUDIO,\n    READ_VIDEO,\n    SAVE_DB,\n)\n\n\nclass VideoContentFlowError(RuntimeError):\n    def __init__(self, step: ChildStep, message: str, result: Any | None = None):\n        super().__init__(message)\n        self.step = step\n        self.result = result\n\n    def to_dict(self) -> JsonMap:\n        return {\n            \"step\": self.step.key,\n            \"title\": self.step.title,\n            \"message\": str(self),\n            \"result\": self.result,\n        }\n\n\ndef confirm_video_content(\n    input_json: Mapping[str, Any] | None = None,\n    *,\n    child_results: Mapping[str, Any] | None = None,\n    child_handlers: Mapping[str, ChildHandler] | None = None,\n    child_commands: Mapping[str, Any] | None = None,\n    allow_partial: bool = False,\n) -> JsonMap:\n    \"\"\"Orchestrate child powans without implementing their organ work.\"\"\"\n    original_input = dict(input_json or {})\n    precomputed = dict(child_results or {})\n    handlers = dict(child_handlers or {})\n    commands = dict(child_commands or {})\n    steps: list[JsonMap] = []\n    failures: list[JsonMap] = []\n\n    try:\n        extract_result = run_child(\n            EXTRACT,\n            build_extract_input(original_input),\n            child_results=precomputed,\n            child_handlers=handlers,\n            child_commands=commands,\n            steps=steps,\n        )\n        ensure_child_ok(EXTRACT, extract_result)\n\n        save_result = run_child(\n            SAVE_VIDEO,\n            build_save_video_input(original_input, extract_result),\n            child_results=precomputed,\n            child_handlers=handlers,\n            child_commands=commands,\n            steps=steps,\n        )\n        ensure_child_ok(SAVE_VIDEO, save_result)\n    except VideoContentFlowError as exc:\n        failures.append(exc.to_dict())\n        return finish_result(\n            original_input=original_input,\n            child_results={\n                EXTRACT.key: locals().get(\"extract_result\"),\n                SAVE_VIDEO.key: locals().get(\"save_result\"),\n            },\n            media_results=[],\n            save_results=[],\n            steps=steps,\n            failures=failures,\n            allow_partial=allow_partial,\n        )\n\n    media_items = extract_saved_media_items(save_result)\n    if not media_items:\n        failure = VideoContentFlowError(\n            SAVE_VIDEO,\n            \"動画ファイル保存ポワンの結果に保存済み動画がありません\",\n            save_result,\n        )\n        failures.append(failure.to_dict())\n        return finish_result(\n            original_input=original_input,\n            child_results={EXTRACT.key: extract_result, SAVE_VIDEO.key: save_result},\n            media_results=[],\n            save_results=[],\n            steps=steps,\n            failures=failures,\n            allow_partial=allow_partial,\n        )\n\n    media_results: list[JsonMap] = []\n    db_save_results: list[Any] = []\n    for media_number, media in enumerate(media_items, start=1):\n        media_context = build_media_context(\n            original_input,\n            extract_result=extract_result,\n            save_result=save_result,\n            media=media,\n            media_number=media_number,\n        )\n        media_result: JsonMap = {\"mediaNumber\": media_number, \"media\": media, \"childResults\": {}}\n        media_results.append(media_result)\n\n        try:\n            frame_result = run_child(\n                EXTRACT_FRAMES,\n                media_context,\n                child_results=precomputed,\n                child_handlers=handlers,\n                child_commands=commands,\n                steps=steps,\n                media_number=media_number,\n            )\n            ensure_child_ok(EXTRACT_FRAMES, frame_result)\n            media_result[\"childResults\"][EXTRACT_FRAMES.key] = frame_result\n\n            transcript_result = run_child(\n                TRANSCRIBE_AUDIO,\n                media_context,\n                child_results=precomputed,\n                child_handlers=handlers,\n                child_commands=commands,\n                steps=steps,\n                media_number=media_number,\n            )\n            ensure_child_ok(TRANSCRIBE_AUDIO, transcript_result)\n            media_result[\"childResults\"][TRANSCRIBE_AUDIO.key] = transcript_result\n\n            read_payload = build_read_input(\n                media_context,\n                frame_result=frame_result,\n                transcript_result=transcript_result,\n            )\n            read_result = run_child(\n                READ_VIDEO,\n                read_payload,\n                child_results=precomputed,\n                child_handlers=handlers,\n                child_commands=commands,\n                steps=steps,\n                media_number=media_number,\n            )\n            ensure_child_ok(READ_VIDEO, read_result)\n            media_result[\"childResults\"][READ_VIDEO.key] = read_result\n\n            db_payload = build_db_save_input(\n                media_context,\n                frame_result=frame_result,\n                transcript_result=transcript_result,\n                read_result=read_result,\n            )\n            db_result = run_child(\n                SAVE_DB,\n                db_payload,\n                child_results=precomputed,\n                child_handlers=handlers,\n                child_commands=commands,\n                steps=steps,\n                media_number=media_number,\n            )\n            ensure_child_ok(SAVE_DB, db_result)\n            media_result[\"childResults\"][SAVE_DB.key] = db_result\n            db_save_results.append(db_result)\n        except VideoContentFlowError as exc:\n            failure = exc.to_dict()\n            failure[\"mediaNumber\"] = media_number\n            failures.append(failure)\n            media_result[\"failure\"] = failure\n            if not allow_partial:\n                break\n\n    return finish_result(\n        original_input=original_input,\n        child_results={EXTRACT.key: extract_result, SAVE_VIDEO.key: save_result},\n        media_results=media_results,\n        save_results=db_save_results,\n        steps=steps,\n        failures=failures,\n        allow_partial=allow_partial,\n    )\n\n\ndef run_child(\n    step: ChildStep,\n    payload: JsonMap,\n    *,\n    child_results: Mapping[str, Any],\n    child_handlers: Mapping[str, ChildHandler],\n    child_commands: Mapping[str, Any],\n    steps: list[JsonMap],\n    media_number: int | None = None,\n) -> Any:\n    cached, cache_key = lookup_by_step(child_results, step)\n    if cached is not _MISSING:\n        steps.append(step_record(step, media_number, \"precomputed\", True, cache_key=cache_key))\n        return cached\n\n    handler, handler_key = lookup_by_step(child_handlers, step)\n    if handler is not _MISSING:\n        try:\n            result = handler(payload)\n        except Exception as exc:\n            steps.append(step_record(step, media_number, \"handler\", False, error=str(exc)))\n            raise VideoContentFlowError(step, f\"{step.title} handler failed: {exc}\") from exc\n        steps.append(step_record(step, media_number, \"handler\", child_result_ok(result), handler_key=handler_key))\n        return result\n\n    command, command_key = lookup_by_step(child_commands, step)\n    if command is not _MISSING:\n        result = run_child_command(command, payload, step)\n        steps.append(step_record(step, media_number, \"command\", child_result_ok(result), command_key=command_key))\n        return result\n\n    steps.append(step_record(step, media_number, \"missing\", False))\n    raise VideoContentFlowError(\n        step,\n        f\"{step.title} を呼ぶ handler / command / precomputed result がありません\",\n    )\n\n\n_MISSING = object()\n\n\ndef lookup_by_step(values: Mapping[str, Any], step: ChildStep) -> tuple[Any, str]:\n    for key in (step.key, step.title):\n        if key in values:\n            return values[key], key\n    return _MISSING, \"\"\n\n\ndef run_child_command(command: Any, payload: JsonMap, step: ChildStep) -> Any:\n    stdin = json.dumps(payload, ensure_ascii=False)\n    if isinstance(command, str):\n        completed = subprocess.run(\n            command,\n            input=stdin,\n            text=True,\n            capture_output=True,\n            shell=True,\n            check=False,\n        )\n    elif isinstance(command, Sequence):\n        completed = subprocess.run(\n            [str(part) for part in command],\n            input=stdin,\n            text=True,\n            capture_output=True,\n            check=False,\n        )\n    else:\n        raise VideoContentFlowError(step, f\"{step.title} command must be a string or list\")\n\n    parsed = parse_json_output(completed.stdout)\n    if completed.returncode != 0:\n        if isinstance(parsed, dict):\n            parsed.setdefault(\"ok\", False)\n            parsed.setdefault(\"error\", (completed.stderr or \"\").strip())\n            parsed[\"_childProcess\"] = {\"returncode\": completed.returncode, \"stderr\": completed.stderr}\n            return parsed\n        raise VideoContentFlowError(\n            step,\n            f\"{step.title} command failed with exit code {completed.returncode}: {completed.stderr.strip()}\",\n        )\n    if parsed is _MISSING:\n        raise VideoContentFlowError(step, f\"{step.title} command did not print JSON\")\n    return parsed\n\n\ndef parse_json_output(text: str) -> Any:\n    clean = (text or \"\").strip()\n    if not clean:\n        return _MISSING\n    try:\n        return json.loads(clean)\n    except json.JSONDecodeError:\n        pass\n    start = clean.find(\"{\")\n    end = clean.rfind(\"}\")\n    if 0 <= start < end:\n        try:\n            return json.loads(clean[start : end + 1])\n        except json.JSONDecodeError:\n            return _MISSING\n    return _MISSING\n\n\ndef ensure_child_ok(step: ChildStep, result: Any) -> None:\n    if not child_result_ok(result):\n        raise VideoContentFlowError(step, child_error_message(step, result), result)\n\n\ndef child_result_ok(result: Any) -> bool:\n    if isinstance(result, Mapping):\n        if result.get(\"ok\") is False:\n            return False\n        error = result.get(\"error\")\n        if error and result.get(\"ok\") is not True:\n            return False\n    return True\n\n\ndef child_error_message(step: ChildStep, result: Any) -> str:\n    if isinstance(result, Mapping):\n        for key in (\"error\", \"message\", \"reason\"):\n            value = result.get(key)\n            if value:\n                return f\"{step.title} failed: {value}\"\n    return f\"{step.title} failed\"\n\n\ndef build_extract_input(original_input: JsonMap) -> JsonMap:\n    return {\"input\": original_input, \"post\": original_input.get(\"post\", original_input)}\n\n\ndef build_save_video_input(original_input: JsonMap, extract_result: Any) -> JsonMap:\n    return {\n        \"input\": original_input,\n        \"video_url_extract_result\": extract_result,\n        \"videos\": mapping_get(extract_result, \"videos\", []),\n    }\n\n\ndef build_media_context(\n    original_input: JsonMap,\n    *,\n    extract_result: Any,\n    save_result: Any,\n    media: JsonMap,\n    media_number: int,\n) -> JsonMap:\n    return {\n        \"input\": original_input,\n        \"mediaNumber\": media_number,\n        \"video_url_extract_result\": extract_result,\n        \"video_save_result\": save_result,\n        \"media_asset\": media,\n        \"video\": media,\n    }\n\n\ndef build_read_input(media_context: JsonMap, *, frame_result: Any, transcript_result: Any) -> JsonMap:\n    return {\n        **media_context,\n        \"frame_extract_result\": frame_result,\n        \"frames_result\": frame_result,\n        \"transcript_result\": transcript_result,\n        \"audio_transcript_result\": transcript_result,\n    }\n\n\ndef build_db_save_input(\n    media_context: JsonMap,\n    *,\n    frame_result: Any,\n    transcript_result: Any,\n    read_result: Any,\n) -> JsonMap:\n    media = dict(media_context.get(\"media_asset\") or {})\n    return {\n        **media_context,\n        \"media_asset\": media,\n        \"video_save_result\": media,\n        \"frame_result\": frame_result,\n        \"frame_extract_result\": frame_result,\n        \"transcript_result\": transcript_result,\n        \"audio_transcript_result\": transcript_result,\n        \"analysis_result\": read_result,\n        \"lmstudio_result\": read_result,\n    }\n\n\ndef extract_saved_media_items(save_result: Any) -> list[JsonMap]:\n    if isinstance(save_result, list):\n        return [item for item in save_result if isinstance(item, dict)]\n    if not isinstance(save_result, Mapping):\n        return []\n    for key in (\"videos\", \"saved\", \"items\", \"results\", \"media\"):\n        value = save_result.get(key)\n        if isinstance(value, list):\n            return [dict(item) for item in value if isinstance(item, Mapping)]\n    if any(key in save_result for key in (\"local_path\", \"localPath\", \"path\", \"savedPath\", \"source_url\")):\n        return [dict(save_result)]\n    return []\n\n\ndef mapping_get(value: Any, key: str, default: Any = None) -> Any:\n    if isinstance(value, Mapping):\n        return value.get(key, default)\n    return default\n\n\ndef step_record(\n    step: ChildStep,\n    media_number: int | None,\n    source: str,\n    ok: bool,\n    **extra: Any,\n) -> JsonMap:\n    record = {\"step\": step.key, \"title\": step.title, \"source\": source, \"ok\": bool(ok)}\n    if media_number is not None:\n        record[\"mediaNumber\"] = media_number\n    record.update({key: value for key, value in extra.items() if value not in (\"\", None)})\n    return record\n\n\ndef finish_result(\n    *,\n    original_input: JsonMap,\n    child_results: JsonMap,\n    media_results: list[JsonMap],\n    save_results: list[Any],\n    steps: list[JsonMap],\n    failures: list[JsonMap],\n    allow_partial: bool,\n) -> JsonMap:\n    ok = not failures and bool(save_results or not media_results)\n    partial_ok = allow_partial and bool(save_results)\n    return {\n        \"ok\": ok or partial_ok,\n        \"partial\": bool(failures and save_results),\n        \"input\": original_input,\n        \"childResults\": child_results,\n        \"mediaResults\": media_results,\n        \"failureReason\": failures[0] if failures else None,\n        \"failures\": failures,\n        \"saveResult\": save_results,\n        \"steps\": steps,\n    }\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        text = sys.stdin.read()\n        return json.loads(text) if text.strip() else {}\n    candidate = Path(value)\n    if candidate.exists():\n        return json.loads(candidate.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef parse_args(argv: list[str]) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Orchestrate X video content confirmation child powans.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"Input JSON, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results\", default=\"\", help=\"Precomputed child result JSON or file path.\")\n    parser.add_argument(\"--child-commands\", default=\"\", help=\"Child command mapping JSON or file path.\")\n    parser.add_argument(\"--allow-partial\", action=\"store_true\")\n    parser.add_argument(\"--indent\", type=int, default=2)\n    return parser.parse_args(argv)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = parse_args(argv or sys.argv[1:])\n    result = confirm_video_content(\n        load_json_arg(args.input_json),\n        child_results=load_json_arg(args.child_results) if args.child_results else None,\n        child_commands=load_json_arg(args.child_commands) if args.child_commands else None,\n        allow_partial=args.allow_partial,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
