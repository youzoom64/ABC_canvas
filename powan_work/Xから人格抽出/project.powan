    {
      "id": "node-de37593461",
      "title": "YouTube内容確認ポワン",
      "body": "終端投稿にYouTubeリンクやYouTubeカードが含まれている時、そのYouTube動画を確認対象として扱う神経ポワン。X終端投稿からYouTube URLを抽出し、既存のAPI scripts材料を使って字幕、動画保存、音声文字起こし、代表フレーム、コメントを取得し、最後にDBへ保存する流れを束ねる。本文だけではなく、字幕・映像・音声・コメントなど確認した材料をすべて保存対象にする。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom collections.abc import Callable, Mapping\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nURL_EXTRACTOR = \"YouTube URL抽出ポワン\"\nSUBTITLE_FETCHER = \"YouTube字幕取得ポワン\"\nVIDEO_SAVER = \"YouTube動画保存ポワン\"\nTRANSCRIBER = \"YouTube音声文字起こしポワン\"\nFRAME_EXTRACTOR = \"YouTube代表フレーム抽出ポワン\"\nCOMMENT_FETCHER = \"YouTubeコメント取得ポワン\"\nDB_SAVER = \"YouTube内容DB保存ポワン\"\n\nPIPELINE = [\n    URL_EXTRACTOR,\n    SUBTITLE_FETCHER,\n    VIDEO_SAVER,\n    TRANSCRIBER,\n    FRAME_EXTRACTOR,\n    COMMENT_FETCHER,\n    DB_SAVER,\n]\n\nDEFAULT_OPTIONS = {\n    \"minSubtitleChars\": 80,\n    \"saveFailures\": True,\n    \"strictMissingRunners\": False,\n}\n\nChildRunner = Callable[[dict[str, Any]], Any]\n\n\n@dataclass\nclass ChildCall:\n    title: str\n    input: dict[str, Any]\n    status: str\n    ok: bool\n    result: Any = None\n    failure_reason: str = \"\"\n\n    def as_dict(self) -> dict[str, Any]:\n        return {\n            \"title\": self.title,\n            \"status\": self.status,\n            \"ok\": self.ok,\n            \"input\": self.input,\n            \"result\": self.result,\n            \"failureReason\": self.failure_reason,\n        }\n\n\ndef confirm_youtube_content(\n    input_json: Any,\n    *,\n    child_runners: Mapping[str, ChildRunner] | None = None,\n    child_results: Mapping[str, Any] | list[Any] | None = None,\n    options: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    \"\"\"Orchestrate child powans for checking YouTube content from an X terminal post.\n\n    This nerve powan does not download subtitles, videos, frames, comments, or write\n    SQLite rows by itself. Pass child_runners to execute child organs, or pass\n    child_results when those organs were already executed elsewhere.\n    \"\"\"\n    opts = {**DEFAULT_OPTIONS, **dict(options or {})}\n    runners = dict(child_runners or {})\n    precomputed = normalize_child_results(child_results)\n    original_input = normalize_input(input_json)\n    children: dict[str, dict[str, Any]] = {}\n    failures: list[dict[str, Any]] = []\n\n    def remember(call: ChildCall) -> dict[str, Any]:\n        data = call.as_dict()\n        children[call.title] = data\n        if not call.ok and call.failure_reason:\n            failures.append({\"child\": call.title, \"reason\": call.failure_reason})\n        return data\n\n    url_call = remember(run_child(URL_EXTRACTOR, build_child_input(URL_EXTRACTOR, original_input), runners, precomputed, opts))\n    url_context = extract_url_context(url_call.get(\"result\"))\n\n    if not url_context.get(\"url\"):\n        if not url_call.get(\"failureReason\"):\n            failures.append({\"child\": URL_EXTRACTOR, \"reason\": \"No YouTube URL was returned by the URL extraction child.\"})\n        db_payload = build_db_payload(original_input, url_context, children, failures, \"none\", False)\n        save_result = maybe_save(db_payload, runners, precomputed, opts, children, failures)\n        return build_final_result(\n            original_input,\n            url_context,\n            children,\n            failures,\n            save_result,\n            status=\"no_youtube_url\",\n            primary_evidence=\"none\",\n            subtitle_adequate=False,\n        )\n\n    subtitle_input = build_child_input(SUBTITLE_FETCHER, original_input, url_context=url_context, previous=children)\n    subtitle_call = remember(run_child(SUBTITLE_FETCHER, subtitle_input, runners, precomputed, opts))\n    subtitle_adequate = has_usable_subtitle(subtitle_call.get(\"result\"), opts)\n\n    primary_evidence = \"subtitle\" if subtitle_adequate else \"none\"\n    video_call: dict[str, Any] | None = None\n    transcript_call: dict[str, Any] | None = None\n    frame_call: dict[str, Any] | None = None\n\n    if not subtitle_adequate:\n        failures.append({\"child\": SUBTITLE_FETCHER, \"reason\": \"Subtitle was missing or too short for first evidence.\"})\n        video_input = build_child_input(VIDEO_SAVER, original_input, url_context=url_context, previous=children)\n        video_call = remember(run_child(VIDEO_SAVER, video_input, runners, precomputed, opts))\n        video_context = extract_video_context(video_call.get(\"result\"))\n\n        if child_call_ok(video_call) and video_context.get(\"localPath\"):\n            transcript_input = build_child_input(\n                TRANSCRIBER,\n                original_input,\n                url_context=url_context,\n                previous=children,\n                extra={\"video\": video_context},\n            )\n            transcript_call = remember(run_child(TRANSCRIBER, transcript_input, runners, precomputed, opts))\n            if has_usable_transcript(transcript_call.get(\"result\"), opts):\n                primary_evidence = \"transcript\"\n            else:\n                failures.append({\"child\": TRANSCRIBER, \"reason\": \"Transcript was missing or not usable.\"})\n\n            frame_input = build_child_input(\n                FRAME_EXTRACTOR,\n                original_input,\n                url_context=url_context,\n                previous=children,\n                extra={\"video\": video_context},\n            )\n            frame_call = remember(run_child(FRAME_EXTRACTOR, frame_input, runners, precomputed, opts))\n        else:\n            reason = video_call.get(\"failureReason\") if video_call else \"Video was not saved.\"\n            failures.append({\"child\": VIDEO_SAVER, \"reason\": reason or \"Video was not saved.\"})\n            remember(skipped_child(TRANSCRIBER, \"Video save result did not provide a local video path.\", original_input, url_context, children))\n            remember(skipped_child(FRAME_EXTRACTOR, \"Video save result did not provide a local video path.\", original_input, url_context, children))\n\n    comments_input = build_child_input(COMMENT_FETCHER, original_input, url_context=url_context, previous=children)\n    remember(run_child(COMMENT_FETCHER, comments_input, runners, precomputed, opts))\n\n    db_payload = build_db_payload(original_input, url_context, children, failures, primary_evidence, subtitle_adequate)\n    save_result = maybe_save(db_payload, runners, precomputed, opts, children, failures)\n    status = choose_status(url_context, primary_evidence, children, save_result)\n    return build_final_result(\n        original_input,\n        url_context,\n        children,\n        failures,\n        save_result,\n        status=status,\n        primary_evidence=primary_evidence,\n        subtitle_adequate=subtitle_adequate,\n    )\n\n\ndef build_child_input(\n    child_title: str,\n    original_input: dict[str, Any],\n    *,\n    url_context: Mapping[str, Any] | None = None,\n    previous: Mapping[str, Any] | None = None,\n    extra: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    youtube = dict(url_context or {})\n    payload: dict[str, Any] = {\n        \"sourcePowan\": \"YouTube内容確認ポワン\",\n        \"childTitle\": child_title,\n        \"input\": original_input,\n        \"youtube\": youtube,\n        \"url\": youtube.get(\"url\") or youtube.get(\"normalizedUrl\") or \"\",\n        \"normalizedUrl\": youtube.get(\"normalizedUrl\") or youtube.get(\"url\") or \"\",\n        \"videoId\": youtube.get(\"videoId\") or youtube.get(\"video_id\") or \"\",\n        \"video_id\": youtube.get(\"video_id\") or youtube.get(\"videoId\") or \"\",\n        \"postId\": youtube.get(\"postId\") or original_input.get(\"postId\") or original_input.get(\"post_id\"),\n        \"post_id\": youtube.get(\"post_id\") or original_input.get(\"post_id\") or original_input.get(\"postId\"),\n        \"mediaIndex\": youtube.get(\"mediaIndex\") or original_input.get(\"mediaIndex\") or original_input.get(\"media_index\"),\n        \"media_index\": youtube.get(\"media_index\") or original_input.get(\"media_index\") or original_input.get(\"mediaIndex\"),\n        \"previousChildren\": previous or {},\n    }\n    if extra:\n        payload.update(dict(extra))\n    return json_safe(payload)\n\n\ndef run_child(\n    title: str,\n    child_input: dict[str, Any],\n    runners: Mapping[str, ChildRunner],\n    precomputed: Mapping[str, Any],\n    options: Mapping[str, Any],\n) -> ChildCall:\n    if title in precomputed:\n        result = precomputed[title]\n        return ChildCall(title=title, input=child_input, status=\"precomputed\", ok=result_looks_ok(result), result=json_safe(result), failure_reason=extract_failure_reason(result))\n\n    runner = runners.get(title)\n    if runner is None:\n        reason = \"No child runner or precomputed child result was supplied.\"\n        return ChildCall(\n            title=title,\n            input=child_input,\n            status=\"missing_runner\" if options.get(\"strictMissingRunners\") else \"skipped\",\n            ok=False,\n            result=None,\n            failure_reason=reason,\n        )\n\n    try:\n        result = runner(child_input)\n    except Exception as exc:  # child organ failure is reported, not hidden\n        return ChildCall(title=title, input=child_input, status=\"error\", ok=False, result=None, failure_reason=str(exc) or exc.__class__.__name__)\n\n    return ChildCall(title=title, input=child_input, status=\"completed\", ok=result_looks_ok(result), result=json_safe(result), failure_reason=extract_failure_reason(result))\n\n\ndef skipped_child(\n    title: str,\n    reason: str,\n    original_input: dict[str, Any],\n    url_context: Mapping[str, Any],\n    previous: Mapping[str, Any],\n) -> ChildCall:\n    return ChildCall(\n        title=title,\n        input=build_child_input(title, original_input, url_context=url_context, previous=previous),\n        status=\"skipped\",\n        ok=False,\n        result=None,\n        failure_reason=reason,\n    )\n\n\ndef maybe_save(\n    db_payload: dict[str, Any],\n    runners: Mapping[str, ChildRunner],\n    precomputed: Mapping[str, Any],\n    options: Mapping[str, Any],\n    children: dict[str, dict[str, Any]],\n    failures: list[dict[str, Any]],\n) -> dict[str, Any]:\n    if not options.get(\"saveFailures\", True) and db_payload.get(\"failures\"):\n        call = ChildCall(DB_SAVER, db_payload, \"skipped\", False, None, \"saveFailures is false and the pipeline has failures.\")\n    else:\n        call = run_child(DB_SAVER, db_payload, runners, precomputed, options)\n    data = call.as_dict()\n    children[DB_SAVER] = data\n    if not call.ok and call.failure_reason:\n        failures.append({\"child\": DB_SAVER, \"reason\": call.failure_reason})\n    return data\n\n\ndef build_db_payload(\n    original_input: dict[str, Any],\n    url_context: Mapping[str, Any],\n    children: Mapping[str, Any],\n    failures: list[dict[str, Any]],\n    primary_evidence: str,\n    subtitle_adequate: bool,\n) -> dict[str, Any]:\n    return json_safe(\n        {\n            \"sourcePowan\": \"YouTube内容確認ポワン\",\n            \"input\": original_input,\n            \"youtube\": dict(url_context),\n            \"primaryEvidence\": primary_evidence,\n            \"subtitleAdequate\": subtitle_adequate,\n            \"commentsRole\": \"surrounding_context\",\n            \"childResults\": children,\n            \"failures\": failures,\n        }\n    )\n\n\ndef build_final_result(\n    original_input: dict[str, Any],\n    url_context: Mapping[str, Any],\n    children: Mapping[str, Any],\n    failures: list[dict[str, Any]],\n    save_result: Mapping[str, Any],\n    *,\n    status: str,\n    primary_evidence: str,\n    subtitle_adequate: bool,\n) -> dict[str, Any]:\n    db_ok = child_call_ok(save_result)\n    enough_evidence = primary_evidence in {\"subtitle\", \"transcript\"}\n    ok = bool(url_context.get(\"url\")) and enough_evidence and db_ok\n    return json_safe(\n        {\n            \"ok\": ok,\n            \"status\": status,\n            \"input\": original_input,\n            \"youtube\": dict(url_context),\n            \"primaryEvidence\": primary_evidence,\n            \"subtitleAdequate\": subtitle_adequate,\n            \"childResults\": children,\n            \"failures\": failures,\n            \"failureReason\": summarize_failures(failures),\n            \"saveResult\": save_result,\n        }\n    )\n\n\ndef choose_status(\n    url_context: Mapping[str, Any],\n    primary_evidence: str,\n    children: Mapping[str, Any],\n    save_result: Mapping[str, Any],\n) -> str:\n    if not url_context.get(\"url\"):\n        return \"no_youtube_url\"\n    if not child_call_ok(save_result):\n        return \"save_failed\"\n    if primary_evidence == \"subtitle\":\n        return \"saved_with_subtitle_primary\"\n    if primary_evidence == \"transcript\":\n        return \"saved_with_transcript_primary\"\n    if children.get(DB_SAVER, {}).get(\"status\") in {\"skipped\", \"missing_runner\"}:\n        return \"needs_db_save_child\"\n    return \"insufficient_evidence_saved\"\n\n\ndef normalize_input(value: Any) -> dict[str, Any]:\n    if value is None:\n        return {}\n    if isinstance(value, Mapping):\n        return json_safe(dict(value))\n    if isinstance(value, str):\n        return {\"text\": value}\n    return {\"value\": json_safe(value)}\n\n\ndef normalize_child_results(value: Mapping[str, Any] | list[Any] | None) -> dict[str, Any]:\n    if value is None:\n        return {}\n    if isinstance(value, Mapping):\n        if isinstance(value.get(\"childResults\"), Mapping):\n            return dict(value[\"childResults\"])\n        if isinstance(value.get(\"children\"), Mapping):\n            return dict(value[\"children\"])\n        return dict(value)\n    if isinstance(value, list):\n        results: dict[str, Any] = {}\n        for item in value:\n            if not isinstance(item, Mapping):\n                continue\n            title = str(item.get(\"title\") or item.get(\"childTitle\") or item.get(\"name\") or \"\")\n            if title:\n                results[title] = dict(item)\n        return results\n    return {}\n\n\ndef extract_url_context(result: Any) -> dict[str, Any]:\n    data = unwrap_result(result)\n    first_found = first_mapping(data.get(\"foundUrls\") if isinstance(data, Mapping) else None)\n    url = first_text(data, \"normalizedUrl\", \"canonicalUrl\", \"url\") or first_text(first_found, \"normalizedUrl\", \"canonicalUrl\", \"url\")\n    video_id = first_text(data, \"videoId\", \"video_id\") or first_text(first_found, \"videoId\", \"video_id\")\n    return {\n        \"url\": url,\n        \"normalizedUrl\": first_text(data, \"normalizedUrl\", \"canonicalUrl\") or url,\n        \"originalUrl\": first_text(data, \"url\", \"originalUrl\") or url,\n        \"videoId\": video_id,\n        \"video_id\": video_id,\n        \"postId\": first_text(data, \"postId\", \"post_id\"),\n        \"post_id\": first_text(data, \"post_id\", \"postId\"),\n        \"mediaIndex\": first_value(data, \"mediaIndex\", \"media_index\"),\n        \"media_index\": first_value(data, \"media_index\", \"mediaIndex\"),\n        \"sourceText\": first_text(data, \"sourceText\", \"source_text\"),\n    }\n\n\ndef extract_video_context(result: Any) -> dict[str, Any]:\n    data = unwrap_result(result)\n    local_path = first_text(data, \"localPath\", \"local_path\", \"filePath\", \"path\", \"savedPath\", \"videoPath\")\n    return {\n        \"localPath\": local_path,\n        \"path\": local_path,\n        \"videoId\": first_text(data, \"videoId\", \"video_id\"),\n        \"url\": first_text(data, \"url\", \"canonicalUrl\", \"normalizedUrl\"),\n        \"bytes\": first_value(data, \"bytes\", \"byteCount\", \"size\"),\n        \"sha256\": first_text(data, \"sha256\"),\n    }\n\n\ndef has_usable_subtitle(result: Any, options: Mapping[str, Any]) -> bool:\n    data = unwrap_result(result)\n    if not result_looks_ok(data):\n        return False\n    if truthy_flag(data, \"insufficient\", \"isInsufficient\", \"subtitleInsufficient\"):\n        return False\n    min_chars = int(options.get(\"minSubtitleChars\") or 0)\n    text = joined_text(data, \"subtitleText\", \"subtitle_text\", \"text\", \"transcript\", \"content\", \"body\")\n    if len(text.strip()) >= min_chars:\n        return True\n    if non_empty_list(data, \"segments\", \"subtitles\", \"captions\"):\n        return True\n    if first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\") or non_empty_list(data, \"savedPaths\", \"files\"):\n        return True\n    return False\n\n\ndef has_usable_transcript(result: Any, options: Mapping[str, Any]) -> bool:\n    data = unwrap_result(result)\n    if not result_looks_ok(data):\n        return False\n    min_chars = int(options.get(\"minTranscriptChars\") or options.get(\"minSubtitleChars\") or 0)\n    text = joined_text(data, \"transcript\", \"transcriptText\", \"text\", \"content\", \"body\")\n    if len(text.strip()) >= min_chars:\n        return True\n    if non_empty_list(data, \"segments\", \"utterances\"):\n        return True\n    return bool(first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\"))\n\n\ndef result_looks_ok(result: Any) -> bool:\n    data = unwrap_result(result)\n    if isinstance(data, Mapping):\n        ok = data.get(\"ok\")\n        if isinstance(ok, bool):\n            return ok\n        status = str(data.get(\"status\") or data.get(\"state\") or \"\").lower()\n        if status in {\"ok\", \"success\", \"succeeded\", \"completed\", \"precomputed\", \"saved\"}:\n            return True\n        if status in {\"error\", \"failed\", \"failure\", \"skipped\", \"missing_runner\"}:\n            return False\n        if extract_failure_reason(data):\n            return False\n        return bool(data)\n    return data is not None\n\n\ndef child_call_ok(call: Mapping[str, Any] | None) -> bool:\n    if not call:\n        return False\n    ok = call.get(\"ok\")\n    return bool(ok)\n\n\ndef extract_failure_reason(result: Any) -> str:\n    data = unwrap_result(result)\n    if isinstance(data, Mapping):\n        for key in (\"failureReason\", \"failure_reason\", \"error\", \"reason\", \"message\"):\n            value = data.get(key)\n            if value:\n                return str(value)\n    return \"\"\n\n\ndef summarize_failures(failures: list[dict[str, Any]]) -> str:\n    if not failures:\n        return \"\"\n    parts = []\n    for item in failures:\n        child = item.get(\"child\") or \"unknown\"\n        reason = item.get(\"reason\") or \"failed\"\n        parts.append(f\"{child}: {reason}\")\n    return \"; \".join(parts)\n\n\ndef unwrap_result(value: Any) -> Any:\n    current = value\n    for _ in range(3):\n        if isinstance(current, Mapping) and \"result\" in current and set(current.keys()) & {\"title\", \"status\", \"ok\", \"input\"}:\n            current = current.get(\"result\")\n            continue\n        break\n    if isinstance(current, Mapping):\n        return current\n    return current\n\n\ndef first_mapping(value: Any) -> Mapping[str, Any]:\n    if isinstance(value, list):\n        for item in value:\n            if isinstance(item, Mapping):\n                return item\n    if isinstance(value, Mapping):\n        return value\n    return {}\n\n\ndef first_value(data: Any, *keys: str) -> Any:\n    if not isinstance(data, Mapping):\n        return None\n    for key in keys:\n        value = data.get(key)\n        if value not in (None, \"\"):\n            return value\n    return None\n\n\ndef first_text(data: Any, *keys: str) -> str:\n    value = first_value(data, *keys)\n    if value is None:\n        return \"\"\n    return str(value).strip()\n\n\ndef joined_text(data: Any, *keys: str) -> str:\n    if not isinstance(data, Mapping):\n        return \"\"\n    chunks: list[str] = []\n    for key in keys:\n        value = data.get(key)\n        if isinstance(value, str):\n            chunks.append(value)\n        elif isinstance(value, list):\n            chunks.extend(str(item.get(\"text\") if isinstance(item, Mapping) else item) for item in value)\n    return \"\\n\".join(part for part in chunks if part)\n\n\ndef non_empty_list(data: Any, *keys: str) -> bool:\n    if not isinstance(data, Mapping):\n        return False\n    for key in keys:\n        value = data.get(key)\n        if isinstance(value, list) and len(value) > 0:\n            return True\n    return False\n\n\ndef truthy_flag(data: Any, *keys: str) -> bool:\n    if not isinstance(data, Mapping):\n        return False\n    return any(bool(data.get(key)) for key in keys)\n\n\ndef json_safe(value: Any) -> Any:\n    if isinstance(value, Mapping):\n        return {str(key): json_safe(item) for key, item in value.items()}\n    if isinstance(value, list):\n        return [json_safe(item) for item in value]\n    if isinstance(value, tuple):\n        return [json_safe(item) for item in value]\n    if isinstance(value, Path):\n        return str(value)\n    if isinstance(value, (str, int, float, bool)) or value is None:\n        return value\n    return str(value)\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value:\n        return {}\n    if value == \"-\":\n        raw = sys.stdin.read()\n        return json.loads(raw) if raw.strip() else {}\n    path = Path(value)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Orchestrate YouTube content confirmation child powans.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results\", default=\"\", help=\"Precomputed child result JSON string or file path.\")\n    parser.add_argument(\"--min-subtitle-chars\", type=int, default=80)\n    parser.add_argument(\"--no-save-failures\", action=\"store_true\")\n    parser.add_argument(\"--strict-missing-runners\", action=\"store_true\")\n    parser.add_argument(\"--indent\", type=int, default=2)\n    args = parser.parse_args(argv)\n\n    payload = load_json_arg(args.input_json)\n    child_results = load_json_arg(args.child_results) if args.child_results else None\n    result = confirm_youtube_content(\n        payload,\n        child_results=child_results,\n        options={\n            \"minSubtitleChars\": args.min_subtitle_chars,\n            \"saveFailures\": not args.no_save_failures,\n            \"strictMissingRunners\": args.strict_missing_runners,\n        },\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
