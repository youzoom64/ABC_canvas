    {
      "id": "node-592fce33f8",
      "title": "動画ファイル保存ポワン",
      "body": "X動画URL抽出ポワンの結果を受け取り、取得可能な動画URLから動画ファイルをローカルへ保存する臓器ポワン。保存先、sha256、mime、拡張子、bytes、duration、width、height、local_path、source_url、post_id、media_indexを返し、DB保存や内容読解は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport mimetypes\nimport os\nimport shutil\nimport subprocess\nimport sys\nimport time\nimport urllib.error\nimport urllib.parse\nimport urllib.request\nimport uuid\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\n\nDEFAULT_OUT_DIR = \"./data/x_media/videos\"\nDEFAULT_USER_AGENT = (\n    \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) \"\n    \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n    \"Chrome/126.0 Safari/537.36\"\n)\nVIDEO_EXTS = {\"mp4\", \"m4v\", \"mov\", \"webm\", \"ts\", \"mkv\", \"avi\"}\nHLS_EXTS = {\"m3u8\"}\nCONTENT_TYPE_EXT = {\n    \"video/mp4\": \"mp4\",\n    \"video/quicktime\": \"mov\",\n    \"video/webm\": \"webm\",\n    \"video/x-m4v\": \"m4v\",\n    \"video/mp2t\": \"ts\",\n    \"application/vnd.apple.mpegurl\": \"m3u8\",\n    \"application/x-mpegurl\": \"m3u8\",\n    \"audio/mpegurl\": \"m3u8\",\n}\nCONTAINER_BOXES = {\n    \"moov\",\n    \"trak\",\n    \"mdia\",\n    \"minf\",\n    \"stbl\",\n    \"edts\",\n    \"dinf\",\n    \"udta\",\n    \"meta\",\n}\n\n\nclass CandidateError(RuntimeError):\n    pass\n\n\n@dataclass\nclass VideoInput:\n    entry: dict[str, Any]\n    post_id: Any\n    media_index: Any\n    urls: list[str]\n\n\n@dataclass\nclass DownloadedFile:\n    path: Path\n    source_url: str\n    response_mime: str | None\n    final_url: str\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(\n        description=\"Download X video URL extraction results into local video files.\"\n    )\n    parser.add_argument(\"--input\", default=\"\", help=\"JSON file path. Defaults to stdin.\")\n    parser.add_argument(\"--out-dir\", default=DEFAULT_OUT_DIR)\n    parser.add_argument(\"--timeout\", type=float, default=30.0)\n    parser.add_argument(\"--ffmpeg-timeout\", type=float, default=180.0)\n    parser.add_argument(\"--max-bytes\", type=int, default=0, help=\"0 means unlimited.\")\n    parser.add_argument(\"--user-agent\", default=DEFAULT_USER_AGENT)\n    parser.add_argument(\"--indent\", type=int, default=2)\n    args = parser.parse_args(argv)\n\n    payload = load_json_payload(args.input)\n    out_dir = Path(args.out_dir)\n    out_dir.mkdir(parents=True, exist_ok=True)\n\n    videos = collect_video_inputs(payload)\n    saved: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n\n    for item_number, video in enumerate(videos):\n        if not video.urls:\n            errors.append(\n                {\n                    \"post_id\": video.post_id,\n                    \"media_index\": video.media_index,\n                    \"error\": \"no sourceUrl or candidateUrls were found\",\n                }\n            )\n            continue\n        try:\n            saved.append(save_first_available_video(video, out_dir, args))\n        except CandidateError as exc:\n            errors.append(\n                {\n                    \"post_id\": video.post_id,\n                    \"media_index\": video.media_index,\n                    \"error\": str(exc),\n                    \"candidate_count\": len(video.urls),\n                    \"item_number\": item_number,\n                }\n            )\n\n    result = {\n        \"ok\": not errors,\n        \"videos\": saved,\n        \"errors\": errors,\n        \"input_count\": len(videos),\n        \"saved_count\": len(saved),\n    }\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if saved or not errors else 1\n\n\ndef load_json_payload(input_path: str) -> Any:\n    if input_path:\n        return json.loads(Path(input_path).read_text(encoding=\"utf-8\"))\n    raw = sys.stdin.read()\n    if not raw.strip():\n        return {}\n    return json.loads(raw)\n\n\ndef collect_video_inputs(payload: Any) -> list[VideoInput]:\n    records = list(find_video_records(payload, inherited_post_id=None))\n    if not records and isinstance(payload, dict) and payload:\n        records = [(payload, payload.get(\"post_id\") or payload.get(\"postId\"))]\n\n    videos: list[VideoInput] = []\n    for index, (entry, inherited_post_id) in enumerate(records):\n        post_id = (\n            entry.get(\"post_id\")\n            or entry.get(\"postId\")\n            or entry.get(\"tweet_id\")\n            or entry.get(\"tweetId\")\n            or inherited_post_id\n        )\n        media_index = (\n            entry.get(\"media_index\")\n            if \"media_index\" in entry\n            else entry.get(\"mediaIndex\", entry.get(\"index\", index))\n        )\n        urls = collect_candidate_urls(entry)\n        videos.append(VideoInput(entry=entry, post_id=post_id, media_index=media_index, urls=urls))\n    return videos\n\n\ndef find_video_records(payload: Any, inherited_post_id: Any) -> list[tuple[dict[str, Any], Any]]:\n    if isinstance(payload, list):\n        records: list[tuple[dict[str, Any], Any]] = []\n        for item in payload:\n            records.extend(find_video_records(item, inherited_post_id))\n        return records\n\n    if not isinstance(payload, dict):\n        return []\n\n    local_post_id = (\n        payload.get(\"post_id\")\n        or payload.get(\"postId\")\n        or payload.get(\"tweet_id\")\n        or payload.get(\"tweetId\")\n        or inherited_post_id\n    )\n    if looks_like_video_record(payload):\n        return [(payload, local_post_id)]\n\n    records = []\n    for key in (\"videos\", \"videoItems\", \"media\", \"items\", \"results\", \"attachments\"):\n        value = payload.get(key)\n        if isinstance(value, list):\n            for item in value:\n                records.extend(find_video_records(item, local_post_id))\n    for key in (\"video\", \"mediaItem\", \"attachment\"):\n        value = payload.get(key)\n        if isinstance(value, dict):\n            records.extend(find_video_records(value, local_post_id))\n    return records\n\n\ndef looks_like_video_record(entry: dict[str, Any]) -> bool:\n    if any(key in entry for key in (\"sourceUrl\", \"source_url\", \"candidateUrls\", \"candidate_urls\")):\n        return True\n    media_type = str(entry.get(\"type\") or entry.get(\"media_type\") or entry.get(\"mediaType\") or \"\").lower()\n    if \"video\" in media_type and any(key in entry for key in (\"url\", \"urls\", \"variants\")):\n        return True\n    return False\n\n\ndef collect_candidate_urls(entry: dict[str, Any]) -> list[str]:\n    urls: list[tuple[int, int, str]] = []\n\n    for key in (\"sourceUrl\", \"source_url\", \"downloadUrl\", \"download_url\", \"playbackUrl\", \"playback_url\"):\n        value = entry.get(key)\n        if isinstance(value, str) and value.strip():\n            urls.append((1000000, len(urls), value.strip()))\n\n    generic_url = entry.get(\"url\")\n    if isinstance(generic_url, str) and is_probably_video_url(generic_url):\n        urls.append((900000, len(urls), generic_url.strip()))\n\n    for key in (\"candidateUrls\", \"candidate_urls\", \"variants\", \"urls\", \"videoUrls\", \"video_urls\"):\n        value = entry.get(key)\n        if isinstance(value, list):\n            for candidate in value:\n                candidate_url, score = parse_candidate_url(candidate)\n                if candidate_url:\n                    urls.append((score, len(urls), candidate_url))\n        elif isinstance(value, str) and value.strip():\n            urls.append((500000, len(urls), value.strip()))\n\n    ordered = sorted(urls, key=lambda item: (-item[0], item[1]))\n    seen = set()\n    result = []\n    for _, _, url in ordered:\n        if url not in seen:\n            seen.add(url)\n            result.append(url)\n    return result\n\n\ndef parse_candidate_url(candidate: Any) -> tuple[str | None, int]:\n    if isinstance(candidate, str):\n        return candidate.strip(), 500000\n    if not isinstance(candidate, dict):\n        return None, 0\n    url = None\n    for key in (\"url\", \"sourceUrl\", \"source_url\", \"downloadUrl\", \"download_url\", \"playbackUrl\"):\n        value = candidate.get(key)\n        if isinstance(value, str) and value.strip():\n            url = value.strip()\n            break\n    if not url:\n        return None, 0\n    bitrate = safe_int(candidate.get(\"bitrate\") or candidate.get(\"bit_rate\"), 0)\n    width = safe_int(candidate.get(\"width\"), 0)\n    height = safe_int(candidate.get(\"height\"), 0)\n    score = 500000 + bitrate + (width * height)\n    return url, score\n\n\ndef safe_int(value: Any, default: int) -> int:\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef is_probably_video_url(url: str) -> bool:\n    parsed = urllib.parse.urlparse(url)\n    path = parsed.path.lower()\n    if \"video.twimg.com\" in parsed.netloc.lower():\n        return True\n    return any(path.endswith(f\".{ext}\") for ext in VIDEO_EXTS | HLS_EXTS)\n\n\ndef save_first_available_video(video: VideoInput, out_dir: Path, args: argparse.Namespace) -> dict[str, Any]:\n    failures = []\n    for url in video.urls:\n        try:\n            downloaded = download_candidate(url, out_dir, args)\n            return finalize_download(video, downloaded, out_dir)\n        except CandidateError as exc:\n            failures.append(f\"{url}: {exc}\")\n    raise CandidateError(\"all candidates failed; \" + \" | \".join(failures))\n\n\ndef download_candidate(url: str, out_dir: Path, args: argparse.Namespace) -> DownloadedFile:\n    if is_hls_url(url):\n        return download_hls_with_ffmpeg(url, out_dir, args)\n    downloaded = download_http_file(url, out_dir, args)\n    ext = choose_extension(downloaded.path, downloaded.response_mime, downloaded.final_url)\n    if ext in HLS_EXTS:\n        remove_quietly(downloaded.path)\n        return download_hls_with_ffmpeg(url, out_dir, args)\n    if not is_video_file(downloaded.path, downloaded.response_mime, ext):\n        remove_quietly(downloaded.path)\n        raise CandidateError(f\"downloaded response is not a video file (mime={downloaded.response_mime!r})\")\n    return downloaded\n\n\ndef download_http_file(url: str, out_dir: Path, args: argparse.Namespace) -> DownloadedFile:\n    temp_path = out_dir / f\".download-{uuid.uuid4().hex}.part\"\n    request = urllib.request.Request(\n        url,\n        headers={\n            \"User-Agent\": args.user_agent,\n            \"Accept\": \"*/*\",\n            \"Referer\": \"https://x.com/\",\n        },\n    )\n    try:\n        with urllib.request.urlopen(request, timeout=args.timeout) as response:\n            response_mime = normalize_mime(response.headers.get(\"Content-Type\"))\n            final_url = response.geturl()\n            total = 0\n            hasher = hashlib.sha256()\n            with temp_path.open(\"wb\") as handle:\n                while True:\n                    chunk = response.read(1024 * 1024)\n                    if not chunk:\n                        break\n                    total += len(chunk)\n                    if args.max_bytes and total > args.max_bytes:\n                        raise CandidateError(f\"download exceeded --max-bytes ({args.max_bytes})\")\n                    hasher.update(chunk)\n                    handle.write(chunk)\n    except urllib.error.HTTPError as exc:\n        remove_quietly(temp_path)\n        raise CandidateError(f\"HTTP {exc.code}\") from exc\n    except urllib.error.URLError as exc:\n        remove_quietly(temp_path)\n        raise CandidateError(f\"URL error: {exc.reason}\") from exc\n    except TimeoutError as exc:\n        remove_quietly(temp_path)\n        raise CandidateError(\"download timed out\") from exc\n    except CandidateError:\n        remove_quietly(temp_path)\n        raise\n    except OSError as exc:\n        remove_quietly(temp_path)\n        raise CandidateError(f\"download failed: {exc}\") from exc\n\n    if not temp_path.exists() or temp_path.stat().st_size == 0:\n        remove_quietly(temp_path)\n        raise CandidateError(\"download produced an empty file\")\n    return DownloadedFile(path=temp_path, source_url=url, response_mime=response_mime, final_url=final_url)\n\n\ndef download_hls_with_ffmpeg(url: str, out_dir: Path, args: argparse.Namespace) -> DownloadedFile:\n    ffmpeg = shutil.which(\"ffmpeg\")\n    if not ffmpeg:\n        raise CandidateError(\"HLS playlist needs ffmpeg, but ffmpeg was not found\")\n\n    temp_path = out_dir / f\".download-{uuid.uuid4().hex}.mp4\"\n    header_lines = f\"User-Agent: {args.user_agent}\\r\\nReferer: https://x.com/\\r\\n\"\n    command = [\n        ffmpeg,\n        \"-hide_banner\",\n        \"-loglevel\",\n        \"error\",\n        \"-nostdin\",\n        \"-y\",\n        \"-headers\",\n        header_lines,\n        \"-i\",\n        url,\n        \"-c\",\n        \"copy\",\n        \"-movflags\",\n        \"+faststart\",\n        str(temp_path),\n    ]\n    try:\n        completed = subprocess.run(\n            command,\n            text=True,\n            capture_output=True,\n            timeout=args.ffmpeg_timeout,\n            check=False,\n        )\n    except subprocess.TimeoutExpired as exc:\n        remove_quietly(temp_path)\n        raise CandidateError(\"ffmpeg HLS download timed out\") from exc\n\n    if completed.returncode != 0:\n        remove_quietly(temp_path)\n        message = (completed.stderr or completed.stdout or \"ffmpeg failed\").strip()\n        raise CandidateError(message[-500:])\n    if not temp_path.exists() or temp_path.stat().st_size == 0:\n        remove_quietly(temp_path)\n        raise CandidateError(\"ffmpeg produced an empty file\")\n    return DownloadedFile(path=temp_path, source_url=url, response_mime=\"video/mp4\", final_url=url)\n\n\ndef finalize_download(video: VideoInput, downloaded: DownloadedFile, out_dir: Path) -> dict[str, Any]:\n    sha256 = hash_file(downloaded.path)\n    mime = choose_mime(downloaded.path, downloaded.response_mime)\n    ext = choose_extension(downloaded.path, mime, downloaded.final_url)\n    if ext in HLS_EXTS:\n        remove_quietly(downloaded.path)\n        raise CandidateError(\"candidate resolved to a playlist instead of a video file\")\n\n    final_path, reused = place_by_sha(downloaded.path, out_dir, sha256, ext)\n    probe = probe_video(final_path)\n    return {\n        \"post_id\": video.post_id,\n        \"media_index\": video.media_index,\n        \"source_url\": downloaded.source_url,\n        \"local_path\": str(final_path.resolve()),\n        \"sha256\": sha256,\n        \"mime\": mime,\n        \"ext\": ext,\n        \"bytes\": final_path.stat().st_size,\n        \"duration\": probe.get(\"duration\"),\n        \"width\": probe.get(\"width\"),\n        \"height\": probe.get(\"height\"),\n        \"reused\": reused,\n    }\n\n\ndef hash_file(path: Path) -> str:\n    hasher = hashlib.sha256()\n    with path.open(\"rb\") as handle:\n        for chunk in iter(lambda: handle.read(1024 * 1024), b\"\"):\n            hasher.update(chunk)\n    return hasher.hexdigest()\n\n\ndef place_by_sha(temp_path: Path, out_dir: Path, sha256: str, ext: str) -> tuple[Path, bool]:\n    ext = clean_ext(ext)\n    existing = find_existing_sha_file(out_dir, sha256)\n    if existing:\n        remove_quietly(temp_path)\n        return existing, True\n    final_path = out_dir / f\"{sha256}.{ext}\"\n    if final_path.exists():\n        remove_quietly(temp_path)\n        return final_path, True\n    temp_path.replace(final_path)\n    return final_path, False\n\n\ndef find_existing_sha_file(out_dir: Path, sha256: str) -> Path | None:\n    for path in sorted(out_dir.glob(f\"{sha256}.*\")):\n        if path.is_file():\n            return path\n    return None\n\n\ndef clean_ext(ext: str | None) -> str:\n    ext = (ext or \"mp4\").lower().strip().lstrip(\".\")\n    if not ext or any(ch in ext for ch in \"\\\\/:*?\\\"<>|\"):\n        return \"mp4\"\n    return ext[:16]\n\n\ndef normalize_mime(value: str | None) -> str | None:\n    if not value:\n        return None\n    return value.split(\";\", 1)[0].strip().lower() or None\n\n\ndef choose_mime(path: Path, response_mime: str | None) -> str:\n    sniffed = sniff_mime(path)\n    if sniffed:\n        return sniffed\n    if response_mime and response_mime not in {\"application/octet-stream\", \"binary/octet-stream\"}:\n        return response_mime\n    guessed, _ = mimetypes.guess_type(str(path))\n    return guessed or response_mime or \"application/octet-stream\"\n\n\ndef choose_extension(path: Path, mime: str | None, url: str) -> str:\n    sniffed = sniff_mime(path)\n    if sniffed in CONTENT_TYPE_EXT:\n        return CONTENT_TYPE_EXT[sniffed]\n    mime = normalize_mime(mime)\n    if mime in CONTENT_TYPE_EXT:\n        return CONTENT_TYPE_EXT[mime]\n    parsed = urllib.parse.urlparse(url)\n    suffix = Path(parsed.path).suffix.lower().lstrip(\".\")\n    if suffix:\n        return suffix\n    guessed = mimetypes.guess_extension(mime or \"\")\n    if guessed:\n        return guessed.lstrip(\".\")\n    return \"mp4\"\n\n\ndef is_hls_url(url: str) -> bool:\n    parsed = urllib.parse.urlparse(url)\n    return parsed.path.lower().endswith(\".m3u8\")\n\n\ndef is_video_file(path: Path, response_mime: str | None, ext: str) -> bool:\n    mime = choose_mime(path, response_mime)\n    if mime.startswith(\"video/\"):\n        return True\n    if ext in VIDEO_EXTS:\n        return True\n    return sniff_mime(path) is not None\n\n\ndef sniff_mime(path: Path) -> str | None:\n    try:\n        with path.open(\"rb\") as handle:\n            head = handle.read(512)\n    except OSError:\n        return None\n    if len(head) >= 12 and head[4:8] == b\"ftyp\":\n        return \"video/mp4\"\n    if head.startswith(b\"\\x1a\\x45\\xdf\\xa3\"):\n        return \"video/webm\"\n    if head.startswith(b\"OggS\"):\n        return \"video/ogg\"\n    if len(head) > 188 and head[0] == 0x47 and head[188] == 0x47:\n        return \"video/mp2t\"\n    return None\n\n\ndef probe_video(path: Path) -> dict[str, Any]:\n    ffprobe_result = probe_with_ffprobe(path)\n    if ffprobe_result:\n        return ffprobe_result\n    return probe_mp4_boxes(path)\n\n\ndef probe_with_ffprobe(path: Path) -> dict[str, Any] | None:\n    ffprobe = shutil.which(\"ffprobe\")\n    if not ffprobe:\n        return None\n    command = [\n        ffprobe,\n        \"-v\",\n        \"error\",\n        \"-select_streams\",\n        \"v:0\",\n        \"-show_entries\",\n        \"stream=width,height,duration:format=duration\",\n        \"-of\",\n        \"json\",\n        str(path),\n    ]\n    try:\n        completed = subprocess.run(command, text=True, capture_output=True, timeout=20, check=False)\n    except (OSError, subprocess.TimeoutExpired):\n        return None\n    if completed.returncode != 0:\n        return None\n    try:\n        payload = json.loads(completed.stdout)\n    except json.JSONDecodeError:\n        return None\n    streams = payload.get(\"streams\") or []\n    stream = streams[0] if streams else {}\n    duration = first_number(stream.get(\"duration\"), (payload.get(\"format\") or {}).get(\"duration\"))\n    return {\n        \"duration\": round(duration, 3) if duration is not None else None,\n        \"width\": safe_int_or_none(stream.get(\"width\")),\n        \"height\": safe_int_or_none(stream.get(\"height\")),\n    }\n\n\ndef first_number(*values: Any) -> float | None:\n    for value in values:\n        try:\n            number = float(value)\n        except (TypeError, ValueError):\n            continue\n        if number >= 0:\n            return number\n    return None\n\n\ndef safe_int_or_none(value: Any) -> int | None:\n    try:\n        number = int(float(value))\n    except (TypeError, ValueError):\n        return None\n    return number if number > 0 else None\n\n\ndef probe_mp4_boxes(path: Path) -> dict[str, Any]:\n    meta: dict[str, Any] = {\"duration\": None, \"width\": None, \"height\": None}\n    try:\n        with path.open(\"rb\") as handle:\n            scan_mp4_boxes(handle, 0, path.stat().st_size, 0, meta)\n    except OSError:\n        return meta\n    if isinstance(meta.get(\"duration\"), float):\n        meta[\"duration\"] = round(meta[\"duration\"], 3)\n    return meta\n\n\ndef scan_mp4_boxes(handle: Any, start: int, end: int, depth: int, meta: dict[str, Any]) -> None:\n    if depth > 8:\n        return\n    position = start\n    while position + 8 <= end:\n        handle.seek(position)\n        header = handle.read(16)\n        if len(header) < 8:\n            return\n        size = read_u32(header, 0)\n        box_type = header[4:8].decode(\"latin-1\", errors=\"replace\")\n        header_size = 8\n        if size == 1:\n            if len(header) < 16:\n                return\n            size = read_u64(header, 8)\n            header_size = 16\n        elif size == 0:\n            size = end - position\n        box_end = position + size\n        if size < header_size or box_end > end:\n            return\n        data_start = position + header_size\n        if box_type == \"mvhd\":\n            read_mvhd(handle, data_start, box_end, meta)\n        elif box_type == \"tkhd\":\n            read_tkhd(handle, data_start, box_end, meta)\n        elif box_type in CONTAINER_BOXES:\n            child_start = data_start + (4 if box_type == \"meta\" else 0)\n            scan_mp4_boxes(handle, child_start, box_end, depth + 1, meta)\n        position = box_end\n\n\ndef read_mvhd(handle: Any, start: int, end: int, meta: dict[str, Any]) -> None:\n    handle.seek(start)\n    data = handle.read(min(40, end - start))\n    if len(data) < 24:\n        return\n    version = data[0]\n    if version == 1 and len(data) >= 32:\n        timescale = read_u32(data, 20)\n        duration = read_u64(data, 24)\n    else:\n        timescale = read_u32(data, 12)\n        duration = read_u32(data, 16)\n    if timescale:\n        seconds = duration / timescale\n        if seconds >= 0:\n            meta[\"duration\"] = seconds\n\n\ndef read_tkhd(handle: Any, start: int, end: int, meta: dict[str, Any]) -> None:\n    handle.seek(start)\n    data = handle.read(min(96, end - start))\n    if len(data) < 88:\n        return\n    version = data[0]\n    width_offset = 88 if version == 1 else 76\n    height_offset = width_offset + 4\n    if len(data) < height_offset + 4:\n        return\n    width = read_u32(data, width_offset) / 65536.0\n    height = read_u32(data, height_offset) / 65536.0\n    if width > 0 and height > 0:\n        meta[\"width\"] = max(safe_int_or_none(width) or 0, meta.get(\"width\") or 0) or None\n        meta[\"height\"] = max(safe_int_or_none(height) or 0, meta.get(\"height\") or 0) or None\n\n\ndef read_u32(data: bytes, offset: int) -> int:\n    return int.from_bytes(data[offset : offset + 4], \"big\", signed=False)\n\n\ndef read_u64(data: bytes, offset: int) -> int:\n    return int.from_bytes(data[offset : offset + 8], \"big\", signed=False)\n\n\ndef remove_quietly(path: Path) -> None:\n    try:\n        if path.exists():\n            path.unlink()\n    except OSError:\n        pass\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
