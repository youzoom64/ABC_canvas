    {
      "id": "node-2e4b5cd891",
      "title": "引用・リポスト発端追跡ポワン",
      "body": "対象投稿や返信チェーン上の投稿が引用、リポスト、再掲、参照カードを使って話題を運んでいる時、その参照先を発端候補として追跡する神経ポワン。返信チェーンの根とは別に、話題がどの投稿から来たのかを探す。引用元、リポスト元、引用の引用、本文内で明示された参照などが混ざるため、さらに小さな子ポワンへ分けて扱う。会話起点判定ポワンに topic_origin 候補を渡す。コードは持たない。",
      "powanKind": "nerve",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\ntype MaybePromise<T> = T | Promise<T>;\n\nexport type ChildFetcher = (ref: PostRef) => MaybePromise<FetchResult>;\n\nexport type RootTraceTools = {\n  classifyPostRelation: (post: PostLike) => MaybePromise<RelationDecision>;\n  getReplyParentRef?: (post: PostLike) => MaybePromise<PostRef | null>;\n  getRepostSourceRef?: (post: PostLike) => MaybePromise<PostRef | null>;\n  getQuoteSourceRef?: (post: PostLike) => MaybePromise<PostRef | null>;\n  fetchNextPost: (ref: PostRef, fetcher: ChildFetcher) => Promise<FetchResult>;\n  fetcher: ChildFetcher;\n  traceUntilRoot: (\n    startPost: PostLike,\n    tools: {\n      classifyPostRelation: (post: PostLike) => MaybePromise<RelationDecision>;\n      fetchNextPost: (ref: PostRef) => MaybePromise<FetchResult>;\n    },\n    options?: { maxDepth?: number },\n  ) => Promise<TraceResult>;\n  buildOriginTraceResult: (path: TraceStep[], rootPost?: PostLike, stopReason?: string) => TraceResult;\n};\n\nexport type OriginTraceOptions = {\n  maxDepth?: number;\n  refPriority?: RefKind[];\n};\n\nexport type OriginTracePipeline = {\n  traceTopicOrigin: (startPost: PostLike, options?: OriginTraceOptions) => Promise<TraceResult>;\n  classifyWithChildRefs: (post: PostLike, options?: OriginTraceOptions) => Promise<RelationDecision>;\n};\n\nconst DEFAULT_REF_PRIORITY: readonly RefKind[] = [\n  \"repost_source\",\n  \"reply_parent\",\n  \"quote_source\",\n  \"url_post\",\n];\n\nconst PREFERRED_REF_KIND_BY_RELATION: Partial<Record<RelationType, RefKind>> = {\n  reply: \"reply_parent\",\n  repost: \"repost_source\",\n  quote: \"quote_source\",\n};\n\nexport function createOriginTracePipeline(\n  tools: RootTraceTools,\n  defaultOptions: OriginTraceOptions = {},\n): OriginTracePipeline {\n  return {\n    traceTopicOrigin: (startPost, options = {}) =>\n      traceTopicOrigin(startPost, tools, { ...defaultOptions, ...options }),\n    classifyWithChildRefs: (post, options = {}) =>\n      classifyWithChildRefs(post, tools, { ...defaultOptions, ...options }),\n  };\n}\n\nexport async function traceTopicOrigin(\n  startPost: PostLike,\n  tools: RootTraceTools,\n  options: OriginTraceOptions = {},\n): Promise<TraceResult> {\n  const toolError = validateRootTools(tools);\n  if (toolError) {\n    return makeErrorTraceResult(startPost, toolError);\n  }\n\n  try {\n    const traceResult = await tools.traceUntilRoot(\n      normalizePost(startPost),\n      {\n        classifyPostRelation: (post) => classifyWithChildRefs(post, tools, options),\n        fetchNextPost: (ref) => tools.fetchNextPost(ref, tools.fetcher),\n      },\n      { maxDepth: options.maxDepth },\n    );\n\n    const shaped = tools.buildOriginTraceResult(\n      Array.isArray(traceResult.path) ? traceResult.path : [],\n      traceResult.rootPost,\n      traceResult.stopReason,\n    );\n\n    return mergeTraceTopicCandidates(shaped, traceResult.topicOriginCandidates);\n  } catch (error) {\n    return makeErrorTraceResult(startPost, errorToReason(error));\n  }\n}\n\nexport async function classifyWithChildRefs(\n  post: PostLike,\n  tools: RootTraceTools,\n  options: OriginTraceOptions = {},\n): Promise<RelationDecision> {\n  const normalizedPost = normalizePost(post);\n  const baseDecision = normalizeDecision(await tools.classifyPostRelation(normalizedPost));\n  const refs = [...baseDecision.refs];\n  const evidence = [...baseDecision.evidence];\n\n  await collectRef(\"reply_parent\", tools.getReplyParentRef, normalizedPost, refs, evidence);\n  await collectRef(\"repost_source\", tools.getRepostSourceRef, normalizedPost, refs, evidence);\n  await collectRef(\"quote_source\", tools.getQuoteSourceRef, normalizedPost, refs, evidence);\n\n  const relationType = inferRelationType(baseDecision.relationType, refs);\n  const primaryRef = choosePrimaryRef(relationType, refs, baseDecision.primaryRef, options.refPriority);\n  const confidence = Math.max(\n    clampConfidence(baseDecision.confidence),\n    ...refs.map((ref) => clampConfidence(ref.confidence)),\n    primaryRef ? clampConfidence(primaryRef.confidence) : 0,\n  );\n\n  return {\n    relationType,\n    refs,\n    ...(primaryRef ? { primaryRef } : {}),\n    evidence: uniqueStrings(evidence.length ? evidence : [\"no relation evidence\"]),\n    confidence,\n  };\n}\n\nasync function collectRef(\n  expectedKind: RefKind,\n  getter: ((post: PostLike) => MaybePromise<PostRef | null>) | undefined,\n  post: PostLike,\n  refs: PostRef[],\n  evidence: string[],\n): Promise<void> {\n  if (typeof getter !== \"function\") {\n    return;\n  }\n\n  try {\n    const ref = normalizeRef(await getter(post));\n    if (!ref) {\n      return;\n    }\n\n    const normalized = ref.kind === expectedKind ? ref : { ...ref, kind: expectedKind };\n    addRef(refs, normalized);\n    evidence.push(normalized.evidence || `${expectedKind} detected`);\n  } catch (error) {\n    evidence.push(`${expectedKind} collector error: ${errorToReason(error)}`);\n  }\n}\n\nfunction validateRootTools(tools: RootTraceTools): string | null {\n  if (!tools || typeof tools !== \"object\") {\n    return \"tools must be provided\";\n  }\n  if (typeof tools.classifyPostRelation !== \"function\") {\n    return \"classifyPostRelation tool is required\";\n  }\n  if (typeof tools.fetchNextPost !== \"function\") {\n    return \"fetchNextPost tool is required\";\n  }\n  if (typeof tools.fetcher !== \"function\") {\n    return \"fetcher tool is required\";\n  }\n  if (typeof tools.traceUntilRoot !== \"function\") {\n    return \"traceUntilRoot tool is required\";\n  }\n  if (typeof tools.buildOriginTraceResult !== \"function\") {\n    return \"buildOriginTraceResult tool is required\";\n  }\n  return null;\n}\n\nfunction normalizePost(post: PostLike | null | undefined): PostLike {\n  return post && typeof post === \"object\" ? post : {};\n}\n\nfunction normalizeDecision(decision: RelationDecision | null | undefined): RelationDecision {\n  if (!decision || typeof decision !== \"object\") {\n    return {\n      relationType: \"unknown\",\n      refs: [],\n      evidence: [\"classifier returned no decision\"],\n      confidence: 0,\n    };\n  }\n\n  const refs = Array.isArray(decision.refs)\n    ? decision.refs.map(normalizeRef).filter((ref): ref is PostRef => Boolean(ref))\n    : [];\n  const primaryRef = normalizeRef(decision.primaryRef);\n  if (primaryRef) {\n    addRef(refs, primaryRef);\n  }\n\n  return {\n    relationType: isRelationType(decision.relationType) ? decision.relationType : \"unknown\",\n    refs,\n    ...(primaryRef ? { primaryRef } : {}),\n    evidence: Array.isArray(decision.evidence) ? uniqueStrings(decision.evidence) : [],\n    confidence: clampConfidence(decision.confidence),\n  };\n}\n\nfunction normalizeRef(ref: PostRef | null | undefined): PostRef | null {\n  if (!ref || typeof ref !== \"object\" || !isRefKind(ref.kind)) {\n    return null;\n  }\n\n  const postId = cleanString(ref.postId);\n  const url = cleanString(ref.url);\n  if (!postId && !url) {\n    return null;\n  }\n\n  return {\n    kind: ref.kind,\n    ...(postId ? { postId } : {}),\n    ...(url ? { url } : {}),\n    evidence: cleanString(ref.evidence) ?? `${ref.kind} reference`,\n    confidence: clampConfidence(ref.confidence),\n  };\n}\n\nfunction addRef(refs: PostRef[], ref: PostRef): void {\n  const key = refKey(ref);\n  if (!key || refs.some((existing) => refKey(existing) === key)) {\n    return;\n  }\n  refs.push(ref);\n}\n\nfunction choosePrimaryRef(\n  relationType: RelationType,\n  refs: PostRef[],\n  basePrimaryRef?: PostRef,\n  refPriority?: RefKind[],\n): PostRef | undefined {\n  const normalizedBase = normalizeRef(basePrimaryRef);\n  if (normalizedBase && refs.some((ref) => refKey(ref) === refKey(normalizedBase))) {\n    return normalizedBase;\n  }\n\n  const preferredKind = PREFERRED_REF_KIND_BY_RELATION[relationType];\n  if (preferredKind) {\n    const preferred = refs.find((ref) => ref.kind === preferredKind);\n    if (preferred) {\n      return preferred;\n    }\n  }\n\n  const priority = normalizeRefPriority(refPriority);\n  for (const kind of priority) {\n    const match = refs.find((ref) => ref.kind === kind);\n    if (match) {\n      return match;\n    }\n  }\n\n  return refs[0];\n}\n\nfunction inferRelationType(base: RelationType, refs: PostRef[]): RelationType {\n  if (base !== \"unknown\" && base !== \"standalone\") {\n    return base;\n  }\n  if (refs.some((ref) => ref.kind === \"repost_source\")) {\n    return \"repost\";\n  }\n  if (refs.some((ref) => ref.kind === \"reply_parent\")) {\n    return \"reply\";\n  }\n  if (refs.some((ref) => ref.kind === \"quote_source\" || ref.kind === \"url_post\")) {\n    return \"quote\";\n  }\n  return base === \"standalone\" ? \"standalone\" : \"unknown\";\n}\n\nfunction mergeTraceTopicCandidates(result: TraceResult, candidates: PostRef[] | undefined): TraceResult {\n  const merged = Array.isArray(result.topicOriginCandidates)\n    ? result.topicOriginCandidates.filter(isTopicOriginRef)\n    : [];\n\n  if (!Array.isArray(candidates) || candidates.length === 0) {\n    return { ...result, topicOriginCandidates: merged };\n  }\n\n  for (const candidate of candidates) {\n    const ref = normalizeRef(candidate);\n    if (ref && isTopicOriginRef(ref)) {\n      addRef(merged, ref);\n    }\n  }\n\n  return { ...result, topicOriginCandidates: merged };\n}\n\nfunction isTopicOriginRef(ref: PostRef): boolean {\n  return ref.kind === \"repost_source\" || ref.kind === \"quote_source\" || ref.kind === \"url_post\";\n}\n\nfunction makeErrorTraceResult(startPost: PostLike, reason: string): TraceResult {\n  return {\n    rootPost: normalizePost(startPost),\n    path: [],\n    stopReason: `error: ${reason}`,\n    topicOriginCandidates: [],\n  };\n}\n\nfunction normalizeRefPriority(priority: RefKind[] | undefined): readonly RefKind[] {\n  if (!Array.isArray(priority) || priority.length === 0) {\n    return DEFAULT_REF_PRIORITY;\n  }\n  const normalized = priority.filter(isRefKind);\n  return normalized.length ? uniqueRefKinds(normalized) : DEFAULT_REF_PRIORITY;\n}\n\nfunction refKey(ref: PostRef): string {\n  return `${ref.kind}:${ref.postId ?? \"\"}:${ref.url ?? \"\"}`;\n}\n\nfunction cleanString(value: unknown): string | undefined {\n  if (typeof value !== \"string\") {\n    return undefined;\n  }\n  const cleaned = value.trim();\n  return cleaned || undefined;\n}\n\nfunction clampConfidence(value: unknown): number {\n  if (typeof value !== \"number\" || Number.isNaN(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}\n\nfunction uniqueStrings(values: string[]): string[] {\n  return [...new Set(values.map((value) => value.trim()).filter(Boolean))];\n}\n\nfunction uniqueRefKinds(values: RefKind[]): RefKind[] {\n  return [...new Set(values)];\n}\n\nfunction isRelationType(value: unknown): value is RelationType {\n  return value === \"reply\" || value === \"repost\" || value === \"quote\" || value === \"standalone\" || value === \"unknown\";\n}\n\nfunction isRefKind(value: unknown): value is RefKind {\n  return value === \"reply_parent\" || value === \"repost_source\" || value === \"quote_source\" || value === \"url_post\";\n}\n\nfunction errorToReason(error: unknown): string {\n  if (error instanceof Error && error.message) {\n    return error.message;\n  }\n  if (typeof error === \"string\" && error.trim()) {\n    return error.trim();\n  }\n  return \"unknown error\";\n}",
