    {
      "id": "node-2b1485633c",
      "title": "X投稿収集テストポワン",
      "body": "X投稿収集ポワン全体が正しく収集・保存・判定・追跡・分類できているかを、ユーザーがGUIで確認しながら育てるための神経ポワン。終端判定だけに狭めず、既存DB投稿、単発投稿URL、収集疎通、投稿読み取り、返信・引用・リポスト追跡、投稿出どころ判定、終端内容分類、画像・動画・YouTube・ニュース素材確認、正解ラベル管理、バッチ再テストまでを束ねる。既存のX構造整理ポワン配下をコピーせず、リンクポワン経由で参照して使う。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom pathlib import Path\nfrom typing import Any\n\n\nDEFAULT_STATE_DIR = \".powan_test_gui\"\nDEFAULT_RESULTS_NAME = \"x_post_test_results.json\"\nDEFAULT_LABELS_NAME = \"x_post_test_expected_labels.json\"\nDEFAULT_PROJECT_FILE = \"project.powan\"\nDEFAULT_GUI_FILE = \".codex_tmp_test_gui_powan_code.py\"\nGUI_TITLE = \"テストGUIポワン\"\n\n\ndef project_root_from(start: Path | None = None) -> Path:\n    base = (start or Path.cwd()).resolve()\n    if base.is_file():\n        base = base.parent\n    for candidate in (base, *base.parents):\n        if (candidate / DEFAULT_PROJECT_FILE).exists():\n            return candidate\n    return Path.cwd().resolve()\n\n\ndef resolve_path(value: str, root: Path) -> Path | None:\n    if not value:\n        return None\n    path = Path(value).expanduser()\n    return path if path.is_absolute() else root / path\n\n\ndef default_json_path(root: Path, state_dir: Path, name: str) -> Path:\n    return state_dir / name if state_dir.is_absolute() else root / state_dir / name\n\n\ndef load_gui_code_from_project(project_file: Path) -> str:\n    data = json.loads(project_file.read_text(encoding=\"utf-8\"))\n    for node in data.get(\"nodes\", []):\n        if node.get(\"title\") == GUI_TITLE:\n            code = node.get(\"code\") or \"\"\n            if code.strip():\n                return code\n            raise RuntimeError(f\"{GUI_TITLE} has no code in {project_file}\")\n    raise RuntimeError(f\"{GUI_TITLE} was not found in {project_file}\")\n\n\ndef resolve_gui_file(root: Path, project_file: Path, gui_code: str, state_dir: Path, dry_run: bool) -> tuple[Path, bool, str]:\n    explicit = resolve_path(gui_code, root)\n    if explicit:\n        return explicit, explicit.exists(), \"explicit\"\n    default_gui = root / DEFAULT_GUI_FILE\n    if default_gui.exists():\n        return default_gui, True, \"default-temp-file\"\n    if dry_run:\n        try:\n            load_gui_code_from_project(project_file)\n            return root / DEFAULT_GUI_FILE, False, \"project-powan-extractable\"\n        except Exception:\n            return root / DEFAULT_GUI_FILE, False, \"missing\"\n    code = load_gui_code_from_project(project_file)\n    target_dir = state_dir if state_dir.is_absolute() else root / state_dir\n    target_dir.mkdir(parents=True, exist_ok=True)\n    extracted = target_dir / \"extracted_test_gui_powan_code.py\"\n    extracted.write_text(code, encoding=\"utf-8\")\n    return extracted, True, \"extracted-from-project-powan\"\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(\n        prog=\"x-post-collection-test\",\n        description=\"Thin launcher for the first-stage X post collection test GUI.\",\n        epilog=(\n            \"The launcher does not run Selenium, deep relation tracing, external material fetching, \"\n            \"or production DB writes. x_archive.db is passed to the GUI as read-only input; \"\n            \"test results and labels are JSON files.\"\n        ),\n    )\n    parser.add_argument(\"--db\", default=\"\", help=\"Optional path to an existing x_archive.db. The GUI treats it as read-only.\")\n    parser.add_argument(\"--results\", default=\"\", help=\"Path to x_post_test_results.json. Defaults to .powan_test_gui/x_post_test_results.json.\")\n    parser.add_argument(\"--labels\", default=\"\", help=\"Path to x_post_test_expected_labels.json. Defaults to .powan_test_gui/x_post_test_expected_labels.json.\")\n    parser.add_argument(\"--state-dir\", default=DEFAULT_STATE_DIR, help=\"Directory for GUI temp state and default JSON stores.\")\n    parser.add_argument(\"--project-file\", default=DEFAULT_PROJECT_FILE, help=\"Path to project.powan used to find saved child GUI code.\")\n    parser.add_argument(\"--gui-code\", default=\"\", help=\"Optional explicit path to extracted test GUI Python code.\")\n    parser.add_argument(\"--url\", default=\"\", help=\"Optional post URL to prefill in the GUI.\")\n    parser.add_argument(\"--run-id\", default=\"\", help=\"Optional run_id to pass through to the GUI.\")\n    parser.add_argument(\"--test-type\", default=\"\", help=\"Optional initial test type supported by the GUI.\")\n    parser.add_argument(\"--no-gui\", action=\"store_true\", help=\"Ask the child GUI code to run one CLI stub test instead of opening Tk.\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Print resolved paths and GUI availability without opening the GUI.\")\n    return parser\n\n\ndef resolved_config(args: argparse.Namespace) -> dict[str, Any]:\n    root = project_root_from(Path(__file__).resolve() if \"__file__\" in globals() else Path.cwd())\n    state_dir = resolve_path(args.state_dir, root) or (root / DEFAULT_STATE_DIR)\n    project_file = resolve_path(args.project_file, root) or (root / DEFAULT_PROJECT_FILE)\n    results = resolve_path(args.results, root) or default_json_path(root, state_dir, DEFAULT_RESULTS_NAME)\n    labels = resolve_path(args.labels, root) or default_json_path(root, state_dir, DEFAULT_LABELS_NAME)\n    db_path = resolve_path(args.db, root)\n    gui_path, gui_exists, gui_source = resolve_gui_file(root, project_file, args.gui_code, state_dir, args.dry_run)\n    return {\n        \"project_root\": root,\n        \"state_dir\": state_dir,\n        \"project_file\": project_file,\n        \"db_path\": db_path,\n        \"results_path\": results,\n        \"labels_path\": labels,\n        \"gui_code_path\": gui_path,\n        \"gui_code_exists\": gui_exists,\n        \"gui_code_source\": gui_source,\n        \"production_db_write\": False,\n        \"selenium_enabled\": False,\n        \"external_fetch_enabled\": False,\n    }\n\n\ndef print_dry_run(config: dict[str, Any]) -> None:\n    display = {key: (str(value) if isinstance(value, Path) else value) for key, value in config.items()}\n    print(json.dumps(display, ensure_ascii=False, indent=2, sort_keys=True))\n\n\ndef launch_gui(args: argparse.Namespace, config: dict[str, Any]) -> int:\n    gui = Path(config[\"gui_code_path\"])\n    if not gui.exists():\n        raise FileNotFoundError(f\"GUI code was not found: {gui}\")\n    Path(config[\"state_dir\"]).mkdir(parents=True, exist_ok=True)\n    command = [\n        sys.executable,\n        str(gui),\n        \"--project-file\",\n        str(config[\"project_file\"]),\n        \"--result-store\",\n        str(config[\"results_path\"]),\n        \"--label-store\",\n        str(config[\"labels_path\"]),\n        \"--state-dir\",\n        str(config[\"state_dir\"]),\n    ]\n    if config[\"db_path\"]:\n        command.extend([\"--db\", str(config[\"db_path\"])])\n    if args.url:\n        command.extend([\"--url\", args.url])\n    if args.run_id:\n        command.extend([\"--run-id\", args.run_id])\n    if args.test_type:\n        command.extend([\"--test-type\", args.test_type])\n    if args.no_gui:\n        command.append(\"--no-gui\")\n    return subprocess.run(command, cwd=str(config[\"project_root\"]), check=False).returncode\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = build_parser()\n    args = parser.parse_args(argv)\n    try:\n        config = resolved_config(args)\n        if args.dry_run:\n            print_dry_run(config)\n            return 0\n        return launch_gui(args, config)\n    except Exception as exc:\n        print(f\"x-post-collection-test launcher error: {exc}\", file=sys.stderr)\n        return 2\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
