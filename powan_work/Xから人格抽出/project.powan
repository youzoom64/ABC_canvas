    {
      "id": "node-f8fee6b397",
      "title": "YouTube URL抽出ポワン",
      "body": "終端投稿や投稿カード、本文リンクからYouTubeのURLと動画IDを抽出する臓器ポワン。youtube.com、youtu.be、埋め込みURL、共有URLを正規化し、後続の字幕取得、動画保存、コメント取得へ渡せるURL、video_id、元リンク表記を返す。字幕取得や動画保存やDB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport html\nimport json\nimport re\nfrom dataclasses import dataclass\nfrom typing import Any, Iterable\nfrom urllib.parse import parse_qs, unquote, urlparse\n\nYOUTUBE_HOSTS = {\n    \"youtube.com\",\n    \"www.youtube.com\",\n    \"m.youtube.com\",\n    \"music.youtube.com\",\n    \"youtube-nocookie.com\",\n    \"www.youtube-nocookie.com\",\n}\nSHORT_YOUTUBE_HOSTS = {\"youtu.be\", \"www.youtu.be\"}\nVIDEO_ID_RE = re.compile(r\"^[A-Za-z0-9_-]{11}$\")\nURL_RE = re.compile(\n    r\"(?i)(?:https?://|www\\.|m\\.youtube\\.com/|youtube\\.com/|youtu\\.be/|youtube-nocookie\\.com/)\"\n    r\"[^\\s<>\\\"'`{}|\\\\^\\[\\]]+\"\n)\nTRAILING_PUNCTUATION = \".,;:!?)]}\\u3001\\u3002\\uff09\\uff3d\\uff5d\\u300b\\u300d\\u300f\\u201d\\u2019\"\nURL_KEY_HINTS = (\n    \"url\",\n    \"uri\",\n    \"href\",\n    \"link\",\n    \"expanded\",\n    \"canonical\",\n    \"card\",\n    \"media\",\n    \"source\",\n    \"share\",\n    \"embed\",\n)\nTEXT_KEY_HINTS = (\n    \"text\",\n    \"body\",\n    \"content\",\n    \"description\",\n    \"title\",\n    \"caption\",\n    \"summary\",\n)\nPOST_ID_KEYS = {\n    \"postid\",\n    \"post_id\",\n    \"tweetid\",\n    \"tweet_id\",\n    \"statusid\",\n    \"status_id\",\n    \"id_str\",\n}\nMEDIA_INDEX_KEYS = {\"mediaindex\", \"media_index\", \"mediaidx\", \"media_idx\"}\nDOWNSTREAM_SCRIPT_HINTS = {\n    \"subtitle\": \"C:/project_root/app_workspaces/API/scripts/youtube_subtitle.py::download_subtitle_as_text(url, output_dir, lang)\",\n    \"comments\": \"C:/project_root/app_workspaces/API/scripts/youtube_comments.py::download_comments_as_text(url, output_dir, max_comments)\",\n    \"video\": \"C:/project_root/app_workspaces/API/scripts/video_downloader.py::download(url, output_dir)\",\n}\n\n\n@dataclass(frozen=True)\nclass TextSource:\n    text: str\n    path: str\n    priority: int\n    media_index: int | None = None\n\n\n@dataclass(frozen=True)\nclass YoutubeUrl:\n    url: str\n    normalized_url: str\n    video_id: str\n    source_text: str\n    source_path: str\n    priority: int\n    order: int\n    media_index: int | None = None\n\n\ndef _clean_scalar(value: Any) -> str:\n    if value is None:\n        return \"\"\n    if isinstance(value, bytes):\n        value = value.decode(\"utf-8\", errors=\"replace\")\n    if isinstance(value, (int, float)) and not isinstance(value, bool):\n        return str(value)\n    if not isinstance(value, str):\n        return \"\"\n    text = html.unescape(value)\n    text = text.replace(\"\\\\/\", \"/\")\n    text = text.replace(\"\\u200b\", \"\").replace(\"\\ufeff\", \"\")\n    return text.strip()\n\n\ndef _looks_urlish_key(key: str) -> bool:\n    lower = key.replace(\"-\", \"_\").lower()\n    return any(hint in lower for hint in URL_KEY_HINTS)\n\n\ndef _looks_textish_key(key: str) -> bool:\n    lower = key.replace(\"-\", \"_\").lower()\n    return any(hint in lower for hint in TEXT_KEY_HINTS)\n\n\ndef _path_join(path: str, key: str) -> str:\n    if not path:\n        return key\n    if key.startswith(\"[\"):\n        return f\"{path}{key}\"\n    return f\"{path}.{key}\"\n\n\ndef _coerce_int(value: Any) -> int | None:\n    if isinstance(value, bool) or value is None:\n        return None\n    if isinstance(value, int):\n        return value\n    text = _clean_scalar(value)\n    if not text:\n        return None\n    try:\n        return int(text)\n    except ValueError:\n        return None\n\n\ndef _coerce_jsonish(value: Any) -> Any:\n    if not isinstance(value, str):\n        return value\n    text = value.strip()\n    if not text:\n        return value\n    if not ((text.startswith(\"{\") and text.endswith(\"}\")) or (text.startswith(\"[\") and text.endswith(\"]\"))):\n        return value\n    try:\n        return json.loads(text)\n    except json.JSONDecodeError:\n        return value\n\n\ndef _infer_media_index_from_path(path: str) -> int | None:\n    match = re.search(r\"(?:media|card|attachments?)\\[(\\d+)\\]\", path, flags=re.IGNORECASE)\n    if not match:\n        return None\n    return int(match.group(1))\n\n\ndef _walk_text_sources(value: Any, *, path: str = \"root\", depth: int = 0) -> list[TextSource]:\n    if depth > 12:\n        return []\n    value = _coerce_jsonish(value)\n    sources: list[TextSource] = []\n\n    if isinstance(value, str):\n        text = _clean_scalar(value)\n        if text:\n            key = path.rsplit(\".\", 1)[-1].split(\"[\", 1)[0]\n            priority = 15\n            if _looks_urlish_key(key):\n                priority = 0\n            elif _looks_textish_key(key):\n                priority = 5\n            sources.append(\n                TextSource(\n                    text=text,\n                    path=path,\n                    priority=priority,\n                    media_index=_infer_media_index_from_path(path),\n                )\n            )\n        return sources\n\n    if isinstance(value, dict):\n        for key, child in value.items():\n            child_path = _path_join(path, str(key))\n            child_sources = _walk_text_sources(child, path=child_path, depth=depth + 1)\n            if _looks_urlish_key(str(key)):\n                child_sources = [\n                    TextSource(s.text, s.path, min(s.priority, 0), s.media_index) for s in child_sources\n                ]\n            elif _looks_textish_key(str(key)):\n                child_sources = [\n                    TextSource(s.text, s.path, min(s.priority, 5), s.media_index) for s in child_sources\n                ]\n            sources.extend(child_sources)\n        return sources\n\n    if isinstance(value, (list, tuple)):\n        for index, child in enumerate(value):\n            child_path = _path_join(path, f\"[{index}]\")\n            sources.extend(_walk_text_sources(child, path=child_path, depth=depth + 1))\n        return sources\n\n    return sources\n\n\ndef _trim_url_candidate(value: str) -> str:\n    text = _clean_scalar(value)\n    if not text:\n        return \"\"\n    text = text.strip(\"\\\"'`<>\")\n    while text and text[-1] in TRAILING_PUNCTUATION:\n        text = text[:-1]\n    if \"&amp;\" in text:\n        text = html.unescape(text)\n    return text\n\n\ndef _with_scheme(value: str) -> str:\n    text = _trim_url_candidate(value)\n    if not text:\n        return \"\"\n    lowered = text.lower()\n    if lowered.startswith((\"http://\", \"https://\")):\n        return text\n    if lowered.startswith((\"www.\", \"m.youtube.com/\", \"youtube.com/\", \"youtu.be/\", \"youtube-nocookie.com/\")):\n        return \"https://\" + text\n    return text\n\n\ndef _host_without_port(parsed: Any) -> str:\n    host = (parsed.hostname or \"\").lower()\n    return host[:-1] if host.endswith(\".\") else host\n\n\ndef _valid_video_id(value: str | None) -> str:\n    text = _clean_scalar(value)\n    if not text:\n        return \"\"\n    text = unquote(text).strip()\n    text = text.split(\"/\", 1)[0].split(\"?\", 1)[0].split(\"&\", 1)[0].split(\"#\", 1)[0]\n    return text if VIDEO_ID_RE.match(text) else \"\"\n\n\ndef _video_id_from_redirect_query(parsed: Any) -> str:\n    query = parse_qs(parsed.query, keep_blank_values=False)\n    for key in (\"url\", \"u\", \"q\", \"redirect_url\"):\n        for item in query.get(key, []):\n            video_id = _video_id_from_youtube_url(item)\n            if video_id:\n                return video_id\n    return \"\"\n\n\ndef _video_id_from_youtube_url(url: str) -> str:\n    normalized_input = _with_scheme(url)\n    parsed = urlparse(normalized_input)\n    host = _host_without_port(parsed)\n    path_parts = [unquote(part) for part in parsed.path.split(\"/\") if part]\n    query = parse_qs(parsed.query, keep_blank_values=False)\n\n    if host in SHORT_YOUTUBE_HOSTS:\n        return _valid_video_id(path_parts[0] if path_parts else \"\")\n\n    if host not in YOUTUBE_HOSTS:\n        return \"\"\n\n    if parsed.path.lower().startswith((\"/attribution_link\", \"/redirect\")):\n        redirected_id = _video_id_from_redirect_query(parsed)\n        if redirected_id:\n            return redirected_id\n\n    for value in query.get(\"v\", []):\n        video_id = _valid_video_id(value)\n        if video_id:\n            return video_id\n\n    if path_parts:\n        head = path_parts[0].lower()\n        if head in {\"shorts\", \"embed\", \"v\", \"live\"} and len(path_parts) >= 2:\n            video_id = _valid_video_id(path_parts[1])\n            if video_id:\n                return video_id\n\n    return \"\"\n\n\ndef _normalize_one_url(url: str) -> tuple[str, str]:\n    original = _with_scheme(url)\n    if not original:\n        return \"\", \"\"\n    video_id = _video_id_from_youtube_url(original)\n    if not video_id:\n        return original, \"\"\n    return original, f\"https://www.youtube.com/watch?v={video_id}\"\n\n\ndef _candidate_urls_from_text(text: str) -> list[str]:\n    clean = _clean_scalar(text)\n    if not clean:\n        return []\n    candidates: list[str] = []\n\n    whole = _with_scheme(clean)\n    whole_parsed = urlparse(whole)\n    if whole_parsed.hostname and _video_id_from_youtube_url(whole):\n        candidates.append(whole)\n\n    for match in URL_RE.finditer(clean):\n        candidate = _with_scheme(match.group(0))\n        if candidate:\n            candidates.append(candidate)\n\n    for match in re.finditer(r\"\\(([^()]+youtube[^()]*)\\)\", clean, flags=re.IGNORECASE):\n        candidate = _with_scheme(match.group(1))\n        if candidate:\n            candidates.append(candidate)\n\n    return candidates\n\n\ndef _source_excerpt(text: str, url: str, *, max_len: int = 240) -> str:\n    clean = _clean_scalar(text)\n    if len(clean) <= max_len:\n        return clean\n    index = clean.find(url)\n    if index < 0:\n        return clean[: max_len - 1] + \"...\"\n    start = max(0, index - 80)\n    end = min(len(clean), index + len(url) + 80)\n    prefix = \"...\" if start > 0 else \"\"\n    suffix = \"...\" if end < len(clean) else \"\"\n    return prefix + clean[start:end] + suffix\n\n\ndef _post_id_from_payload(value: Any) -> str | None:\n    value = _coerce_jsonish(value)\n    if isinstance(value, dict):\n        for key, child in value.items():\n            normalized_key = str(key).replace(\"-\", \"_\").lower()\n            if normalized_key in POST_ID_KEYS:\n                text = _clean_scalar(child)\n                if text:\n                    return text\n        for key, child in value.items():\n            normalized_key = str(key).replace(\"-\", \"_\").lower()\n            if normalized_key == \"id\" and isinstance(child, (str, int)):\n                text = _clean_scalar(child)\n                if text and len(text) >= 8:\n                    return text\n        for child in value.values():\n            found = _post_id_from_payload(child)\n            if found:\n                return found\n    elif isinstance(value, (list, tuple)):\n        for child in value:\n            found = _post_id_from_payload(child)\n            if found:\n                return found\n    return None\n\n\ndef _media_index_from_payload(value: Any) -> int | None:\n    value = _coerce_jsonish(value)\n    if isinstance(value, dict):\n        for key, child in value.items():\n            normalized_key = str(key).replace(\"-\", \"_\").lower()\n            if normalized_key in MEDIA_INDEX_KEYS:\n                index = _coerce_int(child)\n                if index is not None:\n                    return index\n        for child in value.values():\n            found = _media_index_from_payload(child)\n            if found is not None:\n                return found\n    elif isinstance(value, (list, tuple)):\n        for child in value:\n            found = _media_index_from_payload(child)\n            if found is not None:\n                return found\n    return None\n\n\ndef _dedupe_found(found: Iterable[YoutubeUrl]) -> list[YoutubeUrl]:\n    unique: list[YoutubeUrl] = []\n    seen: set[tuple[str, str]] = set()\n    for item in sorted(found, key=lambda x: (x.priority, x.order)):\n        key = (item.video_id, item.source_path)\n        if key in seen:\n            continue\n        seen.add(key)\n        unique.append(item)\n    by_video: list[YoutubeUrl] = []\n    seen_video: set[str] = set()\n    for item in unique:\n        if item.video_id in seen_video:\n            continue\n        seen_video.add(item.video_id)\n        by_video.append(item)\n    return by_video\n\n\ndef extract_youtube_urls(\n    payload: Any = None,\n    *,\n    text: str | None = None,\n    url: str | None = None,\n    card_url: str | None = None,\n    expanded_url: str | None = None,\n    post_id: str | int | None = None,\n    media_index: int | str | None = None,\n) -> dict[str, Any]:\n    \"\"\"Extract YouTube URLs from post text, card URLs, expanded URLs, or arbitrary JSON.\"\"\"\n    bundle: dict[str, Any] = {\"payload\": payload}\n    if text is not None:\n        bundle[\"text\"] = text\n    if url is not None:\n        bundle[\"url\"] = url\n    if card_url is not None:\n        bundle[\"cardUrl\"] = card_url\n    if expanded_url is not None:\n        bundle[\"expandedUrl\"] = expanded_url\n\n    sources = _walk_text_sources(bundle)\n    found: list[YoutubeUrl] = []\n    order = 0\n    for source in sources:\n        for candidate in _candidate_urls_from_text(source.text):\n            original, normalized = _normalize_one_url(candidate)\n            if not normalized:\n                continue\n            video_id = _video_id_from_youtube_url(original)\n            if not video_id:\n                continue\n            found.append(\n                YoutubeUrl(\n                    url=original,\n                    normalized_url=normalized,\n                    video_id=video_id,\n                    source_text=_source_excerpt(source.text, candidate),\n                    source_path=source.path,\n                    priority=source.priority,\n                    order=order,\n                    media_index=source.media_index,\n                )\n            )\n            order += 1\n\n    found = _dedupe_found(found)\n    selected = found[0] if found else None\n    resolved_post_id = _clean_scalar(post_id) or _post_id_from_payload(payload)\n    cli_media_index = _coerce_int(media_index)\n    resolved_media_index = cli_media_index\n    if resolved_media_index is None and selected is not None:\n        resolved_media_index = selected.media_index\n    if resolved_media_index is None:\n        resolved_media_index = _media_index_from_payload(payload)\n\n    result = {\n        \"ok\": selected is not None,\n        \"url\": selected.url if selected else \"\",\n        \"normalizedUrl\": selected.normalized_url if selected else \"\",\n        \"videoId\": selected.video_id if selected else \"\",\n        \"video_id\": selected.video_id if selected else \"\",\n        \"sourceText\": selected.source_text if selected else _source_excerpt(_clean_scalar(text or payload or \"\"), \"\"),\n        \"foundUrls\": [\n            {\n                \"url\": item.url,\n                \"normalizedUrl\": item.normalized_url,\n                \"videoId\": item.video_id,\n                \"video_id\": item.video_id,\n                \"sourceText\": item.source_text,\n                \"sourcePath\": item.source_path,\n                \"mediaIndex\": item.media_index,\n            }\n            for item in found\n        ],\n        \"postId\": resolved_post_id,\n        \"post_id\": resolved_post_id,\n        \"mediaIndex\": resolved_media_index,\n        \"media_index\": resolved_media_index,\n        \"externalExecution\": {\n            \"ran\": False,\n            \"reason\": \"This organ only extracts and normalizes YouTube URLs; subtitle, video, comment, and DB work are downstream.\",\n        },\n        \"savedPaths\": [],\n        \"downstreamScripts\": DOWNSTREAM_SCRIPT_HINTS,\n        \"failureReason\": \"\" if selected else \"No supported YouTube URL was found.\",\n    }\n    return result\n\n\ndef extract(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return extract_youtube_urls(payload, **kwargs)\n",
      "parent": "node-de37593461",
      "children": [],
      "style": {
