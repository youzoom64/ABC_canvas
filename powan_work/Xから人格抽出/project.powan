    {
      "id": "node-d2a790beb1",
      "title": "ニュース本文抽出ポワン",
      "body": "展開済みニュースURLを受け取り、C:\\project_root\\app_workspaces\\API\\scripts\\article_rag\\extractors.py の本文抽出材料を使って記事本文を抽出する臓器ポワン。RAG、embedding、検索、要約は行わず、タイトル、本文、URL、抽出方式、ページ分割の追跡、取得不能理由を返す。DB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport importlib\nimport json\nimport sys\nfrom collections.abc import Mapping\nfrom pathlib import Path\nfrom typing import Any\nfrom urllib.parse import urlparse\n\n\nAPI_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\")\nEXTRACTORS_MODULE = \"scripts.article_rag.extractors\"\n\nURL_KEYS = (\n    \"final_url\",\n    \"finalUrl\",\n    \"expanded_url\",\n    \"expandedUrl\",\n    \"canonical_url\",\n    \"canonicalUrl\",\n    \"url\",\n)\nPOST_ID_KEYS = (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\")\nRAW_JSON_KEYS = (\"raw_json\", \"rawJson\", \"raw\", \"source_json\", \"sourceJson\")\n\n\nclass NewsArticleExtractionError(RuntimeError):\n    pass\n\n\ndef ensure_api_import_path(api_root: str | Path = API_ROOT) -> Path:\n    root = Path(api_root).expanduser()\n    if not root.is_absolute():\n        root = (Path.cwd() / root).resolve()\n    if not root.exists():\n        raise NewsArticleExtractionError(f\"API workspace was not found: {root}\")\n    root_text = str(root)\n    if root_text not in sys.path:\n        sys.path.insert(0, root_text)\n    return root\n\n\ndef load_extractors(api_root: str | Path = API_ROOT) -> Any:\n    ensure_api_import_path(api_root)\n    return importlib.import_module(EXTRACTORS_MODULE)\n\n\ndef first_text(record: Mapping[str, Any], keys: tuple[str, ...]) -> str:\n    for key in keys:\n        value = record.get(key)\n        if value is not None:\n            text = str(value).strip()\n            if text:\n                return text\n    return \"\"\n\n\ndef first_raw_json(record: Mapping[str, Any]) -> Any:\n    for key in RAW_JSON_KEYS:\n        if key in record:\n            return record.get(key)\n    return None\n\n\ndef normalize_record(article_input: Any = None, *, url: str = \"\", post_id: str = \"\") -> dict[str, Any]:\n    if isinstance(article_input, Mapping):\n        record = dict(article_input)\n    elif isinstance(article_input, str) and article_input.strip():\n        record = {\"url\": article_input.strip()}\n    elif article_input is None:\n        record = {}\n    else:\n        raise NewsArticleExtractionError(\"article input must be a URL string or JSON object\")\n\n    if url:\n        record[\"url\"] = url.strip()\n    if post_id:\n        record[\"post_id\"] = str(post_id).strip()\n    return record\n\n\ndef choose_article_url(record: Mapping[str, Any]) -> str:\n    url = first_text(record, URL_KEYS)\n    if not url:\n        raise NewsArticleExtractionError(\"url is required\")\n    parsed = urlparse(url)\n    if parsed.scheme.lower() not in {\"http\", \"https\"} or not parsed.netloc:\n        raise NewsArticleExtractionError(f\"http(s) article URL is required: {url}\")\n    return url\n\n\ndef safe_metadata(value: Any) -> dict[str, Any]:\n    if isinstance(value, Mapping):\n        return dict(value)\n    return {}\n\n\ndef unavailable_reason(exc: BaseException) -> str:\n    message = str(exc).strip()\n    lowered = message.lower()\n    name = exc.__class__.__name__\n    if \"timeout\" in lowered or name in {\"Timeout\", \"ReadTimeout\", \"ConnectTimeout\"}:\n        return \"timeout\"\n    if \"403\" in lowered or \"forbidden\" in lowered:\n        return \"forbidden\"\n    if \"404\" in lowered or \"not found\" in lowered:\n        return \"not_found\"\n    if \"429\" in lowered or \"too many requests\" in lowered:\n        return \"rate_limited\"\n    if \"ssl\" in lowered or \"certificate\" in lowered:\n        return \"tls_error\"\n    if \"name or service not known\" in lowered or \"nodename\" in lowered or \"dns\" in lowered:\n        return \"dns_error\"\n    if \"connection\" in lowered:\n        return \"connection_error\"\n    if \"empty\" in lowered or \"本文\" in message or \"body\" in lowered:\n        return \"empty_body\"\n    return \"extract_failed\"\n\n\ndef make_error_result(\n    record: Mapping[str, Any],\n    request_url: str,\n    exc: BaseException,\n    *,\n    api_root: str | Path = API_ROOT,\n) -> dict[str, Any]:\n    message = str(exc).strip() or exc.__class__.__name__\n    return {\n        \"ok\": False,\n        \"post_id\": first_text(record, POST_ID_KEYS),\n        \"url\": first_text(record, (\"url\",)) or request_url,\n        \"final_url\": first_text(record, (\"final_url\", \"finalUrl\", \"expanded_url\", \"expandedUrl\")) or request_url,\n        \"canonical_url\": first_text(record, (\"canonical_url\", \"canonicalUrl\")) or \"\",\n        \"title\": \"\",\n        \"text\": \"\",\n        \"metadata\": {\n            \"source_module\": EXTRACTORS_MODULE,\n            \"api_root\": str(Path(api_root)),\n            \"unavailable_reason\": unavailable_reason(exc),\n            \"error_type\": exc.__class__.__name__,\n        },\n        \"error\": {\n            \"type\": exc.__class__.__name__,\n            \"message\": message,\n            \"reason\": unavailable_reason(exc),\n        },\n        \"raw_json\": first_raw_json(record),\n    }\n\n\ndef content_to_result(\n    record: Mapping[str, Any],\n    request_url: str,\n    content: Any,\n    *,\n    api_root: str | Path = API_ROOT,\n) -> dict[str, Any]:\n    metadata = safe_metadata(getattr(content, \"metadata\", None))\n    page_urls = list(metadata.get(\"page_urls\") or [])\n    final_url = str(getattr(content, \"url\", \"\") or request_url)\n    extractor = str(metadata.get(\"extractor\") or \"\").strip()\n\n    metadata.update(\n        {\n            \"source_module\": EXTRACTORS_MODULE,\n            \"source_type\": str(getattr(content, \"source_type\", \"\") or \"web_article\"),\n            \"published_at\": getattr(content, \"published_at\", None),\n            \"request_url\": request_url,\n            \"input_url\": first_text(record, (\"url\",)),\n            \"api_root\": str(Path(api_root)),\n            \"page_count\": int(metadata.get(\"page_count\") or len(page_urls) or 1),\n            \"page_urls\": page_urls or [final_url],\n        }\n    )\n    if extractor:\n        metadata[\"extractor\"] = extractor\n\n    return {\n        \"ok\": True,\n        \"post_id\": first_text(record, POST_ID_KEYS),\n        \"url\": first_text(record, (\"url\",)) or request_url,\n        \"final_url\": final_url,\n        \"canonical_url\": final_url,\n        \"title\": str(getattr(content, \"title\", \"\") or \"\").strip(),\n        \"text\": str(getattr(content, \"body\", \"\") or \"\").strip(),\n        \"metadata\": metadata,\n        \"error\": None,\n        \"raw_json\": first_raw_json(record),\n    }\n\n\ndef extract_news_article(\n    article_input: Any = None,\n    *,\n    url: str = \"\",\n    post_id: str = \"\",\n    timeout: float = 20.0,\n    max_pages: int = 5,\n    api_root: str | Path = API_ROOT,\n) -> dict[str, Any]:\n    \"\"\"Extract only article body material from an already expanded news URL.\n\n    This organ intentionally does not call article_rag.service.ingest_url,\n    search_similar, ask, embedding helpers, chat helpers, or any DB writer.\n    \"\"\"\n    record: dict[str, Any] = {}\n    request_url = url.strip()\n    try:\n        record = normalize_record(article_input, url=url, post_id=post_id)\n        request_url = choose_article_url(record)\n        extractors = load_extractors(api_root)\n        extract_web_article = getattr(extractors, \"_extract_web_article\", None)\n        if callable(extract_web_article):\n            content = extract_web_article(\n                request_url,\n                timeout=float(timeout),\n                max_pages=max(1, int(max_pages)),\n            )\n        else:\n            extract_content = getattr(extractors, \"_extract_content\", None)\n            if not callable(extract_content):\n                raise NewsArticleExtractionError(\"article extractor function was not found\")\n            content = extract_content(\n                request_url,\n                \"web_article\",\n                \"ja\",\n                False,\n                \"base\",\n                max(1, int(max_pages)),\n            )\n\n        result = content_to_result(record, request_url, content, api_root=api_root)\n        if not result[\"text\"]:\n            raise NewsArticleExtractionError(\"Extracted article body is empty.\")\n        return result\n    except Exception as exc:\n        return make_error_result(record, request_url, exc, api_root=api_root)\n\n\ndef extract_news_articles(\n    items: list[Any],\n    *,\n    timeout: float = 20.0,\n    max_pages: int = 5,\n    api_root: str | Path = API_ROOT,\n) -> list[dict[str, Any]]:\n    return [\n        extract_news_article(\n            item,\n            timeout=timeout,\n            max_pages=max_pages,\n            api_root=api_root,\n        )\n        for item in items\n    ]\n\n\ndef path_or_json(value: str) -> Any:\n    if not value or value == \"-\":\n        return json.load(sys.stdin)\n    try:\n        path = Path(value)\n        if path.exists():\n            return json.loads(path.read_text(encoding=\"utf-8\"))\n    except OSError:\n        pass\n    return json.loads(value)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Extract a news article body without RAG or DB writes.\")\n    parser.add_argument(\"--input-json\", default=\"\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--url\", default=\"\", help=\"Already expanded news article URL.\")\n    parser.add_argument(\"--post-id\", default=\"\")\n    parser.add_argument(\"--timeout\", type=float, default=20.0)\n    parser.add_argument(\"--max-pages\", type=int, default=5)\n    parser.add_argument(\"--api-root\", default=str(API_ROOT))\n    args = parser.parse_args(argv)\n\n    try:\n        payload = path_or_json(args.input_json) if args.input_json else None\n        if isinstance(payload, list):\n            result: Any = extract_news_articles(\n                payload,\n                timeout=args.timeout,\n                max_pages=args.max_pages,\n                api_root=args.api_root,\n            )\n        else:\n            result = extract_news_article(\n                payload,\n                url=args.url,\n                post_id=args.post_id,\n                timeout=args.timeout,\n                max_pages=args.max_pages,\n                api_root=args.api_root,\n            )\n    except Exception as exc:\n        record = {\"url\": args.url, \"post_id\": args.post_id}\n        result = make_error_result(record, args.url, exc, api_root=args.api_root)\n\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    if isinstance(result, list):\n        return 0 if all(item.get(\"ok\") for item in result if isinstance(item, dict)) else 1\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
