    {
      "id": "node-de37593461",
      "title": "YouTube内容確認ポワン",
      "body": "終端投稿にYouTubeリンクやYouTubeカードが含まれている時、そのYouTube動画を確認対象として扱う神経ポワン。X終端投稿からYouTube URLを抽出し、既存のAPI scripts材料を使って字幕、動画保存、音声文字起こし、代表フレーム、コメントを取得し、最後にDBへ保存する流れを束ねる。本文だけではなく、字幕・映像・音声・コメントなど確認した材料をすべて保存対象にする。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom collections.abc import Callable, Mapping, Sequence\nfrom dataclasses import dataclass\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\nURL_EXTRACTOR = \"YouTube URL抽出ポワン\"\nSUBTITLE_FETCHER = \"YouTube字幕取得ポワン\"\nVIDEO_SAVER = \"YouTube動画保存ポワン\"\nTRANSCRIBER = \"YouTube音声文字起こしポワン\"\nFRAME_EXTRACTOR = \"YouTube代表フレーム抽出ポワン\"\nCOMMENT_FETCHER = \"YouTubeコメント取得ポワン\"\nDB_SAVER = \"YouTube内容DB保存ポワン\"\nSELF_TITLE = \"YouTube内容確認ポワン\"\nCOMPONENT_TYPE = \"youtube\"\n\nPIPELINE = [URL_EXTRACTOR, SUBTITLE_FETCHER, VIDEO_SAVER, TRANSCRIBER, FRAME_EXTRACTOR, COMMENT_FETCHER, DB_SAVER]\nDEFAULT_OPTIONS = {\"minSubtitleChars\": 80, \"saveFailures\": True, \"strictMissingRunners\": False}\nRETRYABLE_ERRORS = {\"download_failed\", \"transcription_failed\", \"comments_unavailable\", \"extractor_failed\", \"db_write_failed\"}\nFATAL_URL_ERRORS = {\"youtube_url_invalid\", \"private_or_deleted\", \"age_or_region_restricted\", \"video_unavailable\"}\nChildRunner = Callable[[dict[str, Any]], Any]\n\n\n@dataclass\nclass ChildCall:\n    title: str\n    input: dict[str, Any]\n    status: str\n    ok: bool\n    result: Any = None\n    failure_reason: str = \"\"\n\n    def as_dict(self) -> dict[str, Any]:\n        return json_safe({\n            \"title\": self.title,\n            \"status\": self.status,\n            \"ok\": self.ok,\n            \"input\": self.input,\n            \"result\": self.result,\n            \"failureReason\": self.failure_reason,\n        })\n\n\ndef confirm_youtube_content(\n    input_json: Any,\n    *,\n    child_runners: Mapping[str, ChildRunner] | None = None,\n    child_results: Mapping[str, Any] | list[Any] | None = None,\n    options: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    return handle_youtube_component(input_json, child_runners=child_runners, child_results=child_results, options=options)\n\n\ndef handle_youtube_component(\n    input_json: Any,\n    *,\n    child_runners: Mapping[str, ChildRunner] | None = None,\n    child_results: Mapping[str, Any] | list[Any] | None = None,\n    options: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    opts = {**DEFAULT_OPTIONS, **dict(options or {})}\n    runners = dict(child_runners or {})\n    precomputed = normalize_child_results(child_results)\n    payload = normalize_input(input_json)\n    envelope = normalize_envelope(payload)\n    url_records = normalize_url_records(payload, envelope)\n    started_at = utc_now()\n\n    if not url_records:\n        context = base_context(envelope, {}, 0)\n        child_result = build_empty_child_result(context, \"skipped\", \"youtube_url_invalid\", \"youtube_urls was empty.\", started_at)\n        finalize_observability(child_result, opts)\n        return {\"ok\": False, \"status\": \"skipped\", \"child_result\": child_result, \"items\": [], \"failureReason\": child_result[\"error_message\"]}\n\n    item_results = []\n    for index, record in enumerate(url_records):\n        item_results.append(process_one_url(envelope, record, index, runners, precomputed, opts))\n\n    aggregate = aggregate_child_result(envelope, item_results, started_at)\n    finalize_observability(aggregate, opts)\n    return {\n        \"ok\": aggregate[\"status\"] in {\"success\", \"partial\"},\n        \"status\": aggregate[\"status\"],\n        \"child_result\": aggregate,\n        \"items\": item_results,\n        \"jsonl_events\": aggregate.get(\"jsonl_events\", []),\n        \"runs_log_summary\": aggregate.get(\"runs_log_summary\", \"\"),\n        \"failureReason\": aggregate.get(\"error_message\", \"\"),\n    }\n\n\ndef process_one_url(\n    envelope: dict[str, Any],\n    url_record: dict[str, Any],\n    index: int,\n    runners: Mapping[str, ChildRunner],\n    precomputed: Mapping[str, Any],\n    options: Mapping[str, Any],\n) -> dict[str, Any]:\n    started_at = utc_now()\n    context = base_context(envelope, url_record, index)\n    children: dict[str, dict[str, Any]] = {}\n    errors: list[dict[str, Any]] = []\n\n    def remember(call: ChildCall) -> dict[str, Any]:\n        data = call.as_dict()\n        children[call.title] = data\n        if not call.ok and call.failure_reason:\n            errors.append(error_entry(call.title, classify_error(call.failure_reason, call.title), call.failure_reason))\n        return data\n\n    url_input = build_child_input(URL_EXTRACTOR, envelope, url_record, context, children)\n    url_call = remember(run_child(URL_EXTRACTOR, url_input, runners, precomputed, options, index))\n    url_context = extract_url_context(url_call.get(\"result\"), url_record, context)\n    context.update({\"source_url\": url_context.get(\"source_url\") or context.get(\"source_url\"), \"video_id\": url_context.get(\"video_id\"), \"canonical_url\": url_context.get(\"canonical_url\")})\n\n    if not url_context.get(\"canonical_url\") or not url_context.get(\"video_id\"):\n        errors.append(error_entry(URL_EXTRACTOR, \"youtube_url_invalid\", \"YouTube URL normalization or video_id extraction failed.\"))\n        item = build_item_child_result(envelope, context, url_record, url_context, children, errors, \"none\", False, started_at)\n        db_result = save_item(item, envelope, url_record, url_context, children, errors, runners, precomputed, options, index)\n        return finish_item_after_save(item, db_result, errors)\n\n    subtitle_call = remember(run_child(SUBTITLE_FETCHER, build_child_input(SUBTITLE_FETCHER, envelope, url_record, context, children), runners, precomputed, options, index))\n    subtitle_ok = has_usable_subtitle(subtitle_call.get(\"result\"), options)\n    primary_evidence = \"subtitle\" if subtitle_ok else \"none\"\n    if not subtitle_ok:\n        errors.append(error_entry(SUBTITLE_FETCHER, \"subtitles_unavailable\", \"Subtitle was missing or too short.\"))\n        video_call = remember(run_child(VIDEO_SAVER, build_child_input(VIDEO_SAVER, envelope, url_record, context, children), runners, precomputed, options, index))\n        video_context = extract_video_context(video_call.get(\"result\"))\n        if child_call_ok(video_call) and video_context.get(\"downloaded_video_path\"):\n            transcript_input = build_child_input(TRANSCRIBER, envelope, url_record, context, children, {\"video\": video_context})\n            transcript_call = remember(run_child(TRANSCRIBER, transcript_input, runners, precomputed, options, index))\n            if has_usable_transcript(transcript_call.get(\"result\"), options):\n                primary_evidence = \"transcript\"\n            else:\n                errors.append(error_entry(TRANSCRIBER, \"transcription_failed\", \"Transcript was missing or not usable.\"))\n            frame_input = build_child_input(FRAME_EXTRACTOR, envelope, url_record, context, children, {\"video\": video_context})\n            remember(run_child(FRAME_EXTRACTOR, frame_input, runners, precomputed, options, index))\n        else:\n            errors.append(error_entry(VIDEO_SAVER, \"download_failed\", video_call.get(\"failureReason\") or \"Video was not saved.\"))\n            remember(skipped_child(TRANSCRIBER, \"Video save result did not provide a local video path.\", envelope, url_record, context, children))\n            remember(skipped_child(FRAME_EXTRACTOR, \"Video save result did not provide a local video path.\", envelope, url_record, context, children))\n\n    comments_call = remember(run_child(COMMENT_FETCHER, build_child_input(COMMENT_FETCHER, envelope, url_record, context, children), runners, precomputed, options, index))\n    if not child_call_ok(comments_call):\n        errors.append(error_entry(COMMENT_FETCHER, \"comments_unavailable\", comments_call.get(\"failureReason\") or \"Comments were unavailable.\"))\n\n    item = build_item_child_result(envelope, context, url_record, url_context, children, errors, primary_evidence, subtitle_ok, started_at)\n    db_result = save_item(item, envelope, url_record, url_context, children, errors, runners, precomputed, options, index)\n    return finish_item_after_save(item, db_result, errors)\n\n\ndef build_child_input(\n    title: str,\n    envelope: Mapping[str, Any],\n    url_record: Mapping[str, Any],\n    context: Mapping[str, Any],\n    previous: Mapping[str, Any],\n    extra: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    url = first_text(url_record, \"canonical_url\", \"canonicalUrl\", \"expanded_url\", \"expandedUrl\", \"raw_url\", \"rawUrl\", \"url\") or context.get(\"source_url\") or \"\"\n    data = {\n        \"sourcePowan\": SELF_TITLE,\n        \"childTitle\": title,\n        \"component_type\": COMPONENT_TYPE,\n        \"componentType\": COMPONENT_TYPE,\n        \"terminal_post_envelope\": envelope,\n        \"youtube_url\": url_record,\n        \"youtube_urls\": [url_record],\n        \"run_id\": context.get(\"run_id\"),\n        \"trace_id\": context.get(\"trace_id\"),\n        \"terminal_post_id\": context.get(\"terminal_post_id\"),\n        \"terminal_post_url\": context.get(\"terminal_post_url\"),\n        \"source_url\": context.get(\"source_url\") or url,\n        \"url\": url,\n        \"raw_url\": first_text(url_record, \"raw_url\", \"rawUrl\") or url,\n        \"expanded_url\": first_text(url_record, \"expanded_url\", \"expandedUrl\") or url,\n        \"canonical_url\": first_text(url_record, \"canonical_url\", \"canonicalUrl\") or url,\n        \"videoId\": context.get(\"video_id\") or first_text(url_record, \"video_id\", \"videoId\"),\n        \"video_id\": context.get(\"video_id\") or first_text(url_record, \"video_id\", \"videoId\"),\n        \"postId\": context.get(\"terminal_post_id\"),\n        \"post_id\": context.get(\"terminal_post_id\"),\n        \"source_entity_index\": url_record.get(\"source_entity_index\", url_record.get(\"sourceEntityIndex\")),\n        \"evidence_url\": first_text(url_record, \"evidence_url\", \"evidenceUrl\") or context.get(\"source_url\"),\n        \"previousChildren\": previous,\n    }\n    if extra:\n        data.update(dict(extra))\n    return json_safe(data)\n\n\ndef run_child(\n    title: str,\n    child_input: dict[str, Any],\n    runners: Mapping[str, ChildRunner],\n    precomputed: Mapping[str, Any],\n    options: Mapping[str, Any],\n    index: int,\n) -> ChildCall:\n    found, result = precomputed_for(precomputed, title, index)\n    if found:\n        return ChildCall(title, child_input, \"precomputed\", result_looks_ok(result), json_safe(result), extract_failure_reason(result))\n    runner = runners.get(title)\n    if runner is None:\n        reason = \"No child runner or precomputed child result was supplied.\"\n        status = \"missing_runner\" if options.get(\"strictMissingRunners\") else \"skipped\"\n        return ChildCall(title, child_input, status, False, None, reason)\n    try:\n        result = runner(child_input)\n    except Exception as exc:\n        return ChildCall(title, child_input, \"error\", False, None, str(exc) or exc.__class__.__name__)\n    return ChildCall(title, child_input, \"completed\", result_looks_ok(result), json_safe(result), extract_failure_reason(result))\n\n\ndef skipped_child(title: str, reason: str, envelope: Mapping[str, Any], url_record: Mapping[str, Any], context: Mapping[str, Any], previous: Mapping[str, Any]) -> ChildCall:\n    return ChildCall(title, build_child_input(title, envelope, url_record, context, previous), \"skipped\", False, None, reason)\n\n\ndef save_item(\n    item: Mapping[str, Any],\n    envelope: Mapping[str, Any],\n    url_record: Mapping[str, Any],\n    url_context: Mapping[str, Any],\n    children: Mapping[str, Any],\n    errors: list[dict[str, Any]],\n    runners: Mapping[str, ChildRunner],\n    precomputed: Mapping[str, Any],\n    options: Mapping[str, Any],\n    index: int,\n) -> dict[str, Any]:\n    db_payload = json_safe({\n        \"sourcePowan\": SELF_TITLE,\n        \"component_type\": COMPONENT_TYPE,\n        \"componentType\": COMPONENT_TYPE,\n        \"run_id\": item.get(\"run_id\"),\n        \"trace_id\": item.get(\"trace_id\"),\n        \"terminal_post_id\": item.get(\"terminal_post_id\"),\n        \"terminal_post_url\": item.get(\"terminal_post_url\"),\n        \"source_url\": item.get(\"source_url\"),\n        \"url\": item.get(\"canonical_url\") or item.get(\"source_url\"),\n        \"canonical_url\": item.get(\"canonical_url\"),\n        \"videoId\": item.get(\"video_id\"),\n        \"video_id\": item.get(\"video_id\"),\n        \"postId\": item.get(\"terminal_post_id\"),\n        \"post_id\": item.get(\"terminal_post_id\"),\n        \"terminal_post_envelope\": envelope,\n        \"youtube_url\": url_record,\n        \"youtube\": url_context,\n        \"primaryEvidence\": item.get(\"primary_evidence\"),\n        \"child_result\": item,\n        \"childResults\": children,\n        \"failures\": errors,\n        \"jsonl_events\": item.get(\"jsonl_events\", []),\n        \"runs_log_summary\": item.get(\"runs_log_summary\", \"\"),\n    })\n    call = run_child(DB_SAVER, db_payload, runners, precomputed, options, index)\n    return call.as_dict()\n\n\ndef finish_item_after_save(item: dict[str, Any], db_result: Mapping[str, Any], errors: list[dict[str, Any]]) -> dict[str, Any]:\n    item[\"db_result\"] = json_safe(db_result)\n    merge_db_artifacts(item, db_result)\n    if not child_call_ok(db_result):\n        db_error = error_entry(DB_SAVER, \"db_write_failed\", db_result.get(\"failureReason\") or \"DB save failed.\")\n        if db_error not in errors:\n            errors.append(db_error)\n    item[\"errors\"] = json_safe(errors)\n    item[\"error_type\"] = first_error_type(errors)\n    item[\"error_message\"] = summarize_errors(errors)\n    item[\"retryable\"] = any(bool(err.get(\"retryable\")) for err in errors)\n    item[\"status\"] = choose_item_status(item, db_result, errors)\n    item[\"finished_at\"] = utc_now()\n    item[\"jsonl_events\"] = [jsonl_event_for_item(item)]\n    item[\"runs_log_summary\"] = runs_summary_for_item(item)\n    return json_safe(item)\n\n\n\ndef merge_db_artifacts(item: dict[str, Any], db_result: Mapping[str, Any]) -> None:\n    refs = db_artifact_refs(db_result)\n    if refs:\n        paths = dedupe_texts(as_list(item.get(\"artifact_paths\")) + refs)\n        item[\"artifact_paths\"] = paths\n        item[\"artifactPaths\"] = paths\n    extracted = dict(item.get(\"extracted_metadata\") or {})\n    extracted[\"db_ref\"] = first_mapping(unwrap_child_result(db_result))\n    item[\"extracted_metadata\"] = json_safe(extracted)\n    item[\"extractedMetadata\"] = json_safe(extracted)\n\n\ndef db_artifact_refs(db_result: Mapping[str, Any]) -> list[str]:\n    data = first_mapping(unwrap_child_result(db_result))\n    refs = []\n    db_path = first_text(data, \"dbPath\", \"db_path\")\n    if db_path:\n        refs.append(db_path)\n    source_key = first_text(data, \"sourceKey\", \"source_key\")\n    if source_key:\n        refs.append(f\"db:source:{source_key}\")\n    run_id = first_text(data, \"runId\", \"run_id\")\n    if run_id:\n        refs.append(f\"db:run:{run_id}\")\n    return refs\n\ndef build_item_child_result(\n    envelope: Mapping[str, Any],\n    context: Mapping[str, Any],\n    url_record: Mapping[str, Any],\n    url_context: Mapping[str, Any],\n    children: Mapping[str, Any],\n    errors: list[dict[str, Any]],\n    primary_evidence: str,\n    subtitle_adequate: bool,\n    started_at: str,\n) -> dict[str, Any]:\n    metadata = collect_metadata(url_record, url_context, children)\n    subtitle_tracks = subtitle_refs(children.get(SUBTITLE_FETCHER))\n    transcript = transcript_ref(children.get(TRANSCRIBER))\n    video_path = downloaded_video_path(children.get(VIDEO_SAVER))\n    frames = frame_paths(children.get(FRAME_EXTRACTOR))\n    comments = comments_ref(children.get(COMMENT_FETCHER))\n    tools = tool_info(children)\n    evidence = evidence_json(envelope, url_record, url_context, children)\n    artifact_paths = collect_artifact_paths(children)\n    extracted_metadata = json_safe({\n        \"video_id\": url_context.get(\"video_id\") or context.get(\"video_id\"),\n        \"canonical_url\": url_context.get(\"canonical_url\") or context.get(\"canonical_url\"),\n        \"metadata\": metadata,\n        \"subtitle_tracks\": subtitle_tracks,\n        \"transcript_ref\": transcript,\n        \"downloaded_video_path\": video_path,\n        \"frame_paths\": frames,\n        \"comments_ref\": comments,\n        \"tool_versions\": tools,\n    })\n    result = {\n        \"status\": \"partial\",\n        \"component_type\": COMPONENT_TYPE,\n        \"componentType\": COMPONENT_TYPE,\n        \"run_id\": context.get(\"run_id\"),\n        \"trace_id\": context.get(\"trace_id\"),\n        \"terminal_post_id\": context.get(\"terminal_post_id\"),\n        \"terminal_post_url\": context.get(\"terminal_post_url\"),\n        \"source_url\": context.get(\"source_url\") or url_context.get(\"source_url\"),\n        \"video_id\": extracted_metadata.get(\"video_id\"),\n        \"videoId\": extracted_metadata.get(\"video_id\"),\n        \"canonical_url\": extracted_metadata.get(\"canonical_url\"),\n        \"canonicalUrl\": extracted_metadata.get(\"canonical_url\"),\n        \"metadata\": metadata,\n        \"subtitle_tracks\": subtitle_tracks,\n        \"subtitleTracks\": subtitle_tracks,\n        \"transcript_ref\": transcript,\n        \"transcriptRef\": transcript,\n        \"downloaded_video_path\": video_path,\n        \"downloadedVideoPath\": video_path,\n        \"frame_paths\": frames,\n        \"framePaths\": frames,\n        \"comments_ref\": comments,\n        \"commentsRef\": comments,\n        \"tool_versions\": tools,\n        \"toolVersions\": tools,\n        \"evidence_json\": evidence,\n        \"evidenceJson\": evidence,\n        \"artifact_paths\": artifact_paths,\n        \"artifactPaths\": artifact_paths,\n        \"extracted_metadata\": extracted_metadata,\n        \"extractedMetadata\": extracted_metadata,\n        \"model_or_tool_info\": tools,\n        \"modelOrToolInfo\": tools,\n        \"primary_evidence\": primary_evidence,\n        \"primaryEvidence\": primary_evidence,\n        \"subtitle_adequate\": subtitle_adequate,\n        \"child_results\": children,\n        \"childResults\": children,\n        \"errors\": errors,\n        \"error_type\": first_error_type(errors),\n        \"error_message\": summarize_errors(errors),\n        \"retryable\": any(bool(err.get(\"retryable\")) for err in errors),\n        \"started_at\": started_at,\n        \"finished_at\": utc_now(),\n    }\n    result[\"status\"] = choose_material_status(result, errors)\n    result[\"jsonl_events\"] = [jsonl_event_for_item(result)]\n    result[\"runs_log_summary\"] = runs_summary_for_item(result)\n    return json_safe(result)\n\n\ndef aggregate_child_result(envelope: Mapping[str, Any], items: list[Mapping[str, Any]], started_at: str) -> dict[str, Any]:\n    status = aggregate_status([str(item.get(\"status\") or \"failed\") for item in items])\n    errors = [err for item in items for err in as_list(item.get(\"errors\")) if isinstance(err, Mapping)]\n    artifact_paths = []\n    for item in items:\n        artifact_paths.extend(as_list(item.get(\"artifact_paths\")))\n    events = [event for item in items for event in as_list(item.get(\"jsonl_events\"))]\n    context = base_context(envelope, {}, 0)\n    source_url = first_text(items[0], \"source_url\", \"canonical_url\") if items else \"\"\n    result = {\n        \"status\": status,\n        \"component_type\": COMPONENT_TYPE,\n        \"componentType\": COMPONENT_TYPE,\n        \"run_id\": context.get(\"run_id\"),\n        \"trace_id\": context.get(\"trace_id\"),\n        \"terminal_post_id\": context.get(\"terminal_post_id\"),\n        \"terminal_post_url\": context.get(\"terminal_post_url\"),\n        \"source_url\": source_url,\n        \"artifact_paths\": dedupe_texts(artifact_paths),\n        \"artifactPaths\": dedupe_texts(artifact_paths),\n        \"extracted_metadata\": {\"item_count\": len(items), \"statuses\": [item.get(\"status\") for item in items]},\n        \"extractedMetadata\": {\"item_count\": len(items), \"statuses\": [item.get(\"status\") for item in items]},\n        \"model_or_tool_info\": {\"orchestrator\": SELF_TITLE, \"children\": PIPELINE},\n        \"modelOrToolInfo\": {\"orchestrator\": SELF_TITLE, \"children\": PIPELINE},\n        \"evidence_json\": {\"parent_trace\": envelope.get(\"parent_trace\"), \"discovery_path\": envelope.get(\"discovery_path\"), \"evidence_urls\": envelope.get(\"evidence_urls\"), \"items\": [item.get(\"evidence_json\") for item in items]},\n        \"evidenceJson\": {\"parent_trace\": envelope.get(\"parent_trace\"), \"discovery_path\": envelope.get(\"discovery_path\"), \"evidence_urls\": envelope.get(\"evidence_urls\"), \"items\": [item.get(\"evidence_json\") for item in items]},\n        \"error_type\": first_error_type(errors),\n        \"error_message\": summarize_errors(errors),\n        \"retryable\": any(bool(err.get(\"retryable\")) for err in errors),\n        \"items\": items,\n        \"jsonl_events\": events,\n        \"runs_log_summary\": runs_summary_for_aggregate(envelope, items),\n        \"started_at\": started_at,\n        \"finished_at\": utc_now(),\n    }\n    return json_safe(result)\n\n\ndef normalize_envelope(payload: Mapping[str, Any]) -> dict[str, Any]:\n    envelope = payload.get(\"terminal_post_envelope\") or payload.get(\"terminalPostEnvelope\") or payload.get(\"envelope\") or payload\n    return json_safe(dict(envelope)) if isinstance(envelope, Mapping) else {}\n\n\ndef normalize_url_records(payload: Mapping[str, Any], envelope: Mapping[str, Any]) -> list[dict[str, Any]]:\n    value = first_present(payload, \"youtube_urls\", \"youtubeUrls\")\n    if value is None:\n        value = first_present(envelope, \"youtube_urls\", \"youtubeUrls\")\n    if value is None and isinstance(payload.get(\"component\"), Mapping):\n        value = first_present(payload[\"component\"], \"youtube_urls\", \"youtubeUrls\", \"urls\")\n    if value is None:\n        value = first_present(payload, \"urls\", \"evidence_urls\", \"evidenceUrls\")\n    records = []\n    for index, item in enumerate(as_list(value)):\n        if isinstance(item, Mapping):\n            record = dict(item)\n        else:\n            record = {\"raw_url\": str(item)}\n        record.setdefault(\"source_entity_index\", index)\n        records.append(json_safe(record))\n    return records\n\n\ndef base_context(envelope: Mapping[str, Any], url_record: Mapping[str, Any], index: int) -> dict[str, Any]:\n    source_url = first_text(url_record, \"canonical_url\", \"canonicalUrl\", \"expanded_url\", \"expandedUrl\", \"raw_url\", \"rawUrl\", \"url\", \"evidence_url\", \"evidenceUrl\")\n    return {\n        \"run_id\": first_text(envelope, \"run_id\", \"runId\"),\n        \"trace_id\": first_text(envelope, \"trace_id\", \"traceId\"),\n        \"terminal_post_id\": first_text(envelope, \"terminal_post_id\", \"terminalPostId\", \"post_id\", \"postId\"),\n        \"terminal_post_url\": first_text(envelope, \"terminal_post_url\", \"terminalPostUrl\", \"url\"),\n        \"component_type\": COMPONENT_TYPE,\n        \"source_url\": source_url,\n        \"source_entity_index\": url_record.get(\"source_entity_index\", url_record.get(\"sourceEntityIndex\", index)),\n        \"canonical_url\": first_text(url_record, \"canonical_url\", \"canonicalUrl\") or source_url,\n        \"video_id\": first_text(url_record, \"video_id\", \"videoId\"),\n    }\n\n\ndef extract_url_context(result: Any, url_record: Mapping[str, Any], context: Mapping[str, Any]) -> dict[str, Any]:\n    data = unwrap_result(result)\n    first_found = first_mapping(data.get(\"foundUrls\") if isinstance(data, Mapping) else None)\n    canonical = first_text(data, \"normalizedUrl\", \"canonicalUrl\", \"canonical_url\", \"url\") or first_text(first_found, \"normalizedUrl\", \"canonicalUrl\", \"url\") or context.get(\"canonical_url\") or \"\"\n    video_id = first_text(data, \"videoId\", \"video_id\") or first_text(first_found, \"videoId\", \"video_id\") or first_text(url_record, \"video_id\", \"videoId\")\n    return {\n        \"source_url\": first_text(url_record, \"raw_url\", \"rawUrl\", \"expanded_url\", \"expandedUrl\", \"url\") or canonical,\n        \"canonical_url\": canonical,\n        \"canonicalUrl\": canonical,\n        \"video_id\": video_id,\n        \"videoId\": video_id,\n        \"raw_url\": first_text(url_record, \"raw_url\", \"rawUrl\"),\n        \"expanded_url\": first_text(url_record, \"expanded_url\", \"expandedUrl\"),\n        \"evidence_url\": first_text(url_record, \"evidence_url\", \"evidenceUrl\") or context.get(\"source_url\"),\n        \"source_entity_index\": context.get(\"source_entity_index\"),\n    }\n\n\ndef extract_video_context(result: Any) -> dict[str, Any]:\n    data = unwrap_result(result)\n    local_path = first_text(data, \"localPath\", \"local_path\", \"filePath\", \"path\", \"savedPath\", \"videoPath\")\n    return {\"downloaded_video_path\": local_path, \"localPath\": local_path, \"video_id\": first_text(data, \"videoId\", \"video_id\"), \"sha256\": first_text(data, \"sha256\")}\n\n\ndef has_usable_subtitle(result: Any, options: Mapping[str, Any]) -> bool:\n    data = unwrap_result(result)\n    if not result_looks_ok(data) or truthy_flag(data, \"insufficient\", \"isInsufficient\", \"subtitleInsufficient\"):\n        return False\n    text = joined_text(data, \"subtitleText\", \"subtitle_text\", \"text\", \"transcript\", \"content\", \"body\")\n    if len(text.strip()) >= int(options.get(\"minSubtitleChars\") or 0):\n        return True\n    return bool(non_empty_list(data, \"subtitleTracks\", \"tracks\", \"segments\", \"subtitles\", \"captions\") or first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\") or non_empty_list(data, \"savedPaths\", \"files\"))\n\n\ndef has_usable_transcript(result: Any, options: Mapping[str, Any]) -> bool:\n    data = unwrap_result(result)\n    if not result_looks_ok(data):\n        return False\n    text = joined_text(data, \"transcript\", \"transcriptText\", \"text\", \"content\", \"body\")\n    if len(text.strip()) >= int(options.get(\"minTranscriptChars\") or options.get(\"minSubtitleChars\") or 0):\n        return True\n    return bool(non_empty_list(data, \"segments\", \"utterances\") or first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\"))\n\n\ndef choose_material_status(item: Mapping[str, Any], errors: list[dict[str, Any]]) -> str:\n    if first_error_type(errors) in FATAL_URL_ERRORS and not item.get(\"video_id\"):\n        return \"failed\"\n    has_material = bool(item.get(\"metadata\") or item.get(\"artifact_paths\") or item.get(\"comments_ref\") or item.get(\"downloaded_video_path\") or item.get(\"frame_paths\") or item.get(\"subtitle_tracks\") or item.get(\"transcript_ref\"))\n    if errors and has_material:\n        return \"partial\"\n    if item.get(\"primary_evidence\") in {\"subtitle\", \"transcript\"}:\n        return \"success\"\n    return \"partial\" if has_material else \"failed\"\n\n\ndef choose_item_status(item: Mapping[str, Any], db_result: Mapping[str, Any], errors: list[dict[str, Any]]) -> str:\n    material_status = choose_material_status(item, errors)\n    if child_call_ok(db_result):\n        return material_status\n    return \"partial\" if material_status in {\"success\", \"partial\"} else \"failed\"\n\n\ndef aggregate_status(statuses: list[str]) -> str:\n    if not statuses:\n        return \"skipped\"\n    if all(status == \"success\" for status in statuses):\n        return \"success\"\n    if any(status in {\"success\", \"partial\"} for status in statuses):\n        return \"partial\"\n    if all(status == \"skipped\" for status in statuses):\n        return \"skipped\"\n    return \"failed\"\n\n\ndef collect_metadata(url_record: Mapping[str, Any], url_context: Mapping[str, Any], children: Mapping[str, Any]) -> dict[str, Any]:\n    metadata = {\n        \"card_title\": first_text(url_record, \"card_title\", \"cardTitle\", \"title\"),\n        \"card_description\": first_text(url_record, \"card_description\", \"cardDescription\", \"description\"),\n        \"source_entity_index\": url_record.get(\"source_entity_index\", url_record.get(\"sourceEntityIndex\")),\n        \"canonical_url\": url_context.get(\"canonical_url\"),\n        \"video_id\": url_context.get(\"video_id\"),\n    }\n    for title, child in children.items():\n        result = unwrap_result(child.get(\"result\") if isinstance(child, Mapping) else child)\n        if isinstance(result, Mapping):\n            child_meta = result.get(\"metadata\") or result.get(\"extracted_metadata\") or result.get(\"info\")\n            if isinstance(child_meta, Mapping):\n                metadata[title] = dict(child_meta)\n    return json_safe({key: value for key, value in metadata.items() if value not in (None, \"\", [], {})})\n\n\ndef subtitle_refs(child: Any) -> list[Any]:\n    result = unwrap_child_result(child)\n    rows = []\n    data = first_mapping(result)\n    for key in (\"subtitleTracks\", \"tracks\", \"subtitles\", \"captions\", \"segments\"):\n        rows.extend(as_list(data.get(key)))\n    path = first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\", \"textPath\")\n    if path:\n        rows.append({\"path\": path, \"language\": first_text(data, \"language\", \"lang\"), \"kind\": first_text(data, \"kind\", \"source\")})\n    text = first_text(data, \"subtitleText\", \"subtitle_text\", \"text\")\n    if text:\n        rows.append({\"text\": text, \"language\": first_text(data, \"language\", \"lang\")})\n    return json_safe(rows)\n\n\ndef transcript_ref(child: Any) -> dict[str, Any]:\n    data = first_mapping(unwrap_child_result(child))\n    path = first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\", \"textPath\")\n    text = first_text(data, \"transcript\", \"transcriptText\", \"text\")\n    return json_safe({\"path\": path, \"text\": text, \"segments\": data.get(\"segments\") or data.get(\"utterances\") or []})\n\n\ndef downloaded_video_path(child: Any) -> str:\n    return first_text(first_mapping(unwrap_child_result(child)), \"localPath\", \"local_path\", \"filePath\", \"videoPath\", \"path\", \"savedPath\")\n\n\ndef frame_paths(child: Any) -> list[str]:\n    data = first_mapping(unwrap_child_result(child))\n    paths = []\n    for key in (\"frame_paths\", \"framePaths\", \"generatedPaths\", \"savedPaths\", \"paths\", \"files\"):\n        paths.extend(str(item) for item in as_list(data.get(key)) if item)\n    for key in (\"contactSheetPath\", \"lastFramePath\", \"framePath\", \"path\", \"savedPath\", \"imagePath\"):\n        value = data.get(key)\n        if value:\n            paths.append(str(value))\n    return dedupe_texts(paths)\n\n\ndef comments_ref(child: Any) -> dict[str, Any]:\n    data = first_mapping(unwrap_child_result(child))\n    path = first_text(data, \"savedPath\", \"localPath\", \"path\", \"filePath\", \"commentsPath\")\n    comments = data.get(\"comments\") or data.get(\"items\") or []\n    return json_safe({\"path\": path, \"count\": data.get(\"count\") or data.get(\"commentCount\") or len(as_list(comments)), \"comments\": comments})\n\n\ndef tool_info(children: Mapping[str, Any]) -> dict[str, Any]:\n    info = {\"orchestrator\": SELF_TITLE, \"children\": {}}\n    for title, child in children.items():\n        result = unwrap_child_result(child)\n        data = first_mapping(result)\n        info[\"children\"][title] = {\"status\": child.get(\"status\") if isinstance(child, Mapping) else \"\", \"ok\": child_call_ok(child if isinstance(child, Mapping) else {}), \"tool\": data.get(\"tool\") or data.get(\"script\") or data.get(\"model\"), \"version\": data.get(\"version\")}\n    return json_safe(info)\n\n\ndef evidence_json(envelope: Mapping[str, Any], url_record: Mapping[str, Any], url_context: Mapping[str, Any], children: Mapping[str, Any]) -> dict[str, Any]:\n    return json_safe({\n        \"terminal_post_url\": first_text(envelope, \"terminal_post_url\", \"terminalPostUrl\", \"url\"),\n        \"terminal_post_id\": first_text(envelope, \"terminal_post_id\", \"terminalPostId\", \"post_id\", \"postId\"),\n        \"parent_trace\": envelope.get(\"parent_trace\"),\n        \"discovery_path\": envelope.get(\"discovery_path\"),\n        \"component_flags\": envelope.get(\"component_flags\"),\n        \"evidence_urls\": envelope.get(\"evidence_urls\"),\n        \"raw_url\": first_text(url_record, \"raw_url\", \"rawUrl\", \"url\"),\n        \"expanded_url\": first_text(url_record, \"expanded_url\", \"expandedUrl\"),\n        \"canonical_url\": url_context.get(\"canonical_url\"),\n        \"source_entity_index\": url_record.get(\"source_entity_index\", url_record.get(\"sourceEntityIndex\")),\n        \"youtube_url\": url_record,\n        \"normalized\": url_context,\n        \"stage_results\": {title: child.get(\"result\") for title, child in children.items() if isinstance(child, Mapping)},\n        \"child_stage_statuses\": {title: {\"phase\": phase_for_child(title), \"status\": child.get(\"status\"), \"ok\": child.get(\"ok\"), \"failureReason\": child.get(\"failureReason\")} for title, child in children.items() if isinstance(child, Mapping)},\n    })\n\n\ndef collect_artifact_paths(children: Mapping[str, Any]) -> list[str]:\n    paths: list[str] = []\n    for child in children.values():\n        data = unwrap_child_result(child)\n        collect_paths_from_value(data, paths)\n    return dedupe_texts(paths)\n\n\ndef collect_paths_from_value(value: Any, paths: list[str]) -> None:\n    if isinstance(value, Mapping):\n        for key, item in value.items():\n            lower = str(key).lower()\n            if any(hint in lower for hint in (\"path\", \"file\")) and isinstance(item, (str, Path)) and str(item):\n                paths.append(str(item))\n            elif isinstance(item, (Mapping, list, tuple)):\n                collect_paths_from_value(item, paths)\n    elif isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray)):\n        for item in value:\n            collect_paths_from_value(item, paths)\n\n\ndef jsonl_event_for_item(item: Mapping[str, Any]) -> dict[str, Any]:\n    return json_safe({\"event_ts\": item.get(\"finished_at\") or utc_now(), \"event_type\": \"child_result_recorded\", \"run_id\": item.get(\"run_id\"), \"trace_id\": item.get(\"trace_id\"), \"terminal_post_id\": item.get(\"terminal_post_id\"), \"content_class\": COMPONENT_TYPE, \"components\": [COMPONENT_TYPE], \"child_title\": SELF_TITLE, \"status\": item.get(\"status\"), \"error_type\": item.get(\"error_type\"), \"retryable\": item.get(\"retryable\"), \"artifact_paths\": item.get(\"artifact_paths\", []), \"evidence_urls\": [item.get(\"source_url\"), item.get(\"canonical_url\")], \"source_url\": item.get(\"source_url\"), \"video_id\": item.get(\"video_id\")})\n\n\ndef runs_summary_for_item(item: Mapping[str, Any]) -> str:\n    phases = \",\".join(dedupe_texts([err.get(\"phase\") for err in as_list(item.get(\"errors\")) if isinstance(err, Mapping) and err.get(\"phase\")]))\n    paths = dedupe_texts(as_list(item.get(\"artifact_paths\")))\n    return f\"run_id={item.get('run_id')} trace_id={item.get('trace_id')} terminal_post_id={item.get('terminal_post_id')} terminal_post_url={item.get('terminal_post_url')} component_type=youtube status={item.get('status')} saved_refs={len(paths)} failure_phase={phases} error_type={item.get('error_type') or ''}\"\n\n\ndef runs_summary_for_aggregate(envelope: Mapping[str, Any], items: list[Mapping[str, Any]]) -> str:\n    statuses = \",\".join(str(item.get(\"status\")) for item in items)\n    context = base_context(envelope, {}, 0)\n    return f\"run_id={context.get('run_id')} trace_id={context.get('trace_id')} terminal_post_id={context.get('terminal_post_id')} component=youtube items={len(items)} statuses={statuses}\"\n\n\ndef finalize_observability(child_result: dict[str, Any], options: Mapping[str, Any]) -> None:\n    jsonl_path = options.get(\"jsonlPath\") or options.get(\"jsonl_path\")\n    runs_log_path = options.get(\"runsLogPath\") or options.get(\"runs_log_path\")\n    written = {}\n    if jsonl_path:\n        path = Path(str(jsonl_path))\n        path.parent.mkdir(parents=True, exist_ok=True)\n        with path.open(\"a\", encoding=\"utf-8\", newline=\"\\n\") as handle:\n            for event in as_list(child_result.get(\"jsonl_events\")):\n                handle.write(json.dumps(event, ensure_ascii=False) + \"\\n\")\n        written[\"jsonlPath\"] = str(path)\n    if runs_log_path:\n        path = Path(str(runs_log_path))\n        path.parent.mkdir(parents=True, exist_ok=True)\n        with path.open(\"a\", encoding=\"utf-8\", newline=\"\\n\") as handle:\n            summary = str(child_result.get(\"runs_log_summary\") or \"\")\n            if summary:\n                handle.write(summary + \"\\n\")\n        written[\"runsLogPath\"] = str(path)\n    if written:\n        child_result.setdefault(\"observability_paths\", {}).update(written)\n\n\ndef build_empty_child_result(context: Mapping[str, Any], status: str, error_type: str, message: str, started_at: str) -> dict[str, Any]:\n    result = {\"status\": status, \"component_type\": COMPONENT_TYPE, \"run_id\": context.get(\"run_id\"), \"trace_id\": context.get(\"trace_id\"), \"terminal_post_id\": context.get(\"terminal_post_id\"), \"terminal_post_url\": context.get(\"terminal_post_url\"), \"source_url\": context.get(\"source_url\"), \"artifact_paths\": [], \"extracted_metadata\": {}, \"model_or_tool_info\": {\"orchestrator\": SELF_TITLE}, \"evidence_json\": {}, \"error_type\": error_type, \"error_message\": message, \"retryable\": False, \"items\": [], \"started_at\": started_at, \"finished_at\": utc_now()}\n    result[\"jsonl_events\"] = [jsonl_event_for_item(result)]\n    result[\"runs_log_summary\"] = runs_summary_for_item(result)\n    return result\n\n\ndef error_entry(child: str, error_type: str, message: str) -> dict[str, Any]:\n    error_type = normalize_error_type(error_type, message)\n    return {\"child\": child, \"phase\": phase_for_child(child), \"error_type\": error_type, \"reason\": message, \"retryable\": error_type in RETRYABLE_ERRORS}\n\n\ndef phase_for_child(child: str) -> str:\n    return {\n        URL_EXTRACTOR: \"url_normalization\",\n        SUBTITLE_FETCHER: \"subtitle_fetch\",\n        VIDEO_SAVER: \"video_download\",\n        TRANSCRIBER: \"transcription\",\n        FRAME_EXTRACTOR: \"frame_extraction\",\n        COMMENT_FETCHER: \"comment_fetch\",\n        DB_SAVER: \"db_write\",\n    }.get(child, \"extractor\")\n\n\ndef classify_error(message: str, child: str) -> str:\n    text = (message or \"\").lower()\n    if \"private\" in text or \"deleted\" in text:\n        return \"private_or_deleted\"\n    if \"age\" in text or \"region\" in text:\n        return \"age_or_region_restricted\"\n    if child == URL_EXTRACTOR:\n        return \"youtube_url_invalid\"\n    if child == SUBTITLE_FETCHER:\n        return \"subtitles_unavailable\"\n    if child == VIDEO_SAVER:\n        return \"download_failed\" if \"download\" in text or \"runner\" in text or \"supplied\" in text else \"video_unavailable\"\n    if child == TRANSCRIBER:\n        return \"transcription_failed\"\n    if child == COMMENT_FETCHER:\n        return \"comments_unavailable\"\n    if child == DB_SAVER:\n        return \"db_write_failed\"\n    if \"unavailable\" in text:\n        return \"video_unavailable\"\n    return \"extractor_failed\"\n\n\ndef normalize_error_type(error_type: str, message: str) -> str:\n    allowed = {\"youtube_url_invalid\", \"video_unavailable\", \"private_or_deleted\", \"age_or_region_restricted\", \"subtitles_unavailable\", \"download_failed\", \"transcription_failed\", \"comments_unavailable\", \"extractor_failed\", \"db_write_failed\"}\n    return error_type if error_type in allowed else classify_error(message, \"\")\n\n\ndef first_error_type(errors: Sequence[Any]) -> str:\n    for item in errors:\n        if isinstance(item, Mapping) and item.get(\"error_type\"):\n            return str(item[\"error_type\"])\n    return \"\"\n\n\ndef summarize_errors(errors: Sequence[Any]) -> str:\n    parts = []\n    seen = set()\n    for item in errors:\n        if not isinstance(item, Mapping):\n            continue\n        text = f\"{item.get('child')}: {item.get('error_type')}: {item.get('reason')}\"\n        if text not in seen:\n            seen.add(text)\n            parts.append(text)\n    return \"; \".join(parts)\n\n\ndef precomputed_for(precomputed: Mapping[str, Any], title: str, index: int) -> tuple[bool, Any]:\n    if title not in precomputed:\n        return False, None\n    value = precomputed[title]\n    if isinstance(value, Mapping) and isinstance(value.get(\"items\"), Sequence) and not isinstance(value.get(\"items\"), (str, bytes, bytearray)):\n        items = list(value[\"items\"])\n        return (index < len(items), items[index] if index < len(items) else None)\n    if isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray, Mapping)):\n        items = list(value)\n        return (index < len(items), items[index] if index < len(items) else None)\n    return True, value\n\n\ndef normalize_child_results(value: Mapping[str, Any] | list[Any] | None) -> dict[str, Any]:\n    if value is None:\n        return {}\n    if isinstance(value, Mapping):\n        if isinstance(value.get(\"childResults\"), Mapping):\n            return dict(value[\"childResults\"])\n        if isinstance(value.get(\"child_results\"), Mapping):\n            return dict(value[\"child_results\"])\n        return dict(value)\n    out = {}\n    for item in as_list(value):\n        if isinstance(item, Mapping):\n            title = first_text(item, \"title\", \"childTitle\", \"name\")\n            if title:\n                out[title] = dict(item)\n    return out\n\n\ndef result_looks_ok(result: Any) -> bool:\n    data = unwrap_result(result)\n    if isinstance(data, Mapping):\n        ok = data.get(\"ok\")\n        if isinstance(ok, bool):\n            return ok\n        status = str(data.get(\"status\") or data.get(\"state\") or \"\").lower()\n        if status in {\"ok\", \"success\", \"succeeded\", \"completed\", \"precomputed\", \"saved\"}:\n            return True\n        if status in {\"error\", \"failed\", \"failure\", \"skipped\", \"missing_runner\"}:\n            return False\n        if extract_failure_reason(data):\n            return False\n        return bool(data)\n    return data is not None\n\n\ndef child_call_ok(call: Mapping[str, Any] | None) -> bool:\n    return bool(call and call.get(\"ok\"))\n\n\ndef extract_failure_reason(result: Any) -> str:\n    data = unwrap_result(result)\n    if isinstance(data, Mapping):\n        for key in (\"failureReason\", \"failure_reason\", \"error\", \"reason\", \"message\", \"error_message\"):\n            value = data.get(key)\n            if value:\n                return str(value)\n    return \"\"\n\n\ndef unwrap_child_result(child: Any) -> Any:\n    if isinstance(child, Mapping) and \"result\" in child:\n        return unwrap_result(child.get(\"result\"))\n    return unwrap_result(child)\n\n\ndef unwrap_result(value: Any) -> Any:\n    current = value\n    for _ in range(4):\n        if isinstance(current, Mapping) and \"result\" in current and set(current.keys()) & {\"title\", \"status\", \"ok\", \"input\"}:\n            current = current.get(\"result\")\n            continue\n        break\n    return current\n\n\ndef normalize_input(value: Any) -> dict[str, Any]:\n    if value is None:\n        return {}\n    if isinstance(value, Mapping):\n        return json_safe(dict(value))\n    if isinstance(value, str):\n        return {\"text_excerpt\": value, \"youtube_urls\": [{\"raw_url\": value}]}\n    return {\"value\": json_safe(value)}\n\n\ndef first_present(data: Mapping[str, Any], *keys: str) -> Any:\n    for key in keys:\n        if key in data and data.get(key) is not None:\n            return data.get(key)\n    return None\n\n\ndef first_mapping(value: Any) -> Mapping[str, Any]:\n    if isinstance(value, Mapping):\n        return value\n    for item in as_list(value):\n        if isinstance(item, Mapping):\n            return item\n    return {}\n\n\ndef first_text(data: Any, *keys: str) -> str:\n    if not isinstance(data, Mapping):\n        return \"\"\n    for key in keys:\n        value = data.get(key)\n        if value not in (None, \"\"):\n            return str(value).strip()\n    return \"\"\n\n\ndef joined_text(data: Any, *keys: str) -> str:\n    if not isinstance(data, Mapping):\n        return \"\"\n    chunks = []\n    for key in keys:\n        value = data.get(key)\n        if isinstance(value, str):\n            chunks.append(value)\n        elif isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray)):\n            chunks.extend(str(item.get(\"text\") if isinstance(item, Mapping) else item) for item in value)\n    return \"\\n\".join(part for part in chunks if part)\n\n\ndef non_empty_list(data: Any, *keys: str) -> bool:\n    return isinstance(data, Mapping) and any(bool(as_list(data.get(key))) for key in keys)\n\n\ndef truthy_flag(data: Any, *keys: str) -> bool:\n    return isinstance(data, Mapping) and any(bool(data.get(key)) for key in keys)\n\n\ndef as_list(value: Any) -> list[Any]:\n    if value is None:\n        return []\n    if isinstance(value, list):\n        return value\n    if isinstance(value, tuple):\n        return list(value)\n    return [value]\n\n\ndef dedupe_texts(values: Sequence[Any]) -> list[str]:\n    out = []\n    seen = set()\n    for value in values:\n        text = str(value).strip()\n        if text and text not in seen:\n            seen.add(text)\n            out.append(text)\n    return out\n\n\ndef json_safe(value: Any) -> Any:\n    if isinstance(value, Mapping):\n        return {str(key): json_safe(item) for key, item in value.items()}\n    if isinstance(value, list):\n        return [json_safe(item) for item in value]\n    if isinstance(value, tuple):\n        return [json_safe(item) for item in value]\n    if isinstance(value, Path):\n        return str(value)\n    if isinstance(value, (str, int, float, bool)) or value is None:\n        return value\n    return str(value)\n\n\ndef utc_now() -> str:\n    return datetime.now(timezone.utc).isoformat()\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value:\n        return {}\n    if value == \"-\":\n        raw = sys.stdin.read()\n        return json.loads(raw) if raw.strip() else {}\n    path = Path(value)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Orchestrate YouTube component confirmation for terminal_post_envelope input.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results\", default=\"\", help=\"Precomputed child result JSON string or file path.\")\n    parser.add_argument(\"--jsonl-path\", default=\"\")\n    parser.add_argument(\"--runs-log-path\", default=\"\")\n    parser.add_argument(\"--min-subtitle-chars\", type=int, default=80)\n    parser.add_argument(\"--strict-missing-runners\", action=\"store_true\")\n    parser.add_argument(\"--indent\", type=int, default=2)\n    args = parser.parse_args(argv)\n    payload = load_json_arg(args.input_json)\n    child_results = load_json_arg(args.child_results) if args.child_results else None\n    result = handle_youtube_component(payload, child_results=child_results, options={\"minSubtitleChars\": args.min_subtitle_chars, \"strictMissingRunners\": args.strict_missing_runners, \"jsonlPath\": args.jsonl_path, \"runsLogPath\": args.runs_log_path})\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
