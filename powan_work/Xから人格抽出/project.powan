    {
      "id": "node-b435ab86a2",
      "title": "投稿出どころ判定ポワン",
      "body": "読み取った投稿、または返信連鎖追跡ポワンから渡されたhandoffPostを見て、リプ、引用、リポスト、外部ニュース、YouTube、画像、動画、本人の単独発言のどれに当たるかを判定する臓器ポワン。根まで追跡ポワンが次にどの枝へ進むべきかを決めるため、kind、next、needsTrace、stopAllowed、primaryRef、refs、evidence、confidenceを返す。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nfrom typing import Any\nfrom urllib.parse import urljoin, urlparse\n\nYOUTUBE_HOSTS = {\"youtube.com\", \"www.youtube.com\", \"m.youtube.com\", \"youtu.be\"}\nX_HOSTS = {\"x.com\", \"twitter.com\", \"mobile.twitter.com\"}\nIMAGE_EXTENSIONS = {\".jpg\", \".jpeg\", \".png\", \".gif\", \".webp\", \".bmp\", \".svg\"}\nVIDEO_EXTENSIONS = {\".mp4\", \".mov\", \".webm\", \".m4v\", \".avi\", \".mkv\"}\nSTATUS_RE = re.compile(r\"/(?:i/web/)?status/(\\d+)\")\nURL_KEYS = {\n    \"url\", \"href\", \"expanded_url\", \"expandedUrl\", \"display_url\", \"displayUrl\",\n    \"sourceUrl\", \"quotedStatusUrl\", \"repostedStatusUrl\", \"inReplyToStatusUrl\",\n    \"mediaUrl\", \"media_url\", \"videoUrl\", \"imageUrl\",\n}\n\n\ndef clean_text(value: Any) -> str:\n    if isinstance(value, list):\n        return \"\\n\".join(clean_text(item) for item in value if clean_text(item))\n    return value.strip() if isinstance(value, str) else \"\"\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    match = STATUS_RE.search(url)\n    return match.group(1) if match else None\n\n\ndef normalize_url(url: str | None, *, base_url: str = \"https://x.com\") -> str:\n    text = clean_text(url)\n    if not text:\n        return \"\"\n    parsed = urlparse(urljoin(base_url, text))\n    if parsed.netloc in {\"twitter.com\", \"mobile.twitter.com\"}:\n        parsed = parsed._replace(netloc=\"x.com\")\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if parsed.netloc == \"x.com\" and len(parts) >= 3 and parts[1] == \"status\" and parts[2].isdigit():\n        parsed = parsed._replace(path=f\"/{parts[0]}/status/{parts[2]}\", query=\"\")\n    return parsed._replace(fragment=\"\").geturl()\n\n\ndef host_of(url: str | None) -> str:\n    try:\n        return urlparse(url or \"\").netloc.lower()\n    except Exception:\n        return \"\"\n\n\ndef path_of(url: str | None) -> str:\n    try:\n        return urlparse(url or \"\").path.lower()\n    except Exception:\n        return \"\"\n\n\ndef author_from_status_url(url: str | None) -> str | None:\n    parsed = urlparse(url or \"\")\n    parts = [part for part in parsed.path.split(\"/\") if part]\n    if len(parts) >= 3 and parts[1] == \"status\":\n        return parts[0]\n    return None\n\n\ndef own_post_ids(post: dict[str, Any]) -> set[str]:\n    ids = {clean_text(post.get(\"id\")), clean_text(post.get(\"postId\"))}\n    ids.add(status_id_from_url(clean_text(post.get(\"url\"))) or \"\")\n    for key in (\"current\", \"post\", \"raw\"):\n        child = post.get(key)\n        if isinstance(child, dict):\n            ids |= own_post_ids(child)\n    return {item for item in ids if item}\n\n\ndef collect_urls(value: Any) -> list[dict[str, Any]]:\n    urls: list[dict[str, Any]] = []\n\n    def add(url: Any, *, source: str, raw: Any = None) -> None:\n        text = clean_text(url)\n        if not text or not (text.startswith(\"http://\") or text.startswith(\"https://\") or text.startswith(\"/\")):\n            return\n        normalized = normalize_url(text)\n        if normalized.startswith(\"http://\") or normalized.startswith(\"https://\"):\n            urls.append({\"url\": normalized, \"source\": source, \"raw\": raw})\n\n    def walk(item: Any, source: str, depth: int = 0) -> None:\n        if depth > 8:\n            return\n        if isinstance(item, str):\n            add(item, source=source, raw=item)\n            return\n        if isinstance(item, list):\n            for index, child in enumerate(item):\n                walk(child, f\"{source}[{index}]\", depth + 1)\n            return\n        if not isinstance(item, dict):\n            return\n\n        for key, child in item.items():\n            if key in URL_KEYS:\n                add(child, source=f\"{source}.{key}\", raw=item)\n            walk(child, f\"{source}.{key}\", depth + 1)\n\n    walk(value, \"post\")\n\n    seen: set[str] = set()\n    unique: list[dict[str, Any]] = []\n    for item in urls:\n        url = item[\"url\"]\n        if url in seen:\n            continue\n        seen.add(url)\n        unique.append(item)\n    return unique\n\n\ndef classify_url(url: str) -> str:\n    host = host_of(url)\n    path = path_of(url)\n    if host in YOUTUBE_HOSTS:\n        return \"youtube\"\n    if host in X_HOSTS and status_id_from_url(url):\n        return \"x_status\"\n    if any(path.endswith(ext) for ext in IMAGE_EXTENSIONS):\n        return \"image\"\n    if any(path.endswith(ext) for ext in VIDEO_EXTENSIONS):\n        return \"video\"\n    if host and host not in X_HOSTS:\n        return \"external_news\"\n    return \"external_link\"\n\n\ndef as_bool_hint(text: str, needles: list[str]) -> bool:\n    lowered = text.lower()\n    return any(needle.lower() in lowered for needle in needles)\n\n\ndef relation_text(post: dict[str, Any]) -> str:\n    pieces = [\n        clean_text(post.get(\"socialContext\")),\n        clean_text(post.get(\"text\")),\n        clean_text(post.get(\"articleText\")),\n    ]\n    raw = post.get(\"raw\")\n    if isinstance(raw, dict):\n        pieces.append(clean_text(raw.get(\"articleText\")))\n        pieces.append(clean_text(raw.get(\"socialContext\")))\n    return \"\\n\".join(piece for piece in pieces if piece)\n\n\ndef make_status_ref(url: str, *, kind: str, evidence: str, confidence: float, source: str = \"\") -> dict[str, Any]:\n    normalized = normalize_url(url)\n    return {\n        \"kind\": kind,\n        \"postId\": status_id_from_url(normalized),\n        \"authorId\": author_from_status_url(normalized),\n        \"url\": normalized or None,\n        \"evidence\": evidence,\n        \"source\": source,\n        \"confidence\": confidence,\n    }\n\n\ndef first_ref(refs: list[dict[str, Any]], kind: str) -> dict[str, Any] | None:\n    for ref in refs:\n        if ref.get(\"kind\") == kind:\n            return ref\n    return None\n\n\ndef dedupe_refs(refs: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    seen: set[tuple[str, str]] = set()\n    unique: list[dict[str, Any]] = []\n    for ref in refs:\n        key = (str(ref.get(\"kind\") or \"\"), str(ref.get(\"postId\") or ref.get(\"url\") or \"\"))\n        if not key[1] or key in seen:\n            continue\n        seen.add(key)\n        unique.append(ref)\n    return unique\n\n\ndef explicit_refs(post: dict[str, Any]) -> tuple[list[dict[str, Any]], list[str]]:\n    refs: list[dict[str, Any]] = []\n    evidence: list[str] = []\n\n    repost_url = clean_text(post.get(\"repostedStatusUrl\"))\n    repost_id = clean_text(post.get(\"repostedPostId\"))\n    if repost_url or repost_id:\n        ref = make_status_ref(repost_url, kind=\"repost_source\", evidence=\"repost field present\", confidence=0.95)\n        if repost_id and not ref.get(\"postId\"):\n            ref[\"postId\"] = repost_id\n        refs.append(ref)\n        evidence.append(\"repost source field detected\")\n\n    quote_url = clean_text(post.get(\"quotedStatusUrl\"))\n    quote_id = clean_text(post.get(\"quotedPostId\"))\n    if quote_url or quote_id:\n        ref = make_status_ref(quote_url, kind=\"quote_source\", evidence=\"quoted post field present\", confidence=0.95)\n        if quote_id and not ref.get(\"postId\"):\n            ref[\"postId\"] = quote_id\n        refs.append(ref)\n        evidence.append(\"quote source field detected\")\n\n    reply_url = clean_text(post.get(\"inReplyToStatusUrl\"))\n    reply_id = clean_text(post.get(\"inReplyToPostId\"))\n    if reply_url or reply_id:\n        ref = make_status_ref(reply_url, kind=\"reply_parent\", evidence=\"reply parent field present\", confidence=0.9)\n        if reply_id and not ref.get(\"postId\"):\n            ref[\"postId\"] = reply_id\n        refs.append(ref)\n        evidence.append(\"reply parent field detected\")\n\n    return refs, evidence\n\n\ndef x_status_refs_from_urls(post: dict[str, Any]) -> list[dict[str, Any]]:\n    own_ids = own_post_ids(post)\n    refs: list[dict[str, Any]] = []\n    for item in collect_urls(post):\n        url = item[\"url\"]\n        if classify_url(url) != \"x_status\":\n            continue\n        post_id = status_id_from_url(url)\n        if not post_id or post_id in own_ids:\n            continue\n        refs.append(make_status_ref(\n            url,\n            kind=\"url_post\",\n            evidence=f\"non-self X status URL in {item['source']}\",\n            confidence=0.7,\n            source=item[\"source\"],\n        ))\n    return dedupe_refs(refs)\n\n\ndef external_refs_from_urls(post: dict[str, Any]) -> list[dict[str, Any]]:\n    refs: list[dict[str, Any]] = []\n    for item in collect_urls(post):\n        url = item[\"url\"]\n        url_kind = classify_url(url)\n        if url_kind in {\"youtube\", \"external_news\", \"image\", \"video\"}:\n            refs.append({\n                \"kind\": url_kind,\n                \"url\": url,\n                \"evidence\": f\"{url_kind} URL in {item['source']}\",\n                \"source\": item[\"source\"],\n                \"confidence\": 0.75,\n            })\n    return dedupe_refs(refs)\n\n\ndef promote_status_refs(post: dict[str, Any], refs: list[dict[str, Any]], evidence: list[str]) -> list[dict[str, Any]]:\n    text = relation_text(post)\n    has_repost_hint = as_bool_hint(text, [\"リポスト\", \"repost\", \"retweeted\", \"retweeted by\"])\n    has_quote_hint = as_bool_hint(text, [\"引用\", \"quote\", \"quoted\"])\n    promoted: list[dict[str, Any]] = []\n\n    for ref in refs:\n        if ref.get(\"kind\") != \"url_post\":\n            promoted.append(ref)\n            continue\n        if has_repost_hint:\n            promoted.append({**ref, \"kind\": \"repost_source\", \"evidence\": \"visible repost marker with non-self X status URL\", \"confidence\": 0.82})\n        elif has_quote_hint:\n            promoted.append({**ref, \"kind\": \"quote_source\", \"evidence\": \"visible quote marker with non-self X status URL\", \"confidence\": 0.82})\n        else:\n            promoted.append(ref)\n\n    if has_repost_hint:\n        evidence.append(\"visible repost marker detected\")\n    if has_quote_hint:\n        evidence.append(\"visible quote marker detected\")\n    return dedupe_refs(promoted)\n\n\ndef classify_post_origin(post: dict[str, Any]) -> dict[str, Any]:\n    evidence: list[str] = []\n    explicit, explicit_evidence = explicit_refs(post)\n    evidence.extend(explicit_evidence)\n\n    x_refs = x_status_refs_from_urls(post)\n    external_refs = external_refs_from_urls(post)\n    refs = promote_status_refs(post, explicit + x_refs + external_refs, evidence)\n\n    priority = [\n        (\"repost\", \"repost_source\", \"repost_source\", True),\n        (\"quote\", \"quote_source\", \"quote_source\", True),\n        (\"reply\", \"reply_parent\", \"reply_parent\", True),\n        (\"youtube\", \"youtube\", \"youtube_verify\", True),\n        (\"external_news\", \"external_news\", \"news_verify\", True),\n        (\"video\", \"video\", \"video_verify\", True),\n        (\"image\", \"image\", \"image_verify\", True),\n        (\"x_status\", \"url_post\", \"x_status_source\", True),\n    ]\n    for kind, ref_kind, next_action, needs_trace in priority:\n        ref = first_ref(refs, ref_kind)\n        if ref:\n            return {\n                \"kind\": kind,\n                \"next\": next_action,\n                \"needsTrace\": needs_trace,\n                \"stopAllowed\": False,\n                \"primaryRef\": ref,\n                \"refs\": refs,\n                \"evidence\": evidence or [ref.get(\"evidence\", \"\")],\n                \"confidence\": ref.get(\"confidence\", 0.5),\n            }\n\n    return {\n        \"kind\": \"original\",\n        \"next\": \"stop\",\n        \"needsTrace\": False,\n        \"stopAllowed\": True,\n        \"primaryRef\": None,\n        \"refs\": refs,\n        \"evidence\": evidence or [\"no upstream relation or external source detected\"],\n        \"confidence\": 0.6,\n    }\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Classify where a post comes from and choose the next tracing branch.\")\n    parser.add_argument(\"--json-file\", default=\"\")\n    args = parser.parse_args(argv)\n\n    if args.json_file:\n        with open(args.json_file, \"r\", encoding=\"utf-8\") as handle:\n            post = json.load(handle)\n    else:\n        post = json.load(__import__(\"sys\").stdin)\n\n    print(json.dumps(classify_post_origin(post), ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
