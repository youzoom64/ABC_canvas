    {
      "id": "node-a2fcb32bf5",
      "title": "ニュースURL抽出ポワン",
      "body": "終端投稿の本文、カード、展開済みリンクからニュース記事や外部記事URLを抽出する臓器ポワン。X内部URL、YouTube、画像、動画を除外し、外部記事候補のURL、表示テキスト、カードタイトル、post_id、media_indexを返す。URL展開、本文取得、DB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nimport sys\nfrom dataclasses import dataclass, replace\nfrom html import unescape\nfrom typing import Any\nfrom urllib.parse import parse_qsl, urlencode, urlparse, urlunparse\n\nURL_PATTERN = re.compile(r\"(?:https?://|www\\.)[^\\s<>'\\\"\\)\\]\\}）】」』]+\", re.IGNORECASE)\nTRAILING_PUNCTUATION = \".,;:!?)]}）】」』\"\nLEADING_WRAPPERS = \"(<[（【「『\"\n\nEXCLUDED_HOSTS = {\n    \"x.com\",\n    \"twitter.com\",\n    \"youtube.com\",\n    \"youtu.be\",\n    \"youtube-nocookie.com\",\n    \"pbs.twimg.com\",\n    \"video.twimg.com\",\n}\nX_INTERNAL_HOSTS = {\"x.com\", \"twitter.com\"}\nYOUTUBE_HOSTS = {\"youtube.com\", \"youtu.be\", \"youtube-nocookie.com\"}\nX_MEDIA_HOSTS = {\"pbs.twimg.com\", \"video.twimg.com\"}\n\nSHORTENER_HOSTS = {\n    \"t.co\",\n    \"bit.ly\",\n    \"buff.ly\",\n    \"dlvr.it\",\n    \"goo.gl\",\n    \"ift.tt\",\n    \"is.gd\",\n    \"lnkd.in\",\n    \"n.pr\",\n    \"nyti.ms\",\n    \"on.wsj.com\",\n    \"ow.ly\",\n    \"reut.rs\",\n    \"trib.al\",\n    \"tinyurl.com\",\n}\n\nIMAGE_EXTENSIONS = {\n    \".avif\",\n    \".bmp\",\n    \".gif\",\n    \".heic\",\n    \".jpeg\",\n    \".jpg\",\n    \".png\",\n    \".svg\",\n    \".tif\",\n    \".tiff\",\n    \".webp\",\n}\nVIDEO_EXTENSIONS = {\n    \".avi\",\n    \".m3u8\",\n    \".m4v\",\n    \".mkv\",\n    \".mov\",\n    \".mp4\",\n    \".mpeg\",\n    \".mpg\",\n    \".webm\",\n    \".wmv\",\n}\nMEDIA_EXTENSIONS = IMAGE_EXTENSIONS | VIDEO_EXTENSIONS\n\nTRACKING_QUERY_KEYS = {\n    \"fbclid\",\n    \"gclid\",\n    \"igshid\",\n    \"mc_cid\",\n    \"mc_eid\",\n    \"mkt_tok\",\n    \"ocid\",\n    \"ref_src\",\n    \"spm\",\n    \"utm_campaign\",\n    \"utm_content\",\n    \"utm_medium\",\n    \"utm_source\",\n    \"utm_term\",\n}\n\nURL_KEYS = {\n    \"articleurl\",\n    \"canonicalurl\",\n    \"expanded\",\n    \"expandedurl\",\n    \"finalurl\",\n    \"href\",\n    \"link\",\n    \"sourceurl\",\n    \"unwoundurl\",\n    \"url\",\n}\nPREFERRED_URL_KEYS = {\n    \"articleurl\",\n    \"canonicalurl\",\n    \"expandedurl\",\n    \"finalurl\",\n    \"sourceurl\",\n    \"unwoundurl\",\n}\nTEXT_KEYS = {\n    \"body\",\n    \"content\",\n    \"description\",\n    \"fulltext\",\n    \"notetext\",\n    \"sourcetext\",\n    \"text\",\n    \"tweettext\",\n}\nCARD_TITLE_KEYS = {\n    \"cardtitle\",\n    \"headline\",\n    \"ogtitle\",\n    \"title\",\n    \"twittertitle\",\n}\nDISPLAY_TEXT_KEYS = {\n    \"display\",\n    \"displaytext\",\n    \"displayurl\",\n    \"label\",\n    \"name\",\n    \"shorturl\",\n    \"text\",\n}\nPOST_ID_KEYS = {\n    \"conversationid\",\n    \"idstr\",\n    \"postid\",\n    \"restid\",\n    \"statusid\",\n    \"tweetid\",\n}\nMEDIA_INDEX_KEYS = {\"mediaindex\", \"mediaidx\"}\nCARD_PATH_HINTS = {\"card\", \"preview\", \"article\", \"unifiedcard\", \"summary\"}\n\n\n@dataclass(frozen=True)\nclass Context:\n    post_id: str = \"\"\n    media_index: Any = None\n    source_text: str = \"\"\n    card_title: str = \"\"\n    display_text: str = \"\"\n    in_card: bool = False\n\n\n@dataclass\nclass Mention:\n    url: str\n    source: str\n    source_text: str\n    display_text: str\n    card_title: str\n    post_id: str\n    media_index: Any\n    source_path: str\n    raw_key: str\n    order: int\n    score: int = 0\n\n\ndef extract_news_urls(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    \"\"\"Extract external article URL candidates from X terminal post data.\n\n    This organ only finds URL candidates. It does not expand redirects, fetch\n    article bodies, create embeddings, summarize content, judge contradictions,\n    or write to a database.\n    \"\"\"\n    try:\n        prepared = _prepare_payload(payload, kwargs)\n        base_context = Context(\n            post_id=_find_post_id(prepared),\n            media_index=_find_media_index(prepared),\n            source_text=_find_source_text(prepared),\n            card_title=_find_card_title(prepared),\n        )\n        mentions: list[Mention] = []\n        excluded: list[dict[str, Any]] = []\n        _walk(prepared, base_context, \"$\", mentions, excluded)\n        urls = _select_candidates(mentions, excluded)\n        primary_url = urls[0][\"url\"] if urls else \"\"\n        result = {\n            \"ok\": True,\n            \"urls\": urls,\n            \"primaryUrl\": primary_url,\n            \"sourceText\": base_context.source_text,\n            \"cardTitle\": _first_non_empty(\n                [base_context.card_title] + [item.get(\"cardTitle\", \"\") for item in urls]\n            ),\n            \"postId\": base_context.post_id,\n            \"mediaIndex\": base_context.media_index,\n            \"excludedUrls\": _dedupe_excluded(excluded),\n        }\n        return result\n    except Exception as exc:\n        return {\n            \"ok\": False,\n            \"urls\": [],\n            \"primaryUrl\": \"\",\n            \"sourceText\": \"\",\n            \"cardTitle\": \"\",\n            \"postId\": \"\",\n            \"mediaIndex\": None,\n            \"excludedUrls\": [],\n            \"error\": str(exc),\n        }\n\n\ndef extract(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return extract_news_urls(payload, **kwargs)\n\n\ndef run(payload: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return extract_news_urls(payload, **kwargs)\n\n\ndef _prepare_payload(payload: Any, kwargs: dict[str, Any]) -> Any:\n    if payload is None:\n        payload = {}\n    if isinstance(payload, str) and _looks_like_json(payload):\n        try:\n            payload = json.loads(payload)\n        except Exception:\n            pass\n    if not kwargs:\n        return payload\n    if isinstance(payload, dict):\n        merged = dict(payload)\n        merged.update({key: value for key, value in kwargs.items() if value is not None})\n        return merged\n    merged = {\"payload\": payload}\n    merged.update({key: value for key, value in kwargs.items() if value is not None})\n    if isinstance(payload, str) and \"text\" not in merged and \"sourceText\" not in merged:\n        merged[\"text\"] = payload\n    return merged\n\n\ndef _looks_like_json(text: str) -> bool:\n    stripped = (text or \"\").strip()\n    return (stripped.startswith(\"{\") and stripped.endswith(\"}\")) or (\n        stripped.startswith(\"[\") and stripped.endswith(\"]\")\n    )\n\n\ndef _walk(\n    value: Any,\n    context: Context,\n    path: str,\n    mentions: list[Mention],\n    excluded: list[dict[str, Any]],\n) -> None:\n    if isinstance(value, dict):\n        next_context = _context_from_dict(value, context, path)\n        preferred_present = any(_key_token(key) in PREFERRED_URL_KEYS for key in value)\n        for key, child in value.items():\n            token = _key_token(key)\n            child_path = f\"{path}.{key}\"\n            child_context = next_context\n            if _path_or_key_says_card(path, key):\n                child_context = replace(child_context, in_card=True)\n\n            if isinstance(child, str):\n                if token in URL_KEYS:\n                    if preferred_present and token == \"url\" and _is_shortener_url(child):\n                        continue\n                    _add_urls_from_value(\n                        child,\n                        _source_from_key(token, child_context),\n                        child_context,\n                        child_path,\n                        key,\n                        mentions,\n                        excluded,\n                    )\n                    continue\n                if token in TEXT_KEYS or token in CARD_TITLE_KEYS or token in DISPLAY_TEXT_KEYS:\n                    text_context = child_context\n                    if token in TEXT_KEYS and child.strip():\n                        text_context = replace(text_context, source_text=child.strip())\n                    if token in CARD_TITLE_KEYS and child.strip() and child_context.in_card:\n                        text_context = replace(text_context, card_title=child.strip())\n                    if token in DISPLAY_TEXT_KEYS and child.strip():\n                        text_context = replace(text_context, display_text=child.strip())\n                    _add_urls_from_text(\n                        child,\n                        \"text\" if token in TEXT_KEYS else \"json_string\",\n                        text_context,\n                        child_path,\n                        key,\n                        mentions,\n                        excluded,\n                    )\n                    continue\n                _add_urls_from_text(\n                    child,\n                    \"json_string\",\n                    child_context,\n                    child_path,\n                    key,\n                    mentions,\n                    excluded,\n                )\n                continue\n            _walk(child, child_context, child_path, mentions, excluded)\n        return\n\n    if isinstance(value, list):\n        for index, child in enumerate(value):\n            item_context = context\n            if context.media_index is None and _path_says_media(path):\n                item_context = replace(item_context, media_index=index)\n            _walk(child, item_context, f\"{path}[{index}]\", mentions, excluded)\n        return\n\n    if isinstance(value, str):\n        _add_urls_from_text(value, \"text\", context, path, \"\", mentions, excluded)\n\n\ndef _context_from_dict(data: dict[str, Any], context: Context, path: str) -> Context:\n    post_id = context.post_id or _extract_post_id_from_dict(data)\n    media_index = context.media_index\n    if media_index is None:\n        media_index = _extract_media_index_from_dict(data)\n    in_card = context.in_card or _path_says_card(path) or _dict_says_card(data)\n    source_text = context.source_text or _extract_first_string(data, TEXT_KEYS)\n    display_text = context.display_text or _extract_first_string(data, DISPLAY_TEXT_KEYS)\n    card_title = context.card_title\n    if in_card:\n        card_title = card_title or _extract_first_string(data, CARD_TITLE_KEYS)\n    return Context(\n        post_id=post_id,\n        media_index=media_index,\n        source_text=source_text,\n        card_title=card_title,\n        display_text=display_text,\n        in_card=in_card,\n    )\n\n\ndef _add_urls_from_value(\n    value: str,\n    source: str,\n    context: Context,\n    path: str,\n    raw_key: str,\n    mentions: list[Mention],\n    excluded: list[dict[str, Any]],\n) -> None:\n    found = list(_iter_urls(value))\n    if not found and _clean_url(value):\n        found = [_clean_url(value)]\n    for url in found:\n        _add_one_url(url, source, context, path, raw_key, mentions, excluded)\n\n\ndef _add_urls_from_text(\n    text: str,\n    source: str,\n    context: Context,\n    path: str,\n    raw_key: str,\n    mentions: list[Mention],\n    excluded: list[dict[str, Any]],\n) -> None:\n    for url in _iter_urls(text):\n        _add_one_url(url, source, context, path, raw_key, mentions, excluded)\n\n\ndef _add_one_url(\n    raw_url: str,\n    source: str,\n    context: Context,\n    path: str,\n    raw_key: str,\n    mentions: list[Mention],\n    excluded: list[dict[str, Any]],\n) -> None:\n    cleaned = _clean_url(raw_url)\n    if not cleaned:\n        return\n    ok, reason = _classify_candidate_url(cleaned, context)\n    if not ok:\n        excluded.append(\n            {\n                \"url\": cleaned,\n                \"reason\": reason,\n                \"source\": source,\n                \"sourcePath\": path,\n                \"postId\": context.post_id,\n                \"mediaIndex\": context.media_index,\n            }\n        )\n        return\n    mention = Mention(\n        url=cleaned,\n        source=source,\n        source_text=context.source_text,\n        display_text=context.display_text,\n        card_title=context.card_title,\n        post_id=context.post_id,\n        media_index=context.media_index,\n        source_path=path,\n        raw_key=raw_key,\n        order=len(mentions),\n        score=_article_score(cleaned, context, source),\n    )\n    mentions.append(mention)\n\n\ndef _select_candidates(mentions: list[Mention], excluded: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    selected: dict[str, Mention] = {}\n    for mention in mentions:\n        key = _dedupe_key(mention.url)\n        previous = selected.get(key)\n        if previous is None or _prefer_mention(mention, previous):\n            selected[key] = mention\n    ordered = sorted(selected.values(), key=lambda item: (-item.score, item.order))\n    return [_mention_to_dict(item) for item in ordered]\n\n\ndef _prefer_mention(new: Mention, old: Mention) -> bool:\n    if new.score != old.score:\n        return new.score > old.score\n    if _is_shortener_url(old.url) and not _is_shortener_url(new.url):\n        return True\n    if new.card_title and not old.card_title:\n        return True\n    if new.display_text and not old.display_text:\n        return True\n    return False\n\n\ndef _mention_to_dict(mention: Mention) -> dict[str, Any]:\n    parsed = urlparse(mention.url)\n    host = (parsed.netloc or \"\").lower()\n    item = {\n        \"url\": mention.url,\n        \"post_id\": mention.post_id,\n        \"postId\": mention.post_id,\n        \"media_index\": mention.media_index,\n        \"mediaIndex\": mention.media_index,\n        \"sourceText\": mention.source_text,\n        \"displayText\": mention.display_text,\n        \"cardTitle\": mention.card_title,\n        \"title\": mention.card_title,\n        \"metadata\": {\n            \"source\": mention.source,\n            \"sourcePath\": mention.source_path,\n            \"rawKey\": mention.raw_key,\n            \"host\": host,\n            \"needsExpansion\": _host_matches(host, SHORTENER_HOSTS),\n            \"articleScore\": mention.score,\n        },\n    }\n    return item\n\n\ndef _classify_candidate_url(url: str, context: Context) -> tuple[bool, str]:\n    parsed = urlparse(url)\n    host = (parsed.netloc or \"\").lower()\n    if parsed.scheme not in {\"http\", \"https\"} or not host:\n        return False, \"invalid_http_url\"\n    if _host_matches(host, X_INTERNAL_HOSTS):\n        return False, \"x_internal_url\"\n    if _host_matches(host, YOUTUBE_HOSTS):\n        return False, \"youtube_url\"\n    if _host_matches(host, X_MEDIA_HOSTS):\n        return False, \"x_media_url\"\n    if _is_media_url(parsed):\n        return False, \"media_file_url\"\n    if _article_score(url, context, \"\") <= 0:\n        return False, \"not_article_like_url\"\n    return True, \"\"\n\n\ndef _article_score(url: str, context: Context, source: str) -> int:\n    parsed = urlparse(url)\n    host = (parsed.netloc or \"\").lower()\n    path = parsed.path or \"/\"\n    path_lower = path.lower()\n    segments = [segment for segment in path.split(\"/\") if segment]\n    score = 0\n    if _host_matches(host, SHORTENER_HOSTS):\n        score += 8\n    else:\n        score += 10\n    if context.card_title:\n        score += 35\n    if context.display_text:\n        score += 12\n    if source in {\"expanded_url\", \"canonical_url\", \"final_url\", \"article_url\"}:\n        score += 20\n    if source == \"card\":\n        score += 18\n    if segments:\n        score += min(len(segments), 4) * 8\n    if re.search(r\"/(news|article|articles|story|stories|post|posts|press|release|world|business|tech|politics|economy)(/|$)\", path_lower):\n        score += 24\n    if re.search(r\"/(20\\d{2}|19\\d{2})[/-](0?[1-9]|1[0-2])([/-](0?[1-9]|[12]\\d|3[01]))?(/|$)\", path_lower):\n        score += 18\n    if re.search(r\"[A-Za-z0-9_-]{10,}\", path):\n        score += 8\n    query_keys = {key.lower() for key, _ in parse_qsl(parsed.query, keep_blank_values=True)}\n    if query_keys & {\"id\", \"article\", \"article_id\", \"story\", \"story_id\", \"p\", \"post\"}:\n        score += 10\n    if path in {\"\", \"/\"} and not context.card_title and not context.display_text:\n        score -= 12\n    return score\n\n\ndef _iter_urls(text: str) -> list[str]:\n    urls: list[str] = []\n    for match in URL_PATTERN.finditer(text or \"\"):\n        cleaned = _clean_url(match.group(0))\n        if cleaned:\n            urls.append(cleaned)\n    return urls\n\n\ndef _clean_url(value: Any) -> str:\n    text = unescape(str(value or \"\")).strip()\n    if not text:\n        return \"\"\n    text = text.strip().strip('\"\\'`')\n    while text and text[0] in LEADING_WRAPPERS:\n        text = text[1:].strip()\n    while text and text[-1] in TRAILING_PUNCTUATION:\n        text = text[:-1].strip()\n    if text.startswith(\"www.\"):\n        text = f\"https://{text}\"\n    parsed = urlparse(text)\n    if parsed.scheme and parsed.scheme not in {\"http\", \"https\"}:\n        return text\n    if not parsed.scheme and parsed.netloc:\n        text = f\"https:{text}\" if text.startswith(\"//\") else f\"https://{text}\"\n        parsed = urlparse(text)\n    if not parsed.netloc:\n        return text\n    return urlunparse(\n        (\n            (parsed.scheme or \"https\").lower(),\n            parsed.netloc.lower(),\n            parsed.path or \"/\",\n            \"\",\n            parsed.query,\n            parsed.fragment,\n        )\n    )\n\n\ndef _dedupe_key(url: str) -> str:\n    parsed = urlparse(url)\n    query = []\n    for key, value in parse_qsl(parsed.query, keep_blank_values=True):\n        key_lower = key.lower()\n        if key_lower in TRACKING_QUERY_KEYS or key_lower.startswith(\"utm_\"):\n            continue\n        query.append((key_lower, value))\n    path = parsed.path or \"/\"\n    if path != \"/\" and path.endswith(\"/\"):\n        path = path.rstrip(\"/\")\n    return urlunparse(\n        (\n            (parsed.scheme or \"https\").lower(),\n            (parsed.netloc or \"\").lower(),\n            path,\n            \"\",\n            urlencode(sorted(query)),\n            \"\",\n        )\n    )\n\n\ndef _dedupe_excluded(items: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    seen: set[tuple[str, str]] = set()\n    output: list[dict[str, Any]] = []\n    for item in items:\n        key = (_dedupe_key(str(item.get(\"url\", \"\"))), str(item.get(\"reason\", \"\")))\n        if key in seen:\n            continue\n        seen.add(key)\n        output.append(item)\n    return output\n\n\ndef _host_matches(host: str, blocked_hosts: set[str]) -> bool:\n    host = (host or \"\").lower().strip(\".\")\n    for blocked in blocked_hosts:\n        if host == blocked or host.endswith(f\".{blocked}\"):\n            return True\n    return False\n\n\ndef _is_shortener_url(url: str) -> bool:\n    return _host_matches((urlparse(url).netloc or \"\").lower(), SHORTENER_HOSTS)\n\n\ndef _is_media_url(parsed: Any) -> bool:\n    path = (parsed.path or \"\").lower()\n    for extension in MEDIA_EXTENSIONS:\n        if path.endswith(extension):\n            return True\n    query = dict(parse_qsl(parsed.query, keep_blank_values=True))\n    fmt = str(query.get(\"format\") or query.get(\"fm\") or \"\").lower().strip(\".\")\n    if fmt and f\".{fmt}\" in MEDIA_EXTENSIONS:\n        return True\n    return False\n\n\ndef _source_from_key(token: str, context: Context) -> str:\n    if token == \"expandedurl\" or token == \"expanded\":\n        return \"expanded_url\"\n    if token == \"unwoundurl\":\n        return \"expanded_url\"\n    if token == \"canonicalurl\":\n        return \"canonical_url\"\n    if token == \"finalurl\":\n        return \"final_url\"\n    if token == \"articleurl\" or token == \"sourceurl\":\n        return \"article_url\"\n    if context.in_card:\n        return \"card\"\n    if token in {\"href\", \"link\", \"url\"}:\n        return \"url_field\"\n    return \"json_url\"\n\n\ndef _find_post_id(value: Any) -> str:\n    if isinstance(value, dict):\n        found = _extract_post_id_from_dict(value)\n        if found:\n            return found\n        for child in value.values():\n            nested = _find_post_id(child)\n            if nested:\n                return nested\n    elif isinstance(value, list):\n        for child in value:\n            nested = _find_post_id(child)\n            if nested:\n                return nested\n    return \"\"\n\n\ndef _extract_post_id_from_dict(data: dict[str, Any]) -> str:\n    for key, value in data.items():\n        token = _key_token(key)\n        if token in POST_ID_KEYS:\n            text = _stringify_scalar(value)\n            if text:\n                return text\n        if token == \"id\":\n            text = _stringify_scalar(value)\n            if re.fullmatch(r\"\\d{10,}\", text or \"\"):\n                return text\n    return \"\"\n\n\ndef _find_media_index(value: Any) -> Any:\n    if isinstance(value, dict):\n        found = _extract_media_index_from_dict(value)\n        if found is not None:\n            return found\n        for child in value.values():\n            nested = _find_media_index(child)\n            if nested is not None:\n                return nested\n    elif isinstance(value, list):\n        for child in value:\n            nested = _find_media_index(child)\n            if nested is not None:\n                return nested\n    return None\n\n\ndef _extract_media_index_from_dict(data: dict[str, Any]) -> Any:\n    for key, value in data.items():\n        token = _key_token(key)\n        if token in MEDIA_INDEX_KEYS:\n            return value\n    return None\n\n\ndef _find_source_text(value: Any) -> str:\n    if isinstance(value, dict):\n        found = _extract_first_string(value, {\"sourcetext\", \"tweettext\", \"fulltext\", \"notetext\", \"text\"})\n        if found:\n            return found\n        for child in value.values():\n            nested = _find_source_text(child)\n            if nested:\n                return nested\n    elif isinstance(value, list):\n        for child in value:\n            nested = _find_source_text(child)\n            if nested:\n                return nested\n    elif isinstance(value, str):\n        return value.strip()\n    return \"\"\n\n\ndef _find_card_title(value: Any) -> str:\n    if isinstance(value, dict):\n        if _dict_says_card(value):\n            found = _extract_first_string(value, CARD_TITLE_KEYS)\n            if found:\n                return found\n        for key, child in value.items():\n            if _path_or_key_says_card(\"\", key):\n                nested = _find_card_title(child)\n                if nested:\n                    return nested\n        for child in value.values():\n            nested = _find_card_title(child)\n            if nested:\n                return nested\n    elif isinstance(value, list):\n        for child in value:\n            nested = _find_card_title(child)\n            if nested:\n                return nested\n    return \"\"\n\n\ndef _extract_first_string(data: dict[str, Any], key_tokens: set[str]) -> str:\n    for key, value in data.items():\n        if _key_token(key) in key_tokens and isinstance(value, str) and value.strip():\n            return value.strip()\n    return \"\"\n\n\ndef _stringify_scalar(value: Any) -> str:\n    if isinstance(value, (str, int)):\n        return str(value).strip()\n    return \"\"\n\n\ndef _dict_says_card(data: dict[str, Any]) -> bool:\n    keys = {_key_token(key) for key in data}\n    if keys & {\"card\", \"cardtitle\", \"bindingvalues\", \"unifiedcard\", \"summarycard\"}:\n        return True\n    return bool((keys & URL_KEYS) and (keys & CARD_TITLE_KEYS))\n\n\ndef _path_or_key_says_card(path: str, key: str) -> bool:\n    token = _key_token(key)\n    if any(hint in token for hint in CARD_PATH_HINTS):\n        return True\n    return _path_says_card(path)\n\n\ndef _path_says_card(path: str) -> bool:\n    tokens = [_key_token(part) for part in re.split(r\"[.\\[\\]]+\", path or \"\") if part]\n    return any(any(hint in token for hint in CARD_PATH_HINTS) for token in tokens)\n\n\ndef _path_says_media(path: str) -> bool:\n    lowered = (path or \"\").lower()\n    return any(word in lowered for word in [\"media\", \"image\", \"images\", \"photo\", \"video\"])\n\n\ndef _key_token(key: Any) -> str:\n    return re.sub(r\"[^a-z0-9]\", \"\", str(key or \"\").lower())\n\n\ndef _first_non_empty(values: list[Any]) -> str:\n    for value in values:\n        text = str(value or \"\").strip()\n        if text:\n            return text\n    return \"\"\n\n\ndef _load_cli_payload(args: argparse.Namespace) -> Any:\n    if args.json:\n        return json.loads(args.json)\n    if args.text:\n        return args.text\n    if not sys.stdin.isatty():\n        raw = sys.stdin.read()\n        if _looks_like_json(raw):\n            return json.loads(raw)\n        return raw\n    return {}\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Extract external article URLs from X post data.\")\n    parser.add_argument(\"--json\", default=\"\", help=\"JSON payload string\")\n    parser.add_argument(\"--text\", default=\"\", help=\"Post text to scan\")\n    parser.add_argument(\"--pretty\", action=\"store_true\", help=\"Pretty-print JSON\")\n    args = parser.parse_args(argv)\n    result = extract_news_urls(_load_cli_payload(args))\n    print(json.dumps(result, ensure_ascii=False, indent=2 if args.pretty else None))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
