    {
      "id": "node-9575d22dbe",
      "title": "動画内容確認ポワン",
      "body": "X上の終端投稿に含まれる動画を確認し、動画URLの抽出、動画ファイル保存、代表フレーム抽出、音声文字起こし、LMStudioによる映像内容読解、読解結果と文字起こし結果のDB保存へ振り分ける神経ポワン。本文だけでは分からない動画内の映像・音声・字幕相当の内容も追跡結果としてDBへ残すため、実処理は配下の臓器ポワンに分担させる。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom collections.abc import Callable, Mapping, Sequence\nfrom dataclasses import dataclass\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\n\nJsonMap = dict[str, Any]\nChildHandler = Callable[[JsonMap], Any]\n\n\n@dataclass(frozen=True)\nclass ChildStep:\n    key: str\n    title: str\n    error_type: str\n\n\nURL_EXTRACT = ChildStep(\"x_video_url_extract\", \"X動画URL抽出ポワン\", \"video_url_missing\")\nSAVE_VIDEO = ChildStep(\"video_file_save\", \"動画ファイル保存ポワン\", \"video_download_failed\")\nEXTRACT_FRAMES = ChildStep(\"video_frame_extract\", \"動画代表フレーム抽出ポワン\", \"frame_extract_failed\")\nTRANSCRIBE_AUDIO = ChildStep(\"video_audio_transcript\", \"動画音声文字起こしポワン\", \"transcription_failed\")\nREAD_VIDEO = ChildStep(\"lmstudio_video_read\", \"LMStudio動画読解ポワン\", \"vision_read_failed\")\nSAVE_DB = ChildStep(\"video_read_result_db_save\", \"動画読解結果DB保存ポワン\", \"db_write_failed\")\n\nPIPELINE_STEPS = (URL_EXTRACT, SAVE_VIDEO, EXTRACT_FRAMES, TRANSCRIBE_AUDIO, READ_VIDEO, SAVE_DB)\nRETRYABLE_ERRORS = {\n    \"video_download_failed\",\n    \"frame_extract_failed\",\n    \"audio_extract_failed\",\n    \"transcription_failed\",\n    \"lmstudio_unavailable\",\n    \"vision_read_failed\",\n    \"db_write_failed\",\n}\nDEFAULT_ARTIFACT_ROOT = Path(\"data\") / \"terminal_content\" / \"video\"\n_MISSING = object()\n\n\nclass VideoContentFlowError(RuntimeError):\n    def __init__(self, step: ChildStep, message: str, result: Any | None = None):\n        super().__init__(message)\n        self.step = step\n        self.result = result\n\n    def failure(self, *, phase: str | None = None, source_url: str = \"\") -> JsonMap:\n        message = str(self)\n        error_type = self.step.error_type\n        if self.step == READ_VIDEO and \"connection\" in message.lower():\n            error_type = \"lmstudio_unavailable\"\n        if self.step == TRANSCRIBE_AUDIO and any(word in message.lower() for word in (\"audio extract\", \"audio track\", \"no audio\")):\n            error_type = \"audio_extract_failed\"\n        return {\n            \"phase\": phase or self.step.key,\n            \"child_title\": self.step.title,\n            \"error_type\": error_type,\n            \"error_message\": message,\n            \"retryable\": error_type in RETRYABLE_ERRORS,\n            \"source_url\": source_url,\n            \"child_result\": self.result,\n        }\n\n\ndef confirm_video_component(\n    payload: Mapping[str, Any] | None = None,\n    *,\n    child_results: Mapping[str, Any] | None = None,\n    child_handlers: Mapping[str, ChildHandler] | None = None,\n    child_commands: Mapping[str, Any] | None = None,\n    artifact_root: str | Path | None = None,\n    write_artifacts: bool = True,\n    allow_partial: bool = True,\n) -> JsonMap:\n    original = dict(payload or {})\n    envelope = normalize_envelope(original)\n    video_items = normalize_video_items(original, envelope)\n    steps: list[JsonMap] = []\n    failures: list[JsonMap] = []\n    media_results: list[JsonMap] = []\n    downloaded: list[JsonMap] = []\n    frame_paths: list[str] = []\n    transcript_refs: list[JsonMap] = []\n    visual_summaries: list[str] = []\n    audio_summaries: list[str] = []\n    model_info: list[JsonMap] = []\n\n    if not component_enabled(original, envelope):\n        child_result = build_child_result(\n            envelope=envelope,\n            video_items=video_items,\n            status=\"skipped\",\n            failures=[failure_record(\"skipped\", \"video_url_missing\", \"video component was not requested\")],\n            downloaded=downloaded,\n            frame_paths=frame_paths,\n            transcript_refs=transcript_refs,\n            visual_summaries=visual_summaries,\n            audio_summaries=audio_summaries,\n            model_info=model_info,\n            media_results=media_results,\n            steps=steps,\n        )\n        return wrap_result(original, child_result, write_artifacts, artifact_root)\n\n    if not video_items:\n        failures.append(failure_record(\"url_extract\", \"video_url_missing\", \"video_items did not contain a playable URL\"))\n        child_result = build_child_result(\n            envelope=envelope,\n            video_items=video_items,\n            status=\"failed\",\n            failures=failures,\n            downloaded=downloaded,\n            frame_paths=frame_paths,\n            transcript_refs=transcript_refs,\n            visual_summaries=visual_summaries,\n            audio_summaries=audio_summaries,\n            model_info=model_info,\n            media_results=media_results,\n            steps=steps,\n        )\n        return wrap_result(original, child_result, write_artifacts, artifact_root)\n\n    try:\n        extract_payload = build_url_extract_payload(envelope, video_items, original)\n        extract_result = maybe_run_child(\n            URL_EXTRACT,\n            extract_payload,\n            fallback=synthetic_extract_result(envelope, video_items),\n            child_results=child_results or {},\n            child_handlers=child_handlers or {},\n            child_commands=child_commands or {},\n            steps=steps,\n        )\n        ensure_ok(URL_EXTRACT, extract_result)\n\n        save_result = run_child(\n            SAVE_VIDEO,\n            build_save_payload(envelope, extract_result, video_items, original),\n            child_results=child_results or {},\n            child_handlers=child_handlers or {},\n            child_commands=child_commands or {},\n            steps=steps,\n        )\n        ensure_ok(SAVE_VIDEO, save_result)\n    except VideoContentFlowError as exc:\n        failures.append(exc.failure(phase=\"download\"))\n        child_result = build_child_result(\n            envelope=envelope,\n            video_items=video_items,\n            status=\"failed\",\n            failures=failures,\n            downloaded=downloaded,\n            frame_paths=frame_paths,\n            transcript_refs=transcript_refs,\n            visual_summaries=visual_summaries,\n            audio_summaries=audio_summaries,\n            model_info=model_info,\n            media_results=media_results,\n            steps=steps,\n        )\n        child_result[\"child_results\"] = {URL_EXTRACT.key: locals().get(\"extract_result\"), SAVE_VIDEO.key: locals().get(\"save_result\")}\n        return wrap_result(original, child_result, write_artifacts, artifact_root)\n\n    saved_media = extract_saved_media(save_result)\n    if not saved_media:\n        failures.append(failure_record(\"download\", \"video_download_failed\", \"video file save result contained no saved videos\"))\n\n    for index, media in enumerate(saved_media, start=1):\n        item = video_items[min(index - 1, len(video_items) - 1)]\n        source_url = first_text(media, (\"source_url\", \"sourceUrl\", \"url\")) or item.get(\"source_url\", \"\")\n        media_context = build_media_context(envelope, item, media, save_result, index)\n        media_state: JsonMap = {\"media_index\": index, \"source_url\": source_url, \"media_asset\": media, \"child_results\": {}}\n        media_results.append(media_state)\n        downloaded.append(compact_download(media, item))\n\n        frame_result: Any = {}\n        transcript_result: Any = {}\n        read_result: Any = {}\n\n        try:\n            frame_result = run_child(EXTRACT_FRAMES, media_context, child_results=child_results or {}, child_handlers=child_handlers or {}, child_commands=child_commands or {}, steps=steps, media_number=index)\n            ensure_ok(EXTRACT_FRAMES, frame_result)\n            media_state[\"child_results\"][EXTRACT_FRAMES.key] = frame_result\n            frame_paths.extend(collect_paths(frame_result))\n            model_info.extend(collect_model_info(EXTRACT_FRAMES, frame_result))\n        except VideoContentFlowError as exc:\n            failures.append(exc.failure(phase=\"frame_extract\", source_url=source_url))\n            media_state[\"frame_error\"] = failures[-1]\n            if not allow_partial:\n                break\n\n        try:\n            transcript_result = run_child(TRANSCRIBE_AUDIO, media_context, child_results=child_results or {}, child_handlers=child_handlers or {}, child_commands=child_commands or {}, steps=steps, media_number=index)\n            ensure_ok(TRANSCRIBE_AUDIO, transcript_result)\n            media_state[\"child_results\"][TRANSCRIBE_AUDIO.key] = transcript_result\n            transcript_refs.extend(collect_transcript_refs(transcript_result))\n            audio_summaries.extend(collect_audio_summary(transcript_result))\n            model_info.extend(collect_model_info(TRANSCRIBE_AUDIO, transcript_result))\n        except VideoContentFlowError as exc:\n            failure = exc.failure(phase=\"transcription\", source_url=source_url)\n            failures.append(failure)\n            transcript_result = {\"ok\": False, \"error_type\": failure[\"error_type\"], \"error\": failure[\"error_message\"]}\n            media_state[\"transcription_error\"] = failure\n            if not allow_partial and not frame_result:\n                break\n\n        if child_ok(frame_result):\n            try:\n                read_result = run_child(\n                    READ_VIDEO,\n                    build_read_payload(media_context, frame_result, transcript_result),\n                    child_results=child_results or {},\n                    child_handlers=child_handlers or {},\n                    child_commands=child_commands or {},\n                    steps=steps,\n                    media_number=index,\n                )\n                ensure_ok(READ_VIDEO, read_result)\n                media_state[\"child_results\"][READ_VIDEO.key] = read_result\n                visual_summaries.extend(collect_visual_summary(read_result))\n                model_info.extend(collect_model_info(READ_VIDEO, read_result))\n            except VideoContentFlowError as exc:\n                failures.append(exc.failure(phase=\"vision_read\", source_url=source_url))\n                read_result = {\"ok\": False, \"error\": failures[-1][\"error_message\"], \"error_type\": failures[-1][\"error_type\"]}\n                media_state[\"vision_error\"] = failures[-1]\n\n        try:\n            db_result = run_child(\n                SAVE_DB,\n                build_db_payload(media_context, frame_result, transcript_result, read_result, failures),\n                child_results=child_results or {},\n                child_handlers=child_handlers or {},\n                child_commands=child_commands or {},\n                steps=steps,\n                media_number=index,\n            )\n            ensure_ok(SAVE_DB, db_result)\n            media_state[\"child_results\"][SAVE_DB.key] = db_result\n            model_info.extend(collect_model_info(SAVE_DB, db_result))\n        except VideoContentFlowError as exc:\n            failures.append(exc.failure(phase=\"db_write\", source_url=source_url))\n            media_state[\"db_error\"] = failures[-1]\n            if not allow_partial:\n                break\n\n    status = decide_status(video_items, downloaded, failures)\n    child_result = build_child_result(\n        envelope=envelope,\n        video_items=video_items,\n        status=status,\n        failures=failures,\n        downloaded=downloaded,\n        frame_paths=unique_text(frame_paths),\n        transcript_refs=transcript_refs,\n        visual_summaries=unique_text(visual_summaries),\n        audio_summaries=unique_text(audio_summaries),\n        model_info=model_info,\n        media_results=media_results,\n        steps=steps,\n    )\n    child_result[\"child_results\"] = {URL_EXTRACT.key: extract_result, SAVE_VIDEO.key: save_result}\n    return wrap_result(original, child_result, write_artifacts, artifact_root)\n\n\ndef confirm_video_content(*args: Any, **kwargs: Any) -> JsonMap:\n    return confirm_video_component(*args, **kwargs)\n\n\ndef maybe_run_child(step: ChildStep, payload: JsonMap, *, fallback: Any, child_results: Mapping[str, Any], child_handlers: Mapping[str, ChildHandler], child_commands: Mapping[str, Any], steps: list[JsonMap]) -> Any:\n    if has_step_value(child_results, step) or has_step_value(child_handlers, step) or has_step_value(child_commands, step):\n        return run_child(step, payload, child_results=child_results, child_handlers=child_handlers, child_commands=child_commands, steps=steps)\n    steps.append(step_record(step, None, \"synthetic\", True))\n    return fallback\n\n\ndef run_child(step: ChildStep, payload: JsonMap, *, child_results: Mapping[str, Any], child_handlers: Mapping[str, ChildHandler], child_commands: Mapping[str, Any], steps: list[JsonMap], media_number: int | None = None) -> Any:\n    cached, key = lookup_step_value(child_results, step, media_number)\n    if cached is not _MISSING:\n        steps.append(step_record(step, media_number, \"precomputed\", child_ok(cached), key=key))\n        return cached\n    handler, key = lookup_step_value(child_handlers, step, media_number)\n    if handler is not _MISSING:\n        try:\n            result = handler(payload)\n        except Exception as exc:\n            steps.append(step_record(step, media_number, \"handler\", False, error=str(exc), key=key))\n            raise VideoContentFlowError(step, f\"{step.title} handler failed: {exc}\") from exc\n        steps.append(step_record(step, media_number, \"handler\", child_ok(result), key=key))\n        return result\n    command, key = lookup_step_value(child_commands, step, media_number)\n    if command is not _MISSING:\n        result = run_command(step, command, payload)\n        steps.append(step_record(step, media_number, \"command\", child_ok(result), key=key))\n        return result\n    steps.append(step_record(step, media_number, \"missing\", False))\n    raise VideoContentFlowError(step, f\"{step.title} を呼ぶ handler / command / precomputed result がありません\")\n\n\ndef run_command(step: ChildStep, command: Any, payload: JsonMap) -> Any:\n    stdin = json.dumps(payload, ensure_ascii=False)\n    args: dict[str, Any] = {\"input\": stdin, \"text\": True, \"capture_output\": True, \"check\": False}\n    completed = subprocess.run(command if isinstance(command, str) else [str(v) for v in command], shell=isinstance(command, str), **args)\n    parsed = parse_json_output(completed.stdout)\n    if completed.returncode != 0:\n        if isinstance(parsed, dict):\n            parsed.setdefault(\"ok\", False)\n            parsed.setdefault(\"error\", (completed.stderr or \"\").strip())\n            parsed[\"_child_process\"] = {\"returncode\": completed.returncode, \"stderr\": completed.stderr}\n            return parsed\n        raise VideoContentFlowError(step, f\"{step.title} command failed: {(completed.stderr or '').strip()}\")\n    if parsed is _MISSING:\n        raise VideoContentFlowError(step, f\"{step.title} command did not print JSON\")\n    return parsed\n\n\ndef normalize_envelope(payload: JsonMap) -> JsonMap:\n    env = dict(payload.get(\"terminal_post_envelope\") or payload.get(\"envelope\") or payload)\n    author = env.get(\"author\") or {\"id\": env.get(\"author_id\"), \"screen_name\": env.get(\"screen_name\")}\n    return {\n        \"run_id\": str(env.get(\"run_id\") or \"\"),\n        \"trace_id\": str(env.get(\"trace_id\") or \"\"),\n        \"terminal_post_id\": str(env.get(\"terminal_post_id\") or env.get(\"post_id\") or env.get(\"postId\") or \"\"),\n        \"terminal_post_url\": str(env.get(\"terminal_post_url\") or env.get(\"post_url\") or env.get(\"url\") or \"\"),\n        \"author\": author,\n        \"text_excerpt\": str(env.get(\"text_excerpt\") or env.get(\"text\") or \"\")[:300],\n        \"parent_trace\": as_list(env.get(\"parent_trace\")),\n        \"discovery_path\": as_list(env.get(\"discovery_path\")),\n        \"component_flags\": dict(env.get(\"component_flags\") or {}),\n        \"evidence_urls\": unique_text(as_list(env.get(\"evidence_urls\"))),\n        \"fetch_status\": env.get(\"fetch_status\"),\n    }\n\n\ndef normalize_video_items(payload: JsonMap, envelope: JsonMap) -> list[JsonMap]:\n    raw = payload.get(\"video_items\") or payload.get(\"videos\")\n    if raw is None:\n        raw = (payload.get(\"terminal_post_envelope\") or payload).get(\"video_items\")\n    if raw is None:\n        raw = [m for m in as_list((payload.get(\"terminal_post_envelope\") or payload).get(\"media_items\")) if \"video\" in str(m).lower()]\n    items: list[JsonMap] = []\n    for index, item in enumerate(as_list(raw), start=1):\n        if not isinstance(item, Mapping):\n            continue\n        candidates = candidate_urls(item)\n        if not candidates:\n            continue\n        evidence = unique_text([item.get(\"evidence_url\"), item.get(\"poster_url\"), *envelope.get(\"evidence_urls\", [])])\n        items.append({\n            \"post_id\": envelope[\"terminal_post_id\"],\n            \"post_url\": envelope[\"terminal_post_url\"],\n            \"media_index\": item.get(\"media_index\", item.get(\"mediaIndex\", index - 1)),\n            \"x_media_key\": item.get(\"x_media_key\") or item.get(\"media_key\") or item.get(\"mediaKey\"),\n            \"source_url\": candidates[0],\n            \"sourceUrl\": candidates[0],\n            \"candidateUrls\": candidates,\n            \"posterUrl\": item.get(\"poster_url\") or item.get(\"posterUrl\") or \"\",\n            \"duration\": ms_to_seconds(item.get(\"duration_ms\") or item.get(\"durationMs\")) or item.get(\"duration\"),\n            \"evidence\": evidence,\n            \"raw_video_item\": dict(item),\n        })\n    return items\n\n\ndef candidate_urls(item: Mapping[str, Any]) -> list[str]:\n    scored: list[tuple[int, int, str]] = []\n    for key in (\"playback_url\", \"playbackUrl\", \"source_url\", \"sourceUrl\", \"url\"):\n        if isinstance(item.get(key), str) and item[key].strip():\n            scored.append((1_000_000, len(scored), item[key].strip()))\n    for variant in as_list(item.get(\"variants\")):\n        if isinstance(variant, str):\n            scored.append((500_000, len(scored), variant.strip()))\n        elif isinstance(variant, Mapping):\n            url = first_text(variant, (\"url\", \"playback_url\", \"playbackUrl\", \"src\"))\n            if url:\n                score = 500_000 + int_value(variant.get(\"bitrate\")) + int_value(variant.get(\"width\")) * int_value(variant.get(\"height\"))\n                scored.append((score, len(scored), url))\n    return unique_text([url for _, _, url in sorted(scored, key=lambda v: (-v[0], v[1])) if url])\n\n\ndef build_url_extract_payload(envelope: JsonMap, video_items: list[JsonMap], original: JsonMap) -> JsonMap:\n    return {\"terminal_post_envelope\": envelope, \"video_items\": video_items, \"input\": original}\n\n\ndef synthetic_extract_result(envelope: JsonMap, video_items: list[JsonMap]) -> JsonMap:\n    return {\"ok\": True, \"post_id\": envelope[\"terminal_post_id\"], \"post_url\": envelope[\"terminal_post_url\"], \"videos\": video_items, \"source\": \"terminal_post_envelope.video_items\"}\n\n\ndef build_save_payload(envelope: JsonMap, extract_result: Any, video_items: list[JsonMap], original: JsonMap) -> JsonMap:\n    return {\"terminal_post_envelope\": envelope, \"input\": original, \"video_url_extract_result\": extract_result, \"videos\": mapping_get(extract_result, \"videos\", video_items)}\n\n\ndef build_media_context(envelope: JsonMap, item: JsonMap, media: JsonMap, save_result: Any, index: int) -> JsonMap:\n    return {\"terminal_post_envelope\": envelope, \"component_type\": \"video\", \"mediaNumber\": index, \"video_item\": item, \"media_asset\": media, \"video\": media, \"video_save_result\": save_result, \"run_id\": envelope[\"run_id\"], \"trace_id\": envelope[\"trace_id\"], \"terminal_post_id\": envelope[\"terminal_post_id\"], \"source_url\": first_text(media, (\"source_url\", \"sourceUrl\", \"url\")) or item.get(\"source_url\", \"\")}\n\n\ndef build_read_payload(context: JsonMap, frame_result: Any, transcript_result: Any) -> JsonMap:\n    return {**context, \"frame_extract_result\": frame_result, \"frames_result\": frame_result, \"transcript_result\": transcript_result, \"audio_transcript_result\": transcript_result}\n\n\ndef build_db_payload(context: JsonMap, frame_result: Any, transcript_result: Any, read_result: Any, failures: list[JsonMap]) -> JsonMap:\n    return {**context, \"video_save_result\": context.get(\"media_asset\"), \"frame_result\": frame_result, \"frame_extract_result\": frame_result, \"transcript_result\": transcript_result, \"audio_transcript_result\": transcript_result, \"analysis_result\": read_result, \"lmstudio_result\": read_result, \"pipeline_failures\": failures}\n\n\ndef build_child_result(*, envelope: JsonMap, video_items: list[JsonMap], status: str, failures: list[JsonMap], downloaded: list[JsonMap], frame_paths: list[str], transcript_refs: list[JsonMap], visual_summaries: list[str], audio_summaries: list[str], model_info: list[JsonMap], media_results: list[JsonMap], steps: list[JsonMap]) -> JsonMap:\n    first_failure = failures[0] if failures else {}\n    return {\n        \"status\": status,\n        \"component_type\": \"video\",\n        \"run_id\": envelope[\"run_id\"],\n        \"trace_id\": envelope[\"trace_id\"],\n        \"terminal_post_id\": envelope[\"terminal_post_id\"],\n        \"terminal_post_url\": envelope[\"terminal_post_url\"],\n        \"source_url\": first_text(downloaded[0], (\"source_url\", \"sourceUrl\")) if downloaded else first_text(video_items[0], (\"source_url\", \"sourceUrl\")) if video_items else \"\",\n        \"video_count\": len(video_items),\n        \"downloaded_videos\": downloaded,\n        \"frame_paths\": frame_paths,\n        \"transcript_path\": first_text(transcript_refs[0], (\"path\", \"transcript_path\", \"transcriptPath\")) if transcript_refs else \"\",\n        \"transcript_text_ref\": first_text(transcript_refs[0], (\"text_ref\", \"textRef\")) if transcript_refs else \"\",\n        \"visual_summary\": \"\\n\".join(visual_summaries)[:2000],\n        \"audio_summary\": \"\\n\".join(audio_summaries)[:1200],\n        \"model_or_tool_info\": model_info,\n        \"artifact_paths\": unique_text([*(first_text(v, (\"local_path\", \"localPath\", \"path\")) for v in downloaded), *frame_paths, *(first_text(t, (\"path\", \"transcript_path\", \"transcriptPath\")) for t in transcript_refs)]),\n        \"extracted_metadata\": {\"video_items\": video_items, \"media_results\": media_results},\n        \"evidence_json\": {\"evidence_urls\": envelope.get(\"evidence_urls\", []), \"parent_trace\": envelope.get(\"parent_trace\", []), \"discovery_path\": envelope.get(\"discovery_path\", []), \"failures\": failures, \"steps\": steps},\n        \"error_type\": first_failure.get(\"error_type\"),\n        \"error_message\": first_failure.get(\"error_message\"),\n        \"retryable\": bool(first_failure.get(\"retryable\", False)),\n        \"finished_at\": now_iso(),\n    }\n\n\ndef wrap_result(original: JsonMap, child_result: JsonMap, write_artifacts: bool, artifact_root: str | Path | None) -> JsonMap:\n    if write_artifacts:\n        artifacts = write_event_artifacts(child_result, Path(artifact_root) if artifact_root else DEFAULT_ARTIFACT_ROOT)\n        child_result[\"artifact_paths\"] = unique_text([*child_result.get(\"artifact_paths\", []), *artifacts.values()])\n    return {\"ok\": child_result[\"status\"] in {\"success\", \"partial\", \"skipped\"}, \"child_result\": child_result, \"input\": original}\n\n\ndef write_event_artifacts(child_result: JsonMap, root: Path) -> dict[str, str]:\n    run_id = safe_name(child_result.get(\"run_id\") or \"no_run\")\n    trace_id = safe_name(child_result.get(\"trace_id\") or child_result.get(\"terminal_post_id\") or \"no_trace\")\n    directory = root / run_id\n    directory.mkdir(parents=True, exist_ok=True)\n    jsonl_path = directory / f\"{trace_id}.jsonl\"\n    log_path = directory / f\"{trace_id}.log\"\n    event = {\"event_type\": \"child_result_recorded\", \"event_ts\": now_iso(), **{k: child_result.get(k) for k in (\"run_id\", \"trace_id\", \"terminal_post_id\", \"component_type\", \"status\", \"error_type\", \"retryable\", \"artifact_paths\")}, \"evidence_urls\": child_result.get(\"evidence_json\", {}).get(\"evidence_urls\", [])}\n    with jsonl_path.open(\"a\", encoding=\"utf-8\") as handle:\n        handle.write(json.dumps(event, ensure_ascii=False) + \"\\n\")\n    summary = f\"{event['event_ts']} video status={child_result.get('status')} post={child_result.get('terminal_post_url')} videos={child_result.get('video_count')} error={child_result.get('error_type') or ''}\\n\"\n    with log_path.open(\"a\", encoding=\"utf-8\") as handle:\n        handle.write(summary)\n    return {\"jsonl_path\": str(jsonl_path), \"runs_log_path\": str(log_path)}\n\n\ndef extract_saved_media(save_result: Any) -> list[JsonMap]:\n    if isinstance(save_result, list):\n        return [dict(v) for v in save_result if isinstance(v, Mapping)]\n    if not isinstance(save_result, Mapping):\n        return []\n    for key in (\"videos\", \"saved\", \"items\", \"results\", \"media\"):\n        if isinstance(save_result.get(key), list):\n            return [dict(v) for v in save_result[key] if isinstance(v, Mapping)]\n    return [dict(save_result)] if any(k in save_result for k in (\"local_path\", \"localPath\", \"path\", \"source_url\")) else []\n\n\ndef compact_download(media: JsonMap, item: JsonMap) -> JsonMap:\n    return {\"source_url\": first_text(media, (\"source_url\", \"sourceUrl\", \"url\")) or item.get(\"source_url\", \"\"), \"local_path\": first_text(media, (\"local_path\", \"localPath\", \"path\")), \"sha256\": first_text(media, (\"sha256\", \"hash\")), \"mime\": first_text(media, (\"mime\", \"mime_type\", \"mimeType\")), \"duration\": media.get(\"duration\") or media.get(\"duration_seconds\") or item.get(\"duration\"), \"x_media_key\": item.get(\"x_media_key\"), \"evidence_url\": first_text(item, (\"evidence_url\", \"evidenceUrl\"))}\n\n\ndef collect_paths(value: Any) -> list[str]:\n    out: list[str] = []\n    if isinstance(value, Mapping):\n        path = first_text(value, (\"local_path\", \"localPath\", \"path\", \"file_path\", \"filePath\", \"transcript_path\", \"transcriptPath\"))\n        if path:\n            out.append(path)\n        for nested in value.values():\n            if isinstance(nested, (Mapping, list)):\n                out.extend(collect_paths(nested))\n    elif isinstance(value, list):\n        for item in value:\n            out.extend(collect_paths(item))\n    return unique_text(out)\n\n\ndef collect_transcript_refs(result: Any) -> list[JsonMap]:\n    refs = []\n    for path in collect_paths(result):\n        refs.append({\"path\": path})\n    text = first_deep_text(result, (\"transcriptText\", \"transcript_text\", \"text\", \"content\"))\n    if text:\n        refs.append({\"text_ref\": f\"inline:{len(text)}chars\", \"text_excerpt\": text[:300]})\n    return refs\n\n\ndef collect_audio_summary(result: Any) -> list[str]:\n    text = first_deep_text(result, (\"summary\", \"transcriptText\", \"transcript_text\", \"text\", \"content\"))\n    return [text[:500]] if text else []\n\n\ndef collect_visual_summary(result: Any) -> list[str]:\n    return unique_text([first_deep_text(result, (\"summary\", \"description\", \"ocr_text\", \"raw_text\"))])\n\n\ndef collect_model_info(step: ChildStep, result: Any) -> list[JsonMap]:\n    if not isinstance(result, Mapping):\n        return []\n    info = {\"step\": step.key, \"title\": step.title}\n    for key in (\"model\", \"engine\", \"sourceScript\", \"source_script\", \"prompt_version\", \"dbPath\"):\n        if result.get(key):\n            info[key] = result[key]\n    return [info] if len(info) > 2 else []\n\n\ndef decide_status(video_items: list[JsonMap], downloaded: list[JsonMap], failures: list[JsonMap]) -> str:\n    if not failures and downloaded:\n        return \"success\"\n    if downloaded:\n        return \"partial\"\n    return \"failed\" if video_items else \"skipped\"\n\n\ndef ensure_ok(step: ChildStep, result: Any) -> None:\n    if not child_ok(result):\n        raise VideoContentFlowError(step, child_error(step, result), result)\n\n\ndef child_ok(result: Any) -> bool:\n    return not (isinstance(result, Mapping) and (result.get(\"ok\") is False or (result.get(\"error\") and result.get(\"ok\") is not True)))\n\n\ndef child_error(step: ChildStep, result: Any) -> str:\n    if isinstance(result, Mapping):\n        return str(result.get(\"error\") or result.get(\"message\") or result.get(\"reason\") or f\"{step.title} failed\")\n    return f\"{step.title} failed\"\n\n\ndef failure_record(phase: str, error_type: str, message: str) -> JsonMap:\n    return {\"phase\": phase, \"error_type\": error_type, \"error_message\": message, \"retryable\": error_type in RETRYABLE_ERRORS}\n\n\ndef lookup_step_value(values: Mapping[str, Any], step: ChildStep, media_number: int | None) -> tuple[Any, str]:\n    for key in (step.key, step.title):\n        if key in values:\n            value = values[key]\n            if media_number is not None and isinstance(value, list) and media_number - 1 < len(value):\n                return value[media_number - 1], key\n            return value, key\n    return _MISSING, \"\"\n\n\ndef has_step_value(values: Mapping[str, Any], step: ChildStep) -> bool:\n    return any(key in values for key in (step.key, step.title))\n\n\ndef step_record(step: ChildStep, media_number: int | None, source: str, ok: bool, **extra: Any) -> JsonMap:\n    record = {\"step\": step.key, \"title\": step.title, \"source\": source, \"ok\": bool(ok)}\n    if media_number is not None:\n        record[\"media_number\"] = media_number\n    record.update({k: v for k, v in extra.items() if v not in (\"\", None)})\n    return record\n\n\ndef parse_json_output(text: str) -> Any:\n    clean = (text or \"\").strip()\n    if not clean:\n        return _MISSING\n    try:\n        return json.loads(clean)\n    except json.JSONDecodeError:\n        start, end = clean.find(\"{\"), clean.rfind(\"}\")\n        if 0 <= start < end:\n            try:\n                return json.loads(clean[start : end + 1])\n            except json.JSONDecodeError:\n                return _MISSING\n    return _MISSING\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        text = sys.stdin.read()\n        return json.loads(text) if text.strip() else {}\n    path = Path(value)\n    return json.loads(path.read_text(encoding=\"utf-8\")) if path.exists() else json.loads(value)\n\n\ndef mapping_get(value: Any, key: str, default: Any = None) -> Any:\n    return value.get(key, default) if isinstance(value, Mapping) else default\n\n\ndef first_text(record: Any, keys: Sequence[str]) -> str:\n    if not isinstance(record, Mapping):\n        return \"\"\n    for key in keys:\n        value = record.get(key)\n        if value not in (None, \"\"):\n            return str(value)\n    return \"\"\n\n\ndef first_deep_text(value: Any, keys: Sequence[str]) -> str:\n    if isinstance(value, Mapping):\n        text = first_text(value, keys)\n        if text:\n            return text\n        for nested in value.values():\n            text = first_deep_text(nested, keys)\n            if text:\n                return text\n    elif isinstance(value, list):\n        for item in value:\n            text = first_deep_text(item, keys)\n            if text:\n                return text\n    return \"\"\n\n\ndef as_list(value: Any) -> list[Any]:\n    if value is None:\n        return []\n    return value if isinstance(value, list) else [value]\n\n\ndef unique_text(values: Sequence[Any]) -> list[str]:\n    out: list[str] = []\n    seen: set[str] = set()\n    for value in values:\n        text = str(value or \"\").strip()\n        if text and text not in seen:\n            seen.add(text)\n            out.append(text)\n    return out\n\n\ndef int_value(value: Any) -> int:\n    try:\n        return int(float(value or 0))\n    except (TypeError, ValueError):\n        return 0\n\n\ndef ms_to_seconds(value: Any) -> float | None:\n    number = int_value(value)\n    return number / 1000 if number else None\n\n\ndef component_enabled(payload: JsonMap, envelope: JsonMap) -> bool:\n    flags = envelope.get(\"component_flags\") or {}\n    requested = payload.get(\"component_type\") or payload.get(\"component\") or \"video\"\n    return flags.get(\"video\", True) is not False and requested in {\"video\", \"mixed\"}\n\n\ndef safe_name(value: Any) -> str:\n    text = \"\".join(ch if ch.isalnum() or ch in \"-_.\" else \"_\" for ch in str(value or \"\").strip())\n    return text[:80] or \"unknown\"\n\n\ndef now_iso() -> str:\n    return datetime.now(timezone.utc).isoformat()\n\n\ndef parse_args(argv: list[str]) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Confirm and save video component content from a terminal X post.\")\n    parser.add_argument(\"--input-json\", default=\"-\")\n    parser.add_argument(\"--child-results\", default=\"\")\n    parser.add_argument(\"--child-commands\", default=\"\")\n    parser.add_argument(\"--artifact-root\", default=str(DEFAULT_ARTIFACT_ROOT))\n    parser.add_argument(\"--no-write-artifacts\", action=\"store_true\")\n    parser.add_argument(\"--strict\", action=\"store_true\", help=\"Stop after the first phase failure.\")\n    parser.add_argument(\"--indent\", type=int, default=2)\n    return parser.parse_args(argv)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = parse_args(argv or sys.argv[1:])\n    result = confirm_video_component(\n        load_json_arg(args.input_json),\n        child_results=load_json_arg(args.child_results) if args.child_results else None,\n        child_commands=load_json_arg(args.child_commands) if args.child_commands else None,\n        artifact_root=args.artifact_root,\n        write_artifacts=not args.no_write_artifacts,\n        allow_partial=not args.strict,\n    )\n    print(json.dumps(result, ensure_ascii=False, indent=args.indent))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
