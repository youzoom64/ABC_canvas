    {
      "id": "node-858b960862",
      "title": "ページ最下部認識ポワン",
      "body": "Selenium driverでスクロール後のscrollY、viewport高さ、scrollHeightを読み、ページ最下部まで到達したかを認識する臓器ポワン。単に底に近いだけでなく、スクロール位置とページ高さが連続して安定した時にat_bottom=trueを返し、X投稿収集ポワンのスクロール停止判断に使える。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nfrom dataclasses import asdict, dataclass\nimport logging\nimport time\nfrom typing import Any\n\nlog = logging.getLogger(\"page_bottom_detector\")\n\n\n@dataclass(frozen=True)\nclass PageBottomState:\n    scroll_y: float\n    viewport_height: float\n    scroll_height: float\n    distance_to_bottom: float\n    near_bottom: bool\n    at_bottom: bool\n    stable_samples: int\n    reason: str\n\n    def to_dict(self) -> dict[str, Any]:\n        return asdict(self)\n\n\ndef _number(value: Any, *, default: float = 0.0) -> float:\n    try:\n        return float(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef read_scroll_metrics(driver: Any) -> dict[str, float]:\n    \"\"\"Read browser scroll metrics from the active page.\"\"\"\n    raw = driver.execute_script(\n        \"\"\"\n        const doc = document.scrollingElement || document.documentElement || document.body;\n        const body = document.body || doc;\n        const root = document.documentElement || doc;\n        const scrollY = window.pageYOffset ?? doc.scrollTop ?? 0;\n        const viewportHeight = window.innerHeight || root.clientHeight || doc.clientHeight || 0;\n        const scrollHeight = Math.max(\n          doc.scrollHeight || 0,\n          body.scrollHeight || 0,\n          root.scrollHeight || 0,\n          doc.offsetHeight || 0,\n          body.offsetHeight || 0,\n          root.offsetHeight || 0\n        );\n        return {scrollY, viewportHeight, scrollHeight};\n        \"\"\"\n    ) or {}\n    metrics = {\n        \"scroll_y\": _number(raw.get(\"scrollY\")),\n        \"viewport_height\": _number(raw.get(\"viewportHeight\")),\n        \"scroll_height\": _number(raw.get(\"scrollHeight\")),\n    }\n    log.debug(\"page_bottom.metrics %s\", metrics)\n    return metrics\n\n\ndef detect_page_bottom(\n    driver: Any,\n    *,\n    previous_state: PageBottomState | None = None,\n    threshold_px: float = 12.0,\n    min_stable_samples: int = 2,\n) -> PageBottomState:\n    \"\"\"Return whether the active page has reached a stable bottom after scrolling.\"\"\"\n    metrics = read_scroll_metrics(driver)\n    scroll_y = metrics[\"scroll_y\"]\n    viewport_height = metrics[\"viewport_height\"]\n    scroll_height = metrics[\"scroll_height\"]\n    distance_to_bottom = max(scroll_height - (scroll_y + viewport_height), 0.0)\n    near_bottom = distance_to_bottom <= threshold_px\n\n    stable_samples = 1\n    if previous_state is not None:\n        scroll_moved = abs(scroll_y - previous_state.scroll_y)\n        height_changed = abs(scroll_height - previous_state.scroll_height)\n        if scroll_moved <= threshold_px and height_changed <= threshold_px:\n            stable_samples = previous_state.stable_samples + 1\n\n    at_bottom = near_bottom and stable_samples >= max(1, min_stable_samples)\n    if at_bottom:\n        reason = \"bottom_and_stable\"\n    elif near_bottom:\n        reason = \"near_bottom_waiting_for_stability\"\n    else:\n        reason = \"not_bottom\"\n\n    state = PageBottomState(\n        scroll_y=scroll_y,\n        viewport_height=viewport_height,\n        scroll_height=scroll_height,\n        distance_to_bottom=distance_to_bottom,\n        near_bottom=near_bottom,\n        at_bottom=at_bottom,\n        stable_samples=stable_samples,\n        reason=reason,\n    )\n    log.info(\n        \"page_bottom.detect at_bottom=%s near_bottom=%s distance=%.1f stable_samples=%s reason=%s\",\n        state.at_bottom,\n        state.near_bottom,\n        state.distance_to_bottom,\n        state.stable_samples,\n        state.reason,\n    )\n    return state\n\n\ndef scroll_and_detect_page_bottom(\n    driver: Any,\n    *,\n    previous_state: PageBottomState | None = None,\n    step_px: float | None = None,\n    wait_seconds: float = 0.8,\n    threshold_px: float = 12.0,\n    min_stable_samples: int = 2,\n) -> PageBottomState:\n    \"\"\"Scroll down once, wait briefly, then detect whether the page bottom is reached.\"\"\"\n    actual_step = driver.execute_script(\n        \"\"\"\n        const requested = arguments[0];\n        const step = requested ?? Math.max(window.innerHeight * 0.85, 400);\n        window.scrollBy(0, step);\n        return step;\n        \"\"\",\n        step_px,\n    )\n    log.info(\"page_bottom.scroll step_px=%s wait_seconds=%s\", actual_step, wait_seconds)\n    if wait_seconds > 0:\n        time.sleep(wait_seconds)\n    return detect_page_bottom(\n        driver,\n        previous_state=previous_state,\n        threshold_px=threshold_px,\n        min_stable_samples=min_stable_samples,\n    )",
