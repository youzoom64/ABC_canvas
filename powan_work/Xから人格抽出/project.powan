    {
      "id": "node-c9920048b7",
      "title": "動画読解結果DB保存ポワン",
      "body": "動画ファイル保存ポワン、動画代表フレーム抽出ポワン、動画音声文字起こしポワン、LMStudio動画読解ポワンの結果を受け取り、SQLite DBへ保存する臓器ポワン。動画アセット、代表サムネイルシート、音声文字起こしテキスト、映像読解結果をpost_idとmedia_indexで紐づけ、追跡の最終根拠として後から参照できるように保存する。Selenium操作、動画保存、文字起こし実行、LMStudio呼び出しは行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport sqlite3\nimport sys\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\nDEFAULT_DB_PATH = Path(\"data\") / \"x_posts.sqlite\"\n\nPOST_KEYS = (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\", \"x_post_id\", \"xPostId\")\nINDEX_KEYS = (\"media_index\", \"mediaIndex\", \"index\", \"ordinal\", \"position\")\nSOURCE_KEYS = (\n    \"source_url\", \"sourceUrl\", \"download_url\", \"downloadUrl\", \"playback_url\", \"playbackUrl\",\n    \"media_url\", \"mediaUrl\", \"video_url\", \"videoUrl\", \"original_url\", \"originalUrl\",\n    \"final_url\", \"finalUrl\", \"url\",\n)\nLOCAL_PATH_KEYS = (\"local_path\", \"localPath\", \"video_path\", \"videoPath\", \"path\", \"file_path\", \"filePath\", \"saved_path\", \"savedPath\")\nSHA_KEYS = (\"sha256\", \"file_sha256\", \"fileSha256\", \"hash\")\nWIDTH_KEYS = (\"width\", \"video_width\", \"videoWidth\")\nHEIGHT_KEYS = (\"height\", \"video_height\", \"videoHeight\")\nDURATION_KEYS = (\"duration\", \"duration_seconds\", \"durationSeconds\", \"seconds\")\nBYTES_KEYS = (\"bytes\", \"size\", \"file_size\", \"fileSize\")\nMIME_KEYS = (\"mime\", \"mime_type\", \"mimeType\", \"content_type\", \"contentType\")\n\nMEDIA_KEYS = (\n    \"media_asset\", \"mediaAsset\", \"video_asset\", \"videoAsset\", \"video_save_result\", \"videoSaveResult\",\n    \"file_save_result\", \"fileSaveResult\", \"save_result\", \"saveResult\", \"saved_video\", \"savedVideo\",\n    \"video_file\", \"videoFile\", \"video\", \"media\", \"file\",\n)\nFRAME_KEYS = (\n    \"frame_result\", \"frameResult\", \"frame_extract_result\", \"frameExtractResult\", \"thumbnail_result\",\n    \"thumbnailResult\", \"thumbnail_sheet_result\", \"thumbnailSheetResult\", \"video_frame_result\",\n    \"videoFrameResult\", \"frames_result\", \"framesResult\",\n)\nTRANSCRIPT_KEYS = (\n    \"transcript_result\", \"transcriptResult\", \"transcription_result\", \"transcriptionResult\",\n    \"audio_transcript_result\", \"audioTranscriptResult\", \"speech_to_text_result\", \"speechToTextResult\",\n    \"video_audio_transcript\", \"videoAudioTranscript\", \"transcript\", \"transcription\",\n)\nANALYSIS_KEYS = (\n    \"analysis\", \"video_analysis\", \"videoAnalysis\", \"analysis_result\", \"analysisResult\", \"lmstudio_result\",\n    \"lmstudioResult\", \"vision_result\", \"visionResult\", \"reader_result\", \"readerResult\", \"read_result\",\n    \"readResult\", \"llm_result\", \"llmResult\",\n)\n\n\ndef now_iso() -> str:\n    return datetime.now(timezone.utc).isoformat()\n\n\ndef as_mapping(value: Any) -> dict[str, Any]:\n    return value if isinstance(value, dict) else {}\n\n\ndef as_list(value: Any) -> list[Any]:\n    if value is None:\n        return []\n    return value if isinstance(value, list) else [value]\n\n\ndef get_any(data: dict[str, Any], keys: tuple[str, ...], default: Any = None) -> Any:\n    for key in keys:\n        if key in data and data[key] not in (None, \"\"):\n            return data[key]\n    return default\n\n\ndef to_int(value: Any) -> int | None:\n    try:\n        return None if value in (None, \"\") else int(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef to_float(value: Any) -> float | None:\n    try:\n        return None if value in (None, \"\") else float(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef to_bool_int(value: Any) -> int | None:\n    if value is None:\n        return None\n    if isinstance(value, bool):\n        return 1 if value else 0\n    if isinstance(value, (int, float)):\n        return 1 if value else 0\n    text = str(value).strip().lower()\n    if text in {\"1\", \"true\", \"yes\", \"on\"}:\n        return 1\n    if text in {\"0\", \"false\", \"no\", \"off\"}:\n        return 0\n    return None\n\n\ndef dump_json(value: Any) -> str:\n    return json.dumps(value, ensure_ascii=False, sort_keys=True)\n\n\ndef sha256_text(text: str) -> str:\n    return hashlib.sha256(text.encode(\"utf-8\")).hexdigest()\n\n\ndef sha256_file(path: str | Path | None) -> str | None:\n    if not path:\n        return None\n    p = Path(path)\n    if not p.exists() or not p.is_file():\n        return None\n    h = hashlib.sha256()\n    with p.open(\"rb\") as f:\n        for chunk in iter(lambda: f.read(1024 * 1024), b\"\"):\n            h.update(chunk)\n    return h.hexdigest()\n\n\ndef file_size(path: str | Path | None) -> int | None:\n    if not path:\n        return None\n    p = Path(path)\n    if not p.exists() or not p.is_file():\n        return None\n    return p.stat().st_size\n\n\ndef first_mapping(payload: dict[str, Any], keys: tuple[str, ...]) -> dict[str, Any]:\n    for key in keys:\n        value = payload.get(key)\n        if isinstance(value, dict):\n            return value\n    return {}\n\n\ndef collect_mappings(payload: dict[str, Any], keys: tuple[str, ...], list_keys: tuple[str, ...]) -> list[dict[str, Any]]:\n    out: list[dict[str, Any]] = []\n    for key in keys:\n        value = payload.get(key)\n        if isinstance(value, dict):\n            out.append(value)\n    for key in list_keys:\n        for item in as_list(payload.get(key)):\n            if isinstance(item, dict):\n                out.append(item)\n    return out\n\n\ndef infer_post_id(*items: dict[str, Any]) -> str | None:\n    for item in items:\n        value = get_any(item, POST_KEYS)\n        if value is not None:\n            return str(value)\n    return None\n\n\ndef infer_media_index(*items: dict[str, Any]) -> int | None:\n    for item in items:\n        value = to_int(get_any(item, INDEX_KEYS))\n        if value is not None:\n            return value\n    return None\n\n\ndef ensure_tables(conn: sqlite3.Connection) -> None:\n    conn.executescript(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS x_media_assets (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            asset_key TEXT NOT NULL UNIQUE,\n            post_id TEXT,\n            media_index INTEGER,\n            media_type TEXT NOT NULL,\n            source_url TEXT,\n            local_path TEXT,\n            sha256 TEXT,\n            mime_type TEXT,\n            width INTEGER,\n            height INTEGER,\n            duration_seconds REAL,\n            bytes INTEGER,\n            raw_json TEXT,\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL\n        );\n\n        CREATE TABLE IF NOT EXISTS x_video_frames (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            frame_key TEXT NOT NULL UNIQUE,\n            media_asset_id INTEGER NOT NULL,\n            post_id TEXT,\n            media_index INTEGER,\n            kind TEXT,\n            local_path TEXT,\n            width INTEGER,\n            height INTEGER,\n            timestamp_seconds REAL,\n            bytes INTEGER,\n            sha256 TEXT,\n            source_script TEXT,\n            raw_json TEXT,\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL,\n            FOREIGN KEY(media_asset_id) REFERENCES x_media_assets(id)\n        );\n\n        CREATE TABLE IF NOT EXISTS x_video_transcripts (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            transcript_key TEXT NOT NULL UNIQUE,\n            media_asset_id INTEGER NOT NULL,\n            post_id TEXT,\n            media_index INTEGER,\n            engine TEXT,\n            model TEXT,\n            language TEXT,\n            word_timestamps INTEGER,\n            diarize INTEGER,\n            transcript_path TEXT,\n            transcript_text TEXT,\n            source_script TEXT,\n            raw_json TEXT,\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL,\n            FOREIGN KEY(media_asset_id) REFERENCES x_media_assets(id)\n        );\n\n        CREATE TABLE IF NOT EXISTS x_video_analyses (\n            id INTEGER PRIMARY KEY AUTOINCREMENT,\n            analysis_key TEXT NOT NULL UNIQUE,\n            media_asset_id INTEGER NOT NULL,\n            post_id TEXT,\n            media_index INTEGER,\n            model TEXT,\n            prompt TEXT,\n            summary TEXT,\n            description TEXT,\n            ocr_text TEXT,\n            raw_text TEXT,\n            raw_json TEXT,\n            created_at TEXT NOT NULL,\n            updated_at TEXT NOT NULL,\n            FOREIGN KEY(media_asset_id) REFERENCES x_media_assets(id)\n        );\n        \"\"\"\n    )\n\n\ndef save_asset(conn: sqlite3.Connection, payload: dict[str, Any]) -> tuple[int, str, str | None, int | None]:\n    media = first_mapping(payload, MEDIA_KEYS)\n    frame = first_mapping(payload, FRAME_KEYS)\n    transcript = first_mapping(payload, TRANSCRIPT_KEYS)\n    analysis = first_mapping(payload, ANALYSIS_KEYS)\n\n    post_id = infer_post_id(payload, media, frame, transcript, analysis)\n    media_index = infer_media_index(payload, media, frame, transcript, analysis)\n    source_url = get_any(media, SOURCE_KEYS, get_any(payload, SOURCE_KEYS))\n    local_path = get_any(media, LOCAL_PATH_KEYS, get_any(payload, LOCAL_PATH_KEYS))\n    local_path = local_path or get_any(frame, LOCAL_PATH_KEYS) or get_any(transcript, (\"video_path\", \"videoPath\"))\n    sha256 = get_any(media, SHA_KEYS) or sha256_file(local_path)\n    bytes_value = to_int(get_any(media, BYTES_KEYS)) or file_size(local_path)\n\n    asset_key = sha256_text(\"|\".join([\n        str(post_id or \"\"),\n        str(media_index if media_index is not None else \"\"),\n        \"video\",\n        str(local_path or \"\"),\n        str(source_url or \"\"),\n    ]))\n    ts = now_iso()\n    raw_json = dump_json(media or payload)\n    conn.execute(\n        \"\"\"\n        INSERT INTO x_media_assets (\n            asset_key, post_id, media_index, media_type, source_url, local_path, sha256, mime_type,\n            width, height, duration_seconds, bytes, raw_json, created_at, updated_at\n        ) VALUES (?, ?, ?, 'video', ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n        ON CONFLICT(asset_key) DO UPDATE SET\n            post_id=excluded.post_id,\n            media_index=excluded.media_index,\n            source_url=excluded.source_url,\n            local_path=excluded.local_path,\n            sha256=excluded.sha256,\n            mime_type=excluded.mime_type,\n            width=excluded.width,\n            height=excluded.height,\n            duration_seconds=excluded.duration_seconds,\n            bytes=excluded.bytes,\n            raw_json=excluded.raw_json,\n            updated_at=excluded.updated_at\n        \"\"\",\n        (\n            asset_key,\n            post_id,\n            media_index,\n            source_url,\n            local_path,\n            sha256,\n            get_any(media, MIME_KEYS),\n            to_int(get_any(media, WIDTH_KEYS)),\n            to_int(get_any(media, HEIGHT_KEYS)),\n            to_float(get_any(media, DURATION_KEYS)),\n            bytes_value,\n            raw_json,\n            ts,\n            ts,\n        ),\n    )\n    row = conn.execute(\"SELECT id FROM x_media_assets WHERE asset_key = ?\", (asset_key,)).fetchone()\n    return int(row[0]), asset_key, post_id, media_index\n\n\ndef save_frames(conn: sqlite3.Connection, asset_id: int, post_id: str | None, media_index: int | None, payload: dict[str, Any]) -> int:\n    frame_results = collect_mappings(payload, FRAME_KEYS, (\"frame_results\", \"frameResults\", \"thumbnail_results\", \"thumbnailResults\"))\n    expanded: list[dict[str, Any]] = []\n    for result in frame_results:\n        expanded.append(result)\n        for key in (\"sheets\", \"frames\", \"images\", \"thumbnails\"):\n            for item in as_list(result.get(key)):\n                if isinstance(item, dict):\n                    merged = dict(item)\n                    merged.setdefault(\"sourceScript\", result.get(\"sourceScript\") or result.get(\"source_script\"))\n                    expanded.append(merged)\n    count = 0\n    for item in expanded:\n        local_path = get_any(item, LOCAL_PATH_KEYS)\n        if not local_path:\n            continue\n        kind = str(item.get(\"kind\") or item.get(\"type\") or \"video_frame\")\n        frame_key = sha256_text(f\"{asset_id}|{kind}|{local_path}\")\n        ts = now_iso()\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_video_frames (\n                frame_key, media_asset_id, post_id, media_index, kind, local_path, width, height,\n                timestamp_seconds, bytes, sha256, source_script, raw_json, created_at, updated_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            ON CONFLICT(frame_key) DO UPDATE SET\n                width=excluded.width,\n                height=excluded.height,\n                timestamp_seconds=excluded.timestamp_seconds,\n                bytes=excluded.bytes,\n                sha256=excluded.sha256,\n                source_script=excluded.source_script,\n                raw_json=excluded.raw_json,\n                updated_at=excluded.updated_at\n            \"\"\",\n            (\n                frame_key,\n                asset_id,\n                post_id,\n                media_index,\n                kind,\n                local_path,\n                to_int(get_any(item, WIDTH_KEYS)),\n                to_int(get_any(item, HEIGHT_KEYS)),\n                to_float(item.get(\"timestamp_seconds\") or item.get(\"timestampSeconds\") or item.get(\"time\") or item.get(\"seconds\")),\n                to_int(get_any(item, BYTES_KEYS)) or file_size(local_path),\n                get_any(item, SHA_KEYS) or sha256_file(local_path),\n                item.get(\"sourceScript\") or item.get(\"source_script\"),\n                dump_json(item),\n                ts,\n                ts,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef save_transcripts(conn: sqlite3.Connection, asset_id: int, post_id: str | None, media_index: int | None, payload: dict[str, Any]) -> int:\n    transcript_results = collect_mappings(payload, TRANSCRIPT_KEYS, (\"transcripts\", \"transcript_results\", \"transcriptResults\"))\n    if not transcript_results and any(k in payload for k in (\"transcriptText\", \"transcript_text\", \"transcriptPath\", \"transcript_path\")):\n        transcript_results = [payload]\n    count = 0\n    for item in transcript_results:\n        text = item.get(\"transcriptText\") or item.get(\"transcript_text\") or item.get(\"text\") or item.get(\"content\")\n        path = item.get(\"transcriptPath\") or item.get(\"transcript_path\") or item.get(\"path\") or item.get(\"localPath\")\n        if not text and not path:\n            continue\n        engine = item.get(\"engine\")\n        model = item.get(\"model\") or item.get(\"modelSize\") or item.get(\"model_size\")\n        transcript_key = sha256_text(f\"{asset_id}|{path or ''}|{engine or ''}|{model or ''}|{sha256_text(str(text or ''))}\")\n        ts = now_iso()\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_video_transcripts (\n                transcript_key, media_asset_id, post_id, media_index, engine, model, language,\n                word_timestamps, diarize, transcript_path, transcript_text, source_script,\n                raw_json, created_at, updated_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            ON CONFLICT(transcript_key) DO UPDATE SET\n                language=excluded.language,\n                word_timestamps=excluded.word_timestamps,\n                diarize=excluded.diarize,\n                transcript_path=excluded.transcript_path,\n                transcript_text=excluded.transcript_text,\n                source_script=excluded.source_script,\n                raw_json=excluded.raw_json,\n                updated_at=excluded.updated_at\n            \"\"\",\n            (\n                transcript_key,\n                asset_id,\n                post_id,\n                media_index,\n                engine,\n                model,\n                item.get(\"language\"),\n                to_bool_int(item.get(\"wordTimestamps\") if \"wordTimestamps\" in item else item.get(\"word_timestamps\")),\n                to_bool_int(item.get(\"diarize\")),\n                path,\n                text,\n                item.get(\"sourceScript\") or item.get(\"source_script\"),\n                dump_json(item),\n                ts,\n                ts,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef save_analyses(conn: sqlite3.Connection, asset_id: int, post_id: str | None, media_index: int | None, payload: dict[str, Any]) -> int:\n    analysis_results = collect_mappings(payload, ANALYSIS_KEYS, (\"analyses\", \"video_analyses\", \"videoAnalyses\", \"analysis_results\", \"analysisResults\"))\n    count = 0\n    for item in analysis_results:\n        raw_text = item.get(\"raw_text\") or item.get(\"rawText\") or item.get(\"text\") or item.get(\"content\") or item.get(\"response\")\n        if not raw_text and not item:\n            continue\n        analysis_key = sha256_text(f\"{asset_id}|{dump_json(item)}\")\n        ts = now_iso()\n        conn.execute(\n            \"\"\"\n            INSERT INTO x_video_analyses (\n                analysis_key, media_asset_id, post_id, media_index, model, prompt, summary,\n                description, ocr_text, raw_text, raw_json, created_at, updated_at\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n            ON CONFLICT(analysis_key) DO UPDATE SET\n                model=excluded.model,\n                prompt=excluded.prompt,\n                summary=excluded.summary,\n                description=excluded.description,\n                ocr_text=excluded.ocr_text,\n                raw_text=excluded.raw_text,\n                raw_json=excluded.raw_json,\n                updated_at=excluded.updated_at\n            \"\"\",\n            (\n                analysis_key,\n                asset_id,\n                post_id,\n                media_index,\n                item.get(\"model\") or item.get(\"modelName\") or item.get(\"model_name\"),\n                item.get(\"prompt\"),\n                item.get(\"summary\"),\n                item.get(\"description\"),\n                item.get(\"ocr_text\") or item.get(\"ocrText\"),\n                raw_text,\n                dump_json(item),\n                ts,\n                ts,\n            ),\n        )\n        count += 1\n    return count\n\n\ndef save_video_results(payload: dict[str, Any], db_path: str | Path = DEFAULT_DB_PATH) -> dict[str, Any]:\n    db_path = Path(db_path)\n    db_path.parent.mkdir(parents=True, exist_ok=True)\n    with sqlite3.connect(db_path) as conn:\n        ensure_tables(conn)\n        asset_id, asset_key, post_id, media_index = save_asset(conn, payload)\n        frames = save_frames(conn, asset_id, post_id, media_index, payload)\n        transcripts = save_transcripts(conn, asset_id, post_id, media_index, payload)\n        analyses = save_analyses(conn, asset_id, post_id, media_index, payload)\n        conn.commit()\n    return {\n        \"ok\": True,\n        \"dbPath\": str(db_path),\n        \"mediaAssetId\": asset_id,\n        \"assetKey\": asset_key,\n        \"postId\": post_id,\n        \"mediaIndex\": media_index,\n        \"saved\": {\n            \"frames\": frames,\n            \"transcripts\": transcripts,\n            \"analyses\": analyses,\n        },\n    }\n\n\ndef parse_args(argv: list[str]) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Save X video read/transcript results to SQLite.\")\n    parser.add_argument(\"--input-json\", help=\"Payload JSON string or path to a JSON file.\")\n    parser.add_argument(\"--db\", default=str(DEFAULT_DB_PATH), help=\"SQLite DB path.\")\n    return parser.parse_args(argv)\n\n\ndef load_payload(input_json: str | None) -> dict[str, Any]:\n    if input_json:\n        candidate = Path(input_json)\n        if candidate.exists():\n            return json.loads(candidate.read_text(encoding=\"utf-8\"))\n        return json.loads(input_json)\n    return json.loads(sys.stdin.read())\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = parse_args(argv or sys.argv[1:])\n    result = save_video_results(load_payload(args.input_json), args.db)\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
