    {
      "id": "node-0da2d90beb",
      "title": "動画音声文字起こしポワン",
      "body": "動画ファイル保存ポワンの結果を受け取り、既存の C:\\project_root\\app_workspaces\\API\\scripts\\transcriber_whisperx.py または transcriber.py を使って動画音声を文字起こしする臓器ポワン。動画の映像だけでなく発話・音声内容も追跡根拠としてDBへ渡すため、文字起こしテキスト、出力ファイル、使用エンジン、モデル、言語、タイムスタンプ有無をJSONで返す。動画保存、映像フレーム抽出、LMStudio映像読解、DB保存は行わない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom collections.abc import Mapping\nfrom pathlib import Path\nfrom typing import Any\n\n\nAPI_ROOT = Path(r\"C:\\project_root\\app_workspaces\\API\")\nWHISPERX_SCRIPT = API_ROOT / \"scripts\" / \"transcriber_whisperx.py\"\nFASTER_WHISPER_SCRIPT = API_ROOT / \"scripts\" / \"transcriber.py\"\nDEFAULT_OUTPUT_DIR = Path(\"data\") / \"x_media\" / \"video_transcripts\"\n\nPATH_KEYS = (\n    \"local_path\",\n    \"localPath\",\n    \"video_path\",\n    \"videoPath\",\n    \"saved_path\",\n    \"savedPath\",\n    \"file_path\",\n    \"filePath\",\n    \"path\",\n)\nPOST_ID_KEYS = (\"post_id\", \"postId\", \"tweet_id\", \"tweetId\", \"status_id\", \"statusId\")\nMEDIA_INDEX_KEYS = (\"media_index\", \"mediaIndex\", \"index\", \"ordinal\", \"position\")\nCOLLECTION_KEYS = (\n    \"videos\",\n    \"saved_videos\",\n    \"savedVideos\",\n    \"media_assets\",\n    \"mediaAssets\",\n    \"media\",\n    \"files\",\n    \"assets\",\n    \"results\",\n    \"items\",\n)\n\n\nclass VideoAudioTranscriptionError(RuntimeError):\n    pass\n\n\ndef transcribe_video_audio(\n    video_input: Any,\n    *,\n    local_path: str = \"\",\n    output_dir: str | Path = DEFAULT_OUTPUT_DIR,\n    engine: str = \"whisperx\",\n    model_size: str | None = None,\n    device: str = \"auto\",\n    compute_type: str = \"auto\",\n    language: str | None = \"ja\",\n    beam_size: int = 5,\n    batch_size: int = 16,\n    word_timestamps: bool = True,\n    diarize: bool = False,\n    hf_token: str | None = None,\n    chunk_size: int = 30,\n    fallback: bool = True,\n) -> dict[str, Any]:\n    record = select_video_record(video_input, override_local_path=local_path)\n    video_path = require_local_video_path(record)\n    destination = build_output_dir(\n        Path(output_dir),\n        video_path=video_path,\n        post_id=first_text(record, POST_ID_KEYS),\n        media_index=first_int(record, MEDIA_INDEX_KEYS),\n    )\n    destination.mkdir(parents=True, exist_ok=True)\n\n    selected_engine = normalize_engine(engine)\n    errors: list[str] = []\n    for candidate in engine_candidates(selected_engine, fallback=fallback):\n        try:\n            transcript_path = call_transcriber(\n                candidate,\n                video_path=video_path,\n                output_dir=destination,\n                model_size=model_size,\n                device=device,\n                compute_type=compute_type,\n                language=language,\n                beam_size=beam_size,\n                batch_size=batch_size,\n                word_timestamps=word_timestamps,\n                diarize=diarize,\n                hf_token=hf_token,\n                chunk_size=chunk_size,\n            )\n            transcript_text = Path(transcript_path).read_text(encoding=\"utf-8\", errors=\"replace\")\n            return {\n                \"ok\": True,\n                \"postId\": first_text(record, POST_ID_KEYS),\n                \"mediaIndex\": first_int(record, MEDIA_INDEX_KEYS),\n                \"videoPath\": display_path(video_path),\n                \"engine\": candidate,\n                \"model\": model_size or default_model_for(candidate),\n                \"language\": language,\n                \"wordTimestamps\": bool(word_timestamps and candidate == \"whisperx\"),\n                \"diarize\": bool(diarize and candidate == \"whisperx\"),\n                \"transcriptPath\": display_path(Path(transcript_path)),\n                \"transcriptText\": transcript_text,\n                \"sourceScript\": display_path(script_path_for(candidate)),\n                \"fallbackErrors\": errors,\n            }\n        except Exception as exc:\n            errors.append(f\"{candidate}: {exc}\")\n            continue\n    raise VideoAudioTranscriptionError(\"; \".join(errors) or \"transcription failed\")\n\n\ndef call_transcriber(\n    engine: str,\n    *,\n    video_path: Path,\n    output_dir: Path,\n    model_size: str | None,\n    device: str,\n    compute_type: str,\n    language: str | None,\n    beam_size: int,\n    batch_size: int,\n    word_timestamps: bool,\n    diarize: bool,\n    hf_token: str | None,\n    chunk_size: int,\n) -> str:\n    ensure_api_import_path()\n    if engine == \"whisperx\":\n        from scripts.transcriber_whisperx import transcribe\n\n        return transcribe(\n            str(video_path),\n            str(output_dir),\n            model_size=model_size or \"large-v3\",\n            device=device,\n            compute_type=compute_type,\n            language=language,\n            beam_size=beam_size,\n            batch_size=batch_size,\n            word_timestamps=word_timestamps,\n            diarize=diarize,\n            hf_token=hf_token,\n            chunk_size=chunk_size,\n        )\n    if engine == \"faster-whisper\":\n        from scripts.transcriber import transcribe\n\n        return transcribe(\n            str(video_path),\n            str(output_dir),\n            model_size=model_size or \"base\",\n            device=device,\n            compute_type=compute_type,\n            language=language,\n            beam_size=beam_size,\n            vad_filter=True,\n            word_timestamps=word_timestamps,\n        )\n    raise VideoAudioTranscriptionError(f\"unknown engine: {engine}\")\n\n\ndef ensure_api_import_path() -> None:\n    if str(API_ROOT) not in sys.path:\n        sys.path.insert(0, str(API_ROOT))\n\n\ndef normalize_engine(engine: str) -> str:\n    value = (engine or \"whisperx\").strip().lower().replace(\"_\", \"-\")\n    if value in {\"whisperx\", \"whisper-x\"}:\n        return \"whisperx\"\n    if value in {\"faster-whisper\", \"faster\", \"whisper\"}:\n        return \"faster-whisper\"\n    if value == \"auto\":\n        return \"whisperx\"\n    raise VideoAudioTranscriptionError(f\"unsupported engine: {engine}\")\n\n\ndef engine_candidates(engine: str, *, fallback: bool) -> list[str]:\n    if engine == \"whisperx\" and fallback:\n        return [\"whisperx\", \"faster-whisper\"]\n    return [engine]\n\n\ndef default_model_for(engine: str) -> str:\n    return \"large-v3\" if engine == \"whisperx\" else \"base\"\n\n\ndef script_path_for(engine: str) -> Path:\n    return WHISPERX_SCRIPT if engine == \"whisperx\" else FASTER_WHISPER_SCRIPT\n\n\ndef select_video_record(video_input: Any, *, override_local_path: str = \"\") -> dict[str, Any]:\n    if override_local_path:\n        base = dict(video_input) if isinstance(video_input, Mapping) else {}\n        return {**base, \"local_path\": override_local_path}\n    if isinstance(video_input, str):\n        return {\"local_path\": video_input}\n    if isinstance(video_input, Mapping):\n        record = dict(video_input)\n        if first_path_value(record):\n            return record\n        for key in COLLECTION_KEYS:\n            try:\n                return select_video_record(record.get(key))\n            except VideoAudioTranscriptionError:\n                pass\n        for value in record.values():\n            if isinstance(value, (Mapping, list)):\n                try:\n                    return select_video_record(value)\n                except VideoAudioTranscriptionError:\n                    pass\n    if isinstance(video_input, list):\n        for item in video_input:\n            try:\n                return select_video_record(item)\n            except VideoAudioTranscriptionError:\n                pass\n    raise VideoAudioTranscriptionError(\"input JSON did not contain a local video path\")\n\n\ndef first_path_value(record: Mapping[str, Any]) -> str:\n    for key in PATH_KEYS:\n        value = record.get(key)\n        if isinstance(value, str):\n            clean = value.strip()\n            if clean and not clean.lower().startswith((\"http://\", \"https://\", \"data:\")):\n                return clean\n    return \"\"\n\n\ndef require_local_video_path(record: Mapping[str, Any]) -> Path:\n    value = first_path_value(record)\n    if not value:\n        raise VideoAudioTranscriptionError(\"local video path is required\")\n    path = Path(value).expanduser()\n    if not path.is_absolute():\n        path = (Path.cwd() / path).resolve()\n    if not path.exists():\n        raise VideoAudioTranscriptionError(f\"video file does not exist: {path}\")\n    if not path.is_file():\n        raise VideoAudioTranscriptionError(f\"video path is not a file: {path}\")\n    return path\n\n\ndef build_output_dir(base: Path, *, video_path: Path, post_id: str, media_index: int | None) -> Path:\n    media_part = str(media_index) if media_index is not None else \"0\"\n    post_part = safe_slug(post_id, fallback=\"no-post\")\n    stem = safe_slug(video_path.stem, fallback=\"video\")\n    return base / f\"{post_part}_m{media_part}_{stem}\"\n\n\ndef first_text(record: Mapping[str, Any], keys: tuple[str, ...]) -> str:\n    for key in keys:\n        value = record.get(key)\n        if value is not None:\n            text = str(value).strip()\n            if text:\n                return text\n    return \"\"\n\n\ndef first_int(record: Mapping[str, Any], keys: tuple[str, ...]) -> int | None:\n    for key in keys:\n        value = record.get(key)\n        try:\n            return int(value)\n        except (TypeError, ValueError):\n            continue\n    return None\n\n\ndef safe_slug(value: Any, *, fallback: str) -> str:\n    text = str(value or \"\").strip()\n    if not text:\n        return fallback\n    slug = \"\".join(char if char.isalnum() or char in (\"-\", \"_\") else \"_\" for char in text).strip(\"_\")\n    return slug[:80] or fallback\n\n\ndef display_path(path: Path) -> str:\n    try:\n        return str(path.resolve())\n    except OSError:\n        return str(path)\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        return json.load(sys.stdin)\n    path = Path(value)\n    if path.exists():\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    return json.loads(value)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Transcribe a saved video through existing API transcriber scripts.\")\n    parser.add_argument(\"--input-json\", default=\"-\")\n    parser.add_argument(\"--local-path\", default=\"\")\n    parser.add_argument(\"--out-dir\", default=str(DEFAULT_OUTPUT_DIR))\n    parser.add_argument(\"--engine\", default=\"whisperx\", choices=[\"auto\", \"whisperx\", \"faster-whisper\"])\n    parser.add_argument(\"--model-size\", default=None)\n    parser.add_argument(\"--device\", default=\"auto\")\n    parser.add_argument(\"--compute-type\", default=\"auto\")\n    parser.add_argument(\"--language\", default=\"ja\")\n    parser.add_argument(\"--beam-size\", type=int, default=5)\n    parser.add_argument(\"--batch-size\", type=int, default=16)\n    parser.add_argument(\"--no-word-timestamps\", action=\"store_true\")\n    parser.add_argument(\"--diarize\", action=\"store_true\")\n    parser.add_argument(\"--hf-token\", default=None)\n    parser.add_argument(\"--chunk-size\", type=int, default=30)\n    parser.add_argument(\"--no-fallback\", action=\"store_true\")\n    args = parser.parse_args(argv)\n\n    try:\n        payload = load_json_arg(args.input_json)\n        result = transcribe_video_audio(\n            payload,\n            local_path=args.local_path,\n            output_dir=args.out_dir,\n            engine=args.engine,\n            model_size=args.model_size,\n            device=args.device,\n            compute_type=args.compute_type,\n            language=args.language,\n            beam_size=args.beam_size,\n            batch_size=args.batch_size,\n            word_timestamps=not args.no_word_timestamps,\n            diarize=args.diarize,\n            hf_token=args.hf_token,\n            chunk_size=args.chunk_size,\n            fallback=not args.no_fallback,\n        )\n    except Exception as exc:\n        result = {\"ok\": False, \"error\": str(exc)}\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
