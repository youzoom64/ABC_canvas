    {
      "id": "node-35fab40909",
      "title": "LMStudio画像読解ポワン",
      "body": "保存済み画像をLM Studioの画像対応モデルへ渡し、画像内の文字、人物、物体、場面、図表、主張に関係しそうな視覚情報をJSONで読み取る臓器候補ポワン。Gemma 4 E4Bなどのローカルモデルにbase64画像を渡し、DB保存しやすい読解結果を返す。まだコードは持たない。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport base64\nimport json\nimport mimetypes\nimport re\nimport sys\nimport urllib.error\nimport urllib.request\nfrom pathlib import Path\nfrom typing import Any\n\n\nDEFAULT_API_URL = \"http://localhost:1234/v1/chat/completions\"\nDEFAULT_PROMPT_VERSION = \"lmstudio-image-reading-v1\"\nPATH_KEYS = (\n    \"local_path\",\n    \"localPath\",\n    \"saved_path\",\n    \"savedPath\",\n    \"file_path\",\n    \"filePath\",\n    \"path\",\n)\nCOLLECTION_KEYS = (\n    \"images\",\n    \"saved_images\",\n    \"savedImages\",\n    \"media_assets\",\n    \"mediaAssets\",\n    \"media\",\n    \"files\",\n    \"assets\",\n    \"results\",\n)\n\n\nSYSTEM_PROMPT = (\n    \"You read one saved image for a downstream database record. \"\n    \"Return only valid JSON. Do not invent text that is not visible. \"\n    \"When unsure, say so in notable_details or possible_claim_relevance.limitations.\"\n)\n\nUSER_PROMPT = \"\"\"Analyze the attached image and return only this JSON object:\n{\n  \"summary\": \"short factual description of the image\",\n  \"ocr_text\": \"all readable text, preserving line breaks when useful\",\n  \"visible_objects\": [\"people, objects, logos, UI parts, charts, or other visible items\"],\n  \"scene\": {\n    \"description\": \"what kind of scene or document it is\",\n    \"setting\": \"place/context if visible\",\n    \"chart_or_diagram\": \"chart/diagram/table type if any, otherwise empty\"\n  },\n  \"notable_details\": [\"specific visual details useful for later verification\"],\n  \"possible_claim_relevance\": {\n    \"summary\": \"how the visual evidence may relate to a factual claim\",\n    \"visual_evidence\": [\"visible evidence relevant to the claim\"],\n    \"limitations\": [\"uncertainties or missing context\"]\n  },\n  \"confidence\": 0.0\n}\"\"\"\n\n\nclass ImageReadError(RuntimeError):\n    pass\n\n\ndef analyze_image_with_lmstudio(\n    image_input: Any,\n    *,\n    model: str,\n    local_path: str = \"\",\n    api_url: str = DEFAULT_API_URL,\n    timeout: float = 120.0,\n    max_tokens: int = 1200,\n    temperature: float = 0.0,\n    prompt_version: str = DEFAULT_PROMPT_VERSION,\n) -> dict[str, Any]:\n    record = select_image_record(image_input, override_local_path=local_path)\n    image_path = require_local_image_path(record)\n    mime = guess_image_mime(image_path)\n    data_url = image_to_data_url(image_path, mime)\n    payload = build_lmstudio_payload(\n        model=model,\n        data_url=data_url,\n        max_tokens=max_tokens,\n        temperature=temperature,\n    )\n    raw_response = post_json(api_url, payload, timeout=timeout)\n    content = extract_message_content(raw_response)\n    parsed = parse_json_object(content)\n    normalized = normalize_reading(parsed, raw_response=raw_response, model=model)\n    normalized[\"source\"] = compact_source(record, image_path=image_path, mime=mime)\n    normalized[\"prompt_version\"] = prompt_version\n    return normalized\n\n\ndef select_image_record(image_input: Any, *, override_local_path: str = \"\") -> dict[str, Any]:\n    if override_local_path:\n        base = image_input if isinstance(image_input, dict) else {}\n        return {**base, \"local_path\": override_local_path}\n    if isinstance(image_input, str):\n        return {\"local_path\": image_input}\n    if isinstance(image_input, dict):\n        if first_path_value(image_input):\n            return image_input\n        for key in COLLECTION_KEYS:\n            items = image_input.get(key)\n            if isinstance(items, list):\n                for item in items:\n                    found = select_image_record(item)\n                    if first_path_value(found):\n                        return found\n        for value in image_input.values():\n            if isinstance(value, (dict, list)):\n                found = select_image_record(value)\n                if first_path_value(found):\n                    return found\n    if isinstance(image_input, list):\n        for item in image_input:\n            found = select_image_record(item)\n            if first_path_value(found):\n                return found\n    raise ImageReadError(\"input JSON did not contain a local image path\")\n\n\ndef first_path_value(record: dict[str, Any]) -> str:\n    for key in PATH_KEYS:\n        value = record.get(key)\n        if isinstance(value, str) and value.strip() and not looks_like_remote_url(value):\n            return value.strip()\n    return \"\"\n\n\ndef looks_like_remote_url(value: str) -> bool:\n    lowered = value.strip().lower()\n    return lowered.startswith((\"http://\", \"https://\", \"data:\"))\n\n\ndef require_local_image_path(record: dict[str, Any]) -> Path:\n    value = first_path_value(record)\n    if not value:\n        raise ImageReadError(\"local_path is required\")\n    path = Path(value).expanduser()\n    if not path.is_absolute():\n        path = (Path.cwd() / path).resolve()\n    if not path.exists():\n        raise ImageReadError(f\"image file does not exist: {path}\")\n    if not path.is_file():\n        raise ImageReadError(f\"image path is not a file: {path}\")\n    return path\n\n\ndef guess_image_mime(path: Path) -> str:\n    guessed, _ = mimetypes.guess_type(str(path))\n    if guessed and guessed.startswith(\"image/\"):\n        return guessed\n    suffix = path.suffix.lower()\n    if suffix in {\".jpg\", \".jpeg\"}:\n        return \"image/jpeg\"\n    if suffix == \".png\":\n        return \"image/png\"\n    if suffix == \".webp\":\n        return \"image/webp\"\n    if suffix == \".gif\":\n        return \"image/gif\"\n    return \"application/octet-stream\"\n\n\ndef image_to_data_url(path: Path, mime: str) -> str:\n    encoded = base64.b64encode(path.read_bytes()).decode(\"ascii\")\n    return f\"data:{mime};base64,{encoded}\"\n\n\ndef build_lmstudio_payload(\n    *,\n    model: str,\n    data_url: str,\n    max_tokens: int,\n    temperature: float,\n) -> dict[str, Any]:\n    return {\n        \"model\": model,\n        \"messages\": [\n            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n            {\n                \"role\": \"user\",\n                \"content\": [\n                    {\"type\": \"text\", \"text\": USER_PROMPT},\n                    {\"type\": \"image_url\", \"image_url\": {\"url\": data_url}},\n                ],\n            },\n        ],\n        \"temperature\": temperature,\n        \"max_tokens\": max_tokens,\n        \"stream\": False,\n    }\n\n\ndef post_json(url: str, payload: dict[str, Any], *, timeout: float) -> dict[str, Any]:\n    data = json.dumps(payload, ensure_ascii=False).encode(\"utf-8\")\n    request = urllib.request.Request(\n        url,\n        data=data,\n        method=\"POST\",\n        headers={\n            \"Content-Type\": \"application/json; charset=utf-8\",\n            \"Accept\": \"application/json\",\n        },\n    )\n    try:\n        with urllib.request.urlopen(request, timeout=timeout) as response:\n            text = response.read().decode(\"utf-8\", errors=\"replace\")\n    except urllib.error.HTTPError as exc:\n        detail = exc.read().decode(\"utf-8\", errors=\"replace\")\n        raise ImageReadError(f\"LM Studio returned HTTP {exc.code}: {detail}\") from exc\n    except urllib.error.URLError as exc:\n        raise ImageReadError(f\"LM Studio request failed: {exc}\") from exc\n    try:\n        value = json.loads(text)\n    except json.JSONDecodeError as exc:\n        raise ImageReadError(f\"LM Studio returned non-JSON response: {text[:500]}\") from exc\n    if not isinstance(value, dict):\n        raise ImageReadError(\"LM Studio response was not a JSON object\")\n    return value\n\n\ndef extract_message_content(response: dict[str, Any]) -> str:\n    choices = response.get(\"choices\")\n    if not isinstance(choices, list) or not choices:\n        raise ImageReadError(\"LM Studio response did not contain choices\")\n    message = choices[0].get(\"message\") if isinstance(choices[0], dict) else None\n    if not isinstance(message, dict):\n        raise ImageReadError(\"LM Studio response did not contain a message\")\n    content = message.get(\"content\", \"\")\n    if isinstance(content, str):\n        return content.strip()\n    if isinstance(content, list):\n        parts: list[str] = []\n        for item in content:\n            if isinstance(item, dict):\n                text = item.get(\"text\") or item.get(\"content\") or \"\"\n                if isinstance(text, str):\n                    parts.append(text)\n            elif isinstance(item, str):\n                parts.append(item)\n        return \"\\n\".join(part for part in parts if part).strip()\n    return str(content).strip()\n\n\ndef parse_json_object(text: str) -> dict[str, Any]:\n    if not text:\n        raise ImageReadError(\"model response content was empty\")\n    candidates = [strip_code_fence(text), text]\n    embedded = first_embedded_json_object(text)\n    if embedded:\n        candidates.append(embedded)\n    for candidate in candidates:\n        try:\n            value = json.loads(candidate)\n        except json.JSONDecodeError:\n            continue\n        if isinstance(value, dict):\n            return value\n    raise ImageReadError(f\"model response was not parseable JSON: {text[:500]}\")\n\n\ndef strip_code_fence(text: str) -> str:\n    stripped = text.strip()\n    match = re.fullmatch(r\"```(?:json)?\\s*(.*?)\\s*```\", stripped, flags=re.DOTALL | re.IGNORECASE)\n    return match.group(1).strip() if match else stripped\n\n\ndef first_embedded_json_object(text: str) -> str:\n    start = text.find(\"{\")\n    if start < 0:\n        return \"\"\n    depth = 0\n    in_string = False\n    escape = False\n    for index in range(start, len(text)):\n        char = text[index]\n        if in_string:\n            if escape:\n                escape = False\n            elif char == \"\\\\\":\n                escape = True\n            elif char == '\"':\n                in_string = False\n            continue\n        if char == '\"':\n            in_string = True\n        elif char == \"{\":\n            depth += 1\n        elif char == \"}\":\n            depth -= 1\n            if depth == 0:\n                return text[start : index + 1]\n    return \"\"\n\n\ndef normalize_reading(\n    parsed: dict[str, Any],\n    *,\n    raw_response: dict[str, Any],\n    model: str,\n) -> dict[str, Any]:\n    response_model = raw_response.get(\"model\")\n    return {\n        \"summary\": as_text(parsed.get(\"summary\")),\n        \"ocr_text\": as_multiline_text(parsed.get(\"ocr_text\")),\n        \"visible_objects\": as_list(parsed.get(\"visible_objects\")),\n        \"scene\": as_scene(parsed.get(\"scene\")),\n        \"notable_details\": as_list(parsed.get(\"notable_details\")),\n        \"possible_claim_relevance\": as_claim_relevance(parsed.get(\"possible_claim_relevance\")),\n        \"confidence\": as_confidence(parsed.get(\"confidence\")),\n        \"model\": as_text(response_model) or model,\n        \"raw_response\": raw_response,\n    }\n\n\ndef as_text(value: Any) -> str:\n    if value is None:\n        return \"\"\n    if isinstance(value, str):\n        return value.strip()\n    if isinstance(value, (dict, list)):\n        return json.dumps(value, ensure_ascii=False, separators=(\",\", \":\"))\n    return str(value).strip()\n\n\ndef as_multiline_text(value: Any) -> str:\n    if value is None:\n        return \"\"\n    if isinstance(value, list):\n        return \"\\n\".join(as_text(item) for item in value if as_text(item))\n    return as_text(value)\n\n\ndef as_list(value: Any) -> list[Any]:\n    if value is None:\n        return []\n    if isinstance(value, list):\n        return [make_json_safe(item) for item in value if make_json_safe(item) not in (\"\", None)]\n    if isinstance(value, str):\n        lines = [line.strip(\" -\\t\") for line in value.splitlines()]\n        return [line for line in lines if line]\n    return [make_json_safe(value)]\n\n\ndef as_scene(value: Any) -> dict[str, Any]:\n    if isinstance(value, dict):\n        return make_json_safe(value)\n    text = as_text(value)\n    return {\"description\": text, \"setting\": \"\", \"chart_or_diagram\": \"\"} if text else {}\n\n\ndef as_claim_relevance(value: Any) -> dict[str, Any]:\n    if isinstance(value, dict):\n        safe = make_json_safe(value)\n        safe.setdefault(\"summary\", \"\")\n        safe.setdefault(\"visual_evidence\", [])\n        safe.setdefault(\"limitations\", [])\n        return safe\n    text = as_text(value)\n    return {\"summary\": text, \"visual_evidence\": [], \"limitations\": []}\n\n\ndef as_confidence(value: Any) -> float:\n    if value is None:\n        return 0.0\n    if isinstance(value, (int, float)):\n        number = float(value)\n    else:\n        match = re.search(r\"-?\\d+(?:\\.\\d+)?\", str(value))\n        if not match:\n            return 0.0\n        number = float(match.group(0))\n        if \"%\" in str(value):\n            number /= 100.0\n    if number > 1.0 and number <= 100.0:\n        number /= 100.0\n    return max(0.0, min(1.0, number))\n\n\ndef make_json_safe(value: Any) -> Any:\n    if value is None or isinstance(value, (str, int, float, bool)):\n        return value\n    if isinstance(value, list):\n        return [make_json_safe(item) for item in value]\n    if isinstance(value, dict):\n        return {str(key): make_json_safe(item) for key, item in value.items()}\n    return str(value)\n\n\ndef compact_source(record: dict[str, Any], *, image_path: Path, mime: str) -> dict[str, Any]:\n    keys = (\n        \"media_asset_id\",\n        \"mediaAssetId\",\n        \"post_id\",\n        \"postId\",\n        \"media_index\",\n        \"mediaIndex\",\n        \"sha256\",\n        \"source_url\",\n        \"sourceUrl\",\n        \"image_url\",\n        \"imageUrl\",\n        \"width\",\n        \"height\",\n    )\n    source = {key: make_json_safe(record[key]) for key in keys if key in record}\n    source[\"local_path\"] = str(image_path)\n    source[\"mime\"] = mime\n    return source\n\n\ndef load_input_payload(args: argparse.Namespace) -> Any:\n    if args.stdin_json:\n        text = sys.stdin.read()\n        if not text.strip():\n            raise ImageReadError(\"stdin JSON was empty\")\n        return json.loads(text)\n    if args.input_json:\n        return json.loads(args.input_json)\n    if args.input_json_file:\n        return json.loads(Path(args.input_json_file).read_text(encoding=\"utf-8\"))\n    if args.local_path:\n        return {\"local_path\": args.local_path}\n    raise ImageReadError(\"--local-path, --stdin-json, --input-json, or --input-json-file is required\")\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(\n        description=\"Read one saved image through LM Studio vision chat completions.\"\n    )\n    parser.add_argument(\"--model\", required=True, help=\"Vision-capable LM Studio model name.\")\n    parser.add_argument(\"--local-path\", default=\"\", help=\"Saved image path. Overrides any JSON path.\")\n    parser.add_argument(\"--stdin-json\", action=\"store_true\", help=\"Read image-save JSON from stdin.\")\n    parser.add_argument(\"--input-json\", default=\"\", help=\"Image-save JSON as a string.\")\n    parser.add_argument(\"--input-json-file\", default=\"\", help=\"Path to image-save JSON file.\")\n    parser.add_argument(\"--api-url\", default=DEFAULT_API_URL)\n    parser.add_argument(\"--timeout\", type=float, default=120.0)\n    parser.add_argument(\"--max-tokens\", type=int, default=1200)\n    parser.add_argument(\"--temperature\", type=float, default=0.0)\n    parser.add_argument(\"--prompt-version\", default=DEFAULT_PROMPT_VERSION)\n    parser.add_argument(\"--pretty\", action=\"store_true\")\n    return parser\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = build_parser()\n    args = parser.parse_args(argv)\n    try:\n        image_input = load_input_payload(args)\n        result = analyze_image_with_lmstudio(\n            image_input,\n            model=args.model,\n            local_path=args.local_path,\n            api_url=args.api_url,\n            timeout=args.timeout,\n            max_tokens=args.max_tokens,\n            temperature=args.temperature,\n            prompt_version=args.prompt_version,\n        )\n    except Exception as exc:\n        error_result = {\n            \"ok\": False,\n            \"error\": str(exc),\n            \"summary\": \"\",\n            \"ocr_text\": \"\",\n            \"visible_objects\": [],\n            \"scene\": {},\n            \"notable_details\": [],\n            \"possible_claim_relevance\": {\"summary\": \"\", \"visual_evidence\": [], \"limitations\": [str(exc)]},\n            \"confidence\": 0.0,\n            \"model\": getattr(args, \"model\", \"\"),\n            \"raw_response\": None,\n        }\n        print(json.dumps(error_result, ensure_ascii=False, indent=2), file=sys.stderr)\n        return 2\n    print(json.dumps(result, ensure_ascii=False, indent=2 if args.pretty else None))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
