    {
      "id": "node-50607708e4",
      "title": "ニュース本文確認ポワン",
      "body": "終端投稿にニュース記事や外部記事リンクが含まれている時、その記事本文を確認対象として扱う神経ポワン。X終端投稿から外部URLを抽出し、短縮URLやリダイレクトを展開し、既存のAPI scripts/article_rag/extractors.py などの本文抽出材料を使って記事本文、タイトル、媒体名、公開日、取得不能理由を整理し、最後にDBへ保存する流れを束ねる。RAG、意味検索、矛盾判定は行わず、収集と保存だけを担当する。",
      "powanKind": "nerve",
      "code": "from __future__ import annotations\n\nimport argparse\nimport importlib\nimport json\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Callable, Mapping\n\n\nSTAGE_URL_EXTRACTION = \"urlExtraction\"\nSTAGE_URL_EXPANSION = \"urlExpansion\"\nSTAGE_ARTICLE_EXTRACTION = \"articleExtraction\"\nSTAGE_METADATA_EXTRACTION = \"metadataExtraction\"\nSTAGE_UNAVAILABLE_REASON = \"unavailableReason\"\nSTAGE_DB_SAVE = \"dbSave\"\n\nSTAGE_ORDER = (\n    STAGE_URL_EXTRACTION,\n    STAGE_URL_EXPANSION,\n    STAGE_ARTICLE_EXTRACTION,\n    STAGE_METADATA_EXTRACTION,\n    STAGE_UNAVAILABLE_REASON,\n    STAGE_DB_SAVE,\n)\n\nSTAGE_ALIASES = {\n    STAGE_URL_EXTRACTION: (\"newsUrlExtraction\", \"news_url_extraction\", \"url_extraction\"),\n    STAGE_URL_EXPANSION: (\"newsUrlExpansion\", \"news_url_expansion\", \"url_expansion\"),\n    STAGE_ARTICLE_EXTRACTION: (\"newsArticleExtraction\", \"news_article_extraction\", \"article_extraction\"),\n    STAGE_METADATA_EXTRACTION: (\"newsMetadataExtraction\", \"news_metadata_extraction\", \"metadata_extraction\"),\n    STAGE_UNAVAILABLE_REASON: (\"newsUnavailableReason\", \"news_unavailable_reason\", \"failureReason\"),\n    STAGE_DB_SAVE: (\"newsArticleDbSave\", \"news_article_db_save\", \"db_save\", \"save\"),\n}\n\nFUNCTION_CANDIDATES = {\n    STAGE_URL_EXTRACTION: (\"extract_news_urls\", \"extract\", \"run\"),\n    STAGE_URL_EXPANSION: (\"expand_news_url\", \"expand\", \"run\"),\n    STAGE_ARTICLE_EXTRACTION: (\"extract_news_article\", \"extract\", \"run\"),\n    STAGE_METADATA_EXTRACTION: (\"extract_news_metadata\", \"extract_metadata\", \"extract\", \"run\"),\n    STAGE_UNAVAILABLE_REASON: (\"classify_unavailable_reason\", \"classify\", \"run\"),\n    STAGE_DB_SAVE: (\"save_news_article\", \"save\", \"run\"),\n}\n\nURL_KEYS = (\"canonicalUrl\", \"canonical_url\", \"finalUrl\", \"final_url\", \"expandedUrl\", \"expanded_url\", \"url\")\nPOST_ID_KEYS = (\"postId\", \"post_id\", \"tweetId\", \"tweet_id\", \"statusId\", \"status_id\")\nDIRECT_RESULT_KEYS = (\n    \"urls\",\n    \"candidateUrls\",\n    \"candidate_urls\",\n    \"items\",\n    \"finalUrl\",\n    \"final_url\",\n    \"canonicalUrl\",\n    \"canonical_url\",\n    \"title\",\n    \"headline\",\n    \"text\",\n    \"body\",\n    \"articleText\",\n    \"article_text\",\n    \"error\",\n)\n\n\nclass MissingChildRunner(RuntimeError):\n    pass\n\n\ndef confirm_news_articles(\n    input_json: Any = None,\n    *,\n    child_runners: Mapping[str, Any] | None = None,\n    child_results: Mapping[str, Any] | None = None,\n    options: Mapping[str, Any] | None = None,\n) -> dict[str, Any]:\n    \"\"\"Orchestrate news article collection without doing child organ work.\n\n    This nerve powan only passes structured data between child powans. It does\n    not fetch pages itself, run Selenium, call LMStudio, build embeddings, run\n    RAG, summarize articles, judge contradictions, or write SQLite rows.\n    \"\"\"\n    payload = normalize_json_value(input_json)\n    opts = dict(options or {})\n    runners = normalize_runners(child_runners or {})\n    supplied_results = merge_child_results(payload.get(\"childResults\"), child_results)\n    allow_missing = opts.get(\"allowMissingChildren\", True) is not False\n\n    child_result_input = snapshot_child_result_input(supplied_results)\n    run_notes: list[dict[str, Any]] = []\n\n    url_extraction = run_child(\n        STAGE_URL_EXTRACTION,\n        payload,\n        runners=runners,\n        child_results=supplied_results,\n        allow_missing=allow_missing,\n        notes=run_notes,\n    )\n    candidates = candidate_urls(url_extraction)\n\n    items: list[dict[str, Any]] = []\n    save_results: list[dict[str, Any]] = []\n    failure_reasons: list[dict[str, Any]] = []\n\n    for index, candidate in enumerate(candidates):\n        item = {\n            \"index\": index,\n            \"candidate\": candidate,\n            \"childResults\": {},\n            \"failureReason\": None,\n            \"savePayload\": None,\n            \"saveResult\": None,\n        }\n\n        expansion_input = make_expansion_input(payload, candidate, index)\n        expansion = run_child(\n            STAGE_URL_EXPANSION,\n            expansion_input,\n            runners=runners,\n            child_results=supplied_results,\n            index=index,\n            allow_missing=allow_missing,\n            notes=run_notes,\n        )\n        item[\"childResults\"][STAGE_URL_EXPANSION] = expansion\n\n        article = None\n        metadata = None\n        failure = None\n\n        if result_ok(expansion):\n            article_input = make_article_input(payload, candidate, expansion, index)\n            article = run_child(\n                STAGE_ARTICLE_EXTRACTION,\n                article_input,\n                runners=runners,\n                child_results=supplied_results,\n                index=index,\n                allow_missing=allow_missing,\n                notes=run_notes,\n            )\n            item[\"childResults\"][STAGE_ARTICLE_EXTRACTION] = article\n        else:\n            failure = classify_failure(\n                payload,\n                candidate,\n                expansion,\n                STAGE_URL_EXPANSION,\n                runners,\n                supplied_results,\n                index,\n                allow_missing,\n                run_notes,\n            )\n\n        if article is not None and result_ok(article):\n            metadata_input = make_metadata_input(payload, candidate, expansion, article, index)\n            metadata = run_child(\n                STAGE_METADATA_EXTRACTION,\n                metadata_input,\n                runners=runners,\n                child_results=supplied_results,\n                index=index,\n                allow_missing=allow_missing,\n                notes=run_notes,\n            )\n            item[\"childResults\"][STAGE_METADATA_EXTRACTION] = metadata\n        elif article is not None:\n            failure = classify_failure(\n                payload,\n                candidate,\n                article,\n                STAGE_ARTICLE_EXTRACTION,\n                runners,\n                supplied_results,\n                index,\n                allow_missing,\n                run_notes,\n            )\n\n        if failure is not None:\n            item[\"childResults\"][STAGE_UNAVAILABLE_REASON] = failure\n            item[\"failureReason\"] = failure\n            failure_reasons.append(failure)\n\n        save_payload = make_save_payload(\n            payload=payload,\n            index=index,\n            candidate=candidate,\n            url_extraction=url_extraction,\n            url_expansion=expansion,\n            article_extraction=article,\n            metadata_extraction=metadata,\n            unavailable_reason=failure,\n        )\n        save = run_child(\n            STAGE_DB_SAVE,\n            save_payload,\n            runners=runners,\n            child_results=supplied_results,\n            index=index,\n            allow_missing=allow_missing,\n            notes=run_notes,\n        )\n        item[\"savePayload\"] = save_payload\n        item[\"saveResult\"] = save\n        item[\"childResults\"][STAGE_DB_SAVE] = save\n        save_results.append(save)\n        items.append(item)\n\n    if not candidates:\n        status = \"no_news_url\"\n        ok = result_ok(url_extraction)\n    else:\n        status = \"saved\" if all(result_ok(item) for item in save_results) else \"save_failed\"\n        ok = result_ok(url_extraction) and all(result_ok(item) for item in save_results)\n\n    return {\n        \"ok\": bool(ok),\n        \"status\": status,\n        \"inputJson\": payload,\n        \"childResultJson\": child_result_input,\n        \"childResults\": {\n            STAGE_URL_EXTRACTION: url_extraction,\n            STAGE_DB_SAVE: save_results,\n        },\n        \"items\": items,\n        \"failureReasons\": failure_reasons,\n        \"saveResult\": combine_save_results(save_results),\n        \"notes\": run_notes,\n    }\n\n\ndef classify_failure(\n    payload: Mapping[str, Any],\n    candidate: Mapping[str, Any],\n    failed_result: Any,\n    failed_stage: str,\n    runners: Mapping[str, Any],\n    child_results: Mapping[str, Any],\n    index: int,\n    allow_missing: bool,\n    notes: list[dict[str, Any]],\n) -> dict[str, Any]:\n    reason_input = {\n        \"inputJson\": payload,\n        \"candidate\": candidate,\n        \"failedStage\": failed_stage,\n        \"failedResult\": failed_result,\n        \"index\": index,\n    }\n    return run_child(\n        STAGE_UNAVAILABLE_REASON,\n        reason_input,\n        runners=runners,\n        child_results=child_results,\n        index=index,\n        allow_missing=allow_missing,\n        notes=notes,\n    )\n\n\ndef run_child(\n    stage: str,\n    payload: Any,\n    *,\n    runners: Mapping[str, Any],\n    child_results: Mapping[str, Any],\n    index: int | None = None,\n    allow_missing: bool,\n    notes: list[dict[str, Any]],\n) -> dict[str, Any]:\n    supplied = supplied_child_result(child_results, stage, index=index)\n    if supplied is not None:\n        notes.append({\"stage\": stage, \"index\": index, \"source\": \"childResultJson\"})\n        return ensure_result_dict(supplied, stage=stage, source=\"childResultJson\")\n\n    runner = find_runner(runners, stage)\n    if runner is None:\n        result = missing_child_result(stage, payload, index=index)\n        notes.append({\"stage\": stage, \"index\": index, \"source\": \"missing\", \"ok\": False})\n        if allow_missing:\n            return result\n        raise MissingChildRunner(result[\"error\"][\"message\"])\n\n    notes.append({\"stage\": stage, \"index\": index, \"source\": \"runner\"})\n    try:\n        value = call_runner(stage, runner, payload)\n        return ensure_result_dict(value, stage=stage, source=\"runner\")\n    except Exception as exc:\n        return {\n            \"ok\": False,\n            \"stage\": stage,\n            \"source\": \"runner\",\n            \"error\": {\n                \"type\": exc.__class__.__name__,\n                \"message\": str(exc),\n                \"reason\": \"child_runner_failed\",\n            },\n        }\n\n\ndef call_runner(stage: str, runner: Any, payload: Any) -> Any:\n    if isinstance(runner, str):\n        runner = importlib.import_module(runner)\n    if callable(runner):\n        return runner(payload)\n    for name in FUNCTION_CANDIDATES.get(stage, (\"run\",)):\n        func = getattr(runner, name, None)\n        if callable(func):\n            if stage == STAGE_URL_EXPANSION and name == \"expand_news_url\":\n                return func(first_text(payload, URL_KEYS))\n            return func(payload)\n    raise TypeError(f\"No callable child entrypoint for stage {stage}\")\n\n\ndef normalize_runners(runners: Mapping[str, Any]) -> dict[str, Any]:\n    normalized: dict[str, Any] = {}\n    for key, value in runners.items():\n        canonical = canonical_stage(key)\n        if canonical:\n            normalized[canonical] = value\n    return normalized\n\n\ndef find_runner(runners: Mapping[str, Any], stage: str) -> Any:\n    if stage in runners:\n        return runners[stage]\n    for alias in STAGE_ALIASES.get(stage, ()):\n        if alias in runners:\n            return runners[alias]\n    return None\n\n\ndef canonical_stage(value: str) -> str:\n    if value in STAGE_ORDER:\n        return value\n    for stage, aliases in STAGE_ALIASES.items():\n        if value in aliases:\n            return stage\n    return \"\"\n\n\ndef merge_child_results(*sources: Any) -> dict[str, Any]:\n    merged: dict[str, Any] = {}\n    for source in sources:\n        value = normalize_json_value(source)\n        if isinstance(value, Mapping):\n            for key, item in value.items():\n                canonical = canonical_stage(str(key)) or str(key)\n                merged[canonical] = item\n    return merged\n\n\ndef supplied_child_result(child_results: Mapping[str, Any], stage: str, *, index: int | None) -> Any:\n    if stage not in child_results:\n        return None\n    value = child_results[stage]\n    if index is None:\n        return value\n    if isinstance(value, list):\n        return value[index] if index < len(value) else None\n    if isinstance(value, Mapping):\n        for key in (\"items\", \"results\", \"records\"):\n            items = value.get(key)\n            if isinstance(items, list):\n                return items[index] if index < len(items) else None\n        keyed = value.get(str(index))\n        if keyed is not None:\n            return keyed\n    return value\n\n\ndef candidate_urls(url_extraction: Any) -> list[dict[str, Any]]:\n    result = unwrap_result(url_extraction)\n    raw_items = None\n    if isinstance(result, Mapping):\n        for key in (\"urls\", \"candidateUrls\", \"candidate_urls\", \"items\", \"results\"):\n            if isinstance(result.get(key), list):\n                raw_items = result.get(key)\n                break\n        if raw_items is None and first_text(result, URL_KEYS):\n            raw_items = [result]\n    elif isinstance(result, list):\n        raw_items = result\n    if not raw_items:\n        return []\n    candidates: list[dict[str, Any]] = []\n    for raw in raw_items:\n        if isinstance(raw, Mapping):\n            item = dict(raw)\n        else:\n            item = {\"url\": str(raw)}\n        if first_text(item, URL_KEYS):\n            candidates.append(item)\n    return candidates\n\n\ndef make_expansion_input(payload: Mapping[str, Any], candidate: Mapping[str, Any], index: int) -> dict[str, Any]:\n    return {\n        \"inputJson\": payload,\n        \"candidate\": candidate,\n        \"url\": first_text(candidate, URL_KEYS),\n        \"postId\": first_text(candidate, POST_ID_KEYS) or first_text(payload, POST_ID_KEYS),\n        \"index\": index,\n    }\n\n\ndef make_article_input(\n    payload: Mapping[str, Any],\n    candidate: Mapping[str, Any],\n    expansion: Mapping[str, Any],\n    index: int,\n) -> dict[str, Any]:\n    expanded = unwrap_result(expansion)\n    article_url = first_text(expanded, (\"canonicalUrl\", \"canonical_url\", \"finalUrl\", \"final_url\", \"url\"))\n    return {\n        \"inputJson\": payload,\n        \"candidate\": candidate,\n        \"urlExpansion\": expansion,\n        \"url\": article_url or first_text(candidate, URL_KEYS),\n        \"postId\": first_text(candidate, POST_ID_KEYS) or first_text(payload, POST_ID_KEYS),\n        \"index\": index,\n    }\n\n\ndef make_metadata_input(\n    payload: Mapping[str, Any],\n    candidate: Mapping[str, Any],\n    expansion: Mapping[str, Any],\n    article: Mapping[str, Any],\n    index: int,\n) -> dict[str, Any]:\n    return {\n        \"inputJson\": payload,\n        \"candidate\": candidate,\n        \"urlExpansion\": expansion,\n        \"articleExtraction\": article,\n        \"index\": index,\n    }\n\n\ndef make_save_payload(\n    *,\n    payload: Mapping[str, Any],\n    index: int,\n    candidate: Mapping[str, Any],\n    url_extraction: Mapping[str, Any],\n    url_expansion: Mapping[str, Any],\n    article_extraction: Mapping[str, Any] | None,\n    metadata_extraction: Mapping[str, Any] | None,\n    unavailable_reason: Mapping[str, Any] | None,\n) -> dict[str, Any]:\n    article = unwrap_result(article_extraction or {})\n    expansion = unwrap_result(url_expansion)\n    metadata = unwrap_result(metadata_extraction or {})\n    reason = unwrap_result(unavailable_reason or {})\n    return {\n        \"inputJson\": payload,\n        \"index\": index,\n        \"postId\": first_text(candidate, POST_ID_KEYS) or first_text(payload, POST_ID_KEYS),\n        \"url\": first_text(candidate, URL_KEYS),\n        \"finalUrl\": first_text(expansion, (\"finalUrl\", \"final_url\", \"url\")),\n        \"canonicalUrl\": first_text(expansion, (\"canonicalUrl\", \"canonical_url\")),\n        \"title\": first_text(article, (\"title\", \"headline\")) or first_text(metadata, (\"title\", \"ogTitle\", \"og_title\")),\n        \"text\": first_text(article, (\"text\", \"body\", \"articleText\", \"article_text\")),\n        \"metadata\": metadata,\n        \"unavailableReason\": reason if unavailable_reason is not None else None,\n        \"childResults\": {\n            STAGE_URL_EXTRACTION: url_extraction,\n            STAGE_URL_EXPANSION: url_expansion,\n            STAGE_ARTICLE_EXTRACTION: article_extraction,\n            STAGE_METADATA_EXTRACTION: metadata_extraction,\n            STAGE_UNAVAILABLE_REASON: unavailable_reason,\n        },\n        \"rawJson\": {\n            \"inputJson\": payload,\n            \"candidate\": candidate,\n            \"urlExtraction\": url_extraction,\n            \"urlExpansion\": url_expansion,\n            \"articleExtraction\": article_extraction,\n            \"metadataExtraction\": metadata_extraction,\n            \"unavailableReason\": unavailable_reason,\n        },\n    }\n\n\ndef result_ok(result: Any) -> bool:\n    if isinstance(result, Mapping):\n        return result.get(\"ok\") is not False and not result.get(\"error\")\n    return result is not None\n\n\ndef ensure_result_dict(value: Any, *, stage: str, source: str) -> dict[str, Any]:\n    if isinstance(value, Mapping):\n        result = dict(value)\n        result.setdefault(\"stage\", stage)\n        result.setdefault(\"source\", source)\n        if \"ok\" not in result:\n            result[\"ok\"] = not bool(result.get(\"error\"))\n        return result\n    return {\"ok\": True, \"stage\": stage, \"source\": source, \"result\": value}\n\n\ndef missing_child_result(stage: str, payload: Any, *, index: int | None) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"stage\": stage,\n        \"source\": \"missing\",\n        \"index\": index,\n        \"error\": {\n            \"type\": \"MissingChildRunner\",\n            \"reason\": \"child_runner_missing\",\n            \"message\": f\"Child result or runner is required for {stage}.\",\n        },\n        \"input\": payload,\n    }\n\n\ndef unwrap_result(value: Any) -> Any:\n    if isinstance(value, Mapping):\n        if any(key in value for key in DIRECT_RESULT_KEYS):\n            return value\n        for key in (\"result\", \"data\", \"article\", \"record\", \"metadata\"):\n            inner = value.get(key)\n            if isinstance(inner, Mapping):\n                return inner\n    return value\n\n\ndef combine_save_results(save_results: list[dict[str, Any]]) -> dict[str, Any]:\n    return {\n        \"ok\": all(result_ok(item) for item in save_results),\n        \"count\": len(save_results),\n        \"results\": save_results,\n    }\n\n\ndef snapshot_child_result_input(child_results: Mapping[str, Any]) -> dict[str, Any]:\n    return {key: value for key, value in child_results.items() if key in STAGE_ORDER}\n\n\ndef first_text(record: Any, keys: tuple[str, ...]) -> str:\n    if not isinstance(record, Mapping):\n        return \"\"\n    for key in keys:\n        value = record.get(key)\n        if value is not None:\n            text = str(value).strip()\n            if text:\n                return text\n    return \"\"\n\n\ndef normalize_json_value(value: Any) -> Any:\n    if value is None:\n        return {}\n    if isinstance(value, (Mapping, list)):\n        return value\n    if isinstance(value, str):\n        text = value.strip()\n        if not text:\n            return {}\n        try:\n            return json.loads(text)\n        except json.JSONDecodeError:\n            return value\n    return value\n\n\ndef load_json_arg(value: str) -> Any:\n    if not value or value == \"-\":\n        text = sys.stdin.read().strip()\n        return json.loads(text) if text else {}\n    try:\n        path = Path(value)\n        if path.exists():\n            return json.loads(path.read_text(encoding=\"utf-8\"))\n    except OSError:\n        pass\n    return json.loads(value)\n\n\ndef load_runner_modules(value: str) -> dict[str, Any]:\n    if not value:\n        return {}\n    raw = load_json_arg(value)\n    if not isinstance(raw, Mapping):\n        raise ValueError(\"runner modules must be a JSON object\")\n    return {str(key): str(module) for key, module in raw.items()}\n\n\ndef run(input_json: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return confirm_news_articles(input_json, **kwargs)\n\n\ndef orchestrate(input_json: Any = None, **kwargs: Any) -> dict[str, Any]:\n    return confirm_news_articles(input_json, **kwargs)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    parser = argparse.ArgumentParser(description=\"Orchestrate news article collection child powans.\")\n    parser.add_argument(\"--input-json\", default=\"-\", help=\"JSON string, JSON file path, or '-' for stdin.\")\n    parser.add_argument(\"--child-results-json\", default=\"\", help=\"Precomputed child results as JSON or a JSON file path.\")\n    parser.add_argument(\"--runner-modules\", default=\"\", help=\"JSON object mapping stage names to importable modules.\")\n    parser.add_argument(\"--strict-children\", action=\"store_true\", help=\"Raise when a child result or runner is missing.\")\n    args = parser.parse_args(argv)\n\n    try:\n        payload = load_json_arg(args.input_json)\n        child_results = load_json_arg(args.child_results_json) if args.child_results_json else {}\n        runners = load_runner_modules(args.runner_modules)\n        result = confirm_news_articles(\n            payload,\n            child_runners=runners,\n            child_results=child_results,\n            options={\"allowMissingChildren\": not args.strict_children},\n        )\n    except Exception as exc:\n        result = {\n            \"ok\": False,\n            \"status\": \"orchestrator_failed\",\n            \"error\": {\n                \"type\": exc.__class__.__name__,\n                \"message\": str(exc),\n                \"reason\": \"orchestrator_exception\",\n            },\n        }\n\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())",
