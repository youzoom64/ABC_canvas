    {
      "id": "node-e673090d6a",
      "title": "X画像URL抽出ポワン",
      "body": "Xの終端投稿に含まれる画像を開き、article[data-testid='tweet']内のtweetPhoto、/photo/N、pbs.twimg.com/mediaのsmall/large画像URL、alt、画像番号、post_id、post_urlを抽出する臓器ポワン。Selenium driverまたは既存の9221デバッグChromeへ接続し、画像内容を読ませる前に確認対象画像をJSONで決める。DB保存やLMStudio呼び出しはしない。Pythonコードを持つ。",
      "powanKind": "organ",
      "code": "from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nimport sys\nimport time\nfrom dataclasses import dataclass\nfrom typing import Any\nfrom urllib.parse import parse_qsl, urlencode, urlparse, urlunparse\n\n\nSTATUS_RE = re.compile(r\"/status(?:es)?/(\\d+)\")\nPHOTO_RE = re.compile(r\"/photo/(\\d+)\")\nPBS_MEDIA_RE = re.compile(r\"^https?://pbs\\.twimg\\.com/media/\", re.IGNORECASE)\n\n\nclass XImageExtractionError(RuntimeError):\n    pass\n\n\n@dataclass\nclass ImageCandidate:\n    index: int | None\n    photo_url: str\n    image_url: str\n    alt: str\n    width: int | None\n    height: int | None\n\n\ndef connect_debug_chrome(*, port: int = 9221, wait: float = 15.0) -> Any:\n    \"\"\"Attach Selenium to an already running Chrome remote debugging port.\"\"\"\n    try:\n        from scripts.chrome_debug import get_driver  # type: ignore\n\n        return get_driver(port=port, wait=wait)\n    except Exception:\n        pass\n\n    try:\n        from selenium import webdriver\n        from selenium.webdriver.chrome.options import Options\n    except Exception as exc:  # pragma: no cover - depends on runtime package state\n        raise XImageExtractionError(\n            \"selenium is required to connect to debug Chrome\"\n        ) from exc\n\n    last_error: Exception | None = None\n    deadline = time.monotonic() + max(0.0, wait)\n    while True:\n        try:\n            options = Options()\n            options.add_experimental_option(\"debuggerAddress\", f\"127.0.0.1:{port}\")\n            return webdriver.Chrome(options=options)\n        except Exception as exc:  # pragma: no cover - depends on live Chrome state\n            last_error = exc\n            if time.monotonic() >= deadline:\n                break\n            time.sleep(0.5)\n    raise XImageExtractionError(\n        f\"could not connect to Chrome remote debugging port {port}\"\n    ) from last_error\n\n\ndef normalize_input_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    clean = url.strip()\n    if not clean:\n        return None\n    if clean.startswith(\"x.com/\") or clean.startswith(\"twitter.com/\"):\n        return f\"https://{clean}\"\n    return clean\n\n\ndef status_id_from_url(url: str | None) -> str | None:\n    if not url:\n        return None\n    match = STATUS_RE.search(url)\n    return match.group(1) if match else None\n\n\ndef photo_index_from_url(url: str | None) -> int | None:\n    if not url:\n        return None\n    match = PHOTO_RE.search(url)\n    if not match:\n        return None\n    try:\n        return int(match.group(1))\n    except ValueError:\n        return None\n\n\ndef strip_url_noise(url: str | None) -> str:\n    if not url:\n        return \"\"\n    parsed = urlparse(url)\n    return urlunparse((parsed.scheme, parsed.netloc, parsed.path.rstrip(\"/\"), \"\", \"\", \"\"))\n\n\ndef normalize_status_url(url: str | None) -> str:\n    clean = strip_url_noise(url)\n    if not clean:\n        return \"\"\n    parsed = urlparse(clean)\n    path = re.sub(r\"/photo/\\d+$\", \"\", parsed.path.rstrip(\"/\"))\n    return urlunparse((parsed.scheme or \"https\", parsed.netloc, path, \"\", \"\", \"\"))\n\n\ndef normalize_photo_url(url: str | None) -> str:\n    clean = strip_url_noise(url)\n    if not clean:\n        return \"\"\n    parsed = urlparse(clean)\n    return urlunparse((parsed.scheme or \"https\", parsed.netloc, parsed.path, \"\", \"\", \"\"))\n\n\ndef pbs_named_url(url: str | None, name: str) -> str:\n    if not url:\n        return \"\"\n    parsed = urlparse(url)\n    if not PBS_MEDIA_RE.match(urlunparse((parsed.scheme, parsed.netloc, parsed.path, \"\", \"\", \"\"))):\n        return url\n    query = dict(parse_qsl(parsed.query, keep_blank_values=True))\n    query[\"name\"] = name\n    return urlunparse(\n        (\n            parsed.scheme or \"https\",\n            parsed.netloc,\n            parsed.path,\n            \"\",\n            urlencode(query),\n            \"\",\n        )\n    )\n\n\ndef wait_for_page_surface(driver: Any, wait: float) -> None:\n    deadline = time.monotonic() + max(0.0, wait)\n    selectors = (\n        \"article[data-testid='tweet'] [data-testid='tweetPhoto']\",\n        \"article[data-testid='tweet'] a[href*='/photo/']\",\n        \"article[data-testid='tweet'] img[src*='pbs.twimg.com/media']\",\n        \"img[src*='pbs.twimg.com/media']\",\n    )\n    while True:\n        try:\n            found = driver.execute_script(\n                \"return arguments[0].some((selector) => document.querySelector(selector));\",\n                list(selectors),\n            )\n            if found:\n                return\n            ready_state = driver.execute_script(\"return document.readyState\")\n            if ready_state == \"complete\" and time.monotonic() >= deadline:\n                return\n        except Exception:\n            if time.monotonic() >= deadline:\n                return\n        if time.monotonic() >= deadline:\n            return\n        time.sleep(0.25)\n\n\nEXTRACT_SCRIPT = r\"\"\"\nconst pageUrl = window.location.href;\nconst statusMatch = pageUrl.match(/\\/status(?:es)?\\/(\\d+)/);\nconst pageStatusId = statusMatch ? statusMatch[1] : \"\";\n\nfunction absoluteUrl(value) {\n  if (!value) return \"\";\n  try {\n    return new URL(value, window.location.href).toString();\n  } catch {\n    return String(value || \"\");\n  }\n}\n\nfunction statusIdFromUrl(value) {\n  const match = String(value || \"\").match(/\\/status(?:es)?\\/(\\d+)/);\n  return match ? match[1] : \"\";\n}\n\nfunction photoIndexFromUrl(value) {\n  const match = String(value || \"\").match(/\\/photo\\/(\\d+)/);\n  return match ? Number(match[1]) : null;\n}\n\nfunction elementText(value) {\n  return String(value || \"\").replace(/\\s+/g, \" \").trim();\n}\n\nfunction imageInfo(img) {\n  if (!img) {\n    return {src: \"\", alt: \"\", width: null, height: null};\n  }\n  const src = absoluteUrl(img.currentSrc || img.src || img.getAttribute(\"src\") || \"\");\n  const alt = elementText(img.getAttribute(\"alt\") || img.alt || \"\");\n  const naturalWidth = Number(img.naturalWidth || 0);\n  const naturalHeight = Number(img.naturalHeight || 0);\n  const rect = img.getBoundingClientRect ? img.getBoundingClientRect() : null;\n  const width = naturalWidth || (rect ? Math.round(rect.width) : null) || null;\n  const height = naturalHeight || (rect ? Math.round(rect.height) : null) || null;\n  return {src, alt, width, height};\n}\n\nfunction scoreArticle(article) {\n  const links = Array.from(article.querySelectorAll(\"a[href*='/status/']\"));\n  const photoLinks = Array.from(article.querySelectorAll(\"a[href*='/photo/']\"));\n  const pbsImages = Array.from(article.querySelectorAll(\"img[src*='pbs.twimg.com/media']\"));\n  const hasPageStatus = Boolean(pageStatusId) && links.some((link) => statusIdFromUrl(link.href) === pageStatusId);\n  const rect = article.getBoundingClientRect();\n  const visibleCenter = rect ? (rect.top + rect.bottom) / 2 : 0;\n  const centerPenalty = Math.abs(visibleCenter - window.innerHeight / 2) / Math.max(1, window.innerHeight);\n  return (\n    (hasPageStatus ? 1000 : 0) +\n    photoLinks.length * 30 +\n    pbsImages.length * 20 -\n    centerPenalty\n  );\n}\n\nconst articles = Array.from(document.querySelectorAll(\"article[data-testid='tweet']\"));\nlet article = null;\nif (articles.length) {\n  article = articles\n    .map((candidate) => ({candidate, score: scoreArticle(candidate)}))\n    .sort((a, b) => b.score - a.score)[0].candidate;\n}\n\nconst root = article || document;\nconst statusLinks = Array.from(root.querySelectorAll(\"a[href*='/status/']\"))\n  .map((link) => absoluteUrl(link.href))\n  .filter(Boolean);\nconst photoNodes = Array.from(root.querySelectorAll(\"[data-testid='tweetPhoto']\"));\nconst candidates = [];\n\nfunction pushCandidate(sourceNode, anchor, img) {\n  const info = imageInfo(img);\n  const photoUrl = absoluteUrl(anchor ? anchor.href : \"\");\n  candidates.push({\n    photoUrl,\n    imageUrl: info.src,\n    alt: info.alt,\n    width: info.width,\n    height: info.height,\n    index: photoIndexFromUrl(photoUrl)\n  });\n}\n\nfor (const node of photoNodes) {\n  const anchors = Array.from(node.querySelectorAll(\"a[href*='/photo/']\"));\n  const closeAnchor = node.closest ? node.closest(\"a[href*='/photo/']\") : null;\n  const allAnchors = closeAnchor ? [closeAnchor, ...anchors] : anchors;\n  const images = Array.from(node.querySelectorAll(\"img[src*='pbs.twimg.com/media'], img\"));\n  if (allAnchors.length) {\n    for (const anchor of allAnchors) {\n      const img = anchor.querySelector(\"img[src*='pbs.twimg.com/media'], img\") || images[0] || null;\n      pushCandidate(node, anchor, img);\n    }\n  } else {\n    for (const img of images) {\n      pushCandidate(node, null, img);\n    }\n  }\n}\n\nfor (const anchor of Array.from(root.querySelectorAll(\"a[href*='/photo/']\"))) {\n  const img = anchor.querySelector(\"img[src*='pbs.twimg.com/media'], img\");\n  pushCandidate(anchor, anchor, img);\n}\n\nfor (const img of Array.from(root.querySelectorAll(\"img[src*='pbs.twimg.com/media']\"))) {\n  const anchor = img.closest ? img.closest(\"a[href*='/photo/']\") : null;\n  pushCandidate(img, anchor, img);\n}\n\nreturn {\n  pageUrl,\n  pageStatusId,\n  statusLinks,\n  candidates\n};\n\"\"\"\n\n\ndef raw_extract_from_page(driver: Any) -> dict[str, Any]:\n    raw = driver.execute_script(EXTRACT_SCRIPT)\n    if not isinstance(raw, dict):\n        raise XImageExtractionError(\"browser did not return extraction data\")\n    return raw\n\n\ndef build_post_context(raw: dict[str, Any], requested_url: str | None) -> tuple[str, str]:\n    page_url = str(raw.get(\"pageUrl\") or \"\")\n    page_status_id = str(raw.get(\"pageStatusId\") or \"\")\n    status_links = [str(item) for item in raw.get(\"statusLinks\") or [] if item]\n    requested_status_id = status_id_from_url(requested_url)\n    post_id = requested_status_id or page_status_id\n\n    preferred_links: list[str] = []\n    for value in [requested_url, page_url, *status_links]:\n        if not value:\n            continue\n        candidate_id = status_id_from_url(value)\n        if post_id and candidate_id == post_id:\n            preferred_links.append(value)\n        elif not post_id and candidate_id:\n            post_id = candidate_id\n            preferred_links.append(value)\n\n    post_url = normalize_status_url(preferred_links[0] if preferred_links else page_url)\n    return post_id or \"\", post_url\n\n\ndef candidate_from_raw(item: dict[str, Any]) -> ImageCandidate | None:\n    image_url = str(item.get(\"imageUrl\") or \"\")\n    photo_url = normalize_photo_url(str(item.get(\"photoUrl\") or \"\"))\n    if \"pbs.twimg.com/media/\" not in image_url and not photo_url:\n        return None\n\n    index: int | None\n    raw_index = item.get(\"index\")\n    if isinstance(raw_index, int):\n        index = raw_index\n    else:\n        index = photo_index_from_url(photo_url)\n\n    width = item.get(\"width\")\n    height = item.get(\"height\")\n    return ImageCandidate(\n        index=index,\n        photo_url=photo_url,\n        image_url=image_url,\n        alt=str(item.get(\"alt\") or \"\"),\n        width=width if isinstance(width, int) and width > 0 else None,\n        height=height if isinstance(height, int) and height > 0 else None,\n    )\n\n\ndef media_dedupe_key(candidate: ImageCandidate) -> str:\n    if candidate.photo_url:\n        return f\"photo:{candidate.photo_url}\"\n    parsed = urlparse(candidate.image_url)\n    if \"pbs.twimg.com\" in parsed.netloc and parsed.path:\n        return f\"pbs:{parsed.path}\"\n    return candidate.image_url\n\n\ndef finalize_images(candidates: list[ImageCandidate]) -> list[dict[str, Any]]:\n    merged: dict[str, ImageCandidate] = {}\n    order: list[str] = []\n\n    for candidate in candidates:\n        key = media_dedupe_key(candidate)\n        if not key:\n            continue\n        existing = merged.get(key)\n        if existing is None:\n            merged[key] = candidate\n            order.append(key)\n            continue\n        merged[key] = ImageCandidate(\n            index=existing.index or candidate.index,\n            photo_url=existing.photo_url or candidate.photo_url,\n            image_url=existing.image_url or candidate.image_url,\n            alt=existing.alt or candidate.alt,\n            width=existing.width or candidate.width,\n            height=existing.height or candidate.height,\n        )\n\n    images = [merged[key] for key in order]\n    images.sort(key=lambda item: item.index if item.index is not None else 9999)\n\n    output: list[dict[str, Any]] = []\n    for fallback_index, candidate in enumerate(images, start=1):\n        index = candidate.index or fallback_index\n        output.append(\n            {\n                \"index\": index,\n                \"photoUrl\": candidate.photo_url,\n                \"imageUrlSmall\": pbs_named_url(candidate.image_url, \"small\"),\n                \"imageUrlLarge\": pbs_named_url(candidate.image_url, \"large\"),\n                \"alt\": candidate.alt,\n                \"width\": candidate.width,\n                \"height\": candidate.height,\n            }\n        )\n    return output\n\n\ndef extract_x_image_urls(\n    *,\n    driver: Any | None = None,\n    url: str | None = None,\n    port: int = 9221,\n    wait: float = 15.0,\n) -> dict[str, Any]:\n    requested_url = normalize_input_url(url)\n    owns_driver = driver is None\n    if driver is None:\n        driver = connect_debug_chrome(port=port, wait=wait)\n\n    try:\n        if requested_url:\n            driver.get(requested_url)\n        wait_for_page_surface(driver, wait)\n        raw = raw_extract_from_page(driver)\n        post_id, post_url = build_post_context(raw, requested_url)\n        candidates = []\n        for item in raw.get(\"candidates\") or []:\n            if isinstance(item, dict):\n                candidate = candidate_from_raw(item)\n                if candidate is not None:\n                    candidates.append(candidate)\n        return {\n            \"ok\": True,\n            \"postId\": post_id,\n            \"postUrl\": post_url,\n            \"images\": finalize_images(candidates),\n        }\n    finally:\n        if owns_driver:\n            try:\n                driver.quit()\n            except Exception:\n                pass\n\n\ndef parse_args(argv: list[str] | None = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"Extract image URLs from the current or specified X post page.\"\n    )\n    parser.add_argument(\"--url\", default=\"\", help=\"X post URL or X photo URL to open before extraction.\")\n    parser.add_argument(\"--port\", type=int, default=9221, help=\"Chrome remote debugging port.\")\n    parser.add_argument(\"--wait\", type=float, default=15.0, help=\"Seconds to wait for tweet images.\")\n    return parser.parse_args(argv)\n\n\ndef main(argv: list[str] | None = None) -> int:\n    args = parse_args(argv)\n    try:\n        result = extract_x_image_urls(\n            url=args.url or None,\n            port=args.port,\n            wait=args.wait,\n        )\n    except Exception as exc:\n        result = {\n            \"ok\": False,\n            \"postId\": status_id_from_url(args.url) or \"\",\n            \"postUrl\": normalize_status_url(args.url),\n            \"images\": [],\n            \"error\": str(exc),\n        }\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0 if result.get(\"ok\") else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n",
