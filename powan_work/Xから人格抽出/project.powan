    {
      "id": "node-80fa0f8fff",
      "title": "追跡結果整形ポワン",
      "body": "根まで追跡ポワンが作った経路を、会話起点判定ポワンへ渡しやすいtopic_origin候補として整形する臓器ポワン。最終到達ポスト、開始ポストから根までのステップ、途中で通ったリプ、リポスト、引用、信頼度、停止理由をまとめる。会話の根として使うべき情報と、話題の発端候補として使うべき情報を分けて返す。TypeScriptコードを持つ。",
      "powanKind": "organ",
      "code": "export type RelationType = \"reply\" | \"repost\" | \"quote\" | \"standalone\" | \"unknown\";\nexport type RefKind = \"reply_parent\" | \"repost_source\" | \"quote_source\" | \"url_post\";\nexport type FetchStatus = \"ok\" | \"not_found\" | \"private\" | \"deleted\" | \"rate_limited\" | \"invalid_ref\" | \"error\";\n\nexport type PostLike = {\n  id?: string;\n  url?: string;\n  authorId?: string;\n  text?: string;\n  inReplyToPostId?: string | null;\n  repostedPostId?: string | null;\n  quotedPostId?: string | null;\n  urls?: string[];\n  cards?: unknown[];\n  raw?: unknown;\n};\n\nexport type PostRef = {\n  kind: RefKind;\n  postId?: string;\n  url?: string;\n  evidence: string;\n  confidence: number;\n};\n\nexport type RelationDecision = {\n  relationType: RelationType;\n  refs: PostRef[];\n  primaryRef?: PostRef;\n  evidence: string[];\n  confidence: number;\n};\n\nexport type FetchResult = {\n  status: FetchStatus;\n  post?: PostLike;\n  reason?: string;\n};\n\nexport type TraceStep = {\n  index: number;\n  post: PostLike;\n  decision: RelationDecision;\n  followedRef?: PostRef;\n  fetchStatus?: FetchStatus;\n  reason?: string;\n};\n\nexport type TraceResult = {\n  rootPost?: PostLike;\n  path: TraceStep[];\n  stopReason: string;\n  topicOriginCandidates: PostRef[];\n};\n\ntype CandidatePhase = \"followed\" | \"primary\" | \"decisionRef\";\n\ntype CandidateEntry = {\n  ref: PostRef;\n  rank: number;\n  order: number;\n};\n\nconst RELATION_TYPES: readonly RelationType[] = [\"reply\", \"repost\", \"quote\", \"standalone\", \"unknown\"];\nconst REF_KINDS: readonly RefKind[] = [\"reply_parent\", \"repost_source\", \"quote_source\", \"url_post\"];\nconst FETCH_STATUSES: readonly FetchStatus[] = [\n  \"ok\",\n  \"not_found\",\n  \"private\",\n  \"deleted\",\n  \"rate_limited\",\n  \"invalid_ref\",\n  \"error\",\n];\nconst TOPIC_ORIGIN_KINDS: readonly RefKind[] = [\"repost_source\", \"quote_source\", \"url_post\"];\n\nconst PHASE_PRIORITY: Record<CandidatePhase, number> = {\n  followed: 300,\n  primary: 200,\n  decisionRef: 100,\n};\n\nconst REF_KIND_PRIORITY: Record<RefKind, number> = {\n  quote_source: 30,\n  repost_source: 30,\n  url_post: 20,\n  reply_parent: 0,\n};\n\n/**\n * Formats a traced path for the conversation-origin layer.\n *\n * reply_parent refs stay in path/rootPost as conversation-root evidence.\n * quote, repost, and URL refs become topic-origin candidates.\n */\nexport function buildOriginTraceResult(\n  path: TraceStep[],\n  rootPost?: PostLike,\n  stopReason?: string,\n): TraceResult {\n  const normalizedPath = normalizeTracePath(path);\n  const resolvedRootPost = normalizePost(rootPost) ?? lastPostInPath(normalizedPath);\n  const result: TraceResult = {\n    path: normalizedPath,\n    stopReason: cleanString(stopReason) ?? inferStopReason(normalizedPath),\n    topicOriginCandidates: collectTopicOriginCandidates(normalizedPath),\n  };\n\n  if (resolvedRootPost) {\n    result.rootPost = resolvedRootPost;\n  }\n\n  return result;\n}\n\nfunction normalizeTracePath(value: unknown): TraceStep[] {\n  if (!Array.isArray(value)) {\n    return [];\n  }\n\n  const steps: TraceStep[] = [];\n  for (const item of value) {\n    const step = normalizeTraceStep(item, steps.length);\n    if (step) {\n      steps.push(step);\n    }\n  }\n  return steps;\n}\n\nfunction normalizeTraceStep(value: unknown, fallbackIndex: number): TraceStep | undefined {\n  if (!isRecord(value)) {\n    return undefined;\n  }\n\n  const step: TraceStep = {\n    index: normalizeIndex(value.index, fallbackIndex),\n    post: normalizePost(value.post) ?? {},\n    decision: normalizeDecision(value.decision),\n  };\n\n  const followedRef = normalizeRef(value.followedRef);\n  if (followedRef) {\n    step.followedRef = followedRef;\n  }\n\n  const fetchStatus = normalizeFetchStatus(value.fetchStatus);\n  if (fetchStatus) {\n    step.fetchStatus = fetchStatus;\n  }\n\n  const reason = cleanString(value.reason);\n  if (reason) {\n    step.reason = reason;\n  }\n\n  return step;\n}\n\nfunction normalizeDecision(value: unknown): RelationDecision {\n  if (!isRecord(value)) {\n    return {\n      relationType: \"unknown\",\n      refs: [],\n      evidence: [],\n      confidence: 0,\n    };\n  }\n\n  const relationType = isRelationType(value.relationType) ? value.relationType : \"unknown\";\n  const primaryRef = normalizeRef(value.primaryRef);\n  const refs = Array.isArray(value.refs) ? value.refs.map(normalizeRef).filter(isDefined) : [];\n  const normalizedRefs = primaryRef ? uniqueRefs([primaryRef, ...refs]) : uniqueRefs(refs);\n  const evidence = Array.isArray(value.evidence) ? value.evidence.map(cleanString).filter(isDefined) : [];\n  const confidenceFallback = primaryRef?.confidence ?? normalizedRefs[0]?.confidence ?? 0;\n  const decision: RelationDecision = {\n    relationType,\n    refs: normalizedRefs,\n    evidence,\n    confidence: clampConfidence(numberOrDefault(value.confidence, confidenceFallback)),\n  };\n\n  if (primaryRef) {\n    decision.primaryRef = primaryRef;\n  }\n\n  return decision;\n}\n\nfunction collectTopicOriginCandidates(path: readonly TraceStep[]): PostRef[] {\n  const byKey = new Map<string, CandidateEntry>();\n  let order = 0;\n\n  for (const step of path) {\n    order = addCandidate(byKey, step.followedRef, \"followed\", order);\n  }\n\n  for (const step of path) {\n    order = addCandidate(byKey, step.decision.primaryRef, \"primary\", order);\n  }\n\n  for (const step of path) {\n    for (const ref of step.decision.refs) {\n      order = addCandidate(byKey, ref, \"decisionRef\", order);\n    }\n  }\n\n  return [...byKey.values()]\n    .sort(compareCandidates)\n    .map((candidate) => candidate.ref);\n}\n\nfunction addCandidate(\n  byKey: Map<string, CandidateEntry>,\n  ref: PostRef | undefined,\n  phase: CandidatePhase,\n  order: number,\n): number {\n  if (!ref || !isTopicOriginKind(ref.kind)) {\n    return order;\n  }\n\n  const key = refIdentityKey(ref);\n  if (!key) {\n    return order;\n  }\n\n  const entry: CandidateEntry = {\n    ref,\n    rank: PHASE_PRIORITY[phase] + REF_KIND_PRIORITY[ref.kind] + ref.confidence,\n    order,\n  };\n  const existing = byKey.get(key);\n\n  if (!existing) {\n    byKey.set(key, entry);\n    return order + 1;\n  }\n\n  if (isBetterCandidate(entry, existing)) {\n    byKey.set(key, { ...entry, order: existing.order });\n  }\n\n  return order + 1;\n}\n\nfunction isBetterCandidate(left: CandidateEntry, right: CandidateEntry): boolean {\n  if (left.rank !== right.rank) {\n    return left.rank > right.rank;\n  }\n  if (left.ref.confidence !== right.ref.confidence) {\n    return left.ref.confidence > right.ref.confidence;\n  }\n  return left.order < right.order;\n}\n\nfunction compareCandidates(left: CandidateEntry, right: CandidateEntry): number {\n  if (right.rank !== left.rank) {\n    return right.rank - left.rank;\n  }\n  if (right.ref.confidence !== left.ref.confidence) {\n    return right.ref.confidence - left.ref.confidence;\n  }\n  return left.order - right.order;\n}\n\nfunction inferStopReason(path: readonly TraceStep[]): string {\n  const lastStep = path[path.length - 1];\n  if (!lastStep) {\n    return \"unknown\";\n  }\n\n  const reason = cleanString(lastStep.reason);\n  if (reason) {\n    return reason;\n  }\n\n  if (lastStep.fetchStatus && lastStep.fetchStatus !== \"ok\") {\n    return lastStep.fetchStatus;\n  }\n\n  if (lastStep.decision.relationType === \"standalone\") {\n    return \"standalone\";\n  }\n\n  if (!lastStep.followedRef) {\n    return \"no_upstream_ref\";\n  }\n\n  return \"unknown\";\n}\n\nfunction lastPostInPath(path: readonly TraceStep[]): PostLike | undefined {\n  for (let index = path.length - 1; index >= 0; index -= 1) {\n    const post = normalizePost(path[index]?.post);\n    if (post) {\n      return post;\n    }\n  }\n  return undefined;\n}\n\nfunction normalizeRef(value: unknown): PostRef | undefined {\n  if (!isRecord(value) || !isRefKind(value.kind)) {\n    return undefined;\n  }\n\n  const postId = cleanString(value.postId);\n  const url = cleanString(value.url);\n  if (!postId && !url) {\n    return undefined;\n  }\n\n  const ref: PostRef = {\n    kind: value.kind,\n    evidence: cleanString(value.evidence) ?? \"unknown\",\n    confidence: clampConfidence(numberOrDefault(value.confidence, 0)),\n  };\n\n  if (postId) {\n    ref.postId = postId;\n  }\n\n  if (url) {\n    ref.url = url;\n  }\n\n  return ref;\n}\n\nfunction uniqueRefs(refs: readonly PostRef[]): PostRef[] {\n  const output: PostRef[] = [];\n  const seen = new Set<string>();\n\n  for (const ref of refs) {\n    const key = `${ref.kind}:${refIdentityKey(ref) ?? ref.evidence}`;\n    if (seen.has(key)) {\n      continue;\n    }\n    seen.add(key);\n    output.push(ref);\n  }\n\n  return output;\n}\n\nfunction refIdentityKey(ref: PostRef): string | undefined {\n  const postId = cleanString(ref.postId);\n  if (postId) {\n    return `id:${postId}`;\n  }\n\n  const url = normalizeUrlForKey(ref.url);\n  return url ? `url:${url}` : undefined;\n}\n\nfunction normalizeFetchStatus(value: unknown): FetchStatus | undefined {\n  return isFetchStatus(value) ? value : undefined;\n}\n\nfunction normalizePost(value: unknown): PostLike | undefined {\n  return isRecord(value) ? (value as PostLike) : undefined;\n}\n\nfunction normalizeIndex(value: unknown, fallback: number): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value) || value < 0) {\n    return fallback;\n  }\n  return Math.floor(value);\n}\n\nfunction isTopicOriginKind(value: RefKind): boolean {\n  return TOPIC_ORIGIN_KINDS.includes(value);\n}\n\nfunction isRelationType(value: unknown): value is RelationType {\n  return typeof value === \"string\" && RELATION_TYPES.includes(value as RelationType);\n}\n\nfunction isRefKind(value: unknown): value is RefKind {\n  return typeof value === \"string\" && REF_KINDS.includes(value as RefKind);\n}\n\nfunction isFetchStatus(value: unknown): value is FetchStatus {\n  return typeof value === \"string\" && FETCH_STATUSES.includes(value as FetchStatus);\n}\n\nfunction cleanString(value: unknown): string | undefined {\n  if (typeof value !== \"string\") {\n    return undefined;\n  }\n\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : undefined;\n}\n\nfunction numberOrDefault(value: unknown, fallback: number): number {\n  return typeof value === \"number\" && Number.isFinite(value) ? value : fallback;\n}\n\nfunction normalizeUrlForKey(value: unknown): string | undefined {\n  const text = cleanString(value);\n  if (!text) {\n    return undefined;\n  }\n\n  try {\n    const parsed = new URL(text);\n    parsed.hash = \"\";\n    return parsed.toString();\n  } catch {\n    return text;\n  }\n}\n\nfunction clampConfidence(value: number): number {\n  if (!Number.isFinite(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value);\n}\n\nfunction isDefined<T>(value: T | undefined): value is T {\n  return value !== undefined;\n}\n",
